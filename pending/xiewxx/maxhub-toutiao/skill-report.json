  "content": {
    "user_title": "Query Toutiao News Data with AI",
    "value_statement": "News analysts and researchers spend hours manually collecting article, video, and user data from Toutiao, Chinas largest news platform. This skill lets you query all Toutiao data endpoints through simple natural language prompts using the MaxHub API.",
    "seo_keywords": [
      "Toutiao data query",
      "today headlines news",
      "Chinese news API",
      "content analysis tool",
      "Claude",
      "Codex",
      "Claude Code",
      "MaxHub API",
      "news data assistant",
      "social media analytics"
    ],
    "actual_capabilities": [
      "Query article details using group_id or article URL",
      "Fetch video information including title, author, and metadata",
      "Look up user profiles and resolve user IDs from profile page URLs",
      "Retrieve paginated comments for articles and videos",
      "Support both Chinese and English language queries and responses",
      "Chain multiple API calls for comprehensive content and user analysis"
    ],
    "limitations": [
      "Requires a valid MaxHub API key from aconfig.cn to function",
      "Data quality and freshness depend on the third-party API provider",
      "Read-only access - cannot publish, edit, or delete content on Toutiao",
      "Cannot search articles by keyword; requires specific group_id or URL"
    ],
    "use_cases": [
      {
        "title": "Content Research for Journalists",
        "description": "Journalists can quickly look up article and video details to verify facts, gather background data, and track trending topics on Toutiao.",
        "target_user": "Journalists and content researchers"
      },
      {
        "title": "Social Media Analysis for Marketers",
        "description": "Marketing professionals analyze user engagement metrics, read comments, and study video performance to optimize content strategy on Toutiao.",
        "target_user": "Digital marketing specialists"
      },
      {
        "title": "Competitive Intelligence for Product Teams",
        "description": "Product managers track popular content and user discussions on Toutiao to identify market trends and inform product decisions.",
        "target_user": "Product managers and analysts"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic Article Lookup",
        "scenario": "Finding article details using a known group ID from a Toutiao URL.",
        "prompt": "Get the article info for group_id 7450114952884503059"
      },
      {
        "title": "User Profile Research",
        "scenario": "Looking up a Toutiao user profile and their published content.",
        "prompt": "Find the user_id from this profile page URL, then get their user info: https://www.toutiao.com/c/user/token/MS4wLjABAAAAexample/"
      },
      {
        "title": "Multi-Endpoint Content Analysis",
        "scenario": "Analyzing both article content and reader engagement in one session.",
        "prompt": "Get the article info for group_id 7450114952884503059 and fetch the first 20 comments for the same article"
      },
      {
        "title": "Cross-Platform Comparison",
        "scenario": "Comparing engagement across multiple articles or a mix of articles and videos.",
        "prompt": "Compare article 7450114952884503059 and video 7431543350882206242. Show their titles, engagement stats, and highlight key differences"
      }
    ],
    "output_examples": [
      {
        "input": "Get article info for group_id 7450114952884503059",
        "output": "Here is the article information: The article was published on Toutiao and received 45,230 reads with 1,234 comments. The content focuses on technology trends. Reader sentiment is mostly positive based on comment analysis."
      },
      {
        "input": "Get user info for user_id 1352838578180211 and their recent articles",
        "output": "User profile summary: This user has 12,500 followers and has published 89 articles on Toutiao. Their most recent article received 23,400 reads. The user mainly covers entertainment and lifestyle content."
      },
      {
        "input": "Get comments for article 7450114952884503059",
        "output": "Found 45 comments on this article. The top comment has 2,100 likes. Reader sentiment is mostly positive. Key discussion topics include pricing, features, and usability."
      }
    ],
    "best_practices": [
      "Verify the MAXHUB_API_KEY environment variable is configured before making queries to avoid authentication errors.",
      "Chain related queries together in a single conversation for deeper analysis, such as fetching article details and comments in sequence.",
      "Use specific group_id or user_id values from Toutiao URLs for accurate results instead of guessing identifiers."
    ],
    "anti_patterns": [
      "Do not expose the API key value in prompts, output, or share it with others - always reference it via the configured environment variable.",
      "Do not assume data is real-time without checking the cache_url field, as some API responses may contain cached results.",
      "Avoid making queries without a clear group_id or user_id, as the API does not support keyword search and will return errors."
    ],
    "faq": [
      {
        "question": "Do I need an API key to use this skill?",
        "answer": "Yes, you need a MaxHub API key from aconfig.cn. Configure it as the MAXHUB_API_KEY environment variable before using the skill."
      },
      {
        "question": "Which AI tools support this skill?",
        "answer": "This skill works with Claude, Codex, and Claude Code."
      },
      {
        "question": "Can I search for articles by keyword or topic?",
        "answer": "No, the skill requires a specific article group_id or URL. Keyword search is not supported by the current API endpoints."
      },
      {
        "question": "What languages does this skill support?",
        "answer": "The skill supports both Chinese and English. The AI will detect your language and respond in the same language."
      },
      {
        "question": "Is the data from Toutiao in real time?",
        "answer": "Data comes from a third-party API provider and may include cached results. Check the cache_url field in responses for data freshness."
      },
      {
        "question": "Can I post comments or publish articles with this skill?",
        "answer": "No, this skill is read-only. It can query articles, videos, users, and comments but cannot create or modify any content on Toutiao."
      }
    ]
  },
