  "content": {
    "user_title": "Query Twitter/X data using AI and the MaxHub API",
    "value_statement": "Accessing Twitter/X data normally requires writing complex API code and managing authentication directly. This skill lets an AI assistant handle all API calls, data formatting, and language localization so you can get tweet details, user profiles, search results, and trending topics through natural conversation.",
    "seo_keywords": [
      "Twitter",
      "X",
      "social media",
      "API data query",
      "tweet analysis",
      "trending topics",
      "Claude",
      "Codex",
      "Claude Code",
      "user research"
    ],
    "actual_capabilities": [
      "Fetch tweet details, comments, and retweet user lists using tweet IDs",
      "Query user profiles, posts, media, followers, and followings by screen name or user ID",
      "Search Twitter/X content by keyword with filters for Top, Latest, Media, People, and Lists",
      "Retrieve trending topics by country with support for over 30 countries",
      "Perform multi-endpoint orchestration for deep analysis and side-by-side comparisons",
      "Output results in English or Chinese with localized number formatting"
    ],
    "limitations": [
      "Data accuracy depends on the third-party MaxHub API provider and may not match official Twitter API results",
      "Cannot post tweets, send messages, or perform any write operations on Twitter/X",
      "Rate limits and endpoint availability depend on your MaxHub API subscription plan",
      "Some API endpoints may not return all data fields available through the official Twitter API"
    ],
    "use_cases": [
      {
        "title": "Social media sentiment monitoring",
        "description": "Track brand mentions and public sentiment on Twitter/X in real time. Search keywords, analyze engagement metrics, and generate reports on public perception.",
        "target_user": "PR and communications teams monitoring brand reputation"
      },
      {
        "title": "Trending topic analysis",
        "description": "Retrieve and analyze global trending topics by country. Understand what is being discussed, who the key voices are, and how conversations evolve over time.",
        "target_user": "Journalists and media analysts tracking global news trends"
      },
      {
        "title": "KOL influence evaluation",
        "description": "Assess Twitter/X influencer reach by analyzing follower counts, engagement rates, content themes, and audience quality. Supports data-driven marketing decisions.",
        "target_user": "Marketing professionals evaluating influencer partnerships"
      }
    ],
    "prompt_templates": [
      {
        "title": "Look up a tweet by ID",
        "prompt": "Show me the details of tweet ID 1808168603721650364 including text, likes, retweets, and replies.",
        "scenario": "Getting detailed information about a specific tweet using its numeric ID"
      },
      {
        "title": "Analyze a user profile",
        "prompt": "Analyze the Twitter profile of elonmusk. Get their profile info, recent posts, follower count, and engagement patterns.",
        "scenario": "Researching a Twitter/X user's profile and activity in depth"
      },
      {
        "title": "Search trending topics by country",
        "prompt": "What are the top trending topics in Japan right now? Summarize the top 10 trends with context.",
        "scenario": "Discovering what is trending in a specific country"
      },
      {
        "title": "Compare two users side by side",
        "prompt": "Compare elonmusk and brian_armstrong. Show their follower counts, post frequency, engagement rates, and recent topics side by side.",
        "scenario": "Running a competitive analysis between two Twitter/X profiles"
      }
    ],
    "output_examples": [
      {
        "input": "Show me the latest tweets from elonmusk",
        "output": [
          "Here are the recent posts from @elonmusk:",
          "",
          "1. \"Starship flight test 5 ready for launch\"",
          "   - Likes: 245K | Retweets: 32K | Replies: 8.5K",
          "   - Posted: 2 hours ago",
          "",
          "2. \"X premium subscriptions growing fast\"",
          "   - Likes: 189K | Retweets: 28K | Replies: 12.3K",
          "   - Posted: 5 hours ago",
          "",
          "3. \"Mars colony update: new timeline\"",
          "   - Likes: 312K | Retweets: 45K | Replies: 18.7K",
          "   - Posted: 1 day ago",
          "",
          "Next page available. Say 'next page' to see more."
        ]
      },
      {
        "input": "What is trending in Japan right now?",
        "output": [
          "Here are the top 10 trending topics in Japan:",
          "",
          "1. #大谷翔平 - Sports (baseball season update)",
          "2. #新幹線 - Transportation (new Shinkansen route)",
          "3. #AI規制 - Technology (new AI regulation debate)",
          "4. #円相場 - Finance (yen exchange rate movement)",
          "5. #気象警報 - Weather (typhoon warning)",
          "",
          "Key observation: Sports and weather dominate today.",
          "Ask me for details on any topic."
        ]
      }
