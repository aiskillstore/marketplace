    "user_title": "Analyze CVR Thresholds Against Keyword Ranking Volatility",
    "value_statement": "Amazon sellers struggle to know when low conversion rates threaten organic keyword rankings. This skill analyzes your business report and SIF keyword data to identify the CVR thresholds that predict ranking volatility, giving you an early warning system.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "amazon seller",
      "CVR threshold",
      "keyword ranking",
      "organic search",
      "conversion rate analysis",
      "SIF data",
      "ecommerce analytics"
    ],
    "actual_capabilities": [
      "Reads local CSV and XLSX business reports from LingXing ASIN 360 or compatible sources",
      "Parses user-provided SIF daily keyword JSON exports to extract organic ranking data",
      "Computes three threshold lines: observation, danger, and ad CVR confirmation",
      "Generates daily panel data correlating CVR metrics with rank volatility events",
      "Identifies stable keyword baskets and core keywords for targeted monitoring",
      "Produces markdown reports and CSV output files for further analysis"
    ],
    "limitations": [
      "Requires at least 21 days of continuous data for reliable threshold detection",
      "Does not modify advertising budgets, bids, or product listings",
      "Cannot access Amazon APIs or private SIF endpoints directly",
      "Threshold values are operational warnings, not official Amazon algorithm signals"
    ],
    "use_cases": [
      {
        "title": "Offsite traffic scaling risk assessment",
        "description": "Monitor CVR thresholds when running influencer or affiliate campaigns to prevent organic ranking drops from low-quality traffic.",
        "target_user": "Amazon brand managers running offsite scaling campaigns"
      },
      {
        "title": "Pre-launch baseline establishment",
        "description": "Establish stable keyword baskets and CVR baselines before launching new products or promotional events.",
        "target_user": "E-commerce operations analysts preparing for product launches"
      },
      {
        "title": "Weekly ranking volatility review",
        "description": "Generate weekly reports correlating conversion rate dips with organic search position changes for category keywords.",
        "target_user": "PPC specialists and SEO managers tracking organic visibility"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic threshold analysis",
        "prompt": "Analyze the CVR thresholds for ASIN B0XXXXXXXX using my business report at ./data/business-report.csv and SIF cache at ./data/sif-cache.json. Brand: MyBrand, Site: US.",
        "scenario": "First-time analysis with provided data files"
      },
      {
        "title": "Analysis with launch date",
        "prompt": "Run the CVR threshold analyzer for ASIN B0XXXXXXXX with launch date 2026-01-15. Use the sample files to test the workflow first, then run with my actual data.",
        "scenario": "Post-launch analysis with pre/post phase comparison"
      },
      {
        "title": "Custom core keywords",
        "prompt": "Analyze ASIN B0XXXXXXXX with these core keywords: \"wireless earbuds\", \"bluetooth headphones\", \"sport earphones\". Set analysis date to 2026-02-01.",
        "scenario": "Targeted analysis with manually specified keywords"
      },
      {
        "title": "Full diagnostic with concerns",
        "prompt": "Run the analyzer on my data but flag any concerns about sample size, date gaps, or missing SIF days. Show me which threshold lines are statistically reliable.",
        "scenario": "Quality-conscious analysis with validation requirements"
      }
    ],
    "output_examples": [
      {
        "input": "ASIN B0PUBLIC01 with 12 days of data, launch date 2026-01-05",
        "output": [
          "Observation Line: Overall CVR <= 4.50% (lag 1 day, triggered 7 days, precision 57.14%, recall 66.67%, Lift 1.31)",
          "Danger Line: Overall CVR <= 3.80% (lag 0 days, triggered 5 days, precision 60.00%, recall 50.00%, Lift 1.50)",
          "Ad CVR Confirmation: Ad CVR <= 3.10% (lag 1 day, triggered 4 days, precision 50.00%, recall 33.33%, Lift 1.25)"
        ]
      },
      {
        "input": "ASIN with incomplete data (8 days, missing SIF for 2 days)",
        "output": [
          "Status: DONE_WITH_CONCERNS",
          "Sample size below 21-day minimum: 8 days",
          "SIF keyword data missing for: 2026-01-08, 2026-01-12",
          "Observation line did not meet minimum stability conditions",
          "Recommendation: Collect at least 13 more days of data for reliable thresholds"
        ]
      }
    ],
    "best_practices": [
      "Ensure business report dates are continuous and contain at least 21 days of data before relying on threshold values",
      "Manually verify 2-6 core keywords for your ASIN rather than relying solely on automatic selection",
      "Review generated reports for DONE_WITH_CONCERNS status and address flagged issues before making business decisions",
      "Use the observation line for daily monitoring and the danger line only when considering significant campaign changes"
    ],
    "anti_patterns": [
      "Do not treat threshold values as official Amazon algorithm signals or guaranteed predictions",
      "Do not automatically pause advertising or modify budgets based solely on threshold triggers without human review",
      "Do not mix data from multiple ASINs in a single analysis - always specify a single target ASIN",
      "Do not ignore the human verification requirements when core keywords are auto-selected"
    ],
    "faq": [
      {
        "question": "What data do I need to run this skill?",
        "answer": "You need a daily business report (CSV or XLSX) with date, ASIN, sessions, and CVR columns, plus a SIF daily keyword JSON export for the same ASIN and date range."
      },
      {
        "question": "How long should my data history be?",
        "answer": "The skill requires at least 21 days of continuous data for reliable threshold detection. Shorter periods will generate results but with DONE_WITH_CONCERNS status."
      },
      {
        "question": "Can this skill modify my Amazon advertising or listings?",
        "answer": "No. This skill only reads data and generates analysis reports. Any budget, bid, or listing changes must be done manually based on the generated recommendations."
      },
      {
        "question": "What is the difference between the observation and danger lines?",
        "answer": "The observation line prioritizes high recall for early warnings during daily monitoring. The danger line prioritizes high precision for making pause or scale-back decisions."
      },
      {
        "question": "Does this skill access Amazon APIs directly?",
        "answer": "No. The skill only reads local files that you provide. SIF data must be exported separately using your own SIF MCP or tooling."
      },
      {
        "question": "What does the Ad CVR confirmation line indicate?",
        "answer": "This line helps determine whether low advertising conversion rates are also contributing to organic ranking volatility. It serves as a secondary confirmation signal, not a primary action trigger."
      }
    ]
  },
