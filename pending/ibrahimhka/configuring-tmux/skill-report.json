  "content": {
    "user_title": "Configure tmux status bars and custom widgets",
    "value_statement": "Setting up tmux with a polished status bar and custom widgets is complex with many framework choices and syntax pitfalls. This skill guides you through framework selection, plugin installation, multi-bar setup, and widget development with caching patterns.",
    "seo_keywords": [
      "tmux configuration",
      "tmux status bar",
      "oh-my-tmux",
      "Catppuccin tmux",
      "tmux widgets",
      "tmux plugins",
      "tmux-powerline",
      "Claude Code tmux",
      "tmux multiple bars",
      "terminal customization"
    ],
    "actual_capabilities": [
      "Guide framework selection among oh-my-tmux, Catppuccin, tmux-powerline, or custom setups",
      "Install TPM and essential plugins like resurrect, continuum, cpu, and net-speed",
      "Configure multiple status bars using correct status-format[] syntax for tmux 3.2+",
      "Create widget scripts with proper caching for weather, finance, clocks, and news tickers",
      "Troubleshoot common issues like blank bars, overridden settings, and multi-line output",
      "Set up world clocks and rotating tickers with proper timezone handling"
    ],
    "limitations": [
      "Requires tmux 3.2 or later for multiple status bar support",
      "Widget scripts must output exactly one line to avoid corrupting the status bar",
      "Framework-specific theming may override raw set commands in certain configurations",
      "Some widgets require external API access and appropriate User-Agent headers"
    ],
    "use_cases": [
      {
        "title": "Developer workstation setup",
        "description": "Set up tmux from scratch with a professional status bar showing git branch, system metrics, and world clocks for remote teams.",
        "target_user": "Software developers working across timezones"
      },
      {
        "title": "Terminal dashboard creation",
        "description": "Build a multi-bar tmux setup with separate bars for widgets, finance data, and news tickers to monitor while coding.",
        "target_user": "DevOps engineers and traders"
      },
      {
        "title": "Framework migration assistance",
        "description": "Migrate from one tmux framework to another while preserving custom widgets and avoiding common syntax conflicts.",
        "target_user": "Power users switching from oh-my-tmux to Catppuccin"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic tmux setup",
        "prompt": "Help me set up tmux with a nice status bar. I am new to tmux and want a clean setup with git branch and system metrics.",
        "scenario": "First-time tmux user wanting a polished default configuration"
      },
      {
        "title": "Plugin installation",
        "prompt": "Install TPM and show me how to add resurrect and continuum plugins for session persistence.",
        "scenario": "User wants automatic session restore and background saving"
      },
      {
        "title": "Multiple status bars",
        "prompt": "Set up three status bars in tmux: one for widgets, one for finance data from Yahoo Finance, and one for world clocks.",
        "scenario": "Advanced user building a terminal dashboard with multiple information streams"
      },
      {
        "title": "Custom widget with caching",
        "prompt": "Create a weather widget script that caches API responses for 5 minutes and displays in the tmux status bar without rate limiting.",
        "scenario": "User building network-dependent widgets that need caching to avoid API limits"
      }
    ],
    "output_examples": [
      {
        "input": "Set up tmux with a nice status bar",
        "output": [
          "Framework selection complete: oh-my-tmux installed to ~/.tmux",
          "TPM installed with plugins: resurrect, continuum, tmux-cpu, tmux-net-speed",
          "Status bar configured with git branch, CPU/RAM metrics, and world clocks",
          "Reload tmux with: tmux source-file ~/.tmux.conf"
        ]
      },
      {
        "input": "Add a world clock to my tmux bar",
        "output": [
          "Added status-format entry with PT, EST, and JST timezones",
          "Clocks update automatically every minute via tmux #() syntax",
          "Format: PT 14:30 EST 17:30 JST 06:30 (next day)"
        ]
      }
    ],
    "best_practices": [
      "Always use status-format[] array syntax for multiple bars, not the invalid status2-right",
      "Cache network widget output to /tmp with age checks to avoid API rate limits",
      "Use framework theme variables instead of raw set commands to prevent overrides on reload",
      "Ensure widget scripts output exactly one line - multi-line output corrupts the status bar"
    ],
    "anti_patterns": [
      "Using set -g status-right directly when using oh-my-tmux - use tmux_conf_theme_status_right instead",
      "Referencing status2-right or similar invalid options - tmux 3.2+ uses status-format[] arrays",
      "Fetching APIs in widgets without caching - causes rate limiting and slow bar rendering",
      "Using % for time format in tmux_conf_theme_* variables without escaping as %%"
    ],
    "faq": [
      {
        "question": "Why do my tmux status bar changes not appear after editing config?",
        "answer": "Run tmux source-file ~/.tmux.conf for full reload. If using oh-my-tmux, ensure you edit ~/.tmux.conf.local and use tmux_conf_theme_* variables instead of raw set commands."
      },
      {
        "question": "How do I create multiple status bars in tmux?",
        "answer": "Use tmux 3.2+ syntax: set -g status 3 for three bars, then configure extras with status-format[1] and status-format[2]. Bar 0 is controlled by your framework."
      },
      {
        "question": "My widget script works in terminal but shows blank in tmux bar. Why?",
        "answer": "Tmux #() has minimal PATH. Use absolute paths or ~/ expansion in scripts. Also ensure output is exactly one line with no trailing newlines."
      },
      {
        "question": "What is the difference between TPM and framework themes?",
        "answer": "TPM manages plugins like resurrect and cpu widgets. Frameworks like oh-my-tmux provide complete themes with colors and layouts. Use both together."
      },
      {
        "question": "Why does Yahoo Finance API return empty for my curl command?",
        "answer": "Yahoo blocks default curl User-Agent. Add -A Mozilla/5.0 to your curl command and use the v8 finance endpoint with proper interval parameters."
      },
      {
        "question": "How do I rotate multiple headlines in the status bar?",
        "answer": "Store headlines line-by-line in a cache file, use sed to select one line based on current timestamp modulo line count, and refresh cache via background cron job."
      }
    ]
  },
