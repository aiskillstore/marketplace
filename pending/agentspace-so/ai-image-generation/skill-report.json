    "user_title": "Generate AI images with 11+ models via CLI",
    "value_statement": "Choosing the right AI image model for each task is complex and time-consuming. This skill automatically routes your request to the best model for your specific needs, from photoreal portraits to typography-precise posters.",
    "seo_keywords": [
      "AI image generation",
      "text to image",
      "Claude",
      "Codex",
      "Claude Code",
      "RunComfy",
      "image editing",
      "AI art",
      "prompt engineering",
      "FLUX 2"
    ],
    "actual_capabilities": [
      "Route image generation requests to 11+ AI models based on user intent",
      "Generate images from text descriptions using FLUX 2, GPT Image 2, Seedream, and more",
      "Edit and transform existing images with image-to-image capabilities",
      "Handle specialized tasks like typography, photoreal portraits, and speed iteration",
      "Support open-weights models with LoRA compatibility",
      "Provide model-specific prompting patterns for optimal results"
    ],
    "limitations": [
      "Requires an active RunComfy account and CLI installation",
      "Cannot generate images without internet access to the RunComfy API",
      "Advanced editing features like mask-driven inpainting require a separate skill",
      "Does not support custom model training or fine-tuning"
    ],
    "use_cases": [
      {
        "title": "Marketing campaign visuals",
        "description": "Generate brand-consistent posters and ads with precise typography using GPT Image 2",
        "target_user": "Marketing professionals"
      },
      {
        "title": "Product and portrait photography",
        "description": "Create photorealistic product shots and portraits with accurate skin tones and lighting",
        "target_user": "E-commerce sellers and content creators"
      },
      {
        "title": "Concept art and storyboarding",
        "description": "Quickly iterate on visual concepts with sub-second generation for storyboards and moodboards",
        "target_user": "Designers and art directors"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic text-to-image generation",
        "prompt": "Generate an image of [subject] in [style] style",
        "scenario": "A user wants to create an image from a text description"
      },
      {
        "title": "Photoreal portrait with specific lighting",
        "prompt": "Create a photoreal portrait of [subject] with [lighting] lighting and [camera specs] depth of field",
        "scenario": "A user needs a realistic portrait image with controlled lighting"
      },
      {
        "title": "Edit an existing image",
        "prompt": "Edit this image to [change description]. Keep the original composition and identity.",
        "scenario": "A user wants to modify an existing image while preserving key elements"
      },
      {
        "title": "Brand poster with exact typography",
        "prompt": "Create a poster with headline '[exact text]' in [font description]. Layout should be [layout description].",
        "scenario": "A user needs a branded marketing visual with specific text rendering"
      }
    ],
    "output_examples": [
      {
        "input": "Generate a photoreal portrait of a woman by a window with soft natural light",
        "output": "A high-quality photorealistic portrait image with natural skin tones, soft window lighting, and shallow depth of field. The image captures natural-looking reflections and realistic fabric textures."
      },
      {
        "input": "Create a minimalist product poster with the headline AURORA - Spring 2026 in clean white sans-serif on navy background",
        "output": "A professional brand poster with exact typography rendering. The headline appears in crisp white sans-serif text on a deep navy background. The layout follows the specified 3:2 landscape ratio with precise text placement."
      },
      {
        "input": "Edit this portrait image to change the background to a rainy neon cyberpunk street",
        "output": "The edited image preserves the subject identity, pose, and clothing while transforming the background into a cyberpunk street scene with neon reflections and rain effects."
      }
    ],
    "best_practices": [
      "Start with a clear subject-first prompt: describe the main subject, then the scene, then modifiers like lighting and style",
      "Use lower step counts (4-8) for quick ideation rounds and higher steps (25) only for final polished outputs",
      "Quote exact text inside prompts when using GPT Image 2 to ensure accurate typography rendering"
    ],
    "anti_patterns": [
