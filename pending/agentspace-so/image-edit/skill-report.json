  "content": {
    "user_title": "Edit Images with AI on RunComfy",
    "value_statement": "Users need to edit images but lack guidance on which AI model to use. This skill routes requests to the optimal model based on intent, from batch processing to multilingual text edits.",
    "seo_keywords": [
      "Claude image edit skill",
      "Claude Code image editing",
      "AI image editor",
      "batch image processing",
      "RunComfy image edit",
      "GPT Image 2 edit",
      "Flux Kontext Pro",
      "Claude Codex skills",
      "image-to-image AI",
      "mask inpainting"
    ],
    "actual_capabilities": [
      "Route image edit requests to the optimal model (Nano Banana, GPT Image 2, Flux Kontext, or Z-Image) based on user intent",
      "Process batch edits on up to 20 images with consistent aspect ratio and resolution",
      "Handle multilingual in-image text rewrites in Japanese kana, Cyrillic, Arabic, and other scripts",
      "Perform mask-driven precise region edits for object removal or background replacement",
      "Execute single-reference high-fidelity local edits with Flux Kontext Pro",
      "Generate multi-reference compositions combining subjects, scenes, and color palettes from different images"
    ],
    "limitations": [
      "Cannot blend multiple model routes in a single call; picks one model per invocation",
      "Does not generate images from scratch; only edits existing images",
      "Mask-driven inpainting requires a properly prepared grayscale mask file",
      "Output quality depends on the underlying RunComfy model capabilities and image input quality"
    ],
    "use_cases": [
      {
        "title": "Batch product image standardization",
        "description": "Apply consistent edits across a product catalog. Change backgrounds, adjust watermarks, or update branding across 1-20 images in a single pass.",
        "target_user": "E-commerce teams and product photographers"
      },
      {
        "title": "Multilingual marketing localization",
        "description": "Replace in-image headlines with translated text in any language. Preserve layout, brand marks, and visual identity across all language variants.",
        "target_user": "Marketing teams and localization specialists"
      },
      {
        "title": "Professional retouching and object removal",
        "description": "Remove unwanted elements like watermarks, cables, or distractions using mask-driven inpainting. Replace backgrounds with clean studio paper or custom environments.",
        "target_user": "Graphic designers and photo editors"
      }
    ],
    "prompt_templates": [
      {
        "title": "Simple batch edit",
        "prompt": "Edit [number] images: keep the [subject/product] identity unchanged and [describe the edit you want]. Keep aspect ratio [aspect ratio] and resolution [resolution] consistent.",
        "scenario": "When you have multiple images needing the same edit"
      },
      {
        "title": "Multilingual text rewrite",
        "prompt": "Keep the photograph, layout, and brand mark exactly as in the input. Replace only the in-image headline. The new headline reads [exact text] in [language/script name], same position and font weight.",
        "scenario": "When you need to localize in-image text"
      },
      {
        "title": "Object removal with mask",
        "prompt": "Remove [object description]; preserve [surrounding elements to keep]. The mask covers [mask region description]. Use strength [0.3-0.5 for retouching, 0.7-1.0 for replacement].",
        "scenario": "When you have a prepared mask and need precise region editing"
      },
      {
        "title": "Multi-reference composition",
        "prompt": "Compose [subject from image 1] into the [scene/environment from image 2]. Match the [lighting/color palette from image 3]. Keep [elements to preserve] unchanged.",
        "scenario": "When combining elements from multiple source images"
      }
    ],
    "output_examples": [
      {
        "input": "Edit my product photo to have a clean white background instead of the cluttered desk. Keep the watch identity, pose, and lighting unchanged.",
        "output": "The skill routes to Z-Image Turbo Inpaint. Generates a clean white studio background while preserving the watch product identity, lighting, and specular highlights."
      },
      {
        "input": "Translate the headline in my Japanese poster to English. Keep the layout, brand logo, and image content exactly the same.",
        "output": "The skill routes to GPT Image 2 Edit. Replaces the Japanese kana headline with 'SPECIAL OFFER TODAY' in matching bold sans-serif, same position and visual weight."
      }
    ],
    "best_practices": [
      "Lead with preservation goals in your prompt: state what to keep unchanged before describing the edit",
      "Use concrete spatial language like 'upper-right quadrant' or 'bottom-left corner' for localized edits",
      "Lock aspect_ratio and resolution across batch edits to maintain visual consistency"
    ],
    "anti_patterns": [
      "Do not combine multiple compound edits in a single prompt; split into sequential passes for better results",
      "Avoid vague spatial references like 'nearby' or 'around there'; use precise directional language",
      "Do not skip mask edges in inpainting; slight blur (1-3px) on mask boundaries produces cleaner blends"
    ],
    "faq": [
      {
        "question": "Which model should I use for batch editing?",
        "answer": "Use Nano Banana Edit for batch edits of 1-20 images. It supports consistent aspect ratio and resolution locking for gallery-style edits."
      },
      {
        "question": "How do I edit text that appears in an image?",
        "answer": "Use GPT Image 2 Edit for multilingual text rewrites. Quote the exact current text and specify the new text in your prompt along with the script type."
      },
      {
        "question": "What if I need to remove an object from an image?",
        "answer": "Use Z-Image Turbo Inpaint with a grayscale mask where white indicates the region to replace and black indicates areas to preserve."
      },
      {
        "question": "Can I combine elements from multiple images?",
        "answer": "Yes, GPT Image 2 Edit supports up to 10 reference images. Number them in your prompt like 'subject from image 1, lighting from image 2'."
      },
      {
        "question": "What resolution should I use for outputs?",
        "answer": "Use 1K or 2K for web content, 4K for print. Lock your chosen resolution across batch edits to maintain consistency."
      },
      {
        "question": "How do I get consistent results across multiple edits?",
        "answer": "Set a fixed seed value when you want reproducible outputs. Lead prompts with preservation constraints and keep edit instructions precise and singular."
      }
    ]
  },
