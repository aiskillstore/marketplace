  "content": {
    "user_title": "Create and Edit Word Documents with Claude",
    "value_statement": "Creating professional Word documents requires understanding complex DOCX XML structures and formatting rules. This skill provides comprehensive tools and guidance for generating, editing, and validating .docx files with proper formatting, tracked changes, and comments.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Word documents",
      "DOCX",
      "Microsoft Word",
      "document generation",
      "docx-js",
      "tracked changes",
      "document automation"
    ],
    "actual_capabilities": [
      "Create new Word documents with JavaScript using docx-js library",
      "Edit existing DOCX files by unpacking, modifying XML, and repacking",
      "Add tracked changes (insertions and deletions) with proper author attribution",
      "Insert comments and comment replies into Word documents",
      "Validate DOCX files against Office Open XML schema standards",
      "Accept all tracked changes using LibreOffice integration"
    ],
    "limitations": [
      "Cannot edit password-protected or encrypted Word documents",
      "Requires external tools (LibreOffice, pandoc) for some conversions",
      "Legacy .doc format files must be converted to .docx before editing",
      "Table width calculations must use DXA units, not percentages, for Google Docs compatibility"
    ],
    "use_cases": [
      {
        "title": "Generate Professional Reports",
        "description": "Business analysts can automatically generate polished Word reports with tables of contents, headers, footers, and professional formatting from data sources.",
        "target_user": "Business Analyst"
      },
      {
        "title": "Collaborative Document Review",
        "description": "Legal teams can add tracked changes and comments to contracts for collaborative review while maintaining proper author attribution.",
        "target_user": "Legal Professional"
      },
      {
        "title": "Document Template Automation",
        "description": "Marketing teams can create document templates and automatically populate them with content while preserving consistent branding and formatting.",
        "target_user": "Marketing Specialist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Simple Document",
        "prompt": "Create a new Word document with a title, three paragraphs of text, and a bulleted list. Use US Letter page size with 1-inch margins.",
        "scenario": "Beginner users creating basic documents"
      },
      {
        "title": "Generate Report with Tables",
        "prompt": "Create a Word report document with a title page, table of contents, three sections with headings, and a data table with five rows and three columns. Include headers with page numbers.",
        "scenario": "Intermediate users building formatted reports"
      },
      {
        "title": "Edit Existing Document with Tracked Changes",
        "prompt": "Unpack the document 'contract.docx', add tracked changes to replace '30 days' with '60 days' in the first paragraph, add a comment explaining the change, and repack the document.",
        "scenario": "Advanced users editing documents with revision tracking"
      },
      {
        "title": "Multi-Column Layout with Images",
        "prompt": "Create a Word document with a two-column layout, insert an image at 300x200 pixels in the first column, add a caption below it, and flow text around both columns.",
        "scenario": "Advanced users creating complex layouts with media"
      }
    ],
    "output_examples": [
      {
        "input": "Create a Word document with a heading and two paragraphs",
        "output": "Successfully created 'document.docx' with Heading 1 style title 'My Document' and two body paragraphs in Arial 12pt font on US Letter page with 1-inch margins."
      },
      {
        "input": "Add a table to the document with 3 rows and 2 columns",
        "output": "Added table with width 9360 DXA, column widths [4680, 4680], gray borders, and light blue header shading. Table validated successfully."
      },
      {
        "input": "Unpack report.docx, change the title to 'Annual Report 2025', and repack",
        "output": "Unpacked to 'unpacked/', edited document.xml to update title text, validated XML, and repacked to 'report_updated.docx'. Auto-repair fixed 2 RSID formatting issues."
      }
    ],
    "best_practices": [
      "Always explicitly set page size to US Letter (12240 x 15840 DXA) when creating documents for US audiences, as docx-js defaults to A4",
      "Use WidthType.DXA instead of WidthType.PERCENTAGE for table widths to ensure compatibility with Google Docs",
      "Set both table width (columnWidths array) and individual cell widths to ensure consistent rendering across platforms"
    ],
    "anti_patterns": [
      "Avoid using unicode bullet characters directly in text - use the LevelFormat.BULLET numbering configuration instead",
      "Never use the newline character within Paragraph elements - create separate Paragraph objects for each line of text",
      "Do not use tables for creating horizontal lines or dividers - use paragraph borders instead to avoid rendering issues"
    ],
    "faq": [
      {
        "question": "What file formats can this skill work with?",
        "answer": "This skill works with .docx files (Word 2007+ format). Legacy .doc files must first be converted to .docx using the provided soffice.py script."
      },
      {
        "question": "Do I need to install anything to use this skill?",
        "answer": "For creating new documents, install docx-js via 'npm install -g docx'. For some features like accepting tracked changes or PDF conversion, LibreOffice is required."
      },
      {
        "question": "Why does my table look different in Google Docs?",
        "answer": "Google Docs does not support WidthType.PERCENTAGE. Always use WidthType.DXA with explicit column widths for consistent rendering across platforms."
      },
      {
        "question": "How do I add tracked changes to an existing document?",
        "answer": "Unpack the document, edit the XML to add w:ins and w:del elements with proper author and date attributes, then repack. The skill provides detailed XML patterns for tracked changes."
      },
      {
        "question": "Can I edit password-protected documents?",
        "answer": "No, this skill cannot edit documents that are password-protected or encrypted. The document must be unlocked before editing."
      },
      {
        "question": "What happens if my edited document fails validation?",
        "answer": "The pack.py script includes auto-repair that fixes common issues like RSID formatting and missing xml:space attributes. For other issues, review the validation output and manually correct the XML."
      }
    ]
  },
