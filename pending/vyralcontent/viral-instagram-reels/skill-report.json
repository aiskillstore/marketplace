    "user_title": "Create Better Instagram Reels",
    "value_statement": "Reels often fail because creators optimize for generic short-form advice. This skill gives Reels-specific scripts, captions, trial decisions, and metric diagnostics.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Instagram Reels",
      "Reels hooks",
      "Trial Reels",
      "Reels captions",
      "social media strategy",
      "Reels analytics",
      "content creation"
    ],
    "actual_capabilities": [
      "Drafts timed Instagram Reels scripts with spoken, visual, caption, audio, and CTA sections.",
      "Checks hooks against the three-second Reels retention threshold.",
      "Builds captions with keyword-first structure, send prompts, and limited hashtags.",
      "Decides when a draft should use Trial Reels before public publishing.",
      "Diagnoses weak Reels using skip rate, share rate, followers, retention, and audio signals.",
      "Reviews originality risks such as watermarks, reposted footage, and account audio type."
    ],
    "limitations": [
      "It does not guarantee viral reach or specific performance numbers.",
      "It depends on user-provided brief details, draft footage, or Insights metrics.",
      "It cannot fetch live Instagram data or inspect private account analytics.",
      "Platform rules may change, so current Meta guidance should be checked for high-stakes campaigns."
    ],
    "use_cases": [
      {
        "title": "Draft a Cold-Reach Reel",
        "description": "Turn a topic into a concise Reels script with a hook, payoff, caption, audio note, and send-focused CTA.",
        "target_user": "Solo creator"
      },
      {
        "title": "Evaluate a Brand Reel Before Posting",
        "description": "Check a draft for trial eligibility, originality concerns, caption clarity, and Reels-specific distribution risks.",
        "target_user": "Social media manager"
      },
      {
        "title": "Diagnose an Underperforming Reel",
        "description": "Use Reels Insights to identify whether the problem is hook, retention, topic fit, sends, audio, or caption SEO.",
        "target_user": "Growth marketer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Write a Simple Reel",
        "scenario": "Beginner script creation",
        "prompt": "Write a 20-second Instagram Reel about [topic] for [audience]. Include the hook, spoken beats, on-screen text, caption, and CTA."
      },
      {
        "title": "Improve My Hook",
        "scenario": "Intermediate hook rewrite",
        "prompt": "Review this Reels hook for the three-second cliff: [hook]. Give a pass or fail, explain why, and rewrite three stronger options."
      },
      {
        "title": "Choose Trial or Publish",
        "scenario": "Advanced posting decision",
        "prompt": "Decide whether this Reel should use Trial Reels first. Account size: [followers]. Goal: [goal]. Draft summary: [draft]. Risk tolerance: [low or high]."
      },
      {
        "title": "Diagnose With Insights",
        "scenario": "Advanced performance analysis",
        "prompt": "Diagnose this Reel using Insights. Reach: [number]. Skip rate: [number]. Share rate: [number]. Average watch time: [number]. Followers: [number]. Caption: [caption]."
      }
    ],
    "output_examples": [
      {
        "input": "A skincare creator wants a Reel about niacinamide for oily skin.",
        "output": "The skill produces a 15 to 30 second script with a specific first-frame hook, spoken beats, concise on-screen text, caption keywords, and a send prompt."
      },
      {
        "input": "A creator has high views but almost no follows from a Reel.",
        "output": "The skill identifies topic legibility as the likely issue, then recommends clearer first-frame text, caption keywords, and profile alignment."
      },
      {
        "input": "A social media manager is unsure whether to publish a draft publicly.",
        "output": "The skill checks account eligibility, cold-reach goal, timing needs, and uncertainty level before recommending a Trial Reel or direct publish."
      }
    ],
    "best_practices": [
      "Provide the account goal, audience, account type, and follower count before asking for a script.",
      "Share actual Reels Insights when asking for a diagnosis.",
      "Use the originality and audio checklist before publishing or trialling a Reel."
    ],
    "anti_patterns": [
      "Asking for guaranteed viral outcomes or fixed view counts.",
      "Using generic TikTok or Shorts advice for Reels without platform checks.",
      "Ignoring caption keywords, watermarks, and audio licensing when evaluating performance."
    ],
    "faq": [
      {
        "question": "Does this skill guarantee viral Reels?",
        "answer": "No. It uses Reels-specific patterns to improve odds, but it cannot predict or guarantee reach."
      },
      {
        "question": "Can it analyze my Instagram account directly?",
