  "content": {
    "user_title": "Generate Viral Short-Form Video Ideas",
    "value_statement": "Creators often run out of specific short-form video ideas. This skill turns niches, pillars, audience signals, and source assets into organized idea batches.",
    "seo_keywords": [
      "Claude short-form ideas",
      "Codex content ideation",
      "Claude Code creator workflow",
      "TikTok video ideas",
      "Instagram Reels ideas",
      "YouTube Shorts ideas",
      "content pillar generator",
      "short-form content matrix",
      "video repurposing prompts",
      "creator idea mining"
    ],
    "actual_capabilities": [
      "Drafts short-form video ideas grouped by pillar, angle, format, or platform.",
      "Builds 3 to 5 content pillars from a creator niche and audience brief.",
      "Expands one topic into multiple angles using repurposing and content matrix workflows.",
      "Guides audience mining from comments, DMs, Reddit, autocomplete, and competitor outliers.",
      "Scores candidate ideas with hook, audience fit, retention, and creator excitement filters.",
      "Provides fill-in worksheets for pillars, matrices, mining sessions, repurposing, and idea tracking."
    ],
    "limitations": [
      "It does not guarantee virality or predict platform algorithm outcomes.",
      "It does not fetch live platform data or inspect real accounts by itself.",
      "It needs a niche, audience, topic, or sample idea for the strongest output.",
      "It focuses on ideation, not full scripting, editing, posting, or analytics reporting."
    ],
    "use_cases": [
      {
        "title": "Batch Weekly Video Ideas",
        "target_user": "Solo creator",
        "description": "Turn a niche and posting goal into a ranked list of short-form ideas for the next week."
      },
      {
        "title": "Create A Pillar System",
        "target_user": "Creator coach",
        "description": "Help a client reduce scattered topics into 3 to 5 repeatable content pillars."
      },
      {
        "title": "Repurpose Source Assets",
        "target_user": "Marketing team",
        "description": "Convert one podcast, webinar, or guide into short-form video angles and companion post ideas."
      }
    ],
    "prompt_templates": [
      {
        "title": "Get 20 Ideas",
        "scenario": "Beginner one-shot brainstorm",
        "prompt": "I make short-form videos about [niche] for [audience]. Generate 20 specific TikTok, Reels, or Shorts ideas grouped by content pillar."
      },
      {
        "title": "Build My Pillars",
        "scenario": "Creator needs a repeatable system",
        "prompt": "Help me build 3 to 5 content pillars for [niche]. My audience is [audience], and my current topics are [topics]."
      },
      {
        "title": "Turn One Topic Into Angles",
        "scenario": "Intermediate repurposing workflow",
        "prompt": "Turn this topic into 10 distinct short-form video angles: [topic]. Include hook direction, format, and why each angle is different."
      },
      {
        "title": "Mine And Rank Ideas",
        "scenario": "Advanced strategy session",
        "prompt": "Use audience mining and idea evaluation for [niche]. Start from these comments, searches, or competitor outliers: [inputs]. Return ranked production candidates."
      }
    ],
    "output_examples": [
      {
        "input": "I make home espresso videos and need ideas for next week.",
        "output": [
          "Pillars: gear decisions, technique fixes, and beginner mistakes.",
          "Idea: The 3-second tamp check that fixed my channeling.",
          "Idea: I spent too much on grinders before learning this one rule.",
          "Top pick: Film the tamp check first because it has a clear visual payoff."
        ]
      },
      {
        "input": "Turn my podcast episode on client onboarding into Shorts ideas.",
        "output": [
          "Short 1: The onboarding question that prevents scope creep.",
          "Short 2: Why your welcome email is doing too much work.",
          "Short 3: The 10-minute handoff that reduces revision cycles.",
          "Repurpose path: Post three clips first, then turn the strongest into a carousel."
        ]
      },
      {
        "input": "Score these five ideas before I produce them.",
        "output": [
          "The strongest candidate has a clear first frame, broad audience fit, and a concrete payoff.",
          "Two ideas should be merged because they answer the same audience question.",
          "One idea should be cut because the hook cannot be stated clearly in one sentence."
        ]
      }
    ],
    "best_practices": [
      "Provide a clear niche, target audience, platform, and posting cadence before asking for large batches.",
      "Generate first, then run a separate filter pass to rank and cut weak ideas.",
      "Save top audience comments, searches, and outlier examples before mining for new ideas."
    ],
    "anti_patterns": [
