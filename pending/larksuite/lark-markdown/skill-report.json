  "content": {
    "user_title": "Manage Lark Markdown files in Drive",
    "value_statement": "Manually creating and updating Markdown files in Lark Drive is time-consuming. This skill automates Markdown file operations by providing CLI shortcuts to create, fetch, and overwrite .md files stored in your Lark workspace.",
    "seo_keywords": [
      "lark markdown",
      "feishu markdown",
      "lark drive",
      "feishu drive",
      "markdown file management",
      "lark-cli",
      "lark document automation",
      "Claude Codex Claude Code",
      "markdown create",
      "lark file integration"
    ],
    "actual_capabilities": [
      "Create native .md files directly in Lark Drive with content from inline text, local files, or stdin",
      "Fetch and read Markdown file content from Lark Drive using file tokens",
      "Overwrite existing Markdown file content while preserving the file in Drive",
      "Save fetched Markdown content to local files with optional overwrite",
      "Specify target folders for file creation using folder tokens"
    ],
    "limitations": [
      "Only works with native Markdown files (.md) stored in Drive, not docx documents",
      "Requires lark-cli binary and valid Lark authentication to function",
      "Cannot perform file rename, move, delete, search, permissions, or comments operations"
    ],
    "use_cases": [
      {
        "title": "Documentation Automation",
        "description": "Automate creation and updates of project documentation stored in your Lark workspace. Perfect for keeping READMEs and guides synchronized.",
        "target_user": "Developers managing documentation"
      },
      {
        "title": "Meeting Notes Sync",
        "description": "Create Markdown templates in Drive for meeting notes, then update them with generated content after meetings.",
        "target_user": "Team leads and project managers"
      },
      {
        "title": "Knowledge Base Management",
        "description": "Build and maintain a Markdown-based knowledge base in Lark Drive with automated content updates.",
        "target_user": "Content teams and knowledge managers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a new Markdown file",
        "prompt": "Create a new Markdown file called {filename} in my Lark Drive with the following content: {content}",
        "scenario": "When you need to create a new .md file in Lark Drive with specific content"
      },
      {
        "title": "Fetch and read Markdown content",
        "prompt": "Read the content of the Markdown file {file_token} from Lark Drive",
        "scenario": "When you need to retrieve and read existing Markdown files"
      },
      {
        "title": "Update existing Markdown file",
        "prompt": "Update the Markdown file {file_token} in Lark Drive with this new content: {content}",
        "scenario": "When you need to overwrite and update an existing .md file"
      },
      {
        "title": "Download Markdown to local file",
        "prompt": "Fetch the Markdown file {file_token} from Lark Drive and save it to {local_path}",
        "scenario": "When you want to download a Markdown file from Drive to local storage"
      }
    ],
    "output_examples": [
      {
        "input": "Create a new Markdown file called README.md in my Lark Drive with content about the project",
        "output": "Successfully created README.md in Drive with file_token: boxcnxxxx. The file contains your project description and is ready to share."
      },
      {
        "input": "Read the content of the Markdown file with token boxcnxxxx",
        "output": "Fetched README.md from Lark Drive. Content: # Project Name\n\n## Overview\nThis project provides..."
      },
      {
        "input": "Update the Markdown file boxcnxxxx with new release notes",
        "output": "Successfully updated the Markdown file. New version: 7633658129540910621. File size: 2048 bytes."
      }
    ],
    "best_practices": [
      "Always verify file tokens are correct before performing overwrite operations to avoid data loss",
      "Use the --dry-run flag to preview API requests before making changes to Drive",
      "Include the .md file extension in all file names as the CLI requires it"
    ],
    "anti_patterns": [
      "Do not use this skill for docx documents - use lark-drive instead for Word document operations",
      "Do not skip reading the lark-shared skill for authentication and security rules",
      "Do not attempt owner transfer without explicit user confirmation"
    ],
    "faq": [
      {
        "question": "What types of files can this skill manage?",
        "answer": "This skill only works with native Markdown files (.md) stored in Lark Drive. It cannot manage docx, sheets, or other document types."
      },
      {
        "question": "How do I authenticate before using this skill?",
        "answer": "You need to run lark-cli auth login first to authenticate with your Lark workspace. See the lark-shared skill for detailed authentication instructions."
      },
      {
        "question": "Can I create files in specific folders?",
        "answer": "Yes, use the --folder-token parameter to specify the target folder token. Without it, files are created in the root Drive directory."
      },
      {
        "question": "What happens if I try to overwrite without proper permissions?",
        "answer": "The Lark API will return an error. Ensure the authenticated user has edit permissions on the target Markdown file."
      },
      {
        "question": "How do I preview what changes will be made before executing?",
        "answer": "Add the --dry-run flag to any command to see the underlying API request without actually executing it."
      },
      {
        "question": "Can I use stdin to pass content to the skill?",
        "answer": "Yes, use --content - to read content from stdin, which allows piping output from other commands into the Markdown file creation."
      }
    ]
  },
