  "content": {
    "user_title": "Annotate Genetic Variants with ACMG Guidelines",
    "value_statement": "This skill helps researchers and clinicians query and interpret genetic variants from ClinVar and dbSNP databases using the Python VariantAnnotator module. It provides ACMG guideline-based pathogenicity classification alongside population frequency data and functional predictions.",
    "seo_keywords": [
      "variant annotation",
      "ClinVar",
      "dbSNP",
      "ACMG guidelines",
      "pathogenicity classification",
      "genetic variant interpretation",
      "Claude",
      "Codex",
      "Claude Code",
      "bioinformatics"
    ],
    "actual_capabilities": [
      "Query genetic variants by rsID, HGVS cDNA, HGVS protein, HGVS genomic, VCF coordinates, and Gene:Amino Acid format",
      "Retrieve clinical significance classifications from ClinVar with review status and star ratings",
      "Calculate ACMG/AMP pathogenicity scores using weighted evidence criteria from population frequency and clinical data",
