  "content": {
    "user_title": "Build Precise PubMed Search Queries with Boolean Logic",
    "value_statement": "Creating effective PubMed search strings requires expert knowledge of MeSH terms, Boolean operators, and field tags. This skill converts research questions into precise, reproducible search strategies for systematic reviews and clinical queries.",
    "seo_keywords": [
      "PubMed search",
      "Claude",
      "Codex",
      "Claude Code",
      "MeSH terms",
      "Boolean query",
      "medical research",
      "systematic review",
      "literature search",
      "clinical queries"
    ],
    "actual_capabilities": [
      "Maps natural language research questions to standardized MeSH terms",
      "Builds complex Boolean queries with AND/OR/NOT operators and proper nesting",
      "Applies PubMed filters for study type, date range, language, and population",
      "Generates line-by-line search strategies with sensitivity and specificity guidance",
      "Validates query syntax for balanced parentheses and correct field tags",
      "Produces copy-paste ready PubMed search strings from PICO framework inputs"
    ],
    "limitations": [
      "Does not execute PubMed searches or retrieve article results",
      "MeSH term suggestions are based on common mappings, not live database lookup",
      "Does not replace systematic review methodology training",
      "PubMed field tags may change; verify against current PubMed documentation"
    ],
    "use_cases": [
      {
        "title": "Systematic Review Literature Search",
        "description": "A researcher needs a comprehensive search strategy for a systematic review on diabetes treatments. The skill builds a multi-concept Boolean query with MeSH terms and synonyms.",
        "target_user": "Medical researcher conducting systematic reviews"
      },
      {
        "title": "Clinical Question Search Strategy",
        "description": "A clinician wants to find evidence about a specific therapy for hypertension in elderly patients. The skill applies clinical query filters and population-specific limits.",
        "target_user": "Healthcare professional seeking evidence-based answers"
      },
      {
        "title": "Medical Librarian Search Support",
        "description": "A librarian helps a patron find literature on a complex multi-condition topic. The skill generates properly structured queries with correct MeSH mappings and field tags.",
        "target_user": "Health sciences librarian providing search assistance"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic PICO Query Builder",
