    {
      "priority": "P1",
      "title": "One assertion failure: algorithm from training memory presented without live verification",
      "observed_in": [
        4
      ],
      "problem": "One algorithm recommendation was based on training memory without a verified primary paper, presented as if the paper had been found.",
      "root_cause": "Hard rule prohibits fabrication but the transition from 'no live access' to 'training knowledge based' labeling is not consistently enforced.",
      "fix": "Add explicit enforcement: any algorithm mentioned without a verified primary paper URL/DOI must be labeled '[Based on training knowledge — verify before use]' and a PubMed search strategy provided."
    },
    {
      "priority": "P2",
      "title": "No explicit handling of superseded or retracted algorithms",
      "observed_in": [],
      "problem": "The skill recommends recent algorithms but does not specify how to handle algorithms that are known to have been superseded or retracted.",
      "root_cause": "Focus on recency without retraction/supersession awareness.",
      "fix": "Add a retraction caveat: 'Before recommending any algorithm, note that widely-used tools may have been superseded or corrected. When recommending any algorithm, include a check: verify no major corrections or supersession notices in the original paper or follow-up literature.'"
