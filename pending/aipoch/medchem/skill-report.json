  "content": {
    "user_title": "Filter compound libraries with medicinal chemistry rules",
    "value_statement": "Medicinal chemists spend significant time manually applying drug-likeness rules to large compound libraries. This skill automates screening with Lipinski, Veber, PAINS filters, and complexity metrics to prioritize viable drug candidates.",
    "seo_keywords": [
      "compound library filtering",
      "medicinal chemistry",
      "drug-likeness rules",
      "Lipinski rule of five",
      "PAINS filtering",
      "compound prioritization",
      "cheminformatics",
      "Claude",
      "Codex",
      "Claude Code"
    ],
    "actual_capabilities": [
      "Apply drug-likeness rules (Lipinski, Veber, CNS, Oprea) to filter compound libraries",
      "Screen molecules for structural alerts including PAINS, NIBR filters, and Lilly demerits",
      "Calculate molecular complexity scores and filter by configurable thresholds",
      "Detect chemical functional groups using SMARTS-based pattern matching",
      "Apply custom property constraints for molecular weight, logP, TPSA, and hydrogen bond counts",
      "Generate detailed filtering summary reports with pass/fail statistics per filter"
    ],
    "limitations": [
      "Requires Python and external dependencies (medchem, datamol, RDKit) to be installed locally",
      "Does not generate or design new molecules, only filters and evaluates existing compounds",
      "Rule-based filtering cannot predict in vivo efficacy, toxicity, or clinical outcomes",
      "Performance depends on input file size and available CPU cores for parallel processing"
    ],
    "use_cases": [
      {
        "title": "Pharmaceutical researcher screening HTS hits",
        "description": "Apply Lipinski Rule of Five and Veber rules to filter high-throughput screening results and identify drug-like candidates for further development.",
        "target_user": "Medicinal chemist at a pharmaceutical company"
      },
      {
        "title": "Academic lab prioritizing fragment hits",
        "description": "Use Rule of Three and complexity filters to identify promising fragments from a crystallography screen, removing overly complex or reactive compounds.",
        "target_user": "Academic researcher in drug discovery"
      },
      {
        "title": "Toxicology specialist flagging reactive compounds",
        "description": "Apply structural alerts and PAINS filters to flag potentially problematic chemotypes in a compound library before selecting candidates for assay testing.",
        "target_user": "Safety assessment scientist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic drug-likeness screening",
        "prompt": "I have a CSV file with SMILES in the 'smiles' column. Please help me apply Lipinski Rule of Five and Veber rules to filter this compound library for drug-like molecules.",
        "scenario": "New user screening a compound library for the first time"
      },
      {
        "title": "Multi-rule filtering with structural alerts",
        "prompt": "Apply the Oprea and CNS rule sets to my compound library and run common structural alerts alongside PAINS filtering. Show me which molecules pass all filters.",
        "scenario": "Intermediate user combining rule sets with structural alerts"
      },
      {
        "title": "Custom constraints and complexity analysis",
        "prompt": "Filter my compound SDF file using a logP range of -2 to 5, molecular weight under 450, and TPSA under 90. Calculate molecular complexity and reject anything above 400.",
        "scenario": "Advanced user applying target-specific property windows"
      },
      {
        "title": "Full library characterization with group detection",
        "prompt": "Analyze my compound library by applying all rule filters, structural alerts, and complexity metrics. Also detect chemical groups including Michael acceptors, hinge binders, and reactive groups. Generate a full summary report.",
        "scenario": "Expert user performing comprehensive library profiling"
      }
    ],
    "output_examples": [
      {
        "input": "Apply Lipinski Rule of Five and Veber rules to this compound library: CC(=O)OC1=CC=CC=C1C(=O)O, CN1C=NC2=C1C(=O)N(C(=O)N2C)C, c1ccccc1",
        "output": "Screening results:\n- Aspirin (CC(=O)OC1=CC=CC=C1C(=O)O): Passes all rules\n- Caffeine (CN1C=NC2=C1C(=O)N(C(=O)N2C)C): Passes all rules\n- Benzene (c1ccccc1): Fails Lipinski MW < 500 (MW=78 is acceptable) but fails Veber rotatable bonds criterion\n\nCompounds passing all filters: 2/3"
      },
      {
        "input": "Check these compounds for structural alerts and PAINS: O=C(Nc1ccccc1)c2ccccc2, CC(C)(C)c1ccc(O)c(c1)C(C)(C)C",
        "output": "Structural alert analysis:\n- Compound 1 (O=C(Nc1ccccc1)c2ccccc2): No PAINS detected. Common alerts: none. Clean.\n- Compound 2 (CC(C)(C)c1ccc(O)c(c1)C(C)(C)C): No PAINS detected. Common alerts: contains a phenol group (potential aggregation liability).\n\nRecommended action: Compound 2 flagged for manual review of aggregator potential."
      }
    ],
    "best_practices": [
      "Start with broad filters (Lipinski, Veber) and progressively tighten criteria as your understanding of the target space matures.",
      "Review flagged molecules individually rather than discarding them automatically, as some structural alerts may be desirable for specific targets such as covalent inhibitors.",
      "Document all filter parameters and thresholds used in each screening campaign to ensure reproducibility across projects."
    ],
    "anti_patterns": [
      "Applying CNS-specific rules to non-CNS targets without adjusting property windows, which may incorrectly discard viable compounds.",
      "Using maximum complexity thresholds without first analyzing the distribution of complexity scores across the library.",
      "Relying solely on PAINS filters for compound triage while ignoring that some PAINS motifs appear in approved drugs."
    ],
    "faq": [
      {
        "question": "What file formats does the filtering script support?",
        "answer": "The script supports CSV, TSV, SDF, and plain text files with one SMILES per line."
      },
      {
        "question": "What are PAINS filters and why should I use them?",
        "answer": "PAINS (Pan-Assay INterference Compounds) filters identify compounds that frequently cause false positive results in biological screening assays."
      },
      {
        "question": "Can I apply multiple rule sets at the same time?",
        "answer": "Yes, you can combine any number of rule sets by listing them as comma-separated values with the --rules flag."
      },
      {
        "question": "What is the Lilly demerit system?",
        "answer": "Lilly demerits assign penalty scores for each structural alert matched. Compounds with total demerits above 100 are typically rejected."
      },
      {
        "question": "How do I filter molecules for CNS drug targets?",
        "answer": "Apply the CNS rule set along with property constraints such as logP between 2 and 5 and TPSA under 90 square angstroms."
      },
      {
        "question": "Does this skill generate new chemical structures?",
        "answer": "No, this skill only filters and evaluates existing compounds. It does not generate or design new molecules."
      }
    ]
