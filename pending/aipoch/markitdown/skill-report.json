    ],
    "best_practices": [
      "Use streaming conversion for large files to avoid memory issues",
      "Set up proper directory structures before batch processing to keep outputs organized",
      "Use the dedicated prompt types (scientific, medical, data_viz) for specialized image analysis"
    ],
    "anti_patterns": [
      "Passing API keys directly in command-line arguments where they may be visible in process listings",
      "Converting files without verifying the output structure for complex layouts",
      "Running batch conversion on very large directories without testing on a subset first"
    ],
    "faq": [
      {
        "question": "What file formats does this skill support?",
        "answer": "It supports PDF, DOCX, PPTX, XLSX, CSV, HTML, JSON, XML, EPUB, ZIP, images (with OCR), and audio (with transcription)."
      },
      {
        "question": "Do I need an API key to use this skill?",
        "answer": "Basic conversion does not require an API key. AI-enhanced image descriptions require an OpenRouter or OpenAI API key, set via the OPENROUTER_API_KEY environment variable."
      },
      {
        "question": "Is OCR supported for scanned documents?",
        "answer": "Yes, OCR is supported when Tesseract is installed on your system. Install it using your package manager (e.g., apt install tesseract-ocr)."
      },
      {
        "question": "Can I convert multiple files at once?",
        "answer": "Yes, use the batch_convert.py script to process entire directories with parallel workers for faster conversion."
      },
      {
        "question": "How does the AI image description feature work?",
        "answer": "It sends slide or document images to an OpenAI-compatible API (like OpenRouter) which generates text descriptions. These are then inserted into the Markdown output."
      },
      {
        "question": "Are there any file size limitations?",
        "answer": "There are no hard size limits, but large files may cause memory pressure. Use the streaming conversion API for files larger than 100MB."
      }
    ]
  },
