  "content": {
    "user_title": "Convert Documents to Clean Markdown for LLM Pipelines",
    "value_statement": "Researchers and data scientists spend too much time cleaning and reformatting documents before they can use them with LLMs. This skill converts PDFs, Office files, images, and audio directly into clean Markdown, ready for summarization, RAG ingestion, or analysis.",
    "seo_keywords": [
      "markdown conversion",
      "document processing",
      "LLM pipeline",
      "MarkItDown",
      "Claude",
      "Codex",
      "Claude Code",
      "PDF to markdown",
      "RAG preparation",
      "file conversion"
    ],
    "actual_capabilities": [
      "Convert PDF, DOCX, PPTX, XLSX, HTML, EPUB, images, and audio to structured Markdown",
      "Process files in batch mode with parallel workers for large document sets",
      "Generate AI-enhanced image and slide descriptions via OpenRouter or OpenAI-compatible APIs",
      "Extract tables and structured content from spreadsheets into Markdown tables",
      "Organize converted academic papers with metadata extraction and index generation",
      "Stream conversion for large files without loading entire contents into memory"
    ],
    "limitations": [
      "OCR requires Tesseract to be installed at the system level",
      "Audio transcription requires additional dependencies to be installed separately",
      "AI image descriptions require a paid OpenRouter or OpenAI API key",
      "Complex PDF layouts with multi-column text may lose structural fidelity"
    ],
    "use_cases": [
      {
        "title": "Literature Review Preparation",
        "description": "Convert a folder of academic PDFs into Markdown files with metadata extraction and automatic index generation.",
        "target_user": "Academic researcher"
      },
      {
        "title": "RAG Pipeline Ingestion",
        "description": "Batch convert documents in various formats to clean Markdown for embedding and indexing in a retrieval-augmented generation system.",
        "target_user": "ML engineer"
      },
      {
        "title": "Accessible Document Analysis",
        "description": "Convert scanned documents and presentation slides to Markdown with OCR and AI-generated image descriptions for non-visual analysis.",
        "target_user": "Data analyst"
      }
    ],
    "prompt_templates": [
      {
        "title": "Quick Single File Conversion",
        "prompt": "Convert this file to Markdown using markitdown",
        "scenario": "User needs to quickly convert one document"
      },
      {
        "title": "Batch Document Processing",
        "prompt": "Run the batch converter on the input directory and output the results to a markdown folder. Process all PDF and DOCX files.",
        "scenario": "User has a folder of documents to convert in bulk"
      },
      {
        "title": "Academic Paper Processing",
        "prompt": "Convert all PDFs in the papers folder to Markdown, organize output by publication year, and create an index of all papers.",
        "scenario": "Researcher organizing literature for a review paper"
      },
      {
        "title": "AI-Enhanced Image Description",
        "prompt": "Convert this presentation to Markdown with AI-generated image descriptions for all slides. Use the scientific prompt type for detailed analysis.",
        "scenario": "User needs accessible descriptions of slide content"
      }
    ],
    "output_examples": [
      {
