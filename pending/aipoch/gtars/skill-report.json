  "content": {
    "user_title": "Analyze genomic intervals with high-performance Rust tools",
    "value_statement": "Genomic interval analysis is slow with traditional Python-only libraries. Gtars provides a high-performance Rust toolkit with Python bindings for fast overlap queries, coverage generation, and ML tokenization.",
    "seo_keywords": [
      "gtars",
      "genomic analysis",
      "bioinformatics",
      "interval overlap",
      "Claude",
      "Codex",
      "Claude Code",
      "coverage tracks",
      "genomic tokenization",
      "DNA sequence analysis"
    ],
    "actual_capabilities": [
      "Perform fast overlap queries between genomic interval sets using IGD indexing",
      "Generate coverage tracks in WIG, BigWig, and BedGraph formats from BED files",
      "Tokenize genomic regions into discrete representations for machine learning pipelines",
      "Calculate and verify GA4GH refget-compliant sequence digests using SHA-512",
      "Process single-cell fragment data with barcode splitting and enrichment scoring",
      "Convert between genomic data formats including BED, JSON, and NumPy arrays"
    ],
    "limitations": [
      "Requires the gtars Python package or Rust toolchain to be installed separately",
      "Documentation covers only the modules described - not all gtars features may be included",
      "Large genome-wide analyses may require significant memory and disk space",
      "No built-in visualization - coverage tracks must be viewed with external genome browsers"
    ],
    "use_cases": [
      {
        "title": "ChIP-seq peak overlap analysis",
        "description": "Find transcription factor binding sites that overlap with promoter regions using IGD-indexed interval queries.",
        "target_user": "Bioinformatician analyzing regulatory element interactions"
      },
      {
        "title": "Genomic ML preprocessing",
        "description": "Convert genomic regions into discrete tokens for training transformer-based deep learning models.",
        "target_user": "Machine learning researcher working with genomic sequence data"
      },
      {
        "title": "Single-cell fragment processing",
        "description": "Split fragment files by cell barcodes or clusters and score fragments against reference region sets.",
        "target_user": "Single-cell genomics researcher analyzing chromatin accessibility"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic overlap query",
        "prompt": "Use gtars to find which regions from my peaks BED file overlap with my promoters BED file. Load both files, perform the overlap query using IGD indexing, and export the overlapping regions to a new BED file.",
        "scenario": "User has two BED files and needs to find shared genomic intervals"
      },
      {
        "title": "Coverage track generation",
        "prompt": "Generate a coverage track from my ATAC-seq fragments BED file using gtars. Create a BigWig format coverage file at a resolution of 10 base pairs for visualization in a genome browser.",
        "scenario": "User needs to create browser-track coverage data from sequencing fragments"
      },
      {
        "title": "ML tokenization pipeline",
        "prompt": "Build a genomic tokenizer from my training regions BED file using the gtars TreeTokenizer. Tokenize each region and prepare the token sequences for input to a transformer model.",
        "scenario": "User preparing genomic region data for machine learning model training"
      },
      {
        "title": "Reference sequence verification",
        "prompt": "Use gtars refget to load a FASTA reference genome, calculate SHA-512 truncated digests for each chromosome, and verify the digests match the expected GA4GH refget protocol values.",
        "scenario": "User needs to verify integrity of reference genome assemblies"
      }
    ],
    "output_examples": [
      {
        "input": "Find which ChIP-seq peaks overlap with known promoter regions",
        "output": "Overlap analysis complete: 1,247 out of 5,000 ChIP-seq peaks (24.9%) overlap with promoter regions. Results saved to peaks_in_promoters.bed. The IGD index was built once and reused for chromosome-by-chromosome queries."
      },
