        "title": "Research Paper Archival",
        "description": "A researcher saves web-based academic articles or preprints as PDFs for offline reading, citation management, and long-term archival with preserved formatting.",
        "target_user": "Academic researchers and students"
      },
      {
        "title": "Bilingual Report Generation",
        "description": "An office manager creates formatted PDF reports containing both English and Hebrew content, ensuring correct right-to-left layout for the Hebrew sections.",
        "target_user": "Office administrators and business professionals"
      }
    ],
