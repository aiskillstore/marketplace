      "Codex PDF generation",
      "headless Chrome PDF",
      "document automation"
    ],
    "actual_capabilities": [
      "Convert local HTML files to PDF with Chrome-accurate layout rendering",
      "Convert web page URLs to PDF with full JavaScript execution and resource loading",
      "Accept HTML piped via stdin for quick inline conversions",
      "Auto-detect Hebrew and Arabic content and apply RTL text direction",
      "Support custom page formats, margins, scale, headers, and footers",
      "Load additional fonts for improved CJK and RTL character rendering"
    ],
    "limitations": [
      "Requires Node.js and Puppeteer with a Chromium or Chrome browser installed",
      "Single-page PDFs require manual CSS tuning to avoid overflow to extra pages",
      "Large or complex pages with many resources may need longer wait times for full rendering",
      "External font loading depends on network availability and font server response times"
    ],
    "use_cases": [
