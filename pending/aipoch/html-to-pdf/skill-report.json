        "input": "HTML invoice file with CSS grid layout, custom fonts, and a company logo",
        "output": "Print-ready A4 PDF preserving the exact layout, colors, font rendering, and image placement. Margins are consistent, and no content is clipped or split across pages."
      },
      {
        "input": "Hebrew news article URL with mixed English and Hebrew text",
        "output": "PDF with correct right-to-left text direction for Hebrew paragraphs, left-to-right for embedded English terms. Fonts render crisply at 2x device scale factor."
      },
      {
        "input": "HTML piped via stdin containing a simple styled table",
        "output": "Formatted PDF document with the table rendered in proper alignment, including borders, background colors, and cell padding exactly as specified in the CSS."
      }
    ],
    "best_practices": [
      "Always verify the output PDF visually after generation, especially for single-page layouts where overflow can cause extra blank pages.",
      "For RTL documents, use the --rtl flag and add the lang attribute to your HTML element to ensure correct bidirectional text handling.",
      "Increase --wait time for pages that load external fonts, large images, or client-side JavaScript to ensure complete rendering."
    ],
    "anti_patterns": [
      "Do not set background colors or images on the html or body elements directly, as this often causes extra blank pages in PDF output.",
      "Do not assume all web fonts will load instantly; always use a sufficient --wait value and test with the target content.",
      "Do not omit page size and margin settings and rely on defaults, as different content types may produce unexpected results."
    ],
    "faq": [
      {
        "question": "What input formats are supported?",
        "answer": "The skill supports local HTML file paths, HTTP/HTTPS URLs, and standard input via pipe. Use '-' as the input argument to pipe HTML content."
      },
      {
        "question": "How does RTL support work?",
        "answer": "The skill automatically scans the HTML content for Hebrew and Arabic characters. If found, it applies right-to-left text direction. You can force RTL with the --rtl flag for all content."
      },
      {
        "question": "Can I control page size and margins?",
        "answer": "Yes. Use --format to set page size (A4, Letter, Legal, A3, A5) and --margin or --margin-top/--margin-bottom/--margin-left/--margin-right for precise margin control."
      },
      {
        "question": "Why does my PDF have extra blank pages?",
        "answer": "Extra blank pages are usually caused by overflow from the content area. Use overflow:hidden on html and body, set backgrounds on inner containers instead, and adjust --scale or --margin as needed."
      },
      {
        "question": "Does this work without installing a browser?",
        "answer": "Puppeteer bundles Chromium by default during npm install. You can also use an existing Chrome or Edge installation by providing the path via --executable-path or the PUPPETEER_EXECUTABLE_PATH environment variable."
      },
      {
        "question": "How do I handle dynamic JavaScript content?",
        "answer": "The skill waits for networkidle0 and document.fonts.ready by default, plus an additional configurable wait time via --wait. This allows JavaScript-rendered content like charts to finish before PDF generation."
      }
    ]
