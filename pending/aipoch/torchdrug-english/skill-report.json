  "content": {
    "user_title": "Use TorchDrug for drug discovery with graph neural networks",
    "value_statement": "Drug discovery researchers need a specialized framework to apply graph neural networks to molecular and protein data, but building custom GNN pipelines from scratch is complex and time-consuming. This skill provides structured reference guidance for using TorchDrug across molecular property prediction, protein modeling, knowledge graph reasoning, molecular generation, and retrosynthesis planning with 40+ curated datasets and 20+ model architectures.",
    "seo_keywords": [
      "TorchDrug",
      "graph neural networks",
      "drug discovery",
      "molecular property prediction",
      "protein modeling",
      "GNN",
      "Claude",
      "Codex",
      "Claude Code",
      "bioinformatics"
    ],
    "actual_capabilities": [
      "Predict molecular properties such as solubility, toxicity, and binding affinity using GNN models like GIN, GAT, and SchNet",
      "Build and train protein models for function prediction, stability analysis, and structure classification using ESM, GearNet, and ProteinBERT",
      "Perform knowledge graph reasoning for drug repurposing and biomedical link prediction using TransE, RotatE, and ComplEx",
      "Generate novel molecular structures with property optimization using autoregressive models and GCPN",
      "Plan retrosynthesis routes from target molecules to starting materials using USPTO-50k dataset",
      "Load and preprocess 40+ curated datasets with scaffold splitting and automatic feature extraction"
    ],
    "limitations": [
      "Does not include pretrained models or model weights - models must be trained from scratch or user must provide checkpoints",
      "No packaged executable scripts - this is a documentation and reference skill that requires manual implementation",
      "Reference files assume familiarity with PyTorch and basic graph neural network concepts",
      "Does not include benchmark dataset comparisons or leaderboard results - use PyTDC for that purpose"
    ],
    "use_cases": [
      {
        "title": "Predict drug candidate properties",
        "description": "A computational chemist uses TorchDrug GNN models to predict blood-brain barrier permeability and toxicity for a library of drug candidates, enabling early filtering of compounds before experimental testing.",
        "target_user": "Computational chemist in pharmaceutical research"
      },
      {
        "title": "Discover new drug-disease associations",
        "description": "A biomedical researcher uses knowledge graph completion on Hetionet to identify existing drugs that may treat new disease targets, supporting drug repurposing efforts.",
        "target_user": "Biomedical researcher exploring drug repurposing"
      },
      {
        "title": "Design novel molecules with target properties",
        "description": "A machine learning engineer builds a conditional molecular generation pipeline to create drug-like molecules optimized for specific binding affinity and synthesizability scores.",
        "target_user": "ML engineer working on generative chemistry"
      }
    ],
    "prompt_templates": [
