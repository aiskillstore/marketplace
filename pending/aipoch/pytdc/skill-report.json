  "content": {
    "user_title": "Run drug discovery ML with PyTDC datasets and oracles",
    "value_statement": "Drug discovery researchers need curated, standardized datasets and evaluation protocols for machine learning models. This skill provides direct access to 200+ Therapeutics Data Commons datasets, scaffold/cold-start splits, evaluation metrics, and molecular property oracles through PyTDC.",
    "seo_keywords": [
      "PyTDC",
      "drug discovery",
      "therapeutics ML",
      "molecular generation",
      "ADME toxicity prediction",
      "Claude",
      "Codex",
      "Claude Code",
      "benchmark evaluation",
      "molecular oracles"
    ],
    "actual_capabilities": [
      "Load 200+ AI-ready datasets across ADME, Toxicity, DTI, DDI, and molecular generation tasks",
      "Create scaffold splits and cold-start splits (cold drug, cold target) for realistic generalization evaluation",
      "Evaluate model performance using TDC standardized metrics (ROC-AUC, RMSE, MAE, Spearman, and more)",
      "Score molecules using 17+ built-in oracles for target binding, drug-likeness, and synthesis accessibility",
      "Run benchmark group evaluations with multi-seed protocols for consistent leaderboard reporting"
    ],
    "limitations": [
      "Requires the PyTDC library to be installed separately via pip",
      "Oracle scores are predicted values from ML models, not experimental measurements",
      "Slow oracles like docking and ASKCOS require additional external dependencies",
      "Does not train or optimize ML models; provides only data loading, splitting, and evaluation"
    ],
    "use_cases": [
      {
        "title": "ADME absorption prediction for drug candidates",
        "description": "A computational chemist loads the Caco-2 permeability dataset, applies a scaffold split to test on novel chemical structures, trains a baseline model on SMILES fingerprints, and evaluates using MAE with the 5-seed protocol.",
        "target_user": "Computational chemist"
      },
      {
        "title": "Drug-target interaction discovery",
        "description": "A bioinformatics researcher loads the BindingDB Kd dataset, applies a cold-drug split to evaluate generalization to unseen compounds, and benchmarks a prediction model using ROC-AUC and PR-AUC metrics.",
        "target_user": "Bioinformatics researcher"
      },
      {
        "title": "Goal-directed molecular optimization",
        "description": "An ML scientist uses GSK3B and QED oracles to score candidate molecules during generative model training, applying multi-objective optimization to find drug-like compounds with high target binding affinity.",
        "target_user": "Machine learning scientist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Load a dataset and inspect its properties",
        "prompt": "Use PyTDC to load the Caco2_Wang ADME dataset from tdc.single_pred. Print the dataset size, show the first 3 rows, and display label distribution statistics. Then create a scaffold split with seed 42 using fractions 0.7, 0.1, 0.2.",
        "scenario": "Getting started with a new ADME dataset"
      },
      {
        "title": "Run a multi-seed benchmark evaluation",
        "prompt": "Use the ADMET benchmark group from tdc.benchmark_group. Load the Caco2_Wang benchmark, train a ridge regression model using character n-gram features on SMILES strings, and evaluate across 5 seeds. Report mean MAE and standard deviation.",
        "scenario": "Benchmarking a model for leaderboard submission"
      },
      {
        "title": "Score molecules using multiple oracles",
        "prompt": "Initialize oracles for GSK3B, QED, SA, and LogP from tdc. Evaluate the SMILES string CC(C)Cc1ccc(cc1)C(C)C(O)=O with each oracle. Compute a weighted multi-objective score with weights 0.3, 0.2, 0.4, 0.1 and normalize LogP by dividing by 5.",
        "scenario": "Multi-objective molecular optimization"
      },
      {
        "title": "Design a cold-start DTI evaluation pipeline",
        "prompt": "Load the BindingDB_Kd dataset from tdc.multi_pred. Apply cold_drug split with seed 42. Verify no drug overlap between train and test sets. Train a model on SMILES and protein sequences, then evaluate using RMSE and Spearman correlation.",
        "scenario": "Advanced drug-target interaction evaluation"
      }
    ],
