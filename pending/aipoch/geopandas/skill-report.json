  "content": {
    "user_title": "Analyze Geospatial Data with GeoPandas",
    "value_statement": "Working with geospatial vector data requires specialized tools for reading, transforming, and visualizing geographic information. This skill provides comprehensive reference documentation and code examples for using the GeoPandas Python library to perform spatial operations, CRS management, and map visualization.",
    "seo_keywords": [
      "geopandas",
      "geospatial",
      "GIS",
      "spatial analysis",
      "Claude",
      "Codex",
      "Claude Code",
      "vector data",
      "shapefile",
      "GeoJSON"
    ],
    "actual_capabilities": [
      "Read and write geospatial vector data formats including Shapefile, GeoJSON, GeoPackage, Parquet, and PostGIS",
      "Perform geometric operations such as buffering, simplification, centroid computation, and affine transformations",
      "Execute spatial analysis including spatial joins, overlay operations, dissolving, and clipping",
      "Manage coordinate reference systems with CRS inspection, setting, and reprojection between EPSG codes",
      "Create static map visualizations and interactive maps with choropleth capabilities",
      "Filter and optimize geospatial data loading using bounding boxes, masks, and Arrow acceleration"
    ],
    "limitations": [
      "Cannot handle raster data formats such as GeoTIFF or satellite imagery",
      "Does not include machine learning or predictive modeling for geospatial data",
      "Requires compatible Python environment with geopandas and its dependencies installed",
      "Large datasets may require significant memory and performance optimization"
    ],
    "use_cases": [
      {
        "title": "Analyze Geographic Patterns with Spatial Joins",
        "description": "Use spatial joins and overlay operations to combine multiple geospatial datasets and identify geographic relationships between features.",
        "target_user": "GIS Analyst"
      },
      {
        "title": "Prepare Geospatial Data for Modeling",
        "description": "Read, clean, and transform geospatial data using CRS reprojection and geometric operations before feeding into analysis or machine learning pipelines.",
        "target_user": "Data Scientist"
      },
      {
        "title": "Create Visual Maps of Regional Data",
        "description": "Generate choropleth maps and interactive visualizations of demographic, environmental, or infrastructure data organized by geographic region.",
        "target_user": "Urban Planner"
      }
    ],
    "prompt_templates": [
      {
        "title": "Read and Explore Geospatial Data",
        "prompt": "Read a Shapefile or GeoJSON file and display basic information about the data including its CRS, geometry types, and attribute columns.",
        "scenario": "Getting started with a new geospatial dataset"
      },
      {
        "title": "Reproject and Compute Area Measurements",
        "prompt": "Reproject geospatial data to a suitable projected CRS and calculate area or distance measurements for each feature with accurate metric units.",
        "scenario": "Calculating accurate area or distance from geographic coordinates"
      },
      {
        "title": "Perform a Spatial Join Between Two Datasets",
        "prompt": "Use spatial join to combine attributes from two geospatial datasets based on their geometric relationship such as intersection or proximity.",
        "scenario": "Enriching a dataset with attributes from another geographic layer"
      },
      {
        "title": "Create a Multi-Layer Choropleth Map",
        "prompt": "Create a multi-layer static map with a choropleth layer colored by a data column, a basemap from Contextily, and a legend with proper styling.",
        "scenario": "Producing a publication-ready map visualization"
      }
    ],
    "output_examples": [
      {
        "input": "Read a GeoJSON file of world countries and compute population density for each country.",
        "output": "A GeoDataFrame with columns for country name, population, area in square kilometers, and population density, reprojected to EPSG:3857 for accurate area calculations."
      },
      {
        "input": "Create a choropleth map showing population density by region with a color gradient legend.",
        "output": "A matplotlib figure showing a choropleth map with a YlOrRd color gradient, a legend bar, region boundaries in black outline, and a title describing the visualization."
      },
      {
        "input": "Find all hospitals within 10 kilometers of a major highway using spatial join.",
        "output": "A filtered GeoDataFrame containing only hospital features within 10 km of highway segments, with a distance column showing exact proximity in meters."
      }
    ],
    "best_practices": [
      "Always verify and set the correct CRS before performing spatial operations between datasets",
      "Use a projected CRS (not geographic) for area and distance calculations to ensure accurate metric measurements",
      "Filter geospatial data during read operations using bounding boxes or geometry masks to minimize memory usage"
    ],
    "anti_patterns": [
      "Computing area or distance while the data is still in a geographic CRS (EPSG:4326) which produces meaningless values in decimal degrees",
      "Using set_crs() when to_crs() is needed for actual coordinate transformation, or vice versa when only metadata needs updating",
      "Performing spatial joins or overlay operations without ensuring both datasets share the same CRS, causing incorrect results"
    ],
    "faq": [
      {
        "question": "What is the difference between set_crs and to_crs?",
        "answer": "set_crs sets CRS metadata without transforming coordinates. Use it only when CRS metadata is missing. to_crs transforms coordinates into a new CRS and should be used for reprojection."
      },
      {
        "question": "How do I read a Shapefile with GeoPandas?",
        "answer": "Use gpd.read_file('path/to/file.shp'). GeoPandas automatically detects the file format from the file extension and loads the data into a GeoDataFrame."
      },
      {
        "question": "Why are my area calculations producing incorrect values?",
        "answer": "Area calculations require a projected CRS. Geographic CRS like EPSG:4326 uses degrees which are not suitable for metric measurements. Reproject to a projected CRS first."
      },
      {
        "question": "Which AI tools support this skill?",
        "answer": "This skill is compatible with Claude, Codex, and Claude Code for geospatial data analysis workflows."
      },
      {
        "question": "Can this skill handle raster data such as satellite images?",
        "answer": "No, this skill is designed for vector geospatial data only. Raster data requires different tools and libraries for processing."
      },
      {
        "question": "What Python dependencies are needed for this skill?",
        "answer": "Core dependencies are geopandas, pandas, and shapely. Optional dependencies include folium, mapclassify, pyarrow, psycopg2, geoalchemy2, and contextily."
      }
    ]
