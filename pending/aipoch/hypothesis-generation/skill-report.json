  "content": {
    "user_title": "Generate Testable Scientific Hypotheses from Observations",
    "value_statement": "Researchers often struggle to transform experimental observations into rigorous, testable mechanistic hypotheses. This skill provides a complete structured workflow with competing hypotheses, quality evaluation, literature grounding, and validation experiment design.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "scientific hypothesis generation",
      "experimental design",
      "research methodology",
      "academic writing",
      "literature review",
      "mechanistic hypotheses",
      "testable predictions"
    ],
    "actual_capabilities": [
      "Formulate 3 to 5 distinct competing mechanistic hypotheses from experimental observations",
      "Evaluate each hypothesis using quality criteria including testability, falsifiability, and explanatory power",
      "Design decisive validation experiments with controls, measurements, and confounders",
      "Generate discriminative testable predictions with explicit falsifiers for each hypothesis",
      "Produce structured reports compatible with the included LaTeX publication template",
      "Guide literature search and evidence synthesis to support hypothesis development"
    ],
    "limitations": [
      "Requires domain expertise to evaluate the plausibility of proposed mechanisms",
      "Does not execute experiments or collect laboratory data of any kind",
      "Generated references and citations must be verified against primary literature sources",
      "LaTeX report compilation requires a local XeLaTeX or LuaLaTeX installation"
    ],
    "use_cases": [
      {
        "title": "Analyze Unexpected Experimental Results",
        "description": "Transform surprising experimental observations into 3 to 5 competing mechanistic hypotheses with clear predictions and validation experiments.",
        "target_user": "Laboratory scientists and biomedical researchers"
      },
      {
        "title": "Prepare a Mechanistic Study Proposal",
        "description": "Structure preliminary data into a formal hypothesis framework with literature support and experimental design for thesis or grant proposals.",
        "target_user": "PhD students and postdoctoral researchers"
      },
      {
        "title": "Evaluate the Strength of Existing Hypotheses",
        "description": "Apply structured quality criteria to assess competing hypotheses for testability, falsifiability, explanatory power, and novelty.",
        "target_user": "Peer reviewers and grant evaluators"
      }
    ],
    "prompt_templates": [
      {
        "title": "Quick Hypothesis Generation",
        "prompt": "I observed the following phenomenon: [describe observation]. Generate 3 to 5 competing mechanistic hypotheses that could explain this observation. For each hypothesis, provide the proposed mechanism, key supporting evidence, core assumptions, and one testable prediction that could confirm or refute it.",
        "scenario": "Initial hypothesis brainstorming from a single experimental observation"
      },
      {
        "title": "Detailed Hypothesis Report",
        "prompt": "Using the hypothesis generation workflow, produce a complete hypothesis report for the following phenomenon: [describe phenomenon]. Include: (1) an executive summary, (2) 3 to 5 competing hypotheses with mechanisms and evidence, (3) quality evaluation scores for each hypothesis, (4) decisive experiments to discriminate between them, (5) testable predictions with falsifiers, and (6) a structured report suitable for LaTeX compilation.",
        "scenario": "Creating a comprehensive hypothesis report for a research project"
      },
      {
        "title": "Hypothesis Quality Evaluation",
        "prompt": "Evaluate the following hypothesis using the scientific quality criteria: testability, falsifiability, parsimony, explanatory power, scope, consistency, and novelty. Score each criterion on a scale of 1 to 5 and provide justification for each score: [paste hypothesis]",
        "scenario": "Assessing the scientific strength of an existing or proposed hypothesis"
      },
      {
        "title": "Experimental Design for Hypotheses",
        "prompt": "Design decisive experiments to discriminate between the following competing hypotheses: [list hypotheses]. For each experiment, specify: measurements to take, controls to include, potential confounders to address, sample size considerations, predicted outcomes under each hypothesis, and the critical result that would falsify each hypothesis.",
        "scenario": "Planning validation experiments to test and compare competing hypotheses"
      }
    ],
    "output_examples": [
      {
        "input": "Generate hypotheses for why cancer cells in a tumor become resistant to chemotherapy over time.",
        "output": [
          "Hypothesis 1: Pre-existing resistant subclone selection. A small population of resistant cells exists before treatment begins and expands under selective drug pressure.",
          "Hypothesis 2: Acquired mutational adaptation. Chemotherapy induces new mutations that confer resistance in previously sensitive cancer cells.",
          "Hypothesis 3: Epigenetic plasticity. Non-genetic changes allow cells to reversibly switch to a drug-tolerant persister state.",
          "Hypothesis 4: Microenvironment-mediated protection. Stromal cells in the tumor create protective niches that shield cancer cells from drug exposure."
        ]
      },
      {
        "input": "Design an experiment to test whether protein X regulates cell migration through actin polymerization.",
        "output": "Experimental design: Perform CRISPR knockout of protein X in HeLa cells. Measure migration speed using a transwell assay with 8-micrometer pore membrane over 24 hours. Quantify actin polymerization via fluorescence microscopy using phalloidin staining. Include a rescue experiment with wild-type and mutant protein X. Controls: parental cell line, scrambled guide RNA, and a known migration inhibitor (blebbistatin). Predicted outcome if protein X regulates actin: knockout cells show significantly reduced migration and decreased actin filament density."
      }
    ],
    "best_practices": [
      "Ground each hypothesis in existing literature by citing specific evidence that supports the proposed mechanism",
      "Prioritize experiments that produce clearly different predictions across hypotheses to maximize discrimination power",
      "State all assumptions explicitly so they can be tested independently of the main hypothesis"
    ],
    "anti_patterns": [
      "Generating hypotheses that are not falsifiable or cannot be tested with currently available experimental methods",
      "Proposing mechanisms that merely rename the observation without providing a meaningful causal explanation",
      "Including excessive experimental detail in the main body instead of moving protocols to the appendix"
    ],
    "faq": [
      {
        "question": "What types of observations work best with this skill?",
        "answer": "Use this skill when you have experimental observations that need a mechanistic explanation. It works well for unexpected phenotypes, patterns in data, or preliminary results that require testable hypotheses."
      },
      {
        "question": "How many hypotheses should I generate?",
        "answer": "Generate 3 to 5 distinct competing hypotheses. This range provides enough alternatives for meaningful comparison without overwhelming the analysis."
      },
      {
        "question": "Do I need LaTeX installed to use this skill?",
        "answer": "LaTeX is required to compile the included report template. The skill produces structured text output that you can use directly even without a LaTeX installation."
      },
      {
        "question": "Can this skill help with grant proposals?",
        "answer": "Yes. The structured hypothesis framework, literature grounding, and experimental design sections are directly applicable to the preliminary data and specific aims sections of grant proposals."
      },
      {
        "question": "Does this skill run any scripts or code?",
        "answer": "No. This skill is a documentation-based workflow with reference materials. It provides methodology, templates, and formatting guides only."
      },
      {
        "question": "Should I verify the generated references?",
        "answer": "Yes. Always verify citations and references against primary literature sources before using them in any publication or presentation."
      }
    ]
