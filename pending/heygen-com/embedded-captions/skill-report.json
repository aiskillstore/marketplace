  "content": {
    "user_title": "Add Cinematic Captions to Talking-Head Videos",
    "value_statement": "Plain subtitles can feel disconnected from a polished talking-head video. This skill builds readable rails, embedded hero captions, and themed motion treatments while preserving the original footage.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "embedded captions",
      "video subtitles",
      "Hyperframes",
      "talking-head video",
      "caption design",
      "FFmpeg captions",
      "motion typography"
    ],
    "actual_capabilities": [
      "Selects a caption identity from a documented catalog based on tone, scene constraints, and readability needs.",
      "Transcribes speech into word-level timing data for caption authoring.",
      "Builds matte-aware embedded captions that can appear behind the subject.",
      "Generates Hyperframes HTML compositions for cinematic and themed caption styles.",
      "Runs preview and validation checks for timing, occlusion, overflow, and visual readability.",
      "Composites rendered caption layers with the source video into a final MP4."
    ],
    "limitations": [
      "Requires Hyperframes, FFmpeg, headless Chromium dependencies, and local media tooling.",
      "Designed for single-subject talking-head clips, not complex multi-speaker edits.",
      "Does not remove existing burned-in captions or repair source footage.",
      "May need manual review when transcription, matting, or bright backgrounds reduce caption quality."
    ],
    "use_cases": [
      {
        "title": "Social Video Captioning",
        "target_user": "Creator",
        "description": "Add readable subtitle rails and a few designed emphasis moments to a short talking-head clip."
      },
      {
        "title": "Product Explainer Captions",
        "target_user": "Marketing team",
        "description": "Create polished caption treatments for founder updates, product demos, or launch videos."
      },
      {
        "title": "Editorial Motion Typography",
        "target_user": "Video designer",
        "description": "Use themed caption identities such as neon, documentary, chalkboard, or brush styles for a specific visual tone."
      }
    ],
    "prompt_templates": [
      {
        "title": "Add Basic Captions",
        "scenario": "Beginner",
        "prompt": "Add clear captions to this talking-head MP4. Use the conservative anchor style unless another identity is a better fit."
      },
      {
        "title": "Recommend Caption Styles",
        "scenario": "Style selection",
        "prompt": "Review this clip and shortlist three caption identities. Explain which one is best for readability and visual tone."
      },
      {
        "title": "Create Embedded Hero Captions",
        "scenario": "Intermediate",
        "prompt": "Build captions with a readable rail and one embedded hero word at the strongest moment. Preview frames before rendering."
      },
      {
        "title": "Produce a Themed Caption Treatment",
        "scenario": "Advanced",
        "prompt": "Create a full themed caption treatment for this single-speaker clip. Use transcription, safe zones, visual QA, and final compositing."
      }
    ],
    "output_examples": [
      {
        "input": "A 30-second founder update with clear speech and no existing subtitles.",
        "output": "A final MP4 with clean lower-third captions and one embedded emphasis word behind the speaker."
      },
      {
        "input": "A high-energy vertical clip asking for bold visual effects captions.",
        "output": "A preview sheet, a selected high-impact caption identity, and a rendered video with synchronized motion typography."
      },
      {
        "input": "A calm educational talking-head video for a course lesson.",
        "output": "A readable caption rail with restrained styling, validated timing, and no unnecessary cinematic effects."
      }
    ],
    "best_practices": [
      "Use short single-subject clips with clear speech and no burned-in subtitles.",
      "Preview frames before rendering so washout, overlap, and occlusion issues are caught early.",
      "Choose rail-first identities when every spoken word must be readable."
    ],
    "anti_patterns": [
      "Do not use this skill for multi-speaker videos with hard cuts unless the clip is split first.",
      "Do not embed every word when the user needs accessible verbatim captions.",
      "Do not run the scripts on untrusted project folders or sensitive directories."
    ],
    "faq": [
      {
        "question": "Does this edit the original footage?",
        "answer": "It preserves the footage and adds rendered caption layers. Some themed modes can add approved plate reactions."
      },
      {
        "question": "Can it caption videos that already have subtitles?",
        "answer": "No. Existing burned-in captions create visual conflicts and should be handled before using this skill."
      },
      {
        "question": "What type of video works best?",
        "answer": "A single clear talking-head clip with visible face, stable framing, and understandable speech works best."
      },
      {
        "question": "Does it need internet access?",
        "answer": "It may need network access for first-run model downloads or external tooling. Some validation paths avoid CDN dependence."
      },
      {
        "question": "Can I choose a specific style?",
        "answer": "Yes. You can request a named identity such as anchor, neon, documentary, chalkboard, brush, or other catalog styles."
      },
      {
        "question": "Is it safe to publish?",
        "answer": "Yes, with a medium-risk warning. It runs local media commands and browser rendering, so users should sandbox untrusted inputs."
      }
    ]
  },
