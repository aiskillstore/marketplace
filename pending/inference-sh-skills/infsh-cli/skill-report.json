    "user_title": "Run 250+ AI apps with inference.sh CLI",
    "value_statement": "Running AI models like FLUX, Veo, and Gemini requires powerful hardware and complex setup. This skill lets you access 250+ AI apps directly from your terminal with a simple CLI command, no GPU needed.",
    "seo_keywords": [
      "inference.sh",
      "CLI",
      "AI apps",
      "Claude",
      "Codex",
      "Claude Code",
      "image generation",
      "video generation",
      "serverless AI",
      "AI models"
    ],
    "actual_capabilities": [
      "Run image generation models like FLUX, Gemini, and Grok from the terminal",
      "Generate videos using Veo, Seedance, and Wan models with text prompts",
      "Access LLMs including Claude, Gemini, and Kimi via OpenRouter",
      "Perform web search and data extraction using Tavily and Exa APIs",
      "Create 3D models with the Rodin generator",
      "Automate Twitter posts, DMs, likes, and follows"
    ],
    "limitations": [
      "Requires an active internet connection and an inference.sh account",
      "Some apps have usage quotas or credit costs based on the plan",
      "Processing speed depends on the app type and cloud server availability",
      "Not all models support local file uploads for input"
    ],
    "use_cases": [
      {
        "title": "Generate images and videos for content creation",
        "description": "Content creators can generate images with FLUX models and videos with Veo directly from the terminal without needing expensive GPU hardware or cloud setup.",
        "target_user": "Content creators and designers"
      },
      {
        "title": "Prototype and compare AI models as a developer",
        "description": "Quickly test and compare different AI models like Claude, Gemini, and Grok from the command line without switching between platforms or managing API integrations.",
        "target_user": "Software developers"
      },
      {
        "title": "Gather and process web data for research",
        "description": "Use Tavily and Exa search tools to extract information from the web and process the results programmatically in your data analysis pipeline.",
        "target_user": "Data researchers and analysts"
      }
    ],
    "prompt_templates": [
      {
        "title": "Generate an image with FLUX",
        "prompt": "Generate an image of [description] using FLUX through the inference.sh CLI. Run: belt app run falai/flux-dev-lora --input '{\"prompt\": \"[description]\"}'",
        "scenario": "Use this when you need to create an AI-generated image from a text description."
      },
      {
        "title": "Generate a video from a prompt",
        "prompt": "Create a video of [description] using Veo. Run: belt app run google/veo-3-1-fast --input '{\"prompt\": \"[description]\"}'",
        "scenario": "Use this when you need to generate a short video from a text description."
      },
      {
        "title": "Search the web and summarize results",
        "prompt": "Search the web for [topic] using Tavily, then summarize the key findings. Run: belt app run tavily/search-assistant --input '{\"query\": \"[topic]\"}'",
        "scenario": "Use this when you need up-to-date information from the web."
      },
      {
        "title": "Run a multi-model pipeline",
        "prompt": "First search for [topic] using Tavily search, then use the results as context for Claude Sonnet to generate an analysis report. Chain belt commands to pass data between models.",
        "scenario": "Use this when you need a research pipeline that searches then analyzes."
      }
    ],
    "output_examples": [
      {
        "input": "Generate an image of a cat astronaut floating in space",
        "output": "The CLI returns the generated image URL from the FLUX model. The image shows a detailed rendering of a cat in an astronaut suit floating against a starry space background."
      },
      {
        "input": "Search the web for latest AI research papers",
        "output": "The Tavily search assistant returns a list of relevant search results with titles, URLs, and content summaries for recent AI research papers."
      },
      {
        "input": "Explain quantum computing using Claude",
        "output": "The OpenRouter API returns a text response from Claude Sonnet explaining quantum computing concepts in an accessible way."
      }
    ],
    "best_practices": [
      "Always verify app names and availability with belt app search before running a command to avoid errors",
      "Use belt app sample to generate input templates for new apps so you can see the expected schema",
      "Store your API key in the INFSH_API_KEY environment variable instead of pasting it into command history"
    ],
    "anti_patterns": [
      "Running apps without checking the input schema first, which causes schema mismatch errors and wasted credits",
      "Piping installation scripts directly to sh without reviewing them or considering the manual install alternative",
      "Hardcoding sensitive credentials like API keys directly in command-line arguments where they can be captured in shell history"
    ],
    "faq": [
      {
        "question": "Do I need a GPU to run these AI apps?",
        "answer": "No. All AI apps run on inference.sh cloud servers. You only need the CLI installed on your machine."
      },
      {
        "question": "How do I install the CLI?",
        "answer": "Run curl -fsSL https://cli.inference.sh | sh and then run belt login to authenticate."
      },
      {
        "question": "What models are available?",
        "answer": "Over 250 apps are available including FLUX, Veo, Gemini, Grok, Claude, Tavily, Exa, and many more."
      },
      {
        "question": "How do I find the right app?",
        "answer": "Use belt app search <query> to search or belt app list --category <category> to browse by type."
      },
      {
        "question": "Can I upload local files as input?",
        "answer": "Yes. The CLI automatically uploads local files when you provide a file path instead of a URL."
      },
      {
        "question": "How do I check the status of a running task?",
        "answer": "Use belt task get <task-id> to check the status and retrieve results of a previously submitted task."
      }
    ]
