  "content": {
    "user_title": "Generate RBS Signatures for Ruby Code",
    "value_statement": "Ruby projects often lack complete RBS files, which makes static typing harder to adopt. This skill guides Claude, Codex, or Claude Code through generating, refining, and validating RBS signatures.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "RBS generation",
      "Ruby type signatures",
      "Ruby static typing",
      "Steep",
      "rbs validate",
      "Ruby signatures",
      "RBS examples"
    ],
    "actual_capabilities": [
      "Analyzes Ruby classes, modules, methods, constants, inheritance, and visibility.",
      "Generates new .rbs files under sig/ with matching source structure.",
      "Uses included RBS syntax and standard library references for type choices.",
      "Refines signatures to avoid untyped when useful type information is available.",
      "Runs rbs validate and optional steep check when the project supports them."
    ],
    "limitations": [
      "Does not update existing RBS signatures in place as a primary workflow.",
      "Does not handle RBS-inline signatures for this skill path.",
      "Cannot infer precise types when the Ruby source lacks usage evidence.",
      "Validation depends on the project having the required Ruby tools installed."
    ],
    "use_cases": [
      {
        "title": "Add RBS to a Ruby Library",
        "target_user": "Ruby gem maintainer",
        "description": "Generate initial signatures for public classes and modules before adding static checks."
      },
      {
        "title": "Improve Type Coverage in an App",
        "target_user": "Rails or Ruby application developer",
        "description": "Create signatures for selected source files and validate them with the project toolchain."
      },
      {
        "title": "Review Complex Ruby APIs",
        "target_user": "Technical lead",
        "description": "Use the generated signatures to clarify method contracts, overloads, constants, and generic types."
      }
    ],
    "prompt_templates": [
      {
        "title": "Generate a Basic Signature",
        "scenario": "Beginner",
        "prompt": "Generate RBS signatures for this Ruby file and place them under sig/ with the matching path."
      },
      {
        "title": "Infer Better Types",
        "scenario": "Intermediate",
        "prompt": "Generate RBS for this class and use the tests and call sites to avoid untyped where possible."
      },
      {
        "title": "Validate and Fix RBS",
        "scenario": "Advanced",
        "prompt": "Generate RBS for these Ruby files, run rbs validate, and fix all signature shape errors."
      },
      {
        "title": "Prepare Steep-Compatible Signatures",
        "scenario": "Expert",
        "prompt": "Generate RBS for this component, run rbs validate, then run steep check if the project has Steep configured."
      }
    ],
    "output_examples": [
      {
        "input": "A Ruby service object with initializer arguments, public methods, and private helpers.",
        "output": "A matching signature file that lists the class, initializer, public method return types, private methods, and required constants."
      },
      {
        "input": "A module with generic collection helpers and several method overloads.",
        "output": "A reviewed RBS signature that uses type parameters, overloads, and concrete collection element types."
      },
      {
        "input": "A small Ruby library with a Steepfile and existing sig/ directory.",
        "output": "Generated signatures, validation results, and a concise list of fixes made after rbs validate or steep check."
      }
    ],
    "best_practices": [
      "Review generated signatures before committing them to a repository.",
      "Provide tests and call sites so the assistant can infer precise types.",
      "Run validation in a trusted workspace with known project dependencies."
    ],
    "anti_patterns": [
      "Do not ask the skill to run arbitrary Ruby application code.",
      "Do not accept untyped results without checking whether better evidence exists.",
      "Do not generate signatures for large codebases without reviewing files in smaller batches."
    ],
    "faq": [
      {
        "question": "Does this skill run my Ruby application?",
        "answer": "No. The instructions explicitly say not to run Ruby project code. It may run RBS or Steep validation commands."
      },
      {
        "question": "Where are generated signatures placed?",
        "answer": "The skill places new RBS files under sig/ using a structure that mirrors the Ruby source path."
      },
      {
        "question": "Can it remove every untyped type?",
        "answer": "No. It tries to infer precise types, but leaves untyped only when the source and usage evidence are insufficient."
      },
      {
        "question": "Does it support existing RBS updates?",
        "answer": "This skill focuses on generating new pure RBS signatures from Ruby source files."
      },
      {
        "question": "Can it use Steep?",
        "answer": "Yes. It runs steep check only when the project Gemfile includes Steep and a Steepfile exists."
      },
      {
        "question": "Why does the audit show medium risk?",
        "answer": "The skill intentionally writes signature files and can run local validation tools. These actions are useful but should be reviewed."
      }
    ]
  },
