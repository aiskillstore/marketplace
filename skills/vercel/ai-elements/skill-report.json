  "content": {
    "user_title": "Build AI Chat UI Components",
    "value_statement": "Teams need consistent AI chat interfaces that match AI Elements patterns. This skill guides component creation with React, shadcn/ui, and Vercel AI SDK conventions.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "AI Elements",
      "Vercel AI SDK",
      "React components",
      "shadcn/ui",
      "chat interface",
      "AI UI components",
      "TypeScript UI"
    ],
    "actual_capabilities": [
      "Creates composable React components for AI chat interfaces.",
      "Uses AI Elements naming, slot, and composition patterns.",
      "Aligns examples with shadcn/ui and Tailwind styling conventions.",
      "Provides reference material for messages, tools, prompts, citations, and media controls.",
      "Helps add usage examples for components in the scripts directory.",
      "Supports Vercel AI SDK types and common chat interaction patterns."
    ],
    "limitations": [
      "It does not replace a security review of generated backend routes.",
      "Some included examples show demo URLs, placeholder secrets, or unsafe patterns.",
      "It assumes a React, TypeScript, Tailwind, and shadcn/ui project setup.",
      "It does not validate runtime behavior across every browser or AI provider."
    ],
    "use_cases": [
      {
        "title": "Add a Chat Message Component",
        "target_user": "Frontend engineers",
        "description": "Create a reusable AI message component that follows AI Elements composition and styling conventions."
      },
      {
        "title": "Prototype an AI Tool Panel",
        "target_user": "Product teams",
        "description": "Build a tool status, task, or confirmation panel for an AI workflow prototype."
      },
      {
        "title": "Document Component Usage",
        "target_user": "Design system maintainers",
        "description": "Create examples and reference notes for AI-native UI components in a shared component library."
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Basic Component",
        "scenario": "Beginner component creation",
        "prompt": "Create a new AI Elements component for displaying short assistant status messages. Follow existing component naming and composition patterns."
      },
      {
        "title": "Add an Example Script",
        "scenario": "Component documentation",
        "prompt": "Add a usage example for the new component in the scripts directory. Keep data static and avoid real secrets or unsafe network calls."
      },
      {
        "title": "Review Component API",
        "scenario": "API refinement",
        "prompt": "Review this AI Elements component API for consistency with shadcn/ui, Tailwind classes, and Vercel AI SDK usage patterns."
      },
      {
        "title": "Build an Advanced Interaction",
        "scenario": "Advanced workflow UI",
        "prompt": "Design a composable AI tool approval flow with pending, accepted, rejected, and error states. Include accessible labels and safe example data."
      }
    ],
    "output_examples": [
      {
        "input": "Create a component that displays model selection in an AI chat app.",
        "output": "A concise implementation plan, a React component structure, and usage notes aligned with AI Elements conventions."
      },
      {
        "input": "Add documentation for a new prompt input variant.",
        "output": "A reference page outline with props, usage guidance, limitations, and safe demo content."
      },
      {
        "input": "Review this generated AI component for consistency.",
        "output": [
          "Notes on naming and composition.",
          "Suggestions for accessibility and styling.",
          "Warnings about unsafe examples or leaked secrets."
        ]
      }
    ],
    "best_practices": [
      "Use static demo data and placeholders that cannot be mistaken for real credentials.",
      "Keep external API calls on the server and proxy sensitive provider tokens.",
      "Match existing AI Elements component structure before adding new abstractions."
    ],
    "anti_patterns": [
      "Do not place provider API keys in NEXT_PUBLIC environment variables.",
      "Do not include eval-based code execution examples without strict sandboxing.",
      "Do not add network calls or filesystem actions only to make a demo look realistic."
    ],
    "faq": [
      {
        "question": "What does this skill help build?",
        "answer": "It helps build AI Elements React components for chat, tools, messages, inputs, citations, and related AI interface patterns."
      },
      {
        "question": "Which tools can use this skill?",
        "answer": "The report lists support for Claude, Codex, and Claude Code."
      },
      {
        "question": "Does it install AI Elements automatically?",
        "answer": "No. It provides guidance and reference examples. Users still run the relevant package or shadcn/ui commands themselves."
      },
      {
        "question": "Is the skill safe for production use?",
        "answer": "Use caution. The audit found unsafe example patterns that should be corrected before marketplace publication."
      },
      {
        "question": "Can it create backend routes?",
        "answer": "It can guide examples, but backend routes need separate security review for authentication, sandboxing, and secret handling."
      },
      {
        "question": "What project setup is expected?",
        "answer": "It expects React, TypeScript, Tailwind CSS, shadcn/ui, and Vercel AI SDK conventions."
      }
    ]
  },
