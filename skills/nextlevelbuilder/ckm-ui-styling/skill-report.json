  "content": {
    "user_title": "Build Accessible UI Systems",
    "value_statement": "Teams often lose time translating design intent into consistent React interfaces. This skill gives Claude, Codex, and Claude Code focused guidance for shadcn/ui, Tailwind CSS, accessibility, theming, and responsive layouts.",
    "seo_keywords": [
      "Claude UI styling",
      "Codex UI styling",
      "Claude Code UI styling",
      "shadcn ui components",
      "Tailwind CSS design",
      "accessible React components",
      "responsive layout prompts",
      "design system guidance",
      "dark mode theming",
      "canvas visual design"
    ],
    "actual_capabilities": [
      "Guides React UI work with shadcn/ui components and Radix-based accessibility patterns.",
      "Provides Tailwind CSS utility guidance for layout, spacing, typography, colors, and responsive behavior.",
      "Documents theme customization, CSS variables, dark mode, and component variant patterns.",
      "Includes accessibility guidance for forms, dialogs, keyboard navigation, focus handling, and screen reader behavior.",
      "Includes optional Python scripts for shadcn component installation and Tailwind config generation.",
      "Supports canvas-based visual composition guidance for posters, brand materials, and design systems."
    ],
    "limitations": [
      "The shadcn helper can execute npm commands and should be reviewed before use.",
      "The skill does not replace manual accessibility testing with real assistive technologies.",
      "Examples target common React and Tailwind workflows, not every frontend framework.",
      "Generated visual direction still requires product context, brand constraints, and user testing."
    ],
    "use_cases": [
      {
        "title": "Design a Product Dashboard",
        "target_user": "Frontend engineer",
        "description": "Create a responsive dashboard using shadcn/ui cards, tables, dialogs, and Tailwind layout utilities."
      },
      {
        "title": "Standardize a Design System",
        "target_user": "Design systems lead",
        "description": "Define theme tokens, dark mode behavior, component variants, and reusable styling patterns."
      },
      {
        "title": "Improve UI Accessibility",
        "target_user": "Product team",
        "description": "Review forms, overlays, navigation, and feedback states for keyboard and screen reader support."
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Simple Component",
        "scenario": "Beginner UI build",
        "prompt": "Use this skill to create a responsive shadcn/ui card section for [feature]. Include Tailwind classes and accessible labels."
      },
      {
        "title": "Build a Page Layout",
        "scenario": "Intermediate screen design",
        "prompt": "Use this skill to design a mobile-first [page type] with shadcn/ui components, clear hierarchy, dark mode support, and empty states."
      },
      {
        "title": "Audit Existing UI",
        "scenario": "Accessibility and consistency review",
        "prompt": "Use this skill to review my [component or page] for Tailwind consistency, shadcn/ui composition, keyboard access, and responsive behavior."
      },
      {
        "title": "Define a Design System",
        "scenario": "Advanced system planning",
        "prompt": "Use this skill to define a Tailwind and shadcn/ui design system for [product]. Include tokens, variants, layout rules, and accessibility checks."
      }
    ],
    "output_examples": [
      {
        "input": "Design a billing settings page for a SaaS app.",
        "output": [
          "A responsive layout plan with navigation, account summary, payment method, invoice table, and confirmation dialog.",
          "shadcn/ui component choices with Tailwind spacing, typography, and state guidance.",
          "Accessibility notes for form labels, focus order, dialog behavior, and status messages."
        ]
      },
      {
        "input": "Create a dark mode theme for a developer tool.",
        "output": [
          "A token strategy using semantic colors, muted surfaces, foreground pairs, and contrast checks.",
          "Guidance for CSS variables, theme toggle behavior, component variants, and hover states."
        ]
      },
      {
        "input": "Improve a mobile dashboard layout.",
        "output": [
          "A mobile-first structure with prioritized metrics, compact controls, responsive grids, and touch-friendly spacing.",
          "Recommendations for reducing visual clutter while keeping repeated workflows efficient."
        ]
      }
    ],
    "best_practices": [
      "Review generated npm or Python commands before running helper scripts in a project.",
      "Start with semantic HTML and shadcn/ui primitives, then add Tailwind utilities for layout and polish.",
      "Test responsive states, focus states, dark mode, and form errors before considering a UI complete."
    ],
    "anti_patterns": [
      "Do not run the shadcn helper in an untrusted repository without reviewing the command and package source.",
      "Do not rely on color alone to communicate state, errors, or priority.",
      "Do not generate broad design systems without product context, content examples, and accessibility requirements."
    ],
    "faq": [
      {
        "question": "What does this skill help build?",
        "answer": "It helps build accessible React interfaces using shadcn/ui, Tailwind CSS, responsive layouts, themes, and visual design guidance."
      },
      {
        "question": "Does it install components automatically?",
        "answer": "It includes an optional helper script for shadcn/ui installation. Review the command before running it."
      },
      {
        "question": "Can it help with dark mode?",
        "answer": "Yes. It documents CSS variables, semantic tokens, theme toggles, and light and dark component styling."
      },
      {
        "question": "Is this only for shadcn/ui?",
        "answer": "No. It also covers Tailwind utilities, responsive design, accessibility patterns, and canvas-based visual design."
      },
      {
        "question": "Does it guarantee accessibility compliance?",
        "answer": "No. It provides patterns and review guidance, but teams still need real testing with keyboards and assistive technology."
      },
      {
        "question": "Why is the security risk rated medium?",
        "answer": "The skill includes scripts that can run package manager commands. No malicious behavior was confirmed, but command execution needs caution."
      }
    ]
  },
