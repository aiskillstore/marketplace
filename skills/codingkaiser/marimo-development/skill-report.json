  "content": {
    "user_title": "Build Reactive Marimo Notebooks",
    "value_statement": "Reactive notebook development can be slow when agents miss marimo-specific cell rules and UI patterns. This skill gives Claude, Codex, and Claude Code focused guidance for notebooks, dashboards, SQL, interactivity, debugging, and deployment.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "marimo notebooks",
      "reactive Python notebooks",
      "Python data apps",
      "interactive dashboards",
      "marimo SQL",
      "notebook deployment",
      "Jupyter to marimo"
    ],
    "actual_capabilities": [
      "Explains marimo cell structure, return values, reactivity, and variable scoping rules.",
      "Helps create interactive UI controls, layouts, forms, tables, chats, and custom anywidget elements.",
      "Guides pandas, Polars, DuckDB, SQL, plotting, and data exploration workflows in marimo notebooks.",
      "Supports conversion and migration planning from Jupyter-style notebooks to marimo scripts and apps.",
      "Provides troubleshooting guidance for circular dependencies, stale UI values, display issues, and deployment commands."
    ],
    "limitations": [
      "It provides guidance and examples, not the marimo runtime itself.",
      "Generated notebooks can execute Python code, so users must review commands and side effects before running them.",
      "It does not verify live credentials, database access, or third-party API availability.",
      "Security controls for deployed apps still depend on the user environment and hosting configuration."
    ],
    "use_cases": [
      {
        "title": "Create a reactive analysis notebook",
        "description": "Build a marimo notebook with clean cells, reactive dependencies, UI controls, and visible outputs.",
        "target_user": "Data scientist"
      },
      {
        "title": "Ship a lightweight data app",
        "description": "Turn analysis code into a marimo app with forms, charts, SQL queries, and deployment guidance.",
        "target_user": "Analytics engineer"
      },
      {
        "title": "Debug notebook reactivity problems",
        "description": "Diagnose circular dependencies, variable redeclarations, missing displays, and UI value access errors.",
        "target_user": "Python developer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Start a notebook",
        "scenario": "Beginner marimo notebook creation",
        "prompt": "Create a simple marimo notebook plan for exploring a CSV file. Include the cell order, UI controls, and expected outputs."
      },
      {
        "title": "Add interactivity",
        "scenario": "Intermediate dashboard workflow",
        "prompt": "Help me add marimo sliders, dropdowns, and tables to filter a dataframe and update a chart reactively."
      },
      {
        "title": "Debug reactivity",
        "scenario": "Fixing notebook errors",
        "prompt": "Review this marimo notebook structure and identify circular dependencies, redeclared variables, and cells that access UI values too early."
      },
      {
        "title": "Design a deployed app",
        "scenario": "Advanced production planning",
        "prompt": "Design a marimo data app with SQL inputs, cached expensive computations, secure secret handling, and deployment checks."
      }
    ],
    "output_examples": [
      {
        "input": "Build a marimo notebook for sales data exploration.",
        "output": [
          "A cell-by-cell notebook outline with imports, data loading, filters, summaries, and charts.",
          "Guidance on where to place UI elements so reactive values update downstream cells correctly.",
          "Notes about running checks before exporting or serving the notebook."
        ]
      },
      {
        "input": "My marimo notebook has a circular dependency error.",
        "output": [
          "A diagnosis of likely dependency cycles and redeclared names.",
          "A proposed cell reordering strategy that keeps shared state in one direction.",
          "A checklist for validating the fix with marimo tooling."
        ]
      },
      {
        "input": "Deploy this notebook as a small internal app.",
        "output": [
          "A deployment readiness checklist covering host binding, ports, secrets, files, and cached data.",
          "Recommendations for safe environment-variable use and avoiding accidental data exposure."
        ]
      }
    ],
    "best_practices": [
      "Keep marimo dependencies one-directional, with UI controls defined before cells that read their values.",
      "Review generated commands, database connections, and file writes before running notebooks or app servers.",
      "Use environment variables or secret managers for API keys, and avoid embedding real credentials in notebooks."
    ],
    "anti_patterns": [
      "Do not redeclare the same global variable across multiple marimo cells.",
      "Do not expose a marimo server on all interfaces without network controls and authentication planning.",
      "Do not adapt custom widget examples to render user input with innerHTML unless the content is sanitized."
    ],
    "faq": [
      {
        "question": "What is this skill for?",
        "answer": "It helps AI agents create, debug, and deploy marimo reactive Python notebooks and data apps."
      },
      {
        "question": "Can it convert Jupyter notebooks to marimo?",
        "answer": "It can guide migration by restructuring cells, resolving variable redeclarations, and applying marimo reactivity rules."
      },
      {
        "question": "Does it run marimo commands automatically?",
        "answer": "No. It provides command guidance. Users should approve and review any command before an agent runs it."
      },
      {
        "question": "Can it help with SQL and databases?",
        "answer": "Yes. It includes guidance for DuckDB, SQL cells, database connections, and dataframe workflows."
      },
      {
        "question": "How should API keys be handled?",
        "answer": "Use secure configuration such as environment variables. Do not paste real secrets into shared notebooks or prompts."
      },
      {
        "question": "Is it safe to publish?",
        "answer": "Yes, with a medium warning. The reviewed risks are normal development guidance, not confirmed malicious behavior."
      }
    ]
  },
