    "user_title": "Analyze Complex Topics with Prism",
    "value_statement": "Complex events often need more than one discipline and clear source boundaries. Prism helps Claude, Codex, and Claude Code produce structured analysis with adaptive perspectives and transparent limits.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Prism Skill",
      "fact checking skill",
      "multidisciplinary analysis",
      "structured reports",
      "Markdown report generator",
      "HTML analysis report",
      "research assistant skill"
    ],
    "actual_capabilities": [
      "Selects 1 to 3 relevant disciplines for an event, opinion, or incomplete fragment.",
      "Chooses useful subject scales such as individual, organization, city, industry, country, or technical system.",
      "Asks up to 3 follow-up questions when the user request is too broad or missing key context.",
      "Applies source-priority rules for fact-checking requests and marks unverifiable claims clearly.",
      "Produces Markdown tables, lists, text flow diagrams, and plain-text fallbacks for CLI environments.",
      "Can draft self-contained interactive HTML reports with collapsible sections, theme switching, and copy controls."
    ],
    "limitations": [
      "It does not perform live web research unless the host AI tool provides browsing or retrieval tools.",
      "Current-event fact checks may be stale when based only on model knowledge.",
      "It does not replace professional medical, legal, financial, or engineering advice.",
      "Generated HTML is returned as text for review and is not automatically saved or executed."
    ],
    "use_cases": [
      {
        "title": "Check a Public Claim",
        "target_user": "Researchers and analysts",
        "description": "Break a factual claim into verifiable parts, classify sources, and separate confirmed facts from logical inference."
      },
      {
        "title": "Explain a Social or Economic Event",
        "target_user": "Writers and educators",
        "description": "Turn a complex event into a readable explanation with discipline lenses, stakeholder effects, and causal flow."
      },
      {
        "title": "Create a Shareable Report",
        "target_user": "Teams and product leads",
        "description": "Convert a conversation into a Markdown or self-contained HTML report for review, discussion, or handoff."
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic Topic Breakdown",
        "scenario": "Beginner request for a clear first explanation.",
        "prompt": "Analyze this topic with Prism: [topic]. Use the most relevant disciplines and give me a clear summary, key factors, and a short conclusion."
      },
      {
        "title": "Fact-Aware Claim Review",
        "scenario": "Intermediate request for truthfulness checks.",
        "prompt": "Use Prism to check whether this claim is reliable: [claim]. Identify factual claims, source priority, what can be verified, and what remains uncertain."
      },
      {
        "title": "Multi-Perspective Event Analysis",
        "scenario": "Advanced request for cross-disciplinary reasoning.",
        "prompt": "Analyze this event from 2 or 3 disciplines and 2 stakeholder levels: [event]. Show causal links, tradeoffs, and likely short-term and long-term effects."
      },
      {
        "title": "Conversation to HTML Report",
        "scenario": "Advanced request after a detailed discussion.",
        "prompt": "Use Prism to turn our current topic into a self-contained interactive HTML report. Include collapsible sections, dark mode, and a copyable Markdown version."
      }
    ],
    "output_examples": [
      {
        "input": "The central bank raised rates. How does this affect normal households?",
        "output": "Prism would summarize the direct loan-cost impact, compare effects on savings, jobs, prices, and exchange rates, then show a short causal flow."
      },
      {
        "input": "Is this company layoff claim real, and what are the social effects?",
        "output": "Prism would separate the factual verification from the social analysis, then discuss employment, household stress, local business effects, and uncertainty."
      },
      {
        "input": "Make the analysis easier to share with my team.",
        "output": "Prism would draft a polished report with sections for context, evidence quality, discipline lenses, key takeaways, and next questions."
      }
    ],
    "best_practices": [
      "Provide the event, timeframe, region, and any source links when asking for fact-sensitive analysis.",
      "Ask for a specific output format, such as a table, text flow diagram, Markdown report, or HTML report.",
      "Request uncertainty labels when the topic involves current events, health, law, finance, or politics."
