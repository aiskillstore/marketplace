  "content": {
    "user_title": "Automate Browser Testing with Playwright CLI",
    "value_statement": "Manual browser testing is slow and hard to repeat. This skill lets Claude, Codex, and Claude Code drive playwright-cli for navigation, forms, screenshots, traces, and test workflows.",
    "seo_keywords": [
      "Claude Playwright CLI",
      "Codex browser automation",
      "Claude Code web testing",
      "playwright-cli skill",
      "AI browser testing",
      "web automation assistant",
      "Playwright screenshots",
      "storage state automation",
      "network mocking tests",
      "trace debugging"
    ],
    "actual_capabilities": [
      "Open browser sessions and navigate to target web pages.",
      "Click, type, fill forms, select options, upload files, and use keyboard or mouse actions.",
      "Capture snapshots, screenshots, PDFs, videos, traces, console output, and network activity.",
      "Save, load, inspect, and modify cookies, localStorage, sessionStorage, and storage state files.",
      "Mock, modify, block, and inspect network requests during Playwright sessions.",
      "Generate Playwright test steps from interactive browser actions."
    ],
    "limitations": [
      "It requires playwright-cli to be installed or available through npx.",
      "It can only automate sites reachable from the local execution environment.",
      "Generated tests still need human assertions and review.",
      "Artifacts may contain sensitive data and require careful cleanup."
    ],
    "use_cases": [
      {
        "title": "Validate a Login Flow",
        "description": "Automate a sign-in path, save storage state, and confirm the user reaches the expected page.",
        "target_user": "QA engineer"
      },
      {
        "title": "Debug a Failing Web Interaction",
        "description": "Record traces, screenshots, console logs, and network activity around a broken user flow.",
        "target_user": "Frontend developer"
      },
      {
        "title": "Mock API Responses for UI Work",
        "description": "Intercept browser requests and test empty, slow, failed, or premium response states.",
        "target_user": "Product engineer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Open and Inspect a Page",
        "scenario": "Beginner browser exploration",
        "prompt": "Use playwright-cli to open this URL, take a snapshot, and summarize the visible interactive elements: [URL]."
      },
      {
        "title": "Test a Form Flow",
        "scenario": "Basic functional testing",
        "prompt": "Use playwright-cli to complete this form flow with test data, capture a final screenshot, and list any failures: [URL and steps]."
      },
      {
        "title": "Record Debug Evidence",
        "scenario": "Intermediate debugging",
        "prompt": "Use playwright-cli tracing and console tools to reproduce this issue, then report the failed action and likely cause: [issue details]."
      },
      {
        "title": "Mock Network Conditions",
        "scenario": "Advanced test setup",
        "prompt": "Use playwright-cli route commands to mock these API responses, run the UI workflow, and describe how the page behaves: [routes and expected states]."
      }
    ],
    "output_examples": [
      {
        "input": "Open a checkout page and capture evidence after filling test fields.",
        "output": "A browser session is opened, form fields are completed, a screenshot is saved, and the final page state is summarized."
      },
      {
        "input": "Reproduce a button click that fails on staging.",
        "output": "A trace is recorded, console and network activity are reviewed, and the report identifies the failing selector or page state."
      },
      {
        "input": "Mock an API endpoint that returns an empty list.",
        "output": "A request route is installed, the page is reloaded, and the empty-state UI behavior is described."
      }
    ],
    "best_practices": [
      "Use test accounts and test data when automating authenticated pages.",
      "Delete screenshots, traces, videos, and storage-state files after they are no longer needed.",
      "Review generated Playwright code before adding it to a test suite."
    ],
    "anti_patterns": [
      "Do not save real user credentials or production session cookies in repository files.",
      "Do not run custom Playwright code from untrusted sources.",
      "Do not publish traces or videos without checking for secrets and private data."
    ],
    "faq": [
      {
        "question": "What does this skill automate?",
        "answer": "It automates browser actions through playwright-cli, including navigation, clicks, forms, screenshots, traces, videos, and storage state."
      },
      {
        "question": "Does it generate Playwright tests?",
        "answer": "Yes. It can show Playwright test steps from interactive actions, but you should add assertions and review the result."
      },
      {
        "question": "Can it handle authenticated sessions?",
        "answer": "Yes. It can save and load storage state, but those files can contain cookies and tokens."
      },
      {
        "question": "Is it safe for production sites?",
        "answer": "Use caution. Prefer test accounts and avoid entering sensitive production data into automated sessions."
      },
      {
        "question": "Can it mock network requests?",
        "answer": "Yes. It can route, mock, modify, block, and inspect browser network requests during a session."
      },
      {
        "question": "Which assistants can use this skill?",
        "answer": "The report marks it compatible with Claude, Codex, and Claude Code."
      }
    ]
