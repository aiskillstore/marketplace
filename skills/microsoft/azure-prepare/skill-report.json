  "content": {
    "user_title": "Prepare Apps for Azure Deployment",
    "value_statement": "Azure deployment setup often requires many architecture and infrastructure decisions. This skill guides planning and prepares deployment artifacts for Azure projects.",
    "seo_keywords": [
      "Azure deployment",
      "Azure Developer CLI",
      "Bicep templates",
      "Terraform Azure",
      "Dockerfiles",
      "azure.yaml",
      "Claude",
      "Codex",
      "Claude Code",
      "infrastructure as code"
    ],
    "actual_capabilities": [
      "Creates a plan file before generating Azure deployment artifacts.",
      "Selects Azure services based on application components and requirements.",
      "Generates Bicep or Terraform infrastructure guidance for Azure resources.",
      "Prepares azure.yaml configuration for Azure Developer CLI workflows.",
      "Provides Dockerfile and runtime guidance for deployable application components.",
      "Routes users toward validation before deployment."
    ],
    "limitations": [
      "It does not deploy resources by itself.",
      "It requires user approval before execution steps.",
      "It depends on accurate project structure and user requirements.",
      "Some examples require current Azure service knowledge and manual review."
    ],
    "use_cases": [
      {
        "title": "Plan a New Azure App",
        "target_user": "Application developer",
        "description": "Create an Azure-ready plan for a new web app, API, or backend service."
      },
      {
        "title": "Modernize an Existing Project",
        "target_user": "Platform engineer",
        "description": "Map an existing codebase to Azure services and prepare deployment artifacts."
      },
      {
        "title": "Standardize Infrastructure Setup",
        "target_user": "DevOps lead",
        "description": "Use consistent Azure Developer CLI, Bicep, Terraform, and Docker guidance across projects."
      }
    ],
    "prompt_templates": [
      {
        "title": "Start Azure Planning",
        "scenario": "Beginner project setup",
        "prompt": "Prepare this project for Azure deployment. First inspect the app structure, then create a plan for review before generating files."
      },
      {
        "title": "Add Azure Services",
        "scenario": "Existing application update",
        "prompt": "Add Azure deployment support for this application and recommend services for database, secrets, monitoring, and hosting."
      },
      {
        "title": "Generate IaC Artifacts",
        "scenario": "Infrastructure preparation",
        "prompt": "After the plan is approved, generate Azure infrastructure files using the best fit between Bicep and Terraform."
      },
      {
        "title": "Modernize for Azure",
        "scenario": "Advanced migration planning",
        "prompt": "Analyze this existing application for Azure modernization and create an approved plan covering architecture, security, runtime, and validation."
      }
    ],
    "output_examples": [
      {
        "input": "Prepare my Node.js API for Azure hosting.",
        "output": "A reviewed plan describing the runtime, Azure hosting option, required services, deployment files, and validation steps."
      },
      {
        "input": "Add Azure support to this app with Terraform.",
        "output": "Terraform-oriented preparation guidance with planned infrastructure files, Azure Developer CLI configuration, and security notes."
      },
      {
        "input": "Modernize this existing service for Azure Container Apps.",
        "output": "A modernization plan mapping app components to Azure services, container needs, secrets handling, and next validation tasks."
      }
    ],
    "best_practices": [
      "Review and approve the plan before generating infrastructure files.",
      "Use managed identity and Key Vault for secrets wherever possible.",
      "Run validation before any deployment attempt."
    ],
    "anti_patterns": [
      "Do not skip planning and generate deployment files immediately.",
      "Do not hardcode secrets in generated infrastructure or application settings.",
      "Do not deploy before reviewing region, subscription, cost, and security choices."
    ],
    "faq": [
      {
        "question": "Does this skill deploy resources to Azure?",
        "answer": "No. It prepares plans and deployment artifacts, then routes users to validation and deployment workflows."
      },
      {
        "question": "Can it use Terraform?",
        "answer": "Yes. It includes Terraform guidance, especially when used with Azure Developer CLI workflows."
      },
      {
        "question": "Can it create Bicep files?",
        "answer": "Yes. It can prepare Bicep-based infrastructure guidance and file plans."
      },
      {
        "question": "Does it support existing applications?",
        "answer": "Yes. It includes modify and modernization modes for existing Azure and non-Azure projects."
      },
      {
        "question": "Does it handle secrets?",
        "answer": "It recommends Key Vault and managed identity patterns, but generated settings still need review."
      },
      {
        "question": "Why is approval required?",
        "answer": "The workflow can create or modify deployment files, so users should approve the plan first."
      }
    ]
  },
