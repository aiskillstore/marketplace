  "content": {
    "user_title": "Prepare Azure Deployments",
    "value_statement": "Azure preparation often requires matching application code, infrastructure, runtime settings, and deployment tools. This skill guides planning and artifact generation for Azure-ready applications.",
    "seo_keywords": [
      "Azure deployment",
      "Azure Developer CLI",
      "azd",
      "Bicep",
      "Terraform",
      "Docker",
      "Azure Functions",
      "Claude",
      "Codex",
      "Claude Code"
    ],
    "actual_capabilities": [
      "Creates a plan-first workflow for new, modified, or modernized Azure applications.",
      "Maps application components to Azure services and deployment recipes.",
      "Guides generation of Bicep, Terraform, azure.yaml, Dockerfiles, and runtime configuration.",
      "Provides references for Azure Functions, App Service, Container Apps, storage, SQL, and messaging services.",
      "Adds security hardening guidance for managed identity, Key Vault, networking, and secret handling.",
      "Coordinates validation before deployment through an Azure validation workflow."
    ],
    "limitations": [
      "The skill contains prompt-injection language and should be remediated before marketplace publication.",
      "It provides guidance and templates, not guaranteed deployment success for every Azure subscription.",
      "Generated infrastructure still requires review for cost, region availability, and organization policy.",
      "Some commands require installed Azure CLI, Azure Developer CLI, Docker, or language-specific tooling."
    ],
    "use_cases": [
      {
        "title": "Plan a New Azure Application",
        "target_user": "Application developer",
        "description": "Create a deployment plan, choose Azure services, and prepare infrastructure files before implementation."
      },
      {
        "title": "Modernize an Existing Project",
        "target_user": "Platform engineer",
        "description": "Analyze an existing codebase and prepare azd, Docker, Bicep, or Terraform assets for Azure hosting."
      },
      {
        "title": "Prepare Azure Functions Workloads",
        "target_user": "Serverless developer",
        "description": "Select trigger templates, configure bindings, and prepare supporting infrastructure for Azure Functions."
      }
    ],
    "prompt_templates": [
      {
        "title": "Start Azure Planning",
        "scenario": "Beginner project preparation",
        "prompt": "Prepare this application for Azure. First inspect the project structure, then create a deployment plan with recommended Azure services."
      },
      {
        "title": "Choose Deployment Recipe",
        "scenario": "Select azd, Bicep, or Terraform",
        "prompt": "Review this project and recommend the best Azure deployment recipe. Explain whether azd, Bicep, Terraform, or Docker changes are needed."
      },
      {
        "title": "Modernize Existing App",
        "scenario": "Migration and modernization",
        "prompt": "Modernize this existing application for Azure hosting. Identify required code changes, infrastructure files, environment settings, and validation steps."
      },
      {
        "title": "Prepare Secure Multi-Service Deployment",
        "scenario": "Advanced architecture preparation",
        "prompt": "Prepare a secure Azure deployment for this multi-service application. Include managed identity, Key Vault, networking, observability, and validation requirements."
      }
    ],
    "output_examples": [
      {
        "input": "Prepare my Node.js API and frontend for Azure Container Apps.",
        "output": [
          "Deployment plan with Container Apps, managed identity, and health checks.",
          "Recommended azd configuration and Dockerfile changes.",
          "Validation checklist for environment variables, ports, and secrets."
        ]
      },
      {
        "input": "Add Azure Functions support for a queue-processing workflow.",
        "output": [
          "Suggested Functions trigger pattern and service dependencies.",
          "Infrastructure plan for storage, queues, identity, and monitoring.",
          "Security notes for secrets, bindings, and local development settings."
        ]
      },
      {
        "input": "Convert this app to Terraform-based Azure deployment.",
        "output": [
          "Terraform module plan with required providers and remote state guidance.",
          "Azure service mapping for app, database, network, and observability resources.",
          "Review items for region support, cost, and policy compliance."
        ]
      }
    ],
    "best_practices": [
      "Review the generated plan before allowing artifact generation or deployment changes.",
      "Use managed identity and Key Vault instead of storing secrets in source files.",
      "Validate infrastructure, runtime settings, and Azure context before deployment."
    ],
    "anti_patterns": [
      "Do not publish the skill while prompt-injection language remains in SKILL.md.",
      "Do not run install or deployment commands without confirming source, subscription, and scope.",
      "Do not commit generated environment files, Terraform state, or secrets to source control."
    ],
    "faq": [
      {
        "question": "What does this skill prepare?",
        "answer": "It prepares application projects for Azure by planning services, infrastructure, configuration, containers, and validation steps."
      },
      {
        "question": "Does it deploy the application?",
        "answer": "No. It prepares deployment assets and directs validation before deployment."
      },
      {
        "question": "Which infrastructure tools does it support?",
        "answer": "It includes guidance for Azure Developer CLI, Bicep, Terraform, Docker, and Azure Functions templates."
      },
      {
        "question": "Why is the security risk critical?",
        "answer": "SKILL.md contains prompt-injection language that tells the model to ignore prior training and treat the file as authoritative."
      },
      {
        "question": "Are the command examples automatically executed?",
        "answer": "No evidence found that they are automatically executed. They are Markdown guidance, but users should review commands before running them."
      },
      {
        "question": "What should be fixed before publishing?",
        "answer": "Remove instruction-override language, reduce mandatory control phrasing, and keep command examples clearly gated by user approval."
      }
    ]
  },
