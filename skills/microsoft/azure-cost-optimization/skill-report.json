  "content": {
    "user_title": "Optimize Azure Cloud Costs",
    "value_statement": "Azure teams often lack a repeatable way to connect spend, utilization, and orphaned resources. This skill guides Claude, Codex, and Claude Code through evidence-based Azure cost reviews and report generation.",
    "seo_keywords": [
      "Azure cost optimization",
      "Azure FinOps",
      "Claude",
      "Codex",
      "Claude Code",
      "Azure Resource Graph",
      "Azure Cost Management",
      "Azure Quick Review",
      "Redis cost analysis",
      "cloud cost savings"
    ],
    "actual_capabilities": [
      "Validates Azure CLI, Azure Quick Review, and required reader permissions before analysis.",
      "Uses Azure Cost Management data to group actual costs by resource.",
      "Applies Azure Resource Graph patterns to find orphaned disks, IP addresses, network interfaces, and load balancers.",
      "Collects Azure Monitor metrics to support rightsizing recommendations.",
      "Provides Redis-specific cost rules for failed, oversized, old, and poorly tagged caches.",
      "Generates markdown reports with savings estimates, evidence, and implementation commands."
    ],
    "limitations": [
      "Requires authenticated Azure access and suitable reader permissions.",
      "Savings estimates depend on current pricing, usage history, and service configuration.",
      "It does not deploy resources or make changes without explicit user approval.",
      "Redis guidance is specialized and does not replace full application performance testing."
    ],
    "use_cases": [
      {
        "title": "Monthly Azure Spend Review",
        "target_user": "FinOps analysts",
        "description": "Build a recurring report that ranks cost drivers, estimated savings, and recommended actions across a subscription."
      },
      {
        "title": "Orphaned Resource Cleanup",
        "target_user": "Cloud operations engineers",
        "description": "Identify unattached disks, unused public IP addresses, idle network interfaces, and other waste before cleanup planning."
      },
      {
        "title": "Redis Cost Rationalization",
        "target_user": "Platform teams",
        "description": "Review Azure Redis caches for failed states, oversized tiers, old test resources, and missing ownership tags."
      }
    ],
    "prompt_templates": [
      {
        "title": "Review One Subscription",
        "scenario": "Beginner",
        "prompt": "Analyze Azure costs for subscription <subscription-id>. Use actual cost data, identify the top cost drivers, and list low-risk savings opportunities."
      },
      {
        "title": "Find Orphaned Resources",
        "scenario": "Intermediate",
        "prompt": "Use Azure Resource Graph and Azure Quick Review guidance to find orphaned resources in <resource-group>. Include evidence and estimated monthly savings."
      },
      {
        "title": "RightSize Services With Metrics",
        "scenario": "Intermediate",
        "prompt": "Collect the last 14 days of utilization metrics for the resources in <scope>. Recommend rightsizing actions only when metrics support the change."
      },
      {
        "title": "Run Redis Portfolio Analysis",
        "scenario": "Advanced",
        "prompt": "Analyze Redis costs across subscriptions matching <prefix>. Classify failed, oversized, old, and untagged caches, then produce an executive savings summary."
      }
    ],
    "output_examples": [
      {
        "input": "Analyze monthly costs for one production subscription.",
        "output": "A report that lists total monthly cost, top cost drivers, verified pricing sources, utilization evidence, and prioritized savings actions."
      },
      {
        "input": "Find unused infrastructure in a shared development resource group.",
        "output": "A cleanup plan that separates immediate deletion candidates from items requiring owner confirmation and rollback planning."
      },
      {
        "input": "Review Redis caches across team subscriptions.",
        "output": "A Redis summary that highlights failed caches, premium dev instances, old test caches, missing tags, and expected monthly savings."
      }
    ],
    "best_practices": [
      "Query actual Azure cost data before estimating savings.",
      "Validate pricing against official Azure sources before publishing recommendations.",
      "Get explicit approval before deleting, resizing, or downgrading any resource."
    ],
    "anti_patterns": [
      "Do not assume idle resources are safe to delete without ownership validation.",
      "Do not recommend rightsizing from cost data alone without utilization metrics.",
      "Do not treat generated cleanup commands as approved change requests."
    ],
    "faq": [
      {
        "question": "Does this skill change Azure resources automatically?",
        "answer": "No. It provides analysis and command guidance. Destructive actions require explicit user approval."
      },
      {
        "question": "Which Azure permissions are needed?",
        "answer": "The skill expects Cost Management Reader, Monitoring Reader, and Reader permissions for the selected scope."
      },
      {
        "question": "Can it analyze multiple subscriptions?",
        "answer": "Yes. It includes patterns for subscription IDs, names, prefixes, all accessible subscriptions, and tenant-wide Redis reviews."
      },
      {
        "question": "How does it estimate savings?",
        "answer": "It combines actual cost data, utilization metrics, Azure pricing references, and service-specific optimization rules."
      },
      {
        "question": "Does it support Redis-specific reviews?",
        "answer": "Yes. It includes Redis rules for failed caches, premium dev tiers, old test caches, missing tags, and oversized resources."
      },
      {
        "question": "Is it safe for production environments?",
        "answer": "It is safe for analysis. Production changes should use approval, maintenance windows, rollback plans, and post-change monitoring."
      }
    ]
