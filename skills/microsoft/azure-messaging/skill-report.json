  "content": {
    "user_title": "Troubleshoot Azure Messaging SDKs",
    "value_statement": "Azure messaging failures can be hard to isolate across SDKs, network settings, authentication, and message processing behavior. This skill gives Claude, Codex, and Claude Code focused guidance for Event Hubs and Service Bus troubleshooting.",
    "seo_keywords": [
      "Claude Azure messaging",
      "Codex Azure Service Bus",
      "Claude Code Event Hubs",
      "Azure Event Hubs troubleshooting",
      "Azure Service Bus troubleshooting",
      "Azure Messaging SDK",
      "AMQP connection errors",
      "message lock lost",
      "Event Hubs checkpointing",
      "Service Bus dead letter"
    ],
    "actual_capabilities": [
      "Maps common Event Hubs and Service Bus errors to likely causes and fixes.",
      "Provides language-specific guidance for Python, Java, JavaScript, and .NET SDKs.",
      "Explains retry, logging, WebSocket, checkpointing, and client lifecycle settings.",
      "Guides use of Azure MCP tools for service health, resource checks, logs, and documentation search.",
      "Helps diagnose message lock, session lock, timeout, throttling, and receiver issues.",
      "Links to official SDK and Microsoft Learn troubleshooting references."
    ],
    "limitations": [
      "It does not create Event Hubs, Service Bus namespaces, queues, topics, or subscriptions.",
      "It depends on user-provided errors, SDK versions, configuration details, and authorized Azure access.",
      "It does not replace production incident response or Azure support for service outages.",
      "It gives troubleshooting guidance, not guaranteed fixes for application-specific code defects."
    ],
    "use_cases": [
      {
        "title": "Resolve SDK Connection Failures",
        "description": "Diagnose AMQP, WebSocket, firewall, proxy, and authentication problems that prevent a client from connecting.",
        "target_user": "Cloud application developer"
      },
      {
        "title": "Stabilize Message Processing",
        "description": "Investigate lock loss, processor hangs, receiver disconnects, checkpoint churn, and batch behavior in production consumers.",
        "target_user": "Site reliability engineer"
      },
      {
        "title": "Collect Actionable Diagnostics",
        "description": "Enable SDK logs, check Azure health, inspect relevant settings, and prepare useful details for support or issue filing.",
        "target_user": "Platform support engineer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Diagnose a Basic Error",
        "scenario": "Beginner troubleshooting for one error message.",
        "prompt": "Help me troubleshoot this Azure messaging SDK error. Service: [Event Hubs or Service Bus]. Language: [language]. Error: [paste error]."
      },
      {
        "title": "Review Connection Settings",
        "scenario": "Intermediate connectivity analysis.",
        "prompt": "Review my Azure messaging connectivity issue. Include checks for ports, WebSocket fallback, firewall, proxy, private endpoint, and authentication configuration."
      },
      {
        "title": "Analyze Processing Failures",
        "scenario": "Advanced message handling diagnosis.",
        "prompt": "Analyze why my [Event Hubs or Service Bus] processor stops or loses locks. Consider retry settings, prefetch, checkpointing, concurrency, and client lifecycle."
      },
      {
        "title": "Build an Incident Triage Plan",
        "scenario": "Advanced production troubleshooting workflow.",
        "prompt": "Create a triage plan for a production Azure messaging incident. Use available Azure MCP tools, SDK logs, service health, diagnostic logs, and official documentation."
      }
    ],
    "output_examples": [
      {
        "input": "Service Bus messages fail with MessageLockLost during long processing.",
        "output": [
          "Likely causes: processing exceeds lock duration, AMQP link detach, or idle timeout.",
          "Recommended checks: lock renewal settings, processing time, network stability, and client reuse.",
          "Next action: reduce processing time or configure lock renewal before changing concurrency."
        ]
      },
      {
        "input": "Event Hubs consumer does not receive events after scaling workers.",
        "output": [
          "Likely causes: partition ownership churn, consumer group contention, or checkpoint store delays.",
          "Recommended checks: instance count, consumer group, checkpoint frequency, and blob storage soft delete settings.",
          "Next action: verify scaling behavior stabilizes before filing a SDK issue."
        ]
      },
      {
        "input": "JavaScript SDK connection fails behind a corporate firewall.",
        "output": [
          "Likely causes: blocked AMQP ports, proxy interception, or invalid credentials.",
          "Recommended checks: port 443 WebSocket fallback, proxy settings, firewall rules, and RBAC or SAS configuration.",
          "Next action: enable SDK debug logs and test endpoint reachability."
        ]
      }
    ],
    "best_practices": [
      "Start with the exact SDK language, version, service, entity name, and full error message.",
      "Check service health, network path, authentication, and SDK configuration before changing application logic.",
      "Treat SDK clients as long-lived objects and close them cleanly when the application shuts down."
    ],
    "anti_patterns": [
      "Do not create a new Event Hubs or Service Bus client for every message operation.",
      "Do not assume every lock-lost error means processing exceeded the lock duration.",
      "Do not enable verbose AMQP frame logs in production without controlling retention and sensitive data exposure."
    ],
    "faq": [
      {
        "question": "Does this skill support both Event Hubs and Service Bus?",
        "answer": "Yes. It includes troubleshooting guidance for both services and their Python, Java, JavaScript, and .NET SDKs."
      },
      {
        "question": "Can it create Azure messaging resources?",
        "answer": "No. It focuses on SDK troubleshooting and points resource creation tasks to other Azure preparation workflows."
      },
      {
        "question": "Does it need Azure account access?",
        "answer": "Basic guidance does not need access. MCP-based checks for health, logs, or resources require user-authorized Azure access."
      },
      {
        "question": "Can it diagnose authentication failures?",
        "answer": "Yes. It helps check connection strings, SAS tokens, managed identity, and required Azure RBAC roles."
      },
      {
        "question": "Can it help with message lock lost errors?",
        "answer": "Yes. It covers lock duration, auto-renewal, processing time, link detach, idle timeout, and network causes."
      },
      {
        "question": "Does it provide official documentation links?",
        "answer": "Yes. It references Azure SDK repositories, Microsoft Learn troubleshooting pages, and Azure service documentation."
      }
    ]
  },
