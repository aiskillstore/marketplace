  "content": {
    "user_title": "Measure Code Size and Semantic Changes",
    "value_statement": "Codebase size and review scope are hard to estimate by hand. This skill guides Claude, Codex, and Claude Code through tokei and difft workflows for clear metrics and semantic comparisons.",
    "seo_keywords": [
      "Claude code statistics",
      "Codex code metrics",
      "Claude Code semantic diff",
      "tokei line count",
      "difftastic diffs",
      "repository analysis",
      "language breakdown",
      "git diff review",
      "codebase size tracking",
      "developer productivity"
    ],
    "actual_capabilities": [
      "Runs tokei examples to count files, lines, code, comments, and blanks by language.",
      "Shows filters for language, path, depth, ignored files, and generated directories.",
      "Uses difft examples for semantic file, directory, branch, and commit comparisons.",
      "Explains JSON, YAML, compact, and per-file output formats for reporting.",
      "Provides CI and history patterns for tracking codebase growth over time."
    ],
    "limitations": [
      "Requires tokei and difft to be installed in the local environment.",
      "Depends on Bash access and the permissions of the current workspace.",
      "Does not interpret every metric automatically without user direction.",
      "Large repositories may need filters to keep output readable."
    ],
    "use_cases": [
      {
        "title": "Estimate Review Scope",
        "description": "Summarize repository size and language mix before a code review or migration planning session.",
        "target_user": "Engineering leads"
      },
      {
        "title": "Compare Refactoring Results",
        "description": "Use semantic diffs to separate meaningful code changes from formatting or moved code.",
        "target_user": "Application developers"
      },
      {
        "title": "Track Repository Growth",
        "description": "Create repeatable reports for line counts, language changes, and CI size checks.",
        "target_user": "DevOps engineers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Count This Repository",
        "scenario": "Beginner overview",
        "prompt": "Use the code-stats skill to summarize this repository with tokei. Show total code lines and the top languages."
      },
      {
        "title": "Filter Generated Files",
        "scenario": "Focused metrics",
        "prompt": "Run a code statistics summary that excludes node_modules, dist, vendor, and generated files. Explain the resulting language breakdown."
      },
      {
        "title": "Review Semantic Changes",
        "scenario": "Code review",
        "prompt": "Use difft to compare the current branch with main. Highlight semantic changes and ignore formatting-only noise where possible."
      },
      {
        "title": "Create Growth Report",
        "scenario": "Advanced tracking",
        "prompt": "Build a repeatable codebase growth report using tokei output. Include totals, top languages, and a short interpretation for CI review."
      }
    ],
    "output_examples": [
      {
        "input": "Summarize the repository size.",
        "output": "The repository is mostly TypeScript with a smaller JavaScript portion. The summary separates code, comments, and blank lines."
      },
      {
        "input": "Compare my refactor with the previous version.",
        "output": "The semantic diff shows moved helper logic and a renamed variable. Formatting changes are treated as low-signal noise."
      },
      {
        "input": "Prepare a CI size check recommendation.",
        "output": "Set a maximum code-line threshold, exclude generated folders, and report the current total in the CI log."
      }
    ],
