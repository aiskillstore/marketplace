  "content": {
    "user_title": "Review Web Security Patterns",
    "value_statement": "Security reviews often miss common web risks and unsafe defaults. This skill gives OWASP-focused checklists, examples, and local audit helpers for faster review.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "OWASP security review",
      "secure coding patterns",
      "authentication audit",
      "cryptography guidance",
      "security headers",
      "dependency audit",
      "secrets management"
    ],
    "actual_capabilities": [
      "Summarizes OWASP Top 10 risks with prevention guidance.",
      "Provides examples for input validation, output encoding, authentication, and authorization.",
      "Documents password hashing, session cookies, JWT, OAuth, MFA, and rate limiting patterns.",
      "Explains cryptography choices for hashing, encryption, signatures, random values, and key storage.",
      "Lists HTTP security headers and framework-specific implementation examples.",
      "Includes shell scripts for local grep-based checks and dependency audit commands."
    ],
    "limitations": [
      "It is guidance and pattern matching, not a complete penetration test.",
      "Several examples intentionally show unsafe code for comparison.",
      "The audit scripts require local tools such as rg, git, npm, or language scanners.",
      "Results need human review to separate real issues from false positives."
    ],
    "use_cases": [
      {
        "title": "Review a web feature before release",
        "description": "Use OWASP checklists to inspect access control, validation, sessions, headers, and logging before deployment.",
        "target_user": "Application developer"
      },
      {
        "title": "Create secure implementation guidance",
        "description": "Turn authentication, cryptography, and header patterns into practical review notes for a project team.",
        "target_user": "Security engineer"
      },
      {
        "title": "Run quick local security checks",
        "description": "Use the included scripts to find common risky patterns and dependency audit gaps in a repository.",
        "target_user": "DevOps engineer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Check common risks",
        "scenario": "Beginner review of a small feature",
        "prompt": "Review this feature for common OWASP risks. Focus on input validation, output encoding, authentication, authorization, and secrets handling."
      },
      {
        "title": "Review authentication flow",
        "scenario": "Intermediate review of login and sessions",
        "prompt": "Review this authentication flow. Check password hashing, session cookies, reset tokens, MFA, rate limits, and account lockout behavior."
      },
      {
        "title": "Assess cryptography choices",
        "scenario": "Advanced review of sensitive data handling",
        "prompt": "Assess these cryptography choices. Verify algorithms, key storage, random value generation, nonce handling, signatures, and password hashing."
      },
      {
        "title": "Plan a release security audit",
        "scenario": "Advanced pre-release review across a repository",
        "prompt": "Create a release security audit plan for this repository. Include manual checks, local script checks, dependency review, and follow-up fixes."
      }
    ],
    "output_examples": [
      {
        "input": "Review a login endpoint and session configuration.",
        "output": [
          "Findings grouped by authentication, session cookies, rate limiting, reset tokens, and logging.",
          "A severity rating for each issue with clear remediation steps.",
          "A checklist of tests to confirm the fixes."
        ]
      },
      {
        "input": "Assess security headers for a web application.",
        "output": [
          "A header-by-header review of CSP, HSTS, framing, content type, referrer, and permissions policy.",
          "Recommended production settings with notes about compatibility tradeoffs.",
          "A short validation plan using browser tools or trusted header scanners."
        ]
      },
      {
        "input": "Prepare a dependency audit workflow.",
        "output": [
          "A workflow that selects the right scanner for Python, Node.js, Go, Rust, and Docker projects.",
          "A review process for advisories, patched versions, and temporary mitigations.",
          "A summary format for release blockers and accepted risks."
        ]
      }
    ],
    "best_practices": [
      "Treat unsafe examples as teaching material and copy only the corrected patterns.",
      "Run included scripts in trusted repositories and review results before changing code.",
      "Pair automated pattern checks with manual review of business logic and authorization paths."
    ],
    "anti_patterns": [
      "Do not treat grep results as confirmed vulnerabilities without context.",
      "Do not copy examples marked wrong into production code.",
      "Do not use the skill as a substitute for threat modeling or expert review."
    ],
    "faq": [
      {
        "question": "Is this skill for security testing or secure coding?",
        "answer": "It supports both, but it focuses on defensive review, secure implementation patterns, and common audit checks."
      },
      {
        "question": "Does it execute scans automatically?",
        "answer": "No. It includes scripts that a user may run manually in a local repository."
      },
      {
        "question": "Are the unsafe examples vulnerabilities in the skill?",
        "answer": "They are educational examples labeled as wrong or risky. Users should copy only the corrected patterns."
      },
      {
        "question": "Can it find every security issue?",
        "answer": "No. Pattern checks miss business logic flaws, design issues, and context-specific authorization problems."
      },
      {
        "question": "What tools does it support?",
        "answer": "The metadata lists Claude, Codex, and Claude Code as supported tools."
      },
      {
        "question": "What should I review before using it?",
        "answer": "Review the included Bash scripts, required local tools, and any audit output before applying changes."
      }
    ]
  },
