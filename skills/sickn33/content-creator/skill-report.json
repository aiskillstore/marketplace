  "content": {
    "user_title": "Create SEO-Ready Marketing Content",
    "value_statement": "Marketing teams need consistent content that fits each channel and supports search goals. This skill provides templates, brand voice checks, SEO analysis, and content planning guidance for Claude, Codex, and Claude Code workflows.",
    "seo_keywords": [
      "Claude content creation",
      "Codex marketing writing",
      "Claude Code SEO assistant",
      "brand voice analyzer",
      "SEO content optimizer",
      "social media templates",
      "content calendar planning",
      "blog post frameworks",
      "marketing copy workflow",
      "content strategy skill"
    ],
    "actual_capabilities": [
      "Analyzes text for brand voice traits, readability, sentence variety, and improvement suggestions.",
      "Checks blog content for keyword density, headings, links, readability, and metadata suggestions.",
      "Provides reusable frameworks for blog posts, case studies, newsletters, video scripts, and social posts.",
      "Guides platform-specific social media optimization for LinkedIn, X, Instagram, Facebook, and TikTok.",
      "Includes a monthly content calendar template for campaign planning and performance review.",
      "Supports manual command-line use through two local Python scripts."
    ],
    "limitations": [
      "It does not perform live keyword research or fetch current search volume data.",
      "SEO scores are heuristic and should not replace professional SEO tools.",
      "Social platform guidance may need updates as platform algorithms change.",
      "The scripts analyze local files only and do not publish or schedule content."
    ],
    "use_cases": [
      {
        "title": "Build a Blog Content Workflow",
        "description": "Create a structured blog draft, review keyword placement, and apply SEO recommendations before publishing.",
        "target_user": "Content marketer"
      },
      {
        "title": "Standardize Brand Voice",
        "description": "Analyze existing copy, select tone attributes, and keep messaging consistent across campaigns.",
        "target_user": "Brand manager"
      },
      {
        "title": "Plan Multi-Channel Campaigns",
        "description": "Turn one campaign idea into blog, email, video, and social media assets with a shared calendar.",
        "target_user": "Small business owner"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Blog Outline",
        "scenario": "Beginner content planning",
        "prompt": "Use the content creator skill to outline a blog post about [topic] for [audience]. Include a search-friendly title, H2 sections, reader intent, and a clear CTA."
      },
      {
        "title": "Analyze Brand Voice",
        "scenario": "Voice consistency review",
        "prompt": "Analyze this draft for brand voice consistency. My desired voice is [voice attributes]. Return strengths, mismatches, and edits that preserve the original meaning."
      },
      {
        "title": "Optimize an Article for SEO",
        "scenario": "Pre-publishing SEO review",
        "prompt": "Review this article for the primary keyword [keyword] and secondary keywords [keywords]. Assess structure, density, metadata, readability, links, and recommended changes."
      },
      {
        "title": "Repurpose a Campaign",
        "scenario": "Advanced multi-channel production",
        "prompt": "Repurpose this campaign brief into a blog outline, LinkedIn post, X thread, newsletter section, and video script. Keep the same brand voice and adapt each format to the platform."
      }
    ],
    "output_examples": [
      {
        "input": "A draft article about customer onboarding with the keyword customer onboarding checklist.",
        "output": "The skill returns an SEO score, keyword placement notes, heading structure feedback, metadata suggestions, and specific edits to improve readability."
      },
      {
        "input": "A set of product launch notes for a professional B2B audience.",
        "output": "The skill can produce a launch blog outline, LinkedIn post, newsletter blurb, and content calendar entries with a consistent professional tone."
      },
      {
        "input": "A brand voice sample that should sound clear, helpful, and confident.",
        "output": "The skill identifies dominant voice traits, readability level, sentence variety, and practical recommendations for stronger consistency."
      }
    ],
    "best_practices": [
      "Provide audience, channel, keyword, and brand voice details before asking for copy.",
      "Review generated SEO suggestions against current search data and editorial judgment.",
      "Run local scripts only on files you are comfortable analyzing in the current workspace."
    ],
    "anti_patterns": [
      "Do not use keyword stuffing to raise SEO scores at the expense of readability.",
      "Do not reuse one social post unchanged across every platform.",
      "Do not treat template timing and algorithm advice as permanent platform rules."
    ],
    "faq": [
      {
        "question": "Can this skill write complete blog posts?",
        "answer": "Yes. It can guide outlines, drafts, SEO checks, and revisions when you provide topic, audience, and keyword details."
      },
      {
        "question": "Does it connect to SEO platforms?",
        "answer": "No. It does not fetch live search volume, rankings, or competitor data from external SEO services."
      },
      {
        "question": "Can it analyze brand voice?",
        "answer": "Yes. The included analyzer reviews readability, sentence structure, and simple voice indicators from local text files."
      },
      {
        "question": "Which content channels does it support?",
        "answer": "It supports blogs, newsletters, LinkedIn, X, Instagram, Facebook, TikTok, video scripts, and content calendars."
      },
      {
        "question": "Is it safe to run the scripts?",
        "answer": "The scripts read local files and print analysis locally. Use them only with files you intend to analyze."
      },
      {
        "question": "Can Claude Code or Codex use this skill?",
        "answer": "Yes. The report lists support for Claude, Codex, and Claude Code."
      }
    ]
  },
