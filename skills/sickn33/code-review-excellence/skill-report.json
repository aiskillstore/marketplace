  "content": {
    "user_title": "Improve Code Reviews With Structured Feedback",
    "value_statement": "Code reviews often miss risks or create unclear feedback for contributors. This skill gives Claude, Codex, and Claude Code structured review checklists and response templates.",
    "seo_keywords": [
      "Claude code review",
      "Codex code review",
      "Claude Code pull request review",
      "AI code review checklist",
      "software quality review",
      "security review guide",
      "pull request feedback",
      "developer mentoring",
      "review standards"
    ],
    "actual_capabilities": [
      "Guides pull request reviews across correctness, security, performance, testing, and maintainability.",
      "Provides severity labels for blocking issues, important concerns, minor notes, suggestions, and learning comments.",
      "Offers language-specific review examples for Python and TypeScript or JavaScript changes.",
      "Supplies templates for review summaries, required changes, suggestions, questions, and verdicts.",
      "Helps teams set review standards, limit scope, and improve feedback quality."
    ],
    "limitations": [
      "Does not run tests, inspect repositories, or analyze pull requests by itself.",
      "Does not replace project-specific security, compliance, or architecture rules.",
      "Example code is illustrative and may need adaptation for a specific stack.",
      "Does not implement fixes unless combined with separate coding instructions."
    ],
    "use_cases": [
      {
        "title": "Review a Pull Request",
        "description": "Apply a structured checklist to identify bugs, risks, missing tests, and unclear design choices.",
        "target_user": "Software engineers"
      },
      {
        "title": "Create Team Review Standards",
        "description": "Turn common review expectations into consistent guidance for severity, scope, timing, and feedback tone.",
        "target_user": "Engineering leads"
      },
      {
        "title": "Mentor Through Review Feedback",
        "description": "Write comments that explain risk, suggest improvements, and support learning without personal criticism.",
        "target_user": "Senior developers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic Pull Request Review",
        "scenario": "Beginner",
        "prompt": "Use the code-review-excellence skill to review this pull request. Focus on correctness, tests, and any blocking risks."
      },
      {
        "title": "Security-Focused Review",
        "scenario": "Intermediate",
        "prompt": "Use the code-review-excellence skill to review these changes for input validation, authorization, data exposure, and unsafe execution patterns."
      },
      {
        "title": "Review Standards Draft",
        "scenario": "Intermediate",
        "prompt": "Use the code-review-excellence skill to draft concise review standards for our team, including severity labels and expected response times."
      },
      {
        "title": "Architecture and Mentoring Review",
        "scenario": "Advanced",
        "prompt": "Use the code-review-excellence skill to review this large change for architecture fit, test strategy, maintainability, and mentoring-quality feedback."
      }
    ],
    "output_examples": [
      {
        "input": "Review a pull request that adds payment calculation logic.",
        "output": [
          "Blocking: Payment totals mix tax, discount, and persistence concerns, which increases correctness risk.",
          "Important: Add tests for zero-value orders, multiple discounts, and rounding behavior.",
          "Suggestion: Extract calculation logic into a service so it can be tested without controller setup."
        ]
      },
      {
        "input": "Create a review checklist for a backend team.",
        "output": [
          "Check authorization before every state-changing action.",
          "Confirm database queries are parameterized and indexed for expected traffic.",
          "Require tests for happy paths, edge cases, and failure paths."
        ]
      },
      {
        "input": "Help phrase difficult feedback constructively.",
        "output": "This change works for the main path, but the shared mutable state can fail under concurrent requests. Could we isolate the state per request and add a regression test?"
      }
    ],
    "best_practices": [
      "Review the requirements, changed files, and test signals before commenting on details.",
      "Mark each concern with clear severity so authors know what blocks merge.",
      "Explain the risk and suggest a concrete next step for every required change."
    ],
    "anti_patterns": [
      "Do not block a pull request for formatting that automated tools should handle.",
      "Do not rewrite code to personal preference without a clear maintainability reason.",
      "Do not approve changes without checking tests, edge cases, and security-sensitive paths."
    ],
    "faq": [
      {
        "question": "Can this skill review code automatically?",
        "answer": "It provides review structure and guidance. The AI tool still needs access to the diff, context, and test results."
      },
      {
        "question": "Does it support security reviews?",
        "answer": "Yes. It includes checklist items for authorization, input validation, data protection, unsafe execution, and secrets handling."
      },
      {
        "question": "Is this only for senior engineers?",
        "answer": "No. It helps reviewers at any level give clearer, more actionable feedback."
      },
      {
        "question": "Can teams adapt the templates?",
        "answer": "Yes. Teams should align severity labels and checklists with their own engineering standards."
      },
      {
        "question": "Does it replace linters or test suites?",
        "answer": "No. It recommends using automated tools for formatting, linting, and repeatable checks."
      },
      {
        "question": "Why is the security risk listed as low?",
        "answer": "Static scanner hits were found in Markdown examples and checklists, not executable code or malicious instructions."
      }
    ]
