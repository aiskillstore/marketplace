  "content": {
    "user_title": "Build Reliable Python Test Suites",
    "value_statement": "Python projects often lack consistent tests, fixtures, and coverage practices. This skill helps Claude, Codex, and Claude Code apply pytest patterns, mocking, TDD, and CI testing guidance.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Python testing",
      "pytest",
      "test fixtures",
      "mocking",
      "test driven development",
      "CI testing",
      "coverage reports"
    ],
    "actual_capabilities": [
      "Explains unit, integration, functional, and performance test patterns.",
      "Provides pytest examples for fixtures, parameterization, exceptions, and monkeypatching.",
      "Shows mocking patterns for API clients and external services.",
      "Guides testing for async code, file operations, databases, and edge cases.",
      "Includes coverage, marker, configuration, and CI workflow examples."
    ],
    "limitations": [
      "Does not run tests or inspect project results by itself.",
      "Examples require adaptation to the target project structure.",
      "Does not replace security review for real credentials or production endpoints.",
      "Focuses on pytest and common Python testing tools."
    ],
    "use_cases": [
      {
        "title": "Add Unit Tests To A Library",
        "description": "Create focused pytest tests for functions, classes, edge cases, and expected exceptions.",
        "target_user": "Python package maintainer"
      },
      {
        "title": "Mock External Services",
        "description": "Test API clients and service boundaries without making live network calls.",
        "target_user": "Backend engineer"
      },
      {
        "title": "Improve CI Test Coverage",
        "description": "Add coverage reporting, markers, and continuous test workflows for pull requests.",
        "target_user": "DevOps engineer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create Basic Tests",
        "scenario": "Beginner",
        "prompt": "Use python-testing-patterns to write pytest unit tests for this Python function. Include normal cases, edge cases, and one failure case."
      },
      {
        "title": "Add Fixtures",
        "scenario": "Intermediate",
        "prompt": "Use python-testing-patterns to design pytest fixtures for this module. Keep setup and teardown isolated between tests."
      },
      {
        "title": "Mock Dependencies",
        "scenario": "Advanced",
        "prompt": "Use python-testing-patterns to test this API client without live network calls. Mock success, failure, and timeout behavior."
      },
      {
        "title": "Plan A Test Strategy",
        "scenario": "Expert",
        "prompt": "Use python-testing-patterns to propose a full testing strategy for this Python service. Cover fixtures, integration tests, async paths, coverage, and CI."
      }
    ],
    "output_examples": [
      {
        "input": "Test a calculator module with addition, division, and divide-by-zero behavior.",
        "output": "A pytest test plan with separate cases for valid arithmetic, boundary values, and expected exceptions."
      },
      {
        "input": "Test an API client that creates and reads users.",
        "output": "A mocked testing approach that verifies request behavior, response parsing, and HTTP error handling."
      },
      {
        "input": "Add coverage checks to a Python project.",
        "output": "A practical coverage setup with pytest-cov, useful report formats, and a minimum coverage threshold."
      }
    ],
    "best_practices": [
      "Keep tests independent and clean up state after each test.",
      "Mock external services unless the goal is an integration test.",
      "Measure coverage, but prioritize meaningful assertions and behavior."
    ],
    "anti_patterns": [
      "Do not use real production credentials in tests.",
      "Do not let tests depend on execution order or shared mutable state.",
      "Do not mock so much that important behavior is no longer tested."
    ],
    "faq": [
      {
        "question": "What testing framework does this skill focus on?",
        "answer": "It focuses on pytest, with examples for fixtures, mocking, parameterization, async tests, coverage, and CI."
      },
      {
        "question": "Can it help with test-driven development?",
        "answer": "Yes. It includes guidance for writing tests before or alongside implementation."
      },
      {
        "question": "Does it make live API calls?",
        "answer": "No. The playbook shows mocked API tests and placeholder URLs for examples."
      },
      {
        "question": "Can it test database code?",
        "answer": "Yes. It includes examples using in-memory databases and isolated database sessions."
      },
      {
        "question": "Does it support CI workflows?",
        "answer": "Yes. It includes sample guidance for running pytest and coverage in continuous integration."
      },
      {
        "question": "Should examples be copied directly into production projects?",
        "answer": "No. Adapt the examples to your project structure, dependencies, and security requirements."
      }
    ]
