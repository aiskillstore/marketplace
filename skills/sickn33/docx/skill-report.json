  "content": {
    "user_title": "Edit Word Documents with Tracked Changes",
    "value_statement": "DOCX editing often requires precise XML changes that preserve comments, styles, and tracked revisions. This skill gives Claude, Codex, and Claude Code workflows for creating, reading, editing, and validating Word documents.",
    "seo_keywords": [
      "DOCX automation",
      "OOXML editing",
      "Word document editing",
      "tracked changes",
      "document comments",
      "Claude",
      "Codex",
      "Claude Code",
      "docx-js",
      "Word document validation"
    ],
    "actual_capabilities": [
      "Creates new DOCX files with JavaScript examples based on docx-js.",
      "Extracts DOCX text through pandoc workflows, including tracked change views.",
      "Unpacks and repacks Office documents as OOXML zip archives.",
      "Adds and replies to Word comments through bundled Python document helpers.",
      "Builds tracked insertions and deletions with WordprocessingML patterns.",
      "Validates DOCX structure with bundled schema and redlining validators."
    ],
    "limitations": [
      "Requires external tools such as pandoc, LibreOffice, Poppler, npm docx, and Python libraries.",
      "Works directly on local files and temporary directories, so untrusted documents need sandboxing.",
      "Complex Word layouts may still require manual inspection in Microsoft Word or LibreOffice.",
      "The bundled archive extraction helpers do not fully protect against malicious zip paths."
    ],
    "use_cases": [
      {
        "title": "Review contract redlines",
        "target_user": "Legal teams",
        "description": "Apply precise tracked changes and comments while preserving existing Word document structure."
      },
      {
        "title": "Generate formatted reports",
        "target_user": "Business analysts",
        "description": "Create professional DOCX reports with headings, tables, links, images, headers, and footers."
      },
      {
        "title": "Inspect document internals",
        "target_user": "Document automation developers",
        "description": "Unpack DOCX files, inspect OOXML parts, update relationships, and validate packaging before delivery."
      }
    ],
    "prompt_templates": [
      {
        "title": "Extract document text",
        "scenario": "Beginner analysis",
        "prompt": "Read this DOCX file and summarize the main sections. Preserve any tracked changes in the summary."
      },
      {
        "title": "Create a new document",
        "scenario": "Structured generation",
        "prompt": "Create a DOCX report with a title page, table of contents, three sections, a table, and page numbers."
      },
      {
        "title": "Add comments to a review draft",
        "scenario": "Document review",
        "prompt": "Add Word comments to the attached DOCX where terms are unclear. Keep the document text unchanged."
      },
      {
        "title": "Apply tracked legal edits",
        "scenario": "Advanced redlining",
        "prompt": "Use tracked changes to update the agreement terms in this DOCX. Preserve all unrelated formatting and validate the final file."
      }
    ],
    "output_examples": [
      {
        "input": "A user asks for a DOCX summary with tracked changes visible.",
        "output": "A structured summary that separates accepted text, deleted text, inserted text, comments, and open review issues."
      },
      {
        "input": "A user requests a formatted project proposal as a Word file.",
        "output": "A generated DOCX with headings, consistent styles, tables, links, page setup, and accessible image descriptions."
      },
      {
        "input": "A user asks for contract edits as redlines.",
        "output": "A revised DOCX where insertions, deletions, and comments are represented as Word review markup."
      }
    ],
    "best_practices": [
      "Use a disposable workspace when processing documents from unknown sources.",
      "Validate the packed DOCX and inspect it visually before sharing it externally.",
      "Use tracked changes for legal, business, academic, and government edits."
    ],
    "anti_patterns": [
      "Do not run dependency installation commands without reviewing package sources first.",
      "Do not process untrusted DOCX files outside a sandboxed directory.",
      "Do not edit another reviewer’s tracked changes without preserving their original markup."
    ],
    "faq": [
      {
        "question": "Can this skill create new Word documents?",
        "answer": "Yes. It includes docx-js guidance for building formatted DOCX files with JavaScript."
      },
      {
        "question": "Can it edit existing DOCX files?",
        "answer": "Yes. It provides Python helpers and OOXML guidance for modifying unpacked Word documents."
      },
      {
        "question": "Does it support tracked changes?",
        "answer": "Yes. It documents redlining patterns and includes validation for Claude-authored tracked changes."
      },
      {
        "question": "Does it need external software?",
        "answer": "Yes. Some workflows use pandoc, LibreOffice, Poppler, npm docx, and Python XML libraries."
      },
      {
        "question": "Is it safe for untrusted documents?",
        "answer": "Use caution. The archive extraction helpers need sandboxing because DOCX files are zip archives."
      },
      {
        "question": "Can it preserve formatting?",
        "answer": "It is designed to preserve OOXML structure, but complex layouts should be checked in Word or LibreOffice."
      }
    ]
  },
