  "content": {
    "user_title": "Secure Solidity Smart Contracts",
    "value_statement": "Smart contract flaws can lock funds, expose privileged functions, or create exploitable transaction flows. This skill guides Claude, Codex, and Claude Code through practical Solidity security review and safer implementation patterns.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Solidity security",
      "smart contract audit",
      "Ethereum security",
      "reentrancy prevention",
      "access control",
      "DeFi audit",
      "EVM security"
    ],
    "actual_capabilities": [
      "Explains reentrancy risks and safer withdrawal patterns.",
      "Reviews access control, ownership, and role-based protection patterns.",
      "Highlights arithmetic safety requirements for Solidity versions.",
      "Outlines front-running mitigations such as commit and reveal flows.",
      "Provides audit preparation checklists and security testing ideas.",
      "Connects gas optimization choices with security tradeoffs."
    ],
    "limitations": [
      "It does not replace an independent professional audit.",
      "It does not run Slither, Mythril, Echidna, or other scanners by itself.",
      "Example contracts require adaptation before production use.",
      "It focuses on Solidity and EVM contract patterns."
    ],
    "use_cases": [
      {
        "title": "Pre-deployment contract review",
        "description": "Review a Solidity contract for common vulnerability classes before testnet or mainnet deployment.",
        "target_user": "Smart contract developer"
      },
      {
        "title": "DeFi protocol hardening",
        "description": "Check payment flows, access controls, and front-running exposure during protocol design.",
        "target_user": "DeFi engineering team"
      },
      {
        "title": "Audit readiness preparation",
        "description": "Build a concise checklist of fixes, tests, and documentation before an external audit.",
        "target_user": "Security lead"
      }
    ],
    "prompt_templates": [
      {
        "title": "Check one contract",
        "scenario": "Beginner review of a single Solidity file.",
        "prompt": "Review this Solidity contract for reentrancy, access control, arithmetic safety, and unsafe external calls. Explain each issue clearly."
      },
      {
        "title": "Improve a function",
        "scenario": "Focused remediation for a risky function.",
        "prompt": "Analyze this withdrawal or transfer function. Suggest safer ordering, validation, and event handling without changing the business goal."
      },
      {
        "title": "Prepare audit checklist",
        "scenario": "Project readiness before an external review.",
        "prompt": "Create an audit preparation checklist for this Solidity project. Include tests, documentation, privileged roles, and deployment assumptions."
      },
      {
        "title": "Threat model a protocol",
        "scenario": "Advanced review of a DeFi or upgradeable system.",
        "prompt": "Threat model this Solidity protocol. Cover trust boundaries, economic attacks, upgrade paths, oracle risks, and user fund recovery paths."
      }
    ],
    "output_examples": [
      {
        "input": "A developer asks for a review of a withdraw function that sends ether before updating balances.",
        "output": [
          "Flags reentrancy risk and explains the vulnerable order.",
          "Recommends checks, state updates, then external interaction.",
