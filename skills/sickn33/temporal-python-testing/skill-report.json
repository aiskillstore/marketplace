    "actual_capabilities": [
      "Explains pytest fixtures for Temporal WorkflowEnvironment and ActivityEnvironment.",
      "Shows time-skipping patterns for long-running workflow tests.",
      "Guides integration tests with mocked activities and error injection.",
      "Describes replay testing for workflow determinism and compatibility.",
      "Provides local Temporal server setup with Docker Compose examples.",
      "Covers coverage targets, CI patterns, and test organization."
    ],
