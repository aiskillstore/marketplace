      "Python CI workflows"
    ],
    "actual_capabilities": [
      "Explains when to use uv for Python package management and virtual environments.",
      "Provides command patterns for project setup, dependency changes, and lockfile workflows.",
      "Covers Python version pinning, uv run usage, and reproducible sync commands.",
      "Shows migration paths from pip, requirements files, Poetry, and pip-tools.",
      "Includes CI, Docker, workspace, pre-commit, and editor integration examples."
    ],
    "limitations": [
      "Does not execute uv commands or verify results for the user.",
      "Does not replace official uv documentation for new release details.",
      "Examples may need adjustment for private indexes or enterprise policies.",
      "Installer commands should be reviewed before running on production machines."
    ],
    "use_cases": [
      {
        "title": "Start a Python project",
        "description": "Create a uv-based project with pinned Python, dependencies, dev tools, and a lockfile.",
        "target_user": "Python application developer"
      },
      {
        "title": "Modernize dependency workflows",
        "description": "Move an existing project from pip, Poetry, or pip-tools to uv commands and lockfile practices.",
        "target_user": "Maintainer of an existing Python repository"
      },
      {
        "title": "Speed up build pipelines",
        "description": "Apply uv sync, cache, frozen lockfile, and Docker patterns for faster repeatable builds.",
        "target_user": "DevOps or platform engineer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a uv project",
        "scenario": "Beginner setup",
        "prompt": "Help me start a new Python project with uv. Include project creation, Python version pinning, dependencies, dev dependencies, and verification steps."
      },
      {
        "title": "Add dependencies safely",
        "scenario": "Daily package management",
        "prompt": "Show me how to add, remove, upgrade, and lock Python dependencies with uv for this project. Include commands and checks."
      },
      {
        "title": "Migrate an existing repository",
        "scenario": "Migration from older tools",
        "prompt": "Plan a migration from requirements.txt, Poetry, or pip-tools to uv. Include files to keep, commands to run, and rollback checks."
      },
      {
        "title": "Optimize CI and Docker",
        "scenario": "Advanced delivery workflow",
        "prompt": "Design a uv workflow for CI and Docker builds. Include cache strategy, frozen installs, lockfile validation, and security review points."
      }
    ],
    "output_examples": [
      {
        "input": "I need a new FastAPI project managed by uv.",
        "output": "A step-by-step setup plan with project initialization, Python pinning, runtime packages, dev tools, lockfile creation, and test commands."
      },
      {
        "input": "My repository uses requirements.txt and slow CI installs.",
        "output": "A migration checklist that keeps compatibility, adds uv locking, uses frozen installs, and documents verification before merging."
      },
      {
        "input": "I want uv in a Docker build.",
        "output": "A build workflow that separates dependency installation, application copy steps, runtime environment setup, and reproducibility checks."
      }
    ],
    "best_practices": [
      "Pin the Python version and commit the uv lockfile for reproducible installs.",
      "Use frozen sync commands in CI after the lockfile has been reviewed.",
      "Review remote installer commands before running them on trusted machines."
    ],
    "anti_patterns": [
      "Do not mix unmanaged pip installs with uv-managed project dependencies.",
      "Do not update lockfiles in CI without review.",
      "Do not run download-and-execute installer commands from unverified sources."
    ],
    "faq": [
      {
        "question": "What does this skill help with?",
        "answer": "It helps plan and explain uv workflows for Python dependencies, virtual environments, lockfiles, Python versions, CI, and Docker."
      },
      {
        "question": "Does the skill run commands automatically?",
        "answer": "No. It provides guidance and examples. Users choose which commands to run in their own environment."
      },
      {
        "question": "Can it replace pip or Poetry?",
        "answer": "It can help migrate many workflows to uv, but project requirements and team policies should guide the decision."
      },
      {
        "question": "Is it suitable for CI pipelines?",
        "answer": "Yes. It includes patterns for frozen lockfile installs, cache usage, testing, linting, and reproducible builds."
      },
      {
        "question": "What should users verify first?",
        "answer": "Users should verify installer sources, lockfile changes, Python versions, and package indexes before applying commands."
