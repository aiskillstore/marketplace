    "user_title": "Manage Python Projects Faster with uv",
    "value_statement": "Python dependency workflows can be slow and inconsistent. This skill guides uv setup, locking, virtual environments, and migration steps for faster projects.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "uv package manager",
      "Python dependencies",
      "Python virtual environments",
      "Python lockfiles",
      "pip migration",
