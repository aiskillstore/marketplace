  "content": {
    "user_title": "Design Apple Content Components",
    "value_statement": "Apple app teams need clear choices for displaying images, charts, web content, and collections. This skill maps those needs to Apple HIG guidance with accessibility and platform notes.",
    "seo_keywords": [
      "Claude Apple HIG",
      "Codex Apple design",
      "Claude Code UI components",
      "Apple Human Interface Guidelines",
      "SwiftUI content components",
      "iOS chart design",
      "UICollectionView guidance",
      "WKWebView design",
      "Apple accessibility guidance",
      "tvOS lockup design"
    ],
    "actual_capabilities": [
      "Recommends Apple content components for charts, collections, images, web content, sharing, and lockups.",
      "Explains platform support for iOS, iPadOS, macOS, tvOS, visionOS, and watchOS.",
      "Summarizes accessibility requirements for charts, images, collections, and interactive content.",
      "Points to relevant Apple APIs such as Swift Charts, UICollectionView, WKWebView, and UIActivityViewController.",
      "Helps compare similar components, including image views versus image wells and web views versus Safari."
    ],
    "limitations": [
      "It provides design guidance, not complete production code.",
      "It covers content display components only, not every Apple HIG area.",
      "It depends on bundled reference text and may not include newer Apple updates.",
      "It cannot validate an app interface without screenshots, prototypes, or implementation details."
    ],
    "use_cases": [
      {
        "title": "Select a Display Component",
        "description": "Choose the right HIG component for charts, images, web content, collections, sharing, or tvOS media cards.",
        "target_user": "Product designers"
      },
      {
        "title": "Review Apple App UI Plans",
        "description": "Check whether a proposed content interface follows platform behavior, accessibility needs, and component conventions.",
        "target_user": "iOS and macOS developers"
      },
      {
        "title": "Document Component Decisions",
        "description": "Create clear rationale for component choices, platform exceptions, and accessibility requirements in design specs.",
        "target_user": "Design system maintainers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Choose a Component",
        "scenario": "Beginner selection guidance",
        "prompt": "I am designing an Apple app screen that shows [content type]. Which HIG content component should I use and why?"
      },
      {
        "title": "Compare Two Options",
        "scenario": "Component tradeoff review",
        "prompt": "Compare [component A] and [component B] for [platform] and [user task]. Include accessibility and platform constraints."
      },
      {
        "title": "Audit a Screen Concept",
        "scenario": "Design review before implementation",
        "prompt": "Review this screen concept against Apple HIG content component guidance: [describe screen]. List issues and recommended changes."
      },
      {
        "title": "Create Implementation Guidance",
        "scenario": "Advanced product and engineering handoff",
        "prompt": "Write a component decision note for [feature]. Include recommended Apple component, rationale, accessibility requirements, and platform-specific behavior."
      }
    ],
    "output_examples": [
      {
        "input": "Which component should show a grid of photo albums on iPad?",
        "output": "Use a collection view. It supports visual grids, selection, reordering, dynamic layouts, and large content sets. Include clear item labels and VoiceOver order."
      },
      {
        "input": "Should my app show a website inside a web view?",
        "output": "Use a web view for brief in-context web content. Use Safari or SFSafariViewController when people need full browsing, account flows, or broad navigation."
      },
      {
        "input": "How should I make a fitness chart accessible?",
        "output": "Use clear titles, axis labels, summaries, and Audio Graphs when available. Do not require interaction to understand the most important data."
      }
    ],
    "best_practices": [
      "Start with the system component that matches the content and platform.",
      "Include accessibility labels, summaries, and interaction paths for every content display.",
      "Document platform exceptions before committing to one shared component design."
    ],
    "anti_patterns": [
      "Do not use a web view to recreate a full browser experience.",
      "Do not rely only on color to explain chart data or state.",
      "Do not add custom collection layouts when a standard row or grid is clearer."
    ],
    "faq": [
      {
        "question": "What components does this skill cover?",
        "answer": "It covers charts, collections, image views, image wells, color wells, web views, activity views, and lockups."
      },
      {
        "question": "Can it write Swift or SwiftUI code?",
        "answer": "It can guide component choices and mention relevant APIs, but it is not a full code generation skill."
      },
      {
        "question": "Does it include accessibility guidance?",
        "answer": "Yes. It includes guidance for labels, VoiceOver, Audio Graphs, focus order, and accessible interaction."
      },
      {
        "question": "Is it useful outside iOS?",
        "answer": "Yes. It includes notes for iPadOS, macOS, tvOS, visionOS, and watchOS where the references provide them."
      },
      {
        "question": "When should I use a web view?",
        "answer": "Use a web view for limited in-app web content. Prefer Safari-based experiences for broad browsing tasks."
      },
      {
        "question": "How current is the guidance?",
        "answer": "The skill uses its bundled Apple HIG reference files. Check Apple Developer documentation for updates after publication."
      }
    ]
  },
