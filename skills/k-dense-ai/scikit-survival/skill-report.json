  "content": {
    "user_title": "Analyze Survival Data with scikit-survival",
    "value_statement": "Survival analysis requires methods that handle censoring and time-dependent outcomes correctly. This skill helps Claude, Codex, and Claude Code guide scikit-survival workflows from data preparation to model evaluation.",
    "seo_keywords": [
      "Claude scikit-survival skill",
      "Codex survival analysis",
      "Claude Code time-to-event modeling",
      "scikit-survival Python",
      "Cox proportional hazards",
      "Random Survival Forest",
      "survival SVM",
      "censored data analysis",
      "competing risks analysis",
      "Brier score survival models"
    ],
    "actual_capabilities": [
      "Explains when to use Cox, Coxnet, ensemble, and survival SVM models.",
      "Guides creation of scikit-survival Surv objects from arrays or data frames.",
      "Documents preprocessing steps for missing values, categorical variables, scaling, and validation.",
      "Compares survival metrics including C-index, time-dependent AUC, and Brier score.",
      "Provides guidance for competing risks and cumulative incidence analysis.",
      "Summarizes common pitfalls in survival model training and evaluation."
    ],
    "limitations": [
      "Does not execute Python code or validate results against a live dataset.",
      "Focuses on scikit-survival and may not cover every survival-analysis package.",
      "Assumes users can supply suitable time, event, and feature data.",
      "Statistical conclusions still require domain review and study design expertise."
    ],
    "use_cases": [
      {
        "title": "Prepare clinical survival data",
        "target_user": "Clinical data scientist",
        "description": "Structure event and time columns, handle censoring, encode features, and build a reproducible scikit-survival dataset."
      },
      {
        "title": "Compare survival model families",
        "target_user": "Machine learning engineer",
        "description": "Choose between Cox models, Random Survival Forests, gradient boosting, and survival SVMs for a specific prediction task."
      },
      {
        "title": "Evaluate censored predictions",
        "target_user": "Research analyst",
        "description": "Select appropriate survival metrics and avoid biased comparisons when censoring is moderate or high."
      }
    ],
    "prompt_templates": [
      {
        "title": "Prepare a Survival Dataset",
        "scenario": "Beginner data setup",
        "prompt": "Help me prepare a scikit-survival dataset. My time column is [time_column], my event column is [event_column], and my features are [feature_columns]. Explain the checks I should run before modeling."
      },
      {
        "title": "Choose a Survival Model",
        "scenario": "Model selection",
        "prompt": "Recommend a scikit-survival model for this dataset: [sample_size], [feature_count], [censoring_rate], [need_for_interpretability], and [expected_nonlinearity]. Explain the tradeoffs."
      },
      {
        "title": "Design an Evaluation Plan",
        "scenario": "Metric selection",
        "prompt": "Create an evaluation plan for my survival model. I need to compare [models] with censoring around [censoring_rate] and prediction horizons [time_points]. Include suitable metrics and pitfalls."
      },
      {
        "title": "Review a Full Workflow",
        "scenario": "Advanced workflow audit",
        "prompt": "Review my scikit-survival workflow for methodological issues. Focus on censoring, train-test splitting, preprocessing leakage, model choice, hyperparameter tuning, and metric interpretation."
      }
    ],
    "output_examples": [
      {
        "input": "I have 2,000 patients, 60 predictors, and 45% censoring. I need interpretable risk factors.",
        "output": "The skill would recommend starting with a penalized Cox model, checking proportional hazards assumptions, using train-only preprocessing, and reporting Uno C-index with time-dependent AUC."
      },
      {
        "input": "I need to compare Random Survival Forest and gradient boosting at 1, 3, and 5 years.",
        "output": "The skill would outline time-specific evaluation, suggest cumulative dynamic AUC and integrated Brier score, and warn against using only Harrell C-index under high censoring."
      },
      {
        "input": "My dataset has relapse and death as mutually exclusive outcomes.",
        "output": "The skill would identify this as a competing risks problem and guide cumulative incidence analysis instead of treating all competing events as ordinary censoring."
      }
    ],
    "best_practices": [
      "Validate time and event columns before fitting any model.",
      "Fit preprocessing steps on training data only to prevent leakage.",
      "Choose evaluation metrics that match the censoring rate and prediction horizon."
    ],
    "anti_patterns": [
      "Treating competing events as simple censoring without justification.",
      "Using Harrell C-index alone when censoring is high.",
      "Comparing models without consistent train-test splits and preprocessing."
    ],
    "faq": [
      {
        "question": "What is scikit-survival used for?",
        "answer": "It is used for survival analysis and time-to-event prediction with censored data in Python."
      },
      {
        "question": "Can this skill run my analysis?",
        "answer": "No. It provides guidance, examples, and review support. You run the code in your own Python environment."
      },
      {
        "question": "Which models does it cover?",
        "answer": "It covers Cox models, penalized Cox models, Random Survival Forests, gradient boosting, survival trees, and survival SVMs."
      },
      {
        "question": "Does it support competing risks?",
        "answer": "Yes. It explains when to use competing risks methods and how to interpret cumulative incidence functions."
      },
      {
        "question": "Which metrics are included?",
        "answer": "It covers Harrell C-index, Uno C-index, time-dependent AUC, Brier score, and integrated Brier score."
      },
      {
        "question": "Is it suitable for clinical research?",
        "answer": "It can support clinical survival workflows, but final statistical and clinical conclusions require expert review."
      }
    ]
