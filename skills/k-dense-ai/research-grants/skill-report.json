  "content": {
    "user_title": "Draft Competitive Research Grant Proposals",
    "value_statement": "Research grant proposals require agency-specific structure, review criteria, budgets, and compliance details. This skill helps Claude, Codex, and Claude Code draft focused proposal sections and review them against funder expectations.",
    "seo_keywords": [
      "Claude research grants",
      "Codex grant writing",
      "Claude Code proposal assistant",
      "NSF proposal template",
      "NIH specific aims",
      "DOE grant proposal",
      "DARPA proposal guidance",
      "budget justification",
      "broader impacts",
      "research funding application"
    ],
    "actual_capabilities": [
      "Drafts agency-specific proposal sections for NSF, NIH, DOE, DARPA, and Taiwan NSTC programs.",
      "Structures NIH Specific Aims pages with gap, hypothesis, aims, innovation, and impact elements.",
      "Builds NSF project summaries with overview, intellectual merit, and broader impacts sections.",
      "Prepares budget justification language for personnel, equipment, travel, supplies, and other costs.",
      "Provides review checklists for significance, innovation, feasibility, milestones, and compliance.",
      "Compares agency expectations, page limits, review criteria, and submission planning needs."
    ],
    "limitations": [
      "It does not replace official solicitation instructions or institutional sponsored research review.",
      "It cannot verify current deadlines, forms, or funding opportunity changes without fresh source checking.",
      "It provides writing support, not legal, financial, or compliance approval for submissions.",
      "It cannot guarantee funding outcomes or reviewer scores."
    ],
    "use_cases": [
