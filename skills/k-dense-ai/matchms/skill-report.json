  "content": {
    "user_title": "Compare Mass Spectra with matchms",
    "value_statement": "Metabolomics teams need consistent ways to clean spectra and compare unknown compounds. This skill gives Claude, Codex, and Claude Code practical matchms workflows for spectral matching.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "matchms",
      "metabolomics",
      "mass spectrometry",
      "spectral similarity",
      "compound identification",
      "MS/MS analysis",
      "spectral library search"
    ],
    "actual_capabilities": [
      "Explains how to load MGF, MSP, mzML, mzXML, JSON, USI, and pickle spectra with matchms.",
      "Guides metadata harmonization, intensity normalization, peak filtering, and quality control pipelines.",
      "Compares spectra with CosineGreedy, ModifiedCosine, NeutralLossesCosine, and related similarity methods.",
      "Builds library search workflows for unknown spectra and reference spectra.",
      "Shows export options for MGF, MSP, JSON, pickle, CSV-style reports, and score files.",
      "Documents when to use structure fingerprints, precursor matching, and multi-metric scoring."
    ],
    "limitations": [
      "Requires matchms and related Python dependencies in the user environment.",
      "Does not run a complete proteomics LC-MS/MS pipeline.",
      "Quality depends on the user provided spectral libraries and metadata.",
      "Pickle loading should be limited to trusted files only."
    ],
    "use_cases": [
      {
        "title": "Identify Unknown Metabolites",
        "description": "Compare unknown MS/MS spectra against a curated reference library and rank likely compound matches.",
        "target_user": "Metabolomics researcher"
      },
      {
        "title": "Clean Spectral Libraries",
        "description": "Standardize metadata, normalize peak intensities, remove weak peaks, and save processed spectra for later analysis.",
        "target_user": "Bioinformatics analyst"
      },
      {
        "title": "Design Similarity Workflows",
        "description": "Choose cosine, modified cosine, neutral loss, precursor mass, or fingerprint scoring for specific research questions.",
        "target_user": "Computational chemist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Load and Inspect Spectra",
        "scenario": "Beginner workflow setup",
        "prompt": "Help me load an MGF file with matchms, inspect basic metadata, and explain what preprocessing should happen next."
      },
      {
        "title": "Create a Cleaning Pipeline",
        "scenario": "Routine data preparation",
        "prompt": "Create a matchms preprocessing plan for raw MS/MS spectra with metadata harmonization, peak normalization, and quality filters."
      },
      {
        "title": "Run Library Matching",
        "scenario": "Compound identification",
        "prompt": "Design a matchms workflow to compare unknown spectra against a reference library and report the top five matches per query."
      },
      {
        "title": "Compare Multiple Scoring Methods",
        "scenario": "Advanced research workflow",
        "prompt": "Help me combine cosine, modified cosine, neutral loss, precursor mass, and fingerprint scores for robust metabolite identification."
      }
    ],
    "output_examples": [
      {
        "input": "A researcher has unknown MS/MS spectra and a reference library in MGF format.",
        "output": "A stepwise workflow that loads both files, applies the same filters, computes cosine scores, and ranks candidate compounds."
      },
      {
        "input": "An analyst needs to remove low-quality spectra before sharing a library.",
        "output": "A quality control plan with precursor checks, minimum peak requirements, intensity normalization, and export guidance."
      },
      {
        "input": "A chemist wants to compare related compounds with shifted precursor masses.",
        "output": "A recommendation to use ModifiedCosine, with notes about precursor metadata and tolerance selection."
      }
    ],
    "best_practices": [
      "Apply the same preprocessing steps to query spectra and reference spectra.",
      "Validate precursor m/z, ion mode, and minimum peak counts before scoring.",
      "Use pickle only for trusted intermediate files from your own workflow."
    ],
    "anti_patterns": [
      "Do not compare raw spectra against cleaned libraries without matching preprocessing.",
      "Do not treat high similarity scores as confirmed identities without metadata review.",
      "Do not load pickle files from unknown or untrusted sources."
    ],
    "faq": [
      {
        "question": "What is matchms used for?",
        "answer": "It is used to process mass spectra and compare them for metabolomics compound identification."
      },
      {
        "question": "Which spectrum formats are covered?",
        "answer": "The skill covers MGF, MSP, mzML, mzXML, JSON, USI references, and pickle files."
      },
      {
        "question": "Can this identify compounds automatically?",
        "answer": "It can rank likely matches, but final identification needs expert review and supporting metadata."
      },
      {
        "question": "Does it support structural similarity?",
        "answer": "Yes. It covers molecular fingerprints when SMILES or InChI metadata and chemistry dependencies are available."
      },
      {
        "question": "Is pickle support safe?",
        "answer": "Only load pickle files from trusted sources. Untrusted pickle files can execute arbitrary Python code."
      },
      {
        "question": "Does this replace pyopenms?",
        "answer": "No. Use pyopenms for full LC-MS/MS proteomics pipelines and broader raw data processing."
      }
    ]
