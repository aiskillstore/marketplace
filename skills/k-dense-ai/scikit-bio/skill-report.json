  "content": {
    "user_title": "Analyze biological data with scikit-bio",
    "value_statement": "Bioinformatics work often spans sequences, trees, diversity metrics, and statistics. This skill guides scikit-bio workflows with focused examples and analysis patterns.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "scikit-bio",
      "bioinformatics analysis",
      "microbiome diversity",
      "phylogenetic trees",
      "sequence analysis",
      "PERMANOVA",
      "PCoA"
    ],
    "actual_capabilities": [
      "Explains DNA, RNA, protein, and generic sequence operations using scikit-bio classes.",
      "Guides pairwise alignment, multiple sequence alignment, CIGAR handling, and sequence distance calculations.",
      "Supports phylogenetic tree construction, traversal, pruning, rooting, and tree comparison workflows.",
      "Covers alpha diversity, beta diversity, UniFrac, ordination, PERMANOVA, ANOSIM, PERMDISP, and Mantel tests.",
      "Describes FASTA, FASTQ, Newick, BIOM, distance matrix, and ordination file workflows.",
      "Shows integration patterns with pandas, NumPy, matplotlib, seaborn, and QIIME 2 outputs."
    ],
    "limitations": [
      "It provides guidance and examples; it does not guarantee scikit-bio is installed locally.",
      "Statistical results depend on valid input tables, metadata, trees, and biological assumptions.",
      "Large datasets may require generators, sparse formats, or external compute resources.",
      "It does not replace review by a qualified bioinformatics or ecology expert."
    ],
    "use_cases": [
      {
        "title": "Plan microbiome diversity analysis",
        "description": "Design a workflow for alpha diversity, beta diversity, ordination, and PERMANOVA from sample count tables.",
        "target_user": "Microbiome researcher"
      },
      {
        "title": "Process biological sequences",
        "description": "Read FASTA or FASTQ files, validate sequence types, find motifs, translate RNA, and export clean outputs.",
        "target_user": "Bioinformatics analyst"
      },
      {
        "title": "Compare phylogenetic relationships",
        "description": "Build trees from distance matrices, inspect clades, compute tree distances, and prepare Newick outputs.",
        "target_user": "Evolutionary biology student"
      }
    ],
    "prompt_templates": [
      {
        "title": "Begin a sequence task",
        "scenario": "Beginner sequence analysis",
        "prompt": "Use scikit-bio to explain how I should read a FASTA file, validate DNA sequences, find motifs, and write results."
      },
      {
        "title": "Design a diversity workflow",
        "scenario": "Microbiome count table analysis",
        "prompt": "Create a scikit-bio workflow for alpha diversity, beta diversity, PCoA, and PERMANOVA from my feature table and metadata."
      },
      {
        "title": "Audit a phylogeny plan",
        "scenario": "Tree construction and comparison",
        "prompt": "Review my plan to build and compare phylogenetic trees with scikit-bio. Identify required inputs, assumptions, and validation checks."
      },
      {
        "title": "Optimize a complex analysis",
        "scenario": "Advanced multi-step workflow",
        "prompt": "Help optimize a large scikit-bio analysis that combines FASTQ parsing, UniFrac distances, ordination, and statistical testing."
      }
    ],
    "output_examples": [
      {
        "input": "A user asks how to compare microbial communities across treatment groups.",
        "output": [
          "Recommended workflow: validate integer count data, align sample IDs, compute Bray-Curtis and UniFrac distances, then run PCoA.",
          "Statistical check: use PERMANOVA for group differences and PERMDISP to assess dispersion effects."
        ]
      },
      {
        "input": "A user needs to convert raw sequence reads into cleaner sequence outputs.",
        "output": [
          "Recommended workflow: stream FASTQ records, inspect quality metadata, filter or trim sequences, then write validated FASTA output.",
          "Validation check: confirm sequence IDs remain unique and biological alphabets match the selected sequence class."
        ]
      },
      {
        "input": "A user wants to visualize relationships among protein embeddings.",
        "output": [
          "Recommended workflow: convert embeddings to a distance matrix, run ordination, and prepare sample coordinates for plotting.",
          "Interpretation check: report explained variance and confirm clusters match biological metadata before drawing conclusions."
        ]
      }
    ],
    "best_practices": [
      "Validate sample IDs, feature IDs, and tree tip names before running phylogenetic diversity metrics.",
      "Use generators and sparse formats for large sequence files or BIOM tables.",
      "Pair PERMANOVA with dispersion checks before interpreting group differences."
    ],
    "anti_patterns": [
      "Do not use relative abundances where scikit-bio expects integer count data.",
      "Do not compare samples when metadata order and distance matrix IDs are misaligned.",
      "Do not treat ordination plots as proof without statistical testing and biological validation."
    ],
    "faq": [
      {
        "question": "What is scikit-bio used for?",
        "answer": "It supports biological sequence analysis, phylogenetic trees, microbial diversity metrics, ordination, file I/O, and ecological statistics."
      },
