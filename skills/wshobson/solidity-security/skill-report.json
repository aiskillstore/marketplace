  "content": {
    "user_title": "Audit Solidity Contracts for Vulnerabilities",
    "value_statement": "Smart contracts can lose funds when common security patterns are missed. This skill helps Claude, Codex, and Claude Code review Solidity code with practical checks and safer examples.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Solidity security",
      "smart contract audit",
      "reentrancy prevention",
      "DeFi security",
      "Web3 development",
      "blockchain audit",
      "secure Solidity patterns"
    ],
    "actual_capabilities": [
      "Explains reentrancy risks and checks-effects-interactions mitigation.",
      "Shows access control patterns using owner and role-based checks.",
      "Covers integer overflow behavior before and after Solidity 0.8.",
      "Provides front-running, pull payment, and circuit breaker examples.",
      "Lists security testing ideas for Hardhat-based contract projects.",
      "Prepares audit checklists for common Solidity vulnerability classes."
    ],
    "limitations": [
      "It is guidance content, not an automated scanner.",
      "Referenced resource files are listed but not included in this package.",
      "Examples need adaptation before production deployment.",
      "It cannot replace a professional audit for high-value contracts."
    ],
    "use_cases": [
      {
        "title": "Pre-Audit Contract Review",
        "description": "Review a Solidity contract for common vulnerability classes before sending it to an external auditor.",
        "target_user": "Smart contract developer"
      },
      {
        "title": "Security Learning Session",
        "description": "Study vulnerable and safer Solidity examples to understand why common attack patterns work.",
        "target_user": "Blockchain engineering student"
      },
      {
        "title": "DeFi Launch Checklist",
        "description": "Create a focused security checklist for withdrawals, swaps, access control, and emergency stops.",
        "target_user": "DeFi protocol team"
      }
    ],
    "prompt_templates": [
      {
        "title": "Review a Simple Contract",
        "scenario": "Beginner review of one Solidity file.",
        "prompt": "Review this Solidity contract for reentrancy, access control, input validation, and unsafe transfers. Explain each issue in simple terms."
      },
      {
        "title": "Apply Secure Patterns",
        "scenario": "Improve a contract design before implementation.",
        "prompt": "Suggest secure Solidity patterns for this contract design. Include checks-effects-interactions, pull payments, and emergency stop guidance where relevant."
      },
      {
        "title": "Prepare Audit Notes",
        "scenario": "Organize findings before a professional audit.",
        "prompt": "Create pre-audit notes for this Solidity project. Group risks by severity, affected functions, recommended fixes, and open questions for auditors."
      },
      {
        "title": "Model DeFi Attack Paths",
        "scenario": "Advanced review of a protocol workflow.",
        "prompt": "Analyze this DeFi workflow for reentrancy, front-running, oracle assumptions, privilege abuse, and gas denial risks. Prioritize exploitable paths."
      }
    ],
    "output_examples": [
      {
        "input": "A withdrawal function sends ETH before updating the caller balance.",
        "output": "The review identifies a reentrancy risk, explains the attack sequence, and recommends updating state before the external call."
      },
      {
        "input": "A contract has owner-only functions and public payment distribution.",
        "output": "The output separates access control findings from payment flow risks and suggests role checks, pull withdrawals, and event coverage."
      },
      {
        "input": "A DeFi swap flow exposes trade details before execution.",
        "output": "The analysis flags front-running risk and proposes slippage checks, commit-reveal design, or other transaction-order protections."
      }
    ],
    "best_practices": [
      "Provide the full contract context, including inherited contracts and modifiers.",
      "Ask for severity, exploit path, and remediation for each finding.",
      "Validate suggestions with tests, static analysis tools, and human review."
    ],
    "anti_patterns": [
      "Do not copy vulnerable examples into production code.",
      "Do not treat gas optimization as more important than safety.",
      "Do not rely on this skill as the only review for contracts holding funds."
    ],
    "faq": [
      {
        "question": "Does this skill run Solidity analysis tools?",
        "answer": "No. It provides review guidance and examples, but it does not run scanners or compile contracts."
      },
      {
        "question": "Can it replace a professional smart contract audit?",
        "answer": "No. It can improve preparation and internal review, but high-value contracts still need expert audit coverage."
      },
      {
        "question": "Which Solidity risks does it cover?",
        "answer": "It covers reentrancy, integer overflow, access control, front-running, input validation, emergency stops, and payment patterns."
      },
      {
        "question": "Is it useful for Claude Code and Codex?",
        "answer": "Yes. The prompts and guidance work with Claude, Codex, and Claude Code when reviewing Solidity projects."
      },
      {
        "question": "Does it include external dependencies?",
        "answer": "No. The package contains one Markdown skill file and references common tools and libraries as examples."
      },
      {
        "question": "How should teams use the output?",
        "answer": "Treat output as a review aid. Confirm findings with tests, static analysis, and a qualified auditor."
      }
    ]
