  "content": {
    "user_title": "Create and Edit DOCX Documents",
    "value_statement": "Professional DOCX work often requires preserving comments, tracked changes, and formatting. This skill guides Claude, Codex, and Claude Code through structured OOXML workflows.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "DOCX editing",
      "Word document automation",
      "OOXML",
      "tracked changes",
      "document comments",
      "document validation",
      "office documents"
    ],
    "actual_capabilities": [
      "Extract text from DOCX files with tracked change visibility using Pandoc.",
      "Create new DOCX files with JavaScript document components and formatting guidance.",
      "Edit unpacked OOXML files with helper classes for comments and tracked changes.",
      "Pack unpacked Office document directories back into DOCX, PPTX, or XLSX files.",
      "Validate DOCX and PPTX structures against bundled OOXML schemas.",
      "Convert DOCX files to PDF and page images for visual review workflows."
    ],
    "limitations": [
      "Requires local tools such as Pandoc, LibreOffice, Poppler, Node.js packages, and Python dependencies.",
      "Complex formatting changes require careful XML inspection and validation before delivery.",
      "Untrusted Office files should be handled in a controlled workspace because archive extraction is used.",
      "The bundled schema validators may not cover every Microsoft Word compatibility edge case."
    ],
    "use_cases": [
      {
        "title": "Review Contract Revisions",
        "target_user": "Legal and business reviewers",
        "description": "Apply precise tracked changes and comments while preserving review history in Word documents."
      },
      {
        "title": "Generate Structured Reports",
        "target_user": "Operations and analytics teams",
        "description": "Create formatted DOCX reports with headings, tables, lists, images, headers, and footers."
      },
      {
        "title": "Inspect Document Internals",
        "target_user": "Document automation engineers",
        "description": "Unpack DOCX files, inspect OOXML parts, adjust relationships, and validate the rebuilt document."
      }
    ],
    "prompt_templates": [
      {
        "title": "Extract Document Text",
        "scenario": "Beginner text review",
        "prompt": "Read this DOCX file and summarize its contents. Preserve visible tracked changes in the summary."
      },
      {
        "title": "Create a New DOCX",
        "scenario": "Formatted document generation",
        "prompt": "Create a professional DOCX report with a title, sections, bullet lists, a table, and consistent styling."
      },
      {
        "title": "Add Review Comments",
        "scenario": "Collaborative editing",
        "prompt": "Add Word comments to the attached document for unclear clauses, missing definitions, and inconsistent dates."
      },
      {
        "title": "Implement Tracked Changes",
        "scenario": "Advanced redlining workflow",
        "prompt": "Apply these negotiated edits as tracked changes, validate the XML, and produce a final DOCX for review."
      }
    ],
    "output_examples": [
      {
        "input": "A user asks for a contract clause to be revised with tracked changes.",
        "output": "The assistant returns a DOCX where only the changed words are marked as insertions and deletions."
      },
      {
        "input": "A user provides meeting notes and asks for a polished Word report.",
        "output": "The assistant produces a formatted DOCX with headings, lists, tables, page layout, and consistent typography."
      },
      {
        "input": "A user asks whether a generated DOCX is structurally valid.",
        "output": "The assistant reports validation results, explains any document issues, and rebuilds the file after fixes."
      }
    ],
    "best_practices": [
      "Work on copied documents and keep the original DOCX unchanged.",
      "Validate after each batch of tracked changes or XML edits.",
      "Use precise surrounding text when mapping requested edits to OOXML nodes."
    ],
    "anti_patterns": [
      "Do not unpack untrusted Office files outside an isolated working directory.",
      "Do not mark entire paragraphs as changed when only a few words changed.",
      "Do not skip final validation after direct OOXML edits."
    ],
    "faq": [
      {
        "question": "Can this skill create new Word documents?",
        "answer": "Yes. It includes guidance for generating DOCX files with document components, styles, tables, images, and layout settings."
      },
      {
        "question": "Can it preserve tracked changes?",
        "answer": "Yes. The redlining workflow focuses on precise insertions, deletions, comments, and verification."
      },
      {
        "question": "Does it require external software?",
        "answer": "Yes. Some workflows depend on Pandoc, LibreOffice, Poppler, Node.js packages, and Python libraries."
      },
      {
        "question": "Is it safe for untrusted DOCX files?",
        "answer": "Use caution. The skill extracts Office archives, so untrusted files should stay inside an isolated workspace."
      },
      {
        "question": "Can it edit comments?",
        "answer": "Yes. The document helper supports adding comments and replies through Word comment XML infrastructure."
      },
      {
        "question": "Can it validate every Word feature?",
        "answer": "No. It includes OOXML validation helpers, but Microsoft Word compatibility can still require manual review."
      }
    ]
  },
