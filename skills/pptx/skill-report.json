  "content": {
    "user_title": "Create and Edit PowerPoint Presentations",
    "value_statement": "Building or repairing PowerPoint files can be slow when layout, XML, and validation details matter. This skill helps Claude, Codex, and Claude Code create, inspect, edit, validate, and thumbnail PPTX files with guided workflows.",
    "seo_keywords": [
      "Claude PowerPoint skill",
      "Codex PPTX automation",
      "Claude Code presentation editing",
      "PowerPoint generation",
      "PPTX editing",
      "OOXML validation",
      "presentation thumbnails",
      "HTML to PowerPoint",
      "slide deck automation",
      "PowerPoint analysis"
    ],
    "actual_capabilities": [
      "Create new PPTX decks from HTML slides with precise positioning.",
      "Edit existing presentations through OOXML unpack, modify, validate, and pack workflows.",
      "Extract text and inspect raw presentation XML, themes, layouts, notes, and comments.",
      "Generate thumbnail grids to review slide layout, contrast, and text overflow.",
      "Use helper scripts for template inventory, slide rearrangement, and text replacement."
    ],
    "limitations": [
      "Some workflows require local Python, Node.js, Playwright, LibreOffice, or related tools.",
      "Perfect PowerPoint rendering still needs thumbnail validation and manual review.",
      "Advanced animations, embedded objects, and custom fonts may require direct OOXML work.",
      "Important presentations should be edited from copies to protect original files."
    ],
    "use_cases": [
      {
        "title": "Build Client-Ready Slide Decks",
        "target_user": "Consultants and analysts",
        "description": "Turn structured content into a polished PowerPoint deck with consistent layouts, charts, tables, and visual review."
      },
      {
        "title": "Repair Existing Presentations",
        "target_user": "Operations and enablement teams",
        "description": "Update slide text, speaker notes, comments, layouts, and media while validating the final PPTX package."
      },
      {
        "title": "Automate Template-Based Decks",
        "target_user": "Marketing and sales teams",
        "description": "Analyze a branded template, select suitable layouts, replace placeholders, and create a reusable presentation workflow."
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Basic Deck",
        "scenario": "Beginner request for a new presentation.",
        "prompt": "Create a 6-slide PowerPoint presentation about [topic] for [audience]. Use clear headings, concise bullets, and a professional visual style."
      },
      {
        "title": "Analyze an Existing Deck",
        "scenario": "Review content and design before editing.",
        "prompt": "Analyze this PPTX file. Summarize the slide structure, main messages, design patterns, fonts, colors, notes, and any visible layout problems."
      },
      {
        "title": "Edit and Validate a Presentation",
        "scenario": "Modify a deck while preserving its structure.",
        "prompt": "Edit this presentation by applying these changes: [changes]. Preserve the original design, validate the PPTX, and generate thumbnails for review."
      },
      {
        "title": "Create a Template-Driven Deck",
        "scenario": "Advanced workflow using an existing template.",
        "prompt": "Use this PowerPoint template to create a new deck from [content]. Inventory all layouts, choose matching slides, replace placeholders, validate, and inspect thumbnails."
      }
    ],
    "output_examples": [
      {
        "input": "Create a quarterly business review deck from these metrics and notes.",
        "output": "A PowerPoint file with an executive summary, performance slides, charts, risks, next steps, and a thumbnail grid for visual review."
      },
      {
        "input": "Update this sales deck with new product messaging and speaker notes.",
        "output": "An edited PPTX that preserves the template, replaces outdated copy, updates notes, validates the package, and highlights any layout issues."
      },
      {
        "input": "Analyze this presentation for structure and visual consistency.",
        "output": "A concise review covering slide order, repeated layouts, typography, color usage, content gaps, and recommended fixes."
      }
    ],
    "best_practices": [
      "Start by identifying whether the task is creation, editing, template use, or analysis.",
      "Generate thumbnails after changes and inspect for overlap, cutoff text, and contrast issues.",
      "Validate OOXML edits after each meaningful change before packing the final presentation."
    ],
    "anti_patterns": [
      "Do not edit raw XML without validating the presentation package afterward.",
      "Do not rely on unsupported fonts, CSS gradients, or manual bullet symbols in HTML slides.",
      "Do not overwrite important source presentations before confirming the generated output."
    ],
    "faq": [
      {
        "question": "Can this skill create a new PowerPoint file?",
        "answer": "Yes. It can create PPTX files from HTML slides and add charts, tables, images, and styled text."
      },
      {
        "question": "Can it edit an existing presentation?",
        "answer": "Yes. It supports OOXML workflows for editing slide content, notes, comments, layouts, media, and package metadata."
      },
      {
        "question": "Does it preserve branded templates?",
        "answer": "It can analyze a template, inventory slide layouts, choose matching layouts, and replace placeholder content."
      },
      {
        "question": "How does it check visual quality?",
        "answer": "It can generate thumbnail grids so the user can review layout, text overflow, alignment, and contrast."
      },
      {
        "question": "What local tools may be needed?",
        "answer": "Some workflows use Python, Node.js, Playwright or Chromium, LibreOffice, Sharp, and PowerPoint-related helper scripts."
      },
      {
        "question": "Is it safe to publish?",
        "answer": "Yes. This official skill uses expected local file and conversion workflows, with no confirmed malicious findings."
      }
    ]
  },
