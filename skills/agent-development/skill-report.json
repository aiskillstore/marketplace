      },
      {
        "title": "Review Agent Quality",
        "description": "Check whether an existing agent uses specific triggers, focused tools, and usable output expectations.",
        "target_user": "Technical reviewer"
      },
      {
        "title": "Standardize Agent Patterns",
        "description": "Build repeatable agent templates for teams that maintain multiple Claude Code plugins.",
        "target_user": "Platform engineering team"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Basic Agent",
        "scenario": "Beginner request for a new agent.",
        "prompt": "Create a Claude Code plugin agent for reviewing pull requests. Include the name, description examples, model, color, tools, and system prompt."
      },
      {
        "title": "Improve Agent Triggering",
        "scenario": "Intermediate refinement of an existing agent.",
        "prompt": "Review this agent description and improve the triggering examples. Make the conditions specific, include when not to use it, and preserve intent."
      },
      {
        "title": "Restrict Agent Tools",
        "scenario": "Advanced safety review for tool access.",
        "prompt": "Audit this agent for least-privilege tool access. Recommend the minimum tools needed and explain any tradeoffs for validation or testing."
      },
      {
        "title": "Design an Agent Set",
        "scenario": "Advanced plugin architecture work.",
        "prompt": "Design three coordinated Claude Code plugin agents for code review, test generation, and release notes. Define distinct triggers, colors, tools, and responsibilities."
      }
    ],
    "output_examples": [
      {
        "input": "Create an agent that writes API documentation from source files.",
        "output": "A complete agent plan with a hyphenated identifier, trigger examples, selected tools, model choice, color, and a structured documentation-focused system prompt."
      },
      {
        "input": "Validate whether my test-generator agent is ready.",
        "output": [
          "The agent has valid frontmatter and a focused name.",
          "The description needs more concrete trigger examples.",
          "The tool list should remove write access if the agent only reports suggestions."
        ]
      },
      {
        "input": "Help me make my security-review agent more reliable.",
        "output": "A revised triggering strategy, stricter tool recommendations, clearer analysis steps, and output expectations that separate findings from assumptions."
      }
    ],
    "best_practices": [
      "Use two to four concrete triggering examples in every agent description.",
      "Limit agent tools to the minimum needed for the assigned task.",
      "Define responsibilities, process steps, quality standards, and output format in the system prompt."
    ],
    "anti_patterns": [
      "Do not use generic agent names such as helper or assistant.",
      "Do not omit trigger examples from the description field.",
      "Do not grant broad tool access when read-only tools are enough."
    ],
    "faq": [
      {
        "question": "What does this skill help me build?",
        "answer": "It helps create Claude Code plugin agents with valid metadata, useful triggers, and structured system prompts."
      },
      {
        "question": "Does it generate complete agent files?",
        "answer": "Yes. It provides patterns and examples that can be used to draft complete markdown agent files."
      },
      {
        "question": "Can it validate an existing agent?",
        "answer": "Yes. It includes validation guidance and a shell script for common structure and quality checks."
      },
      {
        "question": "Which tools should an agent receive?",
        "answer": "Use the smallest tool set needed. Read-only analysis usually needs Read, Grep, and Glob."
      },
      {
        "question": "Should every agent use the same model?",
        "answer": "No. The recommended default is inherit, unless the agent needs a specific model capability."
      },
      {
        "question": "Is this skill only for Claude Code?",
        "answer": "Its conventions target Claude Code plugin agents, but the prompt design guidance can inform Codex and Claude workflows."
      }
