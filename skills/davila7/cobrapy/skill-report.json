  "content": {
    "user_title": "Analyze Metabolic Models with COBRApy",
    "value_statement": "Metabolic model analysis often requires exact COBRApy patterns for FBA, FVA, knockouts, sampling, and SBML files. This skill gives Claude, Codex, and Claude Code focused guidance for reproducible systems biology workflows.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "COBRApy",
      "constraint-based modeling",
      "flux balance analysis",
      "metabolic engineering",
      "systems biology",
      "SBML models",
      "gene knockout analysis"
    ],
    "actual_capabilities": [
      "Explains how to load and save COBRApy models in SBML, JSON, YAML, and MATLAB formats.",
      "Provides FBA, parsimonious FBA, geometric FBA, and FVA usage patterns.",
      "Guides single and double gene or reaction deletion studies.",
      "Shows media design, minimal media calculation, and boundary condition workflows.",
      "Covers flux sampling, production envelopes, gapfilling, and model validation checks.",
      "Summarizes common COBRApy APIs, model objects, and context-manager patterns."
    ],
    "limitations": [
      "Does not include runnable automation scripts or packaged command-line tools.",
      "Requires COBRApy and compatible solvers to be installed in the user environment.",
      "Example results depend on the selected model, solver, and biological assumptions.",
      "Does not replace expert review of metabolic model quality or experimental design."
    ],
    "use_cases": [
      {
        "title": "Screen Essential Genes",
        "description": "Plan single and double knockout studies, classify growth effects, and summarize synthetic lethal candidates.",
        "target_user": "Systems biology researcher"
      },
      {
        "title": "Design Growth Media",
        "description": "Compare aerobic and anaerobic media, calculate minimal components, and test custom uptake constraints.",
        "target_user": "Metabolic engineer"
      },
      {
        "title": "Validate Metabolic Models",
        "description": "Check feasibility, blocked reactions, mass balance, dead-end metabolites, duplicate reactions, and loop behavior.",
        "target_user": "Computational biology student"
      }
    ],
    "prompt_templates": [
      {
        "title": "Load and Optimize a Model",
        "scenario": "Beginner FBA workflow",
        "prompt": "Use the COBRApy skill to show me how to load an E. coli model, run FBA, check solution status, and interpret growth rate."
      },
      {
        "title": "Compare Media Conditions",
        "scenario": "Intermediate media analysis",
        "prompt": "Guide me through comparing aerobic and anaerobic growth media in COBRApy, including minimal media and limiting nutrient checks."
      },
      {
        "title": "Run Knockout Analysis",
        "scenario": "Intermediate genetic perturbation study",
        "prompt": "Help me design a COBRApy single and double gene deletion analysis that identifies essential genes and synthetic lethal pairs."
      },
      {
        "title": "Build a Production Strain Workflow",
