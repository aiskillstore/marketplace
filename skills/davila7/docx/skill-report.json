  "content": {
    "user_title": "Create and Edit DOCX Documents",
    "value_statement": "DOCX editing often requires careful OOXML handling to preserve formatting, comments, and tracked changes. This skill gives Claude, Codex, and Claude Code structured workflows for document creation, review, conversion, and validation.",
    "seo_keywords": [
      "Claude DOCX editing",
      "Codex DOCX workflow",
      "Claude Code Word documents",
      "OOXML editing",
      "tracked changes",
      "document comments",
      "Word document automation",
      "DOCX validation",
      "office document review",
      "pandoc DOCX conversion"
    ],
    "actual_capabilities": [
      "Create new DOCX files with the docx JavaScript library.",
      "Extract DOCX text to markdown with tracked change options.",
      "Unpack Office files for raw OOXML inspection and editing.",
      "Add or review comments and tracked changes in Word documents.",
      "Repack edited OOXML folders into DOCX, PPTX, or XLSX files.",
      "Validate document structure using bundled OOXML validation helpers."
    ],
    "limitations": [
      "Requires local tools such as pandoc, LibreOffice, Poppler, Node packages, and Python dependencies.",
      "Unsafe archive extraction must be fixed before broad marketplace publishing.",
      "Complex Word formatting can still require manual OOXML inspection.",
      "The skill does not replace legal, editorial, or compliance review by a qualified person."
    ],
    "use_cases": [
      {
        "title": "Legal Document Review",
        "target_user": "Legal teams",
        "description": "Prepare tracked changes, comments, and verification steps for contracts or policy documents."
      },
      {
        "title": "Technical Report Production",
        "target_user": "Researchers and analysts",
        "description": "Generate structured Word documents from planned sections, tables, and supporting content."
      },
      {
        "title": "Office File Troubleshooting",
        "target_user": "Operations teams",
        "description": "Inspect raw OOXML, validate document parts, and repair common packaging or XML issues."
      }
    ],
    "prompt_templates": [
      {
        "title": "Extract Text",
        "scenario": "Beginner document inspection",
        "prompt": "Use the DOCX workflow to extract the text from this Word document and summarize its headings, comments, and tracked changes."
      },
      {
        "title": "Create a Document",
        "scenario": "New Word file creation",
        "prompt": "Create a DOCX file from this outline. Include headings, body sections, a table, and a short appendix."
      },
      {
        "title": "Edit With Tracked Changes",
        "scenario": "Professional document review",
        "prompt": "Review this DOCX and apply the requested revisions as tracked changes. Preserve unchanged formatting and add comments where clarification is needed."
      },
      {
        "title": "Inspect and Repair OOXML",
        "scenario": "Advanced document debugging",
        "prompt": "Unpack this DOCX, inspect the relevant OOXML parts, identify the structural problem, repair it, repack the file, and verify the result."
      }
    ],
    "output_examples": [
      {
        "input": "A contract DOCX with requested date, party name, and termination clause revisions.",
        "output": "A reviewed Word document with precise tracked changes, reviewer comments, and a short verification summary."
      },
      {
        "input": "A technical outline with sections, bullets, and table requirements.",
        "output": "A formatted DOCX report with headings, paragraphs, tables, and consistent document structure."
      },
      {
        "input": "A DOCX file that fails validation after manual editing.",
        "output": "A repaired document package plus a concise explanation of the affected OOXML part."
      }
    ],
    "best_practices": [
      "Work on copies of source documents and keep the original file unchanged.",
      "Use tracked changes for legal, academic, business, and government documents.",
      "Validate and visually inspect final DOCX output before sharing it."
    ],
    "anti_patterns": [
      "Do not process untrusted Office files without sandboxing and safe archive extraction.",
      "Do not replace whole paragraphs when only a few words changed.",
      "Do not rely on markdown line numbers to locate OOXML edits."
    ],
    "faq": [
      {
        "question": "Can this skill create new Word documents?",
        "answer": "Yes. It uses the docx JavaScript library workflow to create structured DOCX files."
      },
      {
        "question": "Can it preserve tracked changes?",
        "answer": "Yes. The skill includes workflows for reading, creating, and verifying tracked changes."
      },
      {
        "question": "Does it require external software?",
        "answer": "Yes. Some workflows require tools such as pandoc, LibreOffice, Poppler, Python packages, and Node packages."
      },
      {
        "question": "Is it safe for untrusted DOCX files?",
        "answer": "Not without additional controls. The audit confirmed unsafe archive extraction that should be fixed first."
      },
      {
        "question": "Can it edit comments in Word documents?",
        "answer": "Yes. The included OOXML workflows cover comments, comment metadata, and related document parts."
      },
      {
        "question": "Does it support Claude, Codex, and Claude Code?",
        "answer": "Yes. The report lists Claude, Codex, and Claude Code as supported tools."
      }
    ]
  },
