  "content": {
    "user_title": "Build Survival Models with scikit-survival",
    "value_statement": "Survival analysis requires methods that handle censored time-to-event data. This skill guides Claude, Codex, and Claude Code through scikit-survival modeling, evaluation, and competing risks.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "scikit-survival",
      "survival analysis",
      "time-to-event modeling",
      "Cox model",
      "censored data",
      "competing risks",
      "Python survival models"
    ],
    "actual_capabilities": [
      "Explains when to use Cox, Coxnet, ensemble, and Survival SVM models.",
      "Guides creation and validation of structured survival outcomes.",
      "Recommends preprocessing steps for censored survival datasets.",
      "Compares survival metrics such as concordance, Brier score, and time-dependent AUC.",
      "Provides workflows for competing risks and cumulative incidence analysis.",
      "Helps select model families based on interpretability, sample size, and nonlinearity."
    ],
    "limitations": [
      "It is guidance only and does not install or run scikit-survival.",
      "It does not validate real clinical decisions or regulatory compliance.",
      "It assumes the user provides appropriate data definitions and event coding.",
      "It cannot replace statistical review for study design or causal claims."
    ],
    "use_cases": [
      {
        "title": "Prepare Clinical Survival Data",
        "description": "Create event and time fields, check censoring, encode features, and choose preprocessing steps before modeling.",
        "target_user": "Clinical data scientist"
      },
      {
        "title": "Compare Survival Model Families",
        "description": "Evaluate Cox models, random survival forests, gradient boosting, and Survival SVMs for a prediction task.",
        "target_user": "Machine learning engineer"
      },
      {
        "title": "Evaluate Time-to-Event Predictions",
        "description": "Select concordance, Brier score, and time-dependent AUC metrics for censored test data.",
        "target_user": "Research statistician"
      }
    ],
    "prompt_templates": [
      {
        "title": "Choose a Survival Workflow",
        "scenario": "Beginner planning a first analysis.",
        "prompt": "Help me plan a scikit-survival workflow for censored time-to-event data. Ask for event coding, time fields, censoring rate, and prediction goal."
      },
      {
        "title": "Prepare Survival Data",
        "scenario": "Intermediate data preparation.",
        "prompt": "Review my survival dataset design. Identify validation checks, missing-data handling, encoding steps, and how to build the structured outcome."
      },
      {
        "title": "Compare Model Options",
        "scenario": "Model selection for an applied project.",
        "prompt": "Compare CoxPH, Coxnet, Random Survival Forest, Gradient Boosting, and Survival SVM for my dataset size, feature count, and interpretability needs."
      },
      {
        "title": "Design Advanced Evaluation",
        "scenario": "Advanced model validation.",
        "prompt": "Design a survival model evaluation plan using concordance, IPCW metrics, Brier score, time-dependent AUC, calibration checks, and competing risks considerations."
      }
    ],
    "output_examples": [
      {
        "input": "I have right-censored patient follow-up data and need a first model.",
        "output": [
          "Recommended start: validate event coding and follow-up time before modeling.",
          "Use a Cox model first when interpretability matters and proportional hazards is plausible.",
          "Compare with an ensemble model if nonlinear effects are expected."
        ]
      },
      {
        "input": "My censoring rate is high and I need reliable model comparison.",
        "output": [
          "Use IPCW-aware metrics instead of relying only on Harrell concordance.",
          "Report performance at clinically meaningful time horizons.",
          "Check whether censoring distributions differ between training and test data."
        ]
      },
      {
        "input": "Some patients can relapse or die before relapse.",
        "output": [
          "Treat relapse and death as competing events when the event types are mutually exclusive.",
          "Estimate cumulative incidence for each event type.",
          "Avoid treating competing events as ordinary censoring without justification."
        ]
      }
    ],
    "best_practices": [
      "Define event indicators and time units before choosing a model.",
      "Use censoring-aware validation metrics that match the prediction goal.",
      "Compare interpretable and flexible models before selecting a final workflow."
    ],
    "anti_patterns": [
      "Do not treat all non-target competing events as censoring without review.",
      "Do not use standard classification metrics for censored survival outcomes.",
      "Do not skip feature scaling for SVMs or regularized Cox models."
    ],
    "faq": [
      {
        "question": "What is scikit-survival used for?",
        "answer": "It supports survival analysis and time-to-event prediction with censored data in Python."
      },
      {
        "question": "Can this skill choose the right model?",
        "answer": "It can guide model selection based on data size, feature count, interpretability, and expected nonlinear effects."
      },
      {
        "question": "Does it run code automatically?",
        "answer": "No. The skill provides guidance and examples for scikit-survival workflows."
      },
      {
        "question": "Does it support competing risks?",
        "answer": "Yes. It explains cumulative incidence functions and when competing risks methods are appropriate."
      },
      {
        "question": "Which metrics does it cover?",
        "answer": "It covers concordance, IPCW concordance, Brier score, integrated Brier score, and time-dependent AUC."
      },
      {
        "question": "Is it suitable for clinical decisions?",
        "answer": "It can support analysis planning, but clinical use needs expert review, validation, and governance."
      }
    ]
