  "content": {
    "user_title": "Create SEO Content With Brand Voice Checks",
    "value_statement": "Marketing teams need content that matches brand voice and search intent. This skill provides analyzers, templates, and platform guidance for repeatable content production.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "SEO content creation",
      "brand voice analyzer",
      "content marketing templates",
      "social media optimization",
      "blog post optimization",
      "marketing copywriting",
      "content calendar planning"
    ],
    "actual_capabilities": [
      "Analyzes brand voice signals such as formality, tone, and perspective.",
      "Scores SEO structure, readability, keyword density, headings, links, and paragraph length.",
      "Suggests meta titles, meta descriptions, and URL slugs from content and keywords.",
      "Provides templates for blog posts, emails, social posts, videos, and calendars.",
      "Documents platform guidance for LinkedIn, X, Instagram, Facebook, and TikTok.",
      "Supports local text analysis through two Python scripts."
    ],
    "limitations": [
      "Does not publish or schedule content on external platforms.",
      "Does not perform live keyword research or competitor analysis through APIs.",
      "Does not verify factual accuracy or legal compliance automatically.",
      "Reads local files only when users pass file paths to the scripts."
    ],
    "use_cases": [
      {
        "title": "Plan Search-Focused Blog Content",
        "description": "Build article outlines, check keyword placement, and improve structure before publication.",
        "target_user": "Content marketers"
      },
      {
        "title": "Adapt Campaigns Across Channels",
        "description": "Turn one message into platform-specific posts, captions, email copy, and video scripts.",
        "target_user": "Social media managers"
      },
      {
        "title": "Maintain Brand Voice",
        "description": "Review drafts for tone, formality, readability, and consistency with brand guidelines.",
        "target_user": "Brand managers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Draft a Blog Outline",
        "scenario": "Beginner content planning",
        "prompt": "Use Content Creator to outline a blog post about [topic] for [audience]. Include title ideas, H2 sections, and a clear call to action."
      },
      {
        "title": "Optimize an Existing Article",
        "scenario": "Intermediate SEO review",
        "prompt": "Use Content Creator to review [file] for the primary keyword [keyword]. Summarize SEO issues, readability issues, and priority edits."
      },
      {
        "title": "Repurpose a Campaign Message",
        "scenario": "Cross-channel content production",
        "prompt": "Use Content Creator to adapt this campaign message for LinkedIn, X, Instagram, email, and a short video script: [message]."
      },
      {
        "title": "Build a Monthly Content System",
        "scenario": "Advanced content operations",
        "prompt": "Use Content Creator to create a monthly calendar for [brand]. Include content pillars, channel mix, SEO targets, review steps, and performance metrics."
      }
    ],
    "output_examples": [
      {
        "input": "Create a LinkedIn post from a blog about remote work productivity.",
        "output": [
          "A strong opening line for professional readers.",
          "A short context paragraph that frames the problem.",
          "Three practical insights with clear outcomes.",
          "A closing question that encourages comments.",
          "Three to five relevant hashtags."
        ]
      },
      {
        "input": "Review an article for the keyword content marketing strategy.",
        "output": [
          "SEO score with the main improvement areas.",
          "Keyword placement notes for title, opening, and headings.",
          "Structure feedback for headings, paragraphs, and links.",
          "Readability level and sentence length guidance.",
          "Meta title and description suggestions."
        ]
      },
      {
        "input": "Check whether this launch email matches our brand voice.",
        "output": [
          "Voice profile covering formality, tone, and perspective.",
          "Readability observations for the intended audience.",
          "Sentence variety notes.",
          "Specific edits to improve brand consistency."
        ]
      }
    ],
    "best_practices": [
      "Start with audience needs, search intent, and one primary keyword before drafting.",
      "Run voice and SEO checks before publishing important content.",
      "Use platform-specific templates when repurposing content across channels."
    ],
    "anti_patterns": [
      "Do not treat SEO scores as a substitute for expert editorial review.",
      "Do not force keywords into copy when readability or trust declines.",
      "Do not pass private or sensitive files to local analyzer scripts."
    ],
    "faq": [
      {
        "question": "Which tools can use this skill?",
        "answer": "It is listed for Claude, Codex, and Claude Code."
      },
      {
        "question": "Does it send content to external services?",
