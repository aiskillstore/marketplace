  "content": {
    "user_title": "Create and Edit PowerPoint Presentations",
    "value_statement": "PowerPoint work often requires layout control, file inspection, and reliable validation. This skill gives Claude, Codex, and Claude Code structured workflows for creating, editing, and reviewing PPTX files.",
    "seo_keywords": [
      "Claude PowerPoint skill",
      "Codex PPTX editing",
      "Claude Code presentation workflow",
      "PowerPoint automation",
      "PPTX generation",
      "OOXML editing",
      "slide thumbnail validation",
      "html2pptx",
      "presentation analysis",
      "Office document workflow"
    ],
    "actual_capabilities": [
      "Creates new PPTX files from HTML slide layouts using a documented html2pptx workflow.",
      "Edits existing presentations by unpacking PPTX files and modifying Office Open XML parts.",
      "Extracts presentation text through markdown conversion for review and analysis.",
      "Validates edited Office files before repacking to reduce corrupt output.",
      "Generates thumbnail grids so slide layout, text overflow, and contrast can be inspected.",
      "Supports template-based slide selection through inventory and visual review steps."
    ],
    "limitations": [
      "Requires local tools such as Python, Node packages, LibreOffice, and Poppler for full workflows.",
      "Raw OOXML editing is complex and can corrupt files if validation steps are skipped.",
      "It does not provide a graphical PowerPoint editor inside the AI tool.",
      "Processing untrusted Office files needs sandboxing because helper scripts unpack archives and run converters."
    ],
    "use_cases": [
      {
        "title": "Build a New Presentation",
        "target_user": "Consultants and analysts",
        "description": "Generate a polished slide deck from an outline, with controlled typography, colors, charts, and layout validation."
      },
      {
        "title": "Update an Existing Deck",
        "target_user": "Product and operations teams",
        "description": "Modify text, speaker notes, comments, or slide structure by editing the underlying PPTX XML safely."
      },
      {
        "title": "Audit Slide Quality",
        "target_user": "Design reviewers",
        "description": "Create thumbnail grids and inspect slides for overflow, overlap, missing content, and weak contrast."
      }
    ],
    "prompt_templates": [
      {
        "title": "Summarize a Deck",
        "scenario": "Beginner analysis request",
        "prompt": "Review this PPTX file. Extract the main message, list the slide titles, and identify any slides that need clearer wording."
      },
      {
        "title": "Create a Basic Deck",
        "scenario": "New presentation from an outline",
        "prompt": "Create a 10-slide PowerPoint presentation from this outline. Use a clear visual hierarchy, speaker-friendly slide titles, and a consistent color palette."
      },
      {
        "title": "Edit a Template Deck",
        "scenario": "Template-based production",
        "prompt": "Use this template PPTX to create a client-ready deck. Inventory the template layouts, choose suitable slides, replace placeholders, and validate the final file."
      },
      {
        "title": "Repair and Validate OOXML",
        "scenario": "Advanced file correction",
        "prompt": "Unpack this PPTX, inspect the OOXML for slide and relationship issues, make the required repair, validate after each edit, and repack the presentation."
      }
    ],
    "output_examples": [
      {
        "input": "Create a quarterly business review deck from these notes.",
        "output": "A structured PowerPoint deck with title, agenda, performance summary, metric slides, risks, and next steps."
      },
      {
        "input": "Check this template and choose slides for a product launch story.",
        "output": [
          "Template inventory with slide purposes",
          "Recommended slide sequence",
          "Updated presentation using selected layouts"
        ]
      },
      {
        "input": "Find visual problems in this presentation.",
        "output": "A thumbnail-based review that flags crowded slides, text cutoff, contrast problems, and inconsistent layout choices."
      }
    ],
    "best_practices": [
      "Work on a copy of the original PPTX before unpacking or editing XML files.",
      "Validate after each OOXML change instead of waiting until the final repack.",
      "Review thumbnail output before delivery to catch layout and readability problems."
    ],
    "anti_patterns": [
      "Do not skip validation when editing raw PPTX XML.",
      "Do not process untrusted Office files outside a sandboxed workspace.",
      "Do not rely only on extracted text when visual layout quality matters."
    ],
    "faq": [
      {
        "question": "Can this skill create PowerPoint files from scratch?",
        "answer": "Yes. It documents an HTML-to-PPTX workflow for creating slides with precise layout control."
      },
      {
        "question": "Can it edit existing PPTX files?",
        "answer": "Yes. It uses Office Open XML workflows to unpack, modify, validate, and repack presentations."
      },
      {
        "question": "Does it require Microsoft PowerPoint?",
        "answer": "No. The workflows use Python, Node.js libraries, LibreOffice, Poppler, and OOXML file operations."
      },
      {
        "question": "Is it safe to use with unknown PPTX files?",
        "answer": "Use caution. The audit found unsafe ZIP extraction patterns, so untrusted files should be processed in a sandbox."
      },
      {
        "question": "Can it check slide visuals?",
        "answer": "Yes. It can generate thumbnail grids for visual review of layout, contrast, and text overflow."
      },
      {
        "question": "Can it preserve a company template?",
        "answer": "Yes. It includes workflows for inventorying template slides and choosing layouts that match new content."
      }
    ]
  },
