  "content": {
    "user_title": "Prepare Venue-Ready Research Documents",
    "value_statement": "Researchers waste time adapting manuscripts, posters, and grants to venue rules. This skill provides LaTeX templates, requirements, and helper scripts for common academic submissions.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "LaTeX templates",
      "academic writing",
      "journal submission",
      "conference paper formatting",
      "grant proposal template",
      "research poster template",
      "venue formatting guidelines"
    ],
    "actual_capabilities": [
      "Provides LaTeX templates for selected journals, conferences, posters, and grant proposals.",
      "Lists formatting requirements for venues such as Nature, PLOS, NeurIPS, NSF, and NIH.",
      "Helps customize template placeholders for title, authors, affiliations, and email.",
      "Searches bundled template metadata by venue, document type, or keyword.",
      "Checks basic PDF page count and font information with local PDF utilities."
    ],
    "limitations": [
      "Venue requirements may change, so users must verify current official instructions.",
      "PDF margin validation is limited and may require manual review.",
      "The bundled templates cover common venues, not every journal, conference, or funder.",
      "Helper scripts require local Python and optional PDF utilities such as pdfinfo and pdffonts."
    ],
    "use_cases": [
      {
        "title": "Format a journal manuscript",
        "description": "Select a venue template, review submission rules, and prepare a manuscript draft with correct sections.",
        "target_user": "Graduate student"
      },
      {
        "title": "Prepare a conference paper",
        "description": "Check page limits, anonymization requirements, citation style, and LaTeX structure before submission.",
        "target_user": "Machine learning researcher"
      },
      {
        "title": "Start a grant proposal",
        "description": "Use agency-specific sections and formatting constraints to structure an NSF or NIH proposal draft.",
        "target_user": "Principal investigator"
      }
    ],
    "prompt_templates": [
      {
        "title": "Find a Venue Template",
        "scenario": "Beginner request for a known venue.",
        "prompt": "Find the best bundled template for a Nature manuscript. Summarize the key formatting requirements and tell me which files to use."
      },
      {
        "title": "Compare Submission Requirements",
        "scenario": "Intermediate request comparing venues.",
        "prompt": "Compare the formatting requirements for PLOS ONE and Nature. Focus on length, citation style, figures, and required sections."
      },
      {
        "title": "Customize a Draft Template",
        "scenario": "Intermediate request with project details.",
        "prompt": "Help me customize the NeurIPS template for my paper. Title: Efficient Protein Design. Authors: Jane Lee and Omar Patel. Keep it anonymous where required."
      },
      {
        "title": "Audit a Submission Package",
        "scenario": "Advanced request before submission.",
        "prompt": "Review my planned NSF proposal structure against the bundled requirements. Identify missing sections, page-limit risks, and formatting checks before submission."
      }
    ],
    "output_examples": [
      {
        "input": "I need to submit a short manuscript to Nature.",
        "output": [
          "Recommended template: Nature article template.",
          "Key checks: short main text, numbered citations, high-resolution figures, and concise methods references.",
          "Next action: verify current Nature author instructions before final submission."
        ]
      },
      {
        "input": "Help me prepare an NIH Specific Aims page.",
        "output": [
          "Recommended template: NIH Specific Aims page.",
          "Suggested structure: opening problem statement, central hypothesis, three aims, and final impact paragraph.",
          "Constraint: keep the page focused and verify the latest NIH page rules."
        ]
      },
      {
        "input": "Check my conference paper for NeurIPS formatting risks.",
        "output": [
          "Review page count, two-column layout, anonymization, and citation formatting.",
          "Use the local PDF validation helper for basic page and font checks.",
          "Manual review is still needed for margins, figures, and supplemental material rules."
        ]
      }
    ],
    "best_practices": [
      "Verify current official venue guidelines before final submission.",
      "Keep the original bundled template unchanged and write customized copies to a project folder.",
      "Run basic PDF checks early, then complete a manual compliance review before submission."
    ],
    "anti_patterns": [
      "Do not assume bundled requirements are current for a live deadline.",
      "Do not overwrite source templates when adding project-specific content.",
      "Do not rely only on automated checks for margins, figures, anonymization, or submission files."
    ],
    "faq": [
      {
        "question": "Does this skill include official venue templates?",
        "answer": "It includes bundled LaTeX templates and reference guidance. Users should still compare them with official venue instructions."
      },
      {
        "question": "Can it validate a finished PDF automatically?",
        "answer": "It can run basic page and font checks with local utilities. It does not fully validate every venue rule."
      },
      {
        "question": "Which document types are supported?",
        "answer": "The skill covers journal articles, conference papers, research posters, and grant proposals."
      },
      {
        "question": "Does it send files to external services?",
        "answer": "No evidence of outbound file upload or network requests was found in the reviewed helper scripts."
      },
      {
        "question": "Can I use it with Claude, Codex, and Claude Code?",
        "answer": "Yes. The report lists Claude, Codex, and Claude Code as supported tools."
      },
      {
        "question": "What should I check manually?",
        "answer": "Check current venue rules, page limits, anonymization, figure requirements, and final submission package contents."
      }
    ]
