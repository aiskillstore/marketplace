  "content": {
    "user_title": "Analyze Mass Spectrometry Data with matchms",
    "value_statement": "Mass spectrometry workflows often need careful file handling, metadata cleanup, and repeatable similarity scoring. This skill guides Claude, Codex, and Claude Code through matchms workflows for metabolomics and MS data analysis.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "matchms",
      "mass spectrometry",
      "metabolomics",
      "spectral similarity",
      "MGF processing",
      "mzML analysis",
      "compound identification"
    ],
    "actual_capabilities": [
      "Explains how to import mzML, mzXML, MGF, MSP, JSON, USI, and pickle spectrum data.",
      "Guides metadata harmonization for precursor mass, ion mode, compound names, SMILES, InChI, and InChIKey fields.",
      "Builds preprocessing pipelines with default filters, intensity normalization, peak selection, and quality checks.",
      "Compares spectra with CosineGreedy, CosineHungarian, ModifiedCosine, NeutralLossesCosine, and metadata-based matching.",
      "Helps design reusable matchms workflows for library matching, format conversion, and compound identification reports.",
      "Summarizes when to use structural fingerprints and precursor mass filters before full spectral scoring."
    ],
    "limitations": [
      "It provides guidance and examples; it does not include the matchms Python package itself.",
      "It depends on user-supplied spectra and local Python environments with required scientific libraries installed.",
      "Chemical enrichment may require optional chemistry dependencies and may contact external services such as PubChem.",
      "Pickle workflows must be limited to trusted files because untrusted pickle data is unsafe to load."
    ],
    "use_cases": [
      {
        "title": "Identify Unknown Metabolites",
        "description": "Match query spectra against a reference library and rank likely compound matches with cosine-based scores.",
        "target_user": "Metabolomics researcher"
      },
      {
        "title": "Standardize Spectral Libraries",
        "description": "Clean metadata, normalize peaks, validate precursor values, and export consistent files for downstream analysis.",
        "target_user": "Data curator"
      },
      {
        "title": "Build Repeatable MS Pipelines",
        "description": "Create reusable processing steps for large datasets, format conversion, quality control, and reporting.",
        "target_user": "Scientific Python developer"
      }
    ],
    "prompt_templates": [
      {
        "title": "Load My Spectrum Files",
        "scenario": "Beginner import guidance",
        "prompt": "Help me load MGF and mzML files with matchms. Explain which importer to use and how to keep memory use reasonable."
      },
      {
        "title": "Clean and Filter Spectra",
        "scenario": "Quality control workflow",
        "prompt": "Design a matchms preprocessing workflow for MS2 spectra with metadata harmonization, intensity normalization, precursor checks, and peak filtering."
      },
      {
        "title": "Compare Unknowns to a Library",
        "scenario": "Spectral matching workflow",
        "prompt": "Plan a matchms workflow that compares unknown spectra against a reference library using CosineGreedy and ModifiedCosine scores."
      },
      {
        "title": "Create a Multi-Metric Report",
        "scenario": "Advanced compound identification",
        "prompt": "Build an advanced compound identification plan using spectral similarity, precursor mass filtering, molecular fingerprints, and ranked reporting."
      }
    ],
    "output_examples": [
      {
        "input": "User asks how to process a raw mzML file and export a cleaned MGF file.",
        "output": "A step-by-step workflow naming the correct importer, recommended filters, quality checks, and export format choices."
      },
      {
        "input": "User asks which similarity score to use for related compounds with different precursor masses.",
        "output": "A comparison of CosineGreedy, ModifiedCosine, and NeutralLossesCosine with a recommendation for shifted precursor matching."
      },
      {
        "input": "User asks how to prepare a reusable library matching pipeline.",
        "output": "A concise pipeline design covering preprocessing, library and query consistency, threshold selection, ranking, and report fields."
      }
    ],
    "best_practices": [
      "Apply the same preprocessing steps to query spectra and reference spectra before comparing scores.",
      "Use precursor mass filtering before expensive similarity scoring on large spectral libraries.",
      "Keep raw files, processed exports, parameters, and score thresholds documented for reproducibility."
    ],
    "anti_patterns": [
      "Do not load untrusted pickle files, even if they appear to contain spectrum objects.",
      "Do not compare raw spectra to filtered spectra without normalizing the processing pipeline.",
      "Do not rely on one similarity score without checking precursor metadata and peak quality."
    ],
    "faq": [
      {
        "question": "What is matchms used for?",
        "answer": "Matchms is used to process mass spectra, clean metadata, filter peaks, and compare spectra for metabolomics analysis."
      },
      {
        "question": "Which file formats does this skill cover?",
        "answer": "It covers mzML, mzXML, MGF, MSP, JSON, USI references, and pickle-based intermediate files."
      },
      {
        "question": "Can it identify unknown compounds automatically?",
        "answer": "It can guide workflows that rank candidate matches, but final identification still requires expert validation."
      },
      {
        "question": "Does it need optional chemistry dependencies?",
        "answer": "Some workflows need chemistry tools such as RDKit for SMILES, InChI, and molecular fingerprint operations."
      },
      {
        "question": "Is network access required?",
        "answer": "Most local workflows do not require network access, but annotation lookup and external references may contact online services."
      },
      {
        "question": "Is pickle safe for spectrum data?",
        "answer": "Pickle is safe only for trusted files. Do not load pickle data from unknown or unverified sources."
      }
    ]
