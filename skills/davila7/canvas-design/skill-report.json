  "content": {
    "user_title": "Create Canvas-Ready Visual Designs",
    "value_statement": "Static design requests often lack a clear visual system before production starts. This skill creates a design philosophy, then turns it into polished PNG or PDF artwork with careful typography and composition.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "canvas design",
      "poster design",
      "visual art skill",
      "PDF design output",
      "PNG artwork",
      "typography workflow",
      "AI design assistant"
    ],
    "actual_capabilities": [
      "Creates a written visual philosophy before producing artwork.",
      "Generates single-page PNG or PDF design artifacts by default.",
      "Uses bundled font files from the canvas-fonts directory.",
      "Guides sparse typography, spacing, margins, and visual hierarchy.",
      "Supports multi-page visual sequences when the user asks for them.",
      "Produces a markdown philosophy file alongside the final visual output."
    ],
    "limitations": [
      "It is best for static visual artifacts, not interactive interfaces.",
      "It may need a rendering tool available in the host environment.",
      "External font downloads should be approved or limited to trusted sources.",
      "It does not guarantee brand or copyright clearance for user-provided references."
    ],
    "use_cases": [
      {
        "title": "Create Event Posters",
        "description": "Turn a short event brief into a refined poster with strong visual direction and minimal text.",
        "target_user": "Designers and creative teams"
      },
      {
        "title": "Develop Concept Artifacts",
        "description": "Explore an abstract mood, theme, or cultural reference as a polished static artwork.",
        "target_user": "Artists and creative directors"
      },
      {
        "title": "Prepare Editorial Visuals",
        "description": "Create magazine-style PDF or PNG pages that use typography, composition, and pattern systems.",
        "target_user": "Writers and publishers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Simple Poster",
        "scenario": "Beginner request for one visual artifact.",
        "prompt": "Create a single-page PNG poster for a quiet evening lecture about urban gardens. Use minimal text and a refined visual style."
      },
      {
        "title": "Abstract Theme",
        "scenario": "Intermediate request with a conceptual reference.",
        "prompt": "Design a PDF artwork based on the feeling of late-night train stations. Keep the reference subtle and make the result gallery-quality."
      },
      {
        "title": "Brand Mood Piece",
        "scenario": "Advanced request with audience and tone constraints.",
        "prompt": "Create a visual philosophy and PNG identity poster for a small ceramics studio. The tone should feel precise, quiet, and handmade."
      },
      {
        "title": "Multi-Page Series",
        "scenario": "Advanced request for a connected set of pages.",
        "prompt": "Create a three-page PDF visual sequence for an experimental music release. Each page should share one philosophy but vary composition and rhythm."
      }
    ],
    "output_examples": [
      {
        "input": "Create a poster for an architecture talk about adaptive reuse.",
        "output": [
          "A short markdown design philosophy that defines the visual movement.",
          "A single-page poster with sparse type, structured geometry, and refined margins.",
          "A downloadable PNG or PDF suitable for review and iteration."
        ]
      },
      {
        "input": "Make an abstract artwork about a favorite science fiction novel without naming it directly.",
        "output": [
          "A subtle conceptual framework for the hidden reference.",
          "A polished visual composition using color, form, and typography as the main language.",
          "A final image file plus the philosophy used to guide the work."
        ]
      }
    ],
    "best_practices": [
      "Provide the subject, desired format, size, and any required text before generation starts.",
      "Approve external font downloads only from trusted sources, or require bundled fonts only.",
      "Review the final image for text clipping, overlap, margins, and licensing concerns."
    ],
    "anti_patterns": [
      "Do not use it for large text-heavy reports or slide decks.",
      "Do not ask it to copy a living artist, brand, or copyrighted style exactly.",
      "Do not allow arbitrary font downloads in restricted or sensitive environments."
    ],
    "faq": [
      {
        "question": "What does this skill create?",
        "answer": "It creates static visual designs, usually as PNG or PDF files, with a markdown design philosophy."
      },
      {
        "question": "Does it create interactive websites?",
        "answer": "No. It is focused on static visual artifacts such as posters, art pieces, and editorial pages."
      },
      {
        "question": "Can it use custom fonts?",
        "answer": "Yes. It can use bundled fonts, and it may download fonts if the environment and user allow network access."
      },
      {
        "question": "Is it safe to publish?",
        "answer": "Yes, with a medium warning. The reviewed static alerts were false positives, but font downloads can use the network."
      },
      {
        "question": "Does it avoid copyright issues?",
        "answer": "It instructs the agent to create original designs and avoid copying existing artists. User-provided references still need review."
      },
      {
        "question": "Which tools can use it?",
        "answer": "The report lists support for Claude, Codex, and Claude Code."
      }
    ]
  },
