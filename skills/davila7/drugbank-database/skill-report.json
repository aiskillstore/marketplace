  "content": {
    "user_title": "Analyze DrugBank Research Data",
    "value_statement": "DrugBank research often requires careful XML parsing, interaction checks, and chemistry data extraction. This skill provides practical workflows for drug profiles, targets, pathways, and similarity analysis.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "DrugBank database",
      "drug interaction analysis",
      "pharmacology research",
      "cheminformatics workflow",
      "drug target analysis",
      "ADMET prediction",
      "bioinformatics data"
    ],
    "actual_capabilities": [
      "Guides DrugBank account setup, credential configuration, downloads, and XML parsing.",
      "Shows how to query drug records by DrugBank ID, name, CAS number, and synonyms.",
      "Extracts drug interactions, classifies interaction text, and builds interaction networks.",
      "Maps drugs to targets, enzymes, transporters, carriers, pathways, and UniProt identifiers.",
      "Supports chemical property extraction, structure similarity, fingerprints, and drug-likeness checks.",
      "Includes a Python helper class for common DrugBank XML lookup tasks."
    ],
    "limitations": [
      "Requires a valid DrugBank account and compliance with DrugBank license terms.",
      "Does not include the DrugBank dataset itself or bypass access restrictions.",
      "Interaction severity examples are heuristic and not a clinical decision system.",
      "Advanced chemistry workflows require optional packages such as RDKit and scikit-learn."
    ],
    "use_cases": [
      {
        "title": "Profile Candidate Drugs",
        "description": "Extract identifiers, indications, mechanisms, chemical properties, and external references for selected compounds.",
        "target_user": "Drug discovery researcher"
      },
      {
        "title": "Review Polypharmacy Risk",
        "description": "Check medication lists for known DrugBank interactions and summarize possible mechanisms for follow-up review.",
        "target_user": "Clinical informatics analyst"
      },
      {
        "title": "Map Targets and Pathways",
        "description": "Connect drugs to protein targets, enzymes, transporters, and pathway identifiers for mechanistic analysis.",
        "target_user": "Bioinformatics scientist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Set Up DrugBank Access",
        "scenario": "Beginner setup for authenticated data access.",
        "prompt": "Help me configure DrugBank access for a Python project. Show secure credential options, required packages, and a reproducible download plan."
      },
      {
        "title": "Find Drug Profile Data",
        "scenario": "Basic lookup for one or more drugs.",
        "prompt": "Using the DrugBank skill, outline how to retrieve profile fields for these DrugBank IDs: [IDs]. Include names, indications, mechanisms, and chemical identifiers."
      },
      {
        "title": "Analyze Drug Interactions",
        "scenario": "Intermediate safety review for a medication list.",
        "prompt": "Analyze this medication list for known DrugBank interactions: [drug names or IDs]. Build a pairwise interaction summary and flag unclear results."
      },
      {
        "title": "Build a Repurposing Workflow",
        "scenario": "Advanced research combining targets, pathways, and structure similarity.",
        "prompt": "Design a DrugBank-based repurposing workflow for [disease or target]. Combine target overlap, pathway mapping, chemical similarity, and interaction screening."
      }
    ],
    "output_examples": [
      {
        "input": "Find key DrugBank profile fields for aspirin.",
        "output": "A concise drug profile with identifiers, approved uses, mechanism summary, selected chemical properties, and links to external database identifiers."
      },
      {
        "input": "Check interactions for warfarin, aspirin, and clopidogrel.",
        "output": "A pairwise interaction table summary with described risks, likely mechanism categories, and a note that clinical verification is required."
      },
      {
        "input": "Compare drugs that share a target with DB00001.",
        "output": "A research summary listing shared targets, target actions, related pathway context, and candidate follow-up analyses."
      }
    ],
    "best_practices": [
      "Store DrugBank credentials in environment variables or protected config files, not source code.",
      "Pin DrugBank versions in research outputs so results remain reproducible.",
      "Validate interaction and ADMET interpretations with clinical or experimental sources before decisions."
    ],
    "anti_patterns": [
      "Do not paste real DrugBank passwords or API keys into prompts, notebooks, or shared logs.",
      "Do not treat heuristic interaction severity labels as medical advice.",
      "Do not load pickle cache files from untrusted sources."
    ],
    "faq": [
      {
        "question": "Does this skill include DrugBank data?",
        "answer": "No. It provides workflows and helper code. Users need their own DrugBank access and license rights."
      },
      {
        "question": "Can it download the latest DrugBank release?",
        "answer": "It explains how to use drugbank-downloader for authenticated downloads, including version-specific downloads for reproducibility."
      },
      {
        "question": "Can it support clinical medication decisions?",
        "answer": "No. It can summarize DrugBank interaction data, but clinicians must verify and interpret patient-specific decisions."
      },
      {
        "question": "Which Python tools does it reference?",
        "answer": "It references drugbank-downloader, lxml, pandas, RDKit, NetworkX, scikit-learn, and related scientific Python tools."
      },
      {
        "question": "Can it analyze chemical similarity?",
        "answer": "Yes. The references cover SMILES extraction, fingerprints, Tanimoto similarity, substructure search, and chemical space analysis."
      },
      {
        "question": "What security caution matters most?",
        "answer": "Protect DrugBank credentials, follow license terms, and avoid loading pickle cache files that came from untrusted sources."
      }
    ]
