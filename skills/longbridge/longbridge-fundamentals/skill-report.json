    "user_title": "Analyze Stocks with Longbridge Fundamentals",
    "value_statement": "Investors and analysts need structured fundamentals from multiple markets. This skill routes questions to Longbridge data workflows for valuation, financial statements, dividends, events, and screening.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Longbridge fundamentals",
      "stock valuation",
      "financial statements",
      "DCF analysis",
      "equity research",
      "investment screening",
      "corporate actions"
    ],
    "actual_capabilities": [
      "Routes financial statement questions to Longbridge CLI or MCP workflows.",
      "Analyzes valuation using PE, PB, PS, dividend yield, and industry comparisons.",
      "Builds DCF, valuation methodology, value screen, and small-cap growth frameworks.",
      "Summarizes dividends, corporate actions, company profiles, executives, and ownership relationships.",
      "Compares stocks and ranks valuation levels within an industry.",
      "Applies behavioral finance frameworks to price, volume, and sentiment signals."
    ],
    "limitations": [
      "It depends on Longbridge CLI, MCP access, or available Longbridge data coverage.",
      "It does not place trades or provide personalized investment advice.",
      "Some markets, symbols, periods, or subcommands may return incomplete data.",
      "DCF and screening results depend heavily on assumptions and user-selected thresholds."
    ],
    "use_cases": [
      {
        "title": "Review an Earnings Report",
        "target_user": "Equity analyst",
        "description": "Pull income statement, balance sheet, and cash flow data, then summarize growth, margins, leverage, and earnings quality."
      },
      {
        "title": "Check Relative Valuation",
        "target_user": "Retail investor",
        "description": "Compare a stock with its industry peers using PE, PB, PS, dividend yield, and valuation percentile context."
      },
      {
        "title": "Screen for Value or Growth Ideas",
        "target_user": "Portfolio researcher",
        "description": "Filter an index or market universe with valuation, ROE, dividend, market cap, and revenue growth criteria."
      }
    ],
    "prompt_templates": [
      {
        "title": "Summarize One Company",
        "scenario": "Beginner fundamentals review",
        "prompt": "Analyze AAPL.US using Longbridge fundamentals. Show financial statement highlights, valuation snapshot, dividends, and key risks."
      },
      {
        "title": "Compare Peer Valuations",
        "scenario": "Intermediate relative valuation",
        "prompt": "Compare TSLA.US with its industry peers using Longbridge valuation data. Include PE, PB, PS, dividend yield, and industry premium or discount."
      },
      {
        "title": "Run a Value Screen",
        "scenario": "Advanced screening workflow",
        "prompt": "Screen HSI.HK constituents for value candidates. Use low PE, low PB, ROE above 10%, and dividend yield above 2%."
      },
      {
        "title": "Build a DCF Case Set",
        "scenario": "Advanced intrinsic valuation",
        "prompt": "Build base, bull, and bear DCF cases for NVDA.US using Longbridge financial data. Show FCF, WACC, terminal value, sensitivity, and margin of safety."
      }
    ],
    "output_examples": [
      {
        "input": "Is 700.HK expensive versus peers?",
        "output": "A valuation report with current PE, PB, PS, industry medians, percentile ranks, premium or discount, caveats, and a not-investment-advice disclaimer."
      },
      {
        "input": "Summarize the latest financial statements for TSLA.US.",
        "output": "A three-statement summary covering revenue, profit, cash flow, leverage, DuPont decomposition, earnings quality, missing data, and source attribution."
      },
      {
        "input": "Find undervalued stocks in the CSI 300.",
        "output": "A ranked shortlist with screening filters, candidate metrics, value score, rationale, key risk, and data limitations."
      }
    ],
    "best_practices": [
      "Provide symbols in CODE.MARKET format, such as AAPL.US, 700.HK, or 600519.SH.",
      "State the target market, time period, and analysis depth before asking for a screen or model.",
      "Review assumptions, missing data notes, and disclaimers before using results in investment research."
    ],
    "anti_patterns": [
      "Do not treat DCF output as a precise price target without sensitivity analysis.",
      "Do not compare market-cap metrics across currencies without currency context.",
      "Do not ask the skill to place trades, guarantee returns, or provide personalized financial advice."
    ],
    "faq": [
      {
        "question": "Does this skill require a Longbridge account?",
        "answer": "The skill states that its commands use public data and do not require login, but local CLI behavior may vary."
