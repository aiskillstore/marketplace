      {
        "title": "Compare News and Community Reaction",
        "scenario": "Intermediate request that combines official items and discussion trends.",
        "prompt": "Review Longbridge news, filings, and community topics for TSLA.US. Separate facts from sentiment and include source labels."
      },
      {
        "title": "Analyze an SEC Filing",
        "scenario": "Advanced filing review with investment-relevant signals.",
        "prompt": "Analyze the most recent 10-Q for AAPL.US using Longbridge data. Highlight financial changes, MD&A themes, and new risk factors."
      },
      {
        "title": "Answer a Regulatory Rule Question",
        "scenario": "Advanced cross-market rule explanation.",
        "prompt": "Explain the day trading, settlement, and circuit breaker rules that apply to US stocks. Include thresholds and practical caveats."
      }
    ],
    "output_examples": [
