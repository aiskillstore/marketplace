  "content": {
    "user_title": "Analyze Longbridge Market Content",
    "value_statement": "Market research often requires checking news, filings, community sentiment, and regulatory context across separate sources. This skill guides Claude, Codex, and Claude Code to produce structured Longbridge-based market summaries.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Longbridge content",
      "stock news analysis",
      "SEC filing analysis",
      "market filings",
      "community sentiment",
      "regulatory rules",
      "investment research assistant"
    ],
    "actual_capabilities": [
      "Routes requests to news, filing, topic, SEC filing, or regulatory rule workflows.",
      "Summarizes Longbridge news into catalyst, regulatory, strategic, financial, opinion, and other buckets.",
      "Analyzes SEC filing types such as 10-K, 10-Q, 8-K, proxy statements, and Form 4 reports.",
      "Explains selected A-share, Hong Kong, US equity, and crypto market rules from the included knowledge base.",
      "Uses Longbridge CLI examples and MCP fallback guidance when live data access is available.",
      "Adds source labels and investment-advice disclaimers to market summaries."
    ],
    "limitations": [
      "It depends on Longbridge CLI or MCP availability for live Longbridge data.",
      "WebSearch fallback is only recommended when Longbridge data is empty, stale, or missing breaking events.",
      "It provides general market research and rule explanations, not personal financial advice.",
      "Regulatory knowledge can become outdated and should be checked against official sources."
    ],
    "use_cases": [
      {
        "title": "Prepare a Stock News Digest",
        "description": "Summarize recent Longbridge news, filings, and community topics for one listed company.",
        "target_user": "Retail investor"
      },
      {
        "title": "Review SEC Filing Signals",
        "description": "Extract key risks, financial changes, and governance signals from recent US company filings.",
        "target_user": "Equity analyst"
      },
      {
        "title": "Explain Market Rules",
        "description": "Answer questions about price limits, settlement, short selling, margin, and circuit breakers.",
        "target_user": "Support specialist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Summarize Recent News",
