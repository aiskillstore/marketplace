    ],
    "actual_capabilities": [
      "Documents React, Next.js, and frontend best practices in three reference guides.",
      "Provides local CLI scripts for component, bundle, and scaffolding workflows.",
      "Validates that a target path exists before running each script workflow.",
      "Prints a simple status report with target path, status, and findings count.",
      "Writes JSON command results to a user-provided output file when requested.",
      "Lists common setup, quality, build, analysis, and deployment commands."
    ],
    "limitations": [
      "The Python scripts are placeholders and do not generate real components.",
      "The bundle analyzer does not inspect build artifacts or dependency sizes.",
      "It does not install dependencies, run tests, or deploy applications automatically.",
      "The reference guides are generic and need project-specific adaptation."
    ],
