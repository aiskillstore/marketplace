  "content": {
    "user_title": "Create SEO-Ready Marketing Content",
    "value_statement": "Marketing teams need consistent content across blogs, email, and social channels. This skill provides templates, voice checks, SEO guidance, and planning tools.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "content creator skill",
      "SEO content",
      "brand voice",
      "social media content",
      "content calendar",
      "marketing copy",
      "content strategy"
    ],
    "actual_capabilities": [
      "Analyzes brand voice, readability, tone, and sentence variety with a local Python script.",
      "Scores SEO structure, keyword density, links, headings, and readability for Markdown content.",
      "Provides templates for blog posts, case studies, newsletters, social posts, and video scripts.",
      "Guides platform-specific content for LinkedIn, X, Instagram, Facebook, and TikTok.",
      "Includes a monthly content calendar template for campaigns, owners, status, and performance review.",
      "Maps content repurposing from long-form posts into social, email, video, audio, and visual assets."
    ],
    "limitations": [
      "It does not perform live keyword research or fetch search volume data.",
      "It does not publish, schedule, or upload content to social platforms.",
      "SEO scoring is heuristic and should not replace specialist tools.",
      "Local scripts require users to choose the files they want analyzed."
    ],
    "use_cases": [
      {
        "title": "Plan a Monthly Campaign",
        "description": "Build a content calendar with channels, topics, owners, status, and review metrics.",
        "target_user": "Content marketing manager"
      },
      {
        "title": "Improve Blog SEO",
        "description": "Check headings, keyword use, readability, links, and meta suggestions before publication.",
        "target_user": "SEO writer"
      },
      {
        "title": "Adapt Content for Social Channels",
        "description": "Turn a core message into platform-ready posts with length, format, timing, and hashtag guidance.",
        "target_user": "Social media specialist"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a Blog Outline",
        "scenario": "Beginner content planning",
        "prompt": "Create a blog outline for [topic] using the content frameworks. Include audience, title, H2 sections, CTA, and SEO keyword placement."
      },
      {
        "title": "Review Brand Voice",
        "scenario": "Intermediate editing",
        "prompt": "Analyze this draft for brand voice using a [professional/friendly/authoritative] tone. Suggest edits for consistency, clarity, and readability."
      },
      {
        "title": "Repurpose a Long Article",
        "scenario": "Multi-channel production",
        "prompt": "Repurpose this article into LinkedIn, X, Instagram, email, and video script formats. Keep the same message and adapt each format."
      },
      {
        "title": "Build a Campaign System",
        "scenario": "Advanced content operations",
        "prompt": "Create a four-week campaign plan for [goal]. Include pillars, channel mix, SEO topics, social formats, owners, KPIs, and review checkpoints."
      }
    ],
    "output_examples": [
      {
        "input": "A SaaS team needs a blog plan for customer onboarding software.",
        "output": "A structured outline with search intent, title options, H2 sections, internal link ideas, CTA copy, and meta description guidance."
      },
      {
        "input": "A founder wants one announcement adapted for LinkedIn, X, and email.",
        "output": "Platform-specific copy variants with adjusted length, hooks, CTA wording, and posting guidance for each channel."
      },
      {
        "input": "A marketing manager wants a monthly content calendar.",
        "output": "A four-week plan with topics, platforms, content pillars, status fields, owners, and end-of-month performance review prompts."
      }
    ],
    "best_practices": [
      "Start with audience intent, primary keyword, and one measurable content goal.",
      "Run voice and SEO checks before final editing and publication.",
      "Adapt each message to the platform instead of copying the same text everywhere."
    ],
    "anti_patterns": [
      "Do not stuff keywords to increase density at the expense of clarity.",
      "Do not publish social posts without platform-specific format checks.",
      "Do not analyze private or sensitive files with the local scripts."
    ],
    "faq": [
      {
        "question": "Does this skill publish content automatically?",
        "answer": "No. It helps create, analyze, and plan content. Users must publish through their own tools."
      },
      {
        "question": "Can it perform live SEO research?",
        "answer": "No. It provides structure and heuristic checks, but it does not fetch search volume or ranking data."
      },
      {
        "question": "Which platforms does it cover?",
        "answer": "It includes guidance for LinkedIn, X, Instagram, Facebook, TikTok, email, blogs, and video scripts."
      },
      {
        "question": "Does it require Python scripts?",
        "answer": "The references are usable without scripts. The brand voice and SEO analyzers require local Python execution."
      },
      {
        "question": "Is user content sent to external services?",
        "answer": "No evidence found. The included scripts analyze local text and do not make network requests."
      },
      {
        "question": "Who is this skill best for?",
