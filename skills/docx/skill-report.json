  "content": {
    "user_title": "Create and Edit Word Documents",
    "value_statement": "Teams need accurate Word documents without losing formatting, comments, or tracked changes. This skill guides Claude, Codex, and Claude Code through reliable DOCX workflows.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "DOCX editing",
      "Word document automation",
      "tracked changes",
      "OOXML",
      "document review",
      "comments in Word",
      "DOCX conversion"
    ],
    "actual_capabilities": [
      "Extract DOCX text to markdown while preserving tracked change visibility.",
      "Create new Word documents with headings, tables, lists, images, links, and page layout.",
      "Edit existing DOCX files through unpacked OOXML and helper document APIs.",
      "Add and manage comments, relationships, media files, and document metadata.",
      "Implement tracked changes with precise insertion and deletion markup.",
      "Convert DOCX files to PDF and page images for visual review."
    ],
    "limitations": [
      "Requires local tools such as pandoc, docx, LibreOffice, Poppler, and Python packages for some workflows.",
      "Complex formatting may require direct OOXML inspection and careful validation.",
      "Does not guarantee legal, academic, or editorial correctness of document content.",
      "Cannot safely process encrypted or password-protected files without user-provided access."
    ],
    "use_cases": [
      {
        "title": "Contract Redline Review",
        "target_user": "Legal operations teams",
        "description": "Apply precise tracked changes and comments to contracts while preserving professional Word review workflows."
      },
      {
        "title": "Report Generation",
        "target_user": "Business analysts",
        "description": "Create polished DOCX reports with headings, tables, lists, images, and consistent document styles."
      },
      {
        "title": "Document Analysis",
        "target_user": "Researchers and editors",
        "description": "Extract text, inspect comments, review metadata, and compare tracked changes in source documents."
      }
    ],
    "prompt_templates": [
      {
        "title": "Extract Document Text",
        "scenario": "Beginner text review",
        "prompt": "Read this DOCX file and summarize its sections. Preserve visible tracked changes in the analysis."
      },
      {
        "title": "Create a Styled Document",
        "scenario": "Intermediate document creation",
        "prompt": "Create a DOCX report with a title page, headings, numbered sections, a table, and a short conclusion."
      },
      {
        "title": "Add Review Comments",
        "scenario": "Advanced editorial review",
        "prompt": "Review this DOCX file and add comments for unclear wording, missing evidence, and formatting issues."
      },
      {
        "title": "Implement Tracked Revisions",
        "scenario": "Advanced redlining workflow",
        "prompt": "Apply tracked changes to this DOCX contract. Make only precise text edits and verify the final document."
      }
    ],
    "output_examples": [
      {
        "input": "A policy DOCX with existing tracked changes and comments.",
        "output": "A concise section-by-section summary, a list of open comments, and a note on each visible tracked change."
      },
      {
        "input": "A request for a quarterly business report in Word format.",
        "output": "A formatted DOCX report with title, executive summary, tables, headings, and consistent spacing."
      },
      {
        "input": "A contract that needs date updates and clearer payment language.",
        "output": "A revised DOCX with precise tracked insertions and deletions, plus verification notes for changed clauses."
      }
    ],
    "best_practices": [
      "Use tracked changes for professional, legal, academic, business, and government document edits.",
      "Verify edits by converting the final DOCX to markdown and checking expected phrases.",
      "Use real Word list, table, heading, and relationship structures instead of visual shortcuts."
    ],
    "anti_patterns": [
      "Do not replace whole paragraphs when only a few words changed.",
      "Do not use plain text bullets when Word list structures are required.",
      "Do not skip final validation after direct OOXML edits."
    ],
    "faq": [
      {
        "question": "Can this skill create new DOCX files?",
        "answer": "Yes. It uses docx-js guidance to create Word documents with structured content and formatting."
      },
      {
        "question": "Can it edit existing Word documents?",
        "answer": "Yes. It supports unpacking DOCX files, editing OOXML, and repacking the document."
      },
      {
        "question": "Does it support tracked changes?",
        "answer": "Yes. It includes a redlining workflow for precise insertions, deletions, and verification."
      },
      {
        "question": "Can it work with comments?",
        "answer": "Yes. It can inspect and add comment files and related Word document relationships."
      },
      {
        "question": "What tools may be required?",
        "answer": "Some workflows need pandoc, Node docx, Python, LibreOffice, Poppler, and defusedxml."
      },
      {
        "question": "Is this skill safe to publish?",
        "answer": "Yes. It is an official skill with expected local file and conversion operations for DOCX processing."
      }
    ]
  },
