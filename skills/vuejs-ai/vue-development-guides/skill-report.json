  "content": {
    "user_title": "Build Better Vue and Nuxt Components",
    "value_statement": "Vue and Nuxt projects often suffer from unclear state, fragile components, and inconsistent data flow. This skill guides AI assistants toward practical Vue 3 and Nuxt 3 patterns.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Vue.js skill",
      "Nuxt development",
      "Vue Composition API",
      "Vue reactivity",
      "Vue SFC best practices",
      "Pinia state management",
      "frontend coding assistant"
    ],
    "actual_capabilities": [
      "Applies Vue 3 Composition API defaults when creating or reviewing components.",
      "Guides correct use of refs, reactive state, computed values, and watchers.",
      "Reviews Single-File Component structure, slots, template refs, attributes, and scoped styles.",
      "Recommends props, emits, v-model, provide, and inject patterns for data flow.",
      "Helps choose between composable stores, VueUse global state, and Pinia."
    ],
    "limitations": [
      "Does not run tests, lint code, or inspect application behavior by itself.",
      "Does not include complete migration guidance for Vue 2 or Nuxt 2 projects.",
      "Does not replace project-specific architecture decisions or team conventions.",
      "Includes documentation examples, not production-ready components for every case."
    ],
    "use_cases": [
      {
        "title": "Review a Vue Component",
        "description": "Check a component for reactivity mistakes, unclear data flow, large responsibilities, and SFC structure issues.",
        "target_user": "Frontend developer"
