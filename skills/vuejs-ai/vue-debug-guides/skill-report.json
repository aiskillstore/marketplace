  "content": {
    "user_title": "Debug Vue 3 Application Issues",
    "value_statement": "Vue 3 bugs often come from reactivity timing, template rules, SSR differences, or component communication. This skill maps symptoms to focused debugging guides and practical fixes.",
    "seo_keywords": [
      "Claude Vue debugging",
      "Codex Vue debugging",
      "Claude Code Vue skill",
      "Vue 3 reactivity bugs",
      "Vue SSR hydration",
      "Vue Composition API debugging",
      "Vue template errors",
      "Vue watcher cleanup",
      "Vue component refs",
      "Vue form v-model issues"
    ],
    "actual_capabilities": [
      "Maps Vue 3 symptoms to targeted reference guides by topic.",
      "Explains reactivity, computed, watcher, and template ref failure modes.",
      "Covers SSR hydration, platform API, Suspense, Teleport, and router issues.",
      "Provides incorrect and corrected examples for common Vue patterns.",
      "Includes TypeScript, Vite, slots, provide/inject, and plugin debugging guidance."
    ],
    "limitations": [
      "Does not run diagnostics or inspect a live Vue application automatically.",
      "Does not replace official Vue, Vite, Nuxt, or browser documentation.",
      "Some snippets are simplified and need project-specific review before use.",
      "Focuses on Vue 3 and may not cover older Vue 2 behavior fully."
    ],
    "use_cases": [
      {
        "title": "Resolve Reactive State Bugs",
        "target_user": "Frontend developer",
        "description": "Find why refs, computed values, watchers, or destructured state do not update as expected."
      },
      {
        "title": "Diagnose SSR Hydration Problems",
        "target_user": "Full-stack Vue engineer",
        "description": "Identify server and client rendering differences caused by browser APIs, shared state, or async components."
      },
      {
        "title": "Review Vue Migration Issues",
        "target_user": "Technical lead",
        "description": "Check Vue 2 to Vue 3 changes in events, TransitionGroup, render functions, and Vite component registration."
      }
    ],
    "prompt_templates": [
      {
        "title": "Find a Vue Bug Guide",
        "scenario": "Beginner symptom matching",
        "prompt": "My Vue 3 component has this symptom: [describe symptom]. Which guide should I use, and what should I check first?"
      },
      {
        "title": "Explain a Runtime Warning",
        "scenario": "Understanding an error message",
        "prompt": "Explain this Vue 3 warning or error in plain language: [paste warning]. Point me to the related guide and likely fix."
      },
      {
        "title": "Debug Reactivity Flow",
        "scenario": "Intermediate component debugging",
        "prompt": "Review this Vue 3 component behavior: [describe refs, computed values, watchers, and template]. Identify likely reactivity mistakes and fixes."
      },
      {
        "title": "Audit SSR Hydration Failure",
        "scenario": "Advanced SSR troubleshooting",
        "prompt": "Analyze this SSR hydration mismatch: [server output, client behavior, relevant code]. Check platform APIs, shared state, async loading, Teleport, and Suspense."
      }
    ],
    "output_examples": [
      {
        "input": "A computed sorted list changes the original list order.",
        "output": "The response identifies mutating array methods inside computed values, recommends copying before sorting, and points to the computed array mutation guide."
      },
      {
        "input": "A page hydrates correctly locally but fails after deployment.",
        "output": "The response checks browser-only APIs, non-deterministic render data, shared server state, and async component timing before suggesting focused SSR guides."
      },
      {
        "input": "A parent cannot call methods on a child component ref.",
        "output": "The response explains script setup privacy, recommends defineExpose where appropriate, and notes timing checks for null template refs."
      }
    ],
    "best_practices": [
      "Start with the exact symptom and choose the closest guide before changing code.",
      "Compare the incorrect and corrected examples, then adapt the fix to your project.",
      "Validate copied snippets for security, SSR context, and framework version compatibility."
    ],
    "anti_patterns": [
      "Do not copy every suggested pattern without checking your app architecture.",
      "Do not treat development-only debugging hooks as production monitoring.",
      "Do not ignore SSR differences between server code and browser-only APIs."
    ],
    "faq": [
      {
        "question": "What Vue version does this skill target?",
        "answer": "It targets Vue 3, including Composition API, script setup, Vue Router, Vite, SSR, and modern component patterns."
      },
      {
        "question": "Can it debug my running application automatically?",
        "answer": "No. It provides reference guidance and troubleshooting paths. You still need to inspect your code and runtime behavior."
      },
      {
        "question": "Does it include SSR and hydration guidance?",
        "answer": "Yes. It covers hydration mismatches, browser-only APIs, shared state across requests, Teleport, Suspense, and async components."
      },
      {
        "question": "Is this useful with Claude, Codex, and Claude Code?",
        "answer": "Yes. The skill is structured as reference material that these tools can use when helping with Vue debugging tasks."
      },
      {
        "question": "Are the code examples production ready?",
        "answer": "They are teaching examples. Review error handling, security, data validation, and project conventions before using them."
      },
      {
        "question": "Does it replace Vue DevTools?",
        "answer": "No. Use Vue DevTools for live inspection, and use this skill to interpret symptoms and choose likely fixes."
      }
    ]
  },
