      "OpenRouter model access",
      "Tavily Exa search",
      "Twitter automation AI"
    ],
    "actual_capabilities": [
      "Lists and searches available inference.sh apps by category, name, and feature status.",
      "Runs hosted image, video, audio, language, search, 3D, and utility apps with CLI inputs.",
      "Generates sample input files for supported apps before execution.",
      "Checks asynchronous task status and saves task results through infsh commands.",
      "Explains authentication with browser login or INFSH_API_KEY for automation.",
      "Documents local file inputs that the CLI uploads for media workflows."
    ],
    "limitations": [
