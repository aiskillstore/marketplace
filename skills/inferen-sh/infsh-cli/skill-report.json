    "actual_capabilities": [
      "List, search, and inspect available inference.sh apps by category or query.",
      "Run hosted AI apps with inline JSON or saved input files.",
      "Generate sample input files before running an app.",
      "Track task status and save task results from the CLI.",
      "Use local files as app inputs when the CLI supports upload.",
      "Reference examples for image, video, audio, LLM, search, 3D, and X automation apps."
    ],
    "limitations": [
