  "content": {
    "user_title": "Create Museum-Quality Canvas Art",
    "value_statement": "Static visual design can feel generic when the creative direction is unclear. This skill turns a brief into a design philosophy and a polished PNG or PDF artwork.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "canvas design",
      "visual art generation",
      "poster design",
      "PDF artwork",
      "PNG artwork",
      "design philosophy",
      "typography composition"
    ],
    "actual_capabilities": [
      "Creates a short design philosophy before producing the final visual artifact.",
      "Guides creation of single-page PNG or PDF canvas artwork.",
      "Emphasizes minimal text, spatial composition, color, and visual hierarchy.",
      "Uses bundled font files from the canvas-fonts directory when typography is needed.",
      "Supports multi-page visual series when the user requests additional pages."
    ],
    "limitations": [
      "It does not create interactive websites, animations, or editable design files.",
      "It depends on the host tool to render images or PDF files.",
      "It should not copy living artists, protected brands, or existing artworks.",
      "It may need user-provided dimensions, text, or output format for exact production needs."
    ],
    "use_cases": [
      {
        "title": "Create Event Posters",
        "target_user": "Marketing designer",
        "description": "Turn a short event brief into a refined poster with sparse text and strong visual composition."
      },
      {
        "title": "Explore Art Direction",
        "target_user": "Creative director",
        "description": "Generate a design philosophy that can guide visual choices for a campaign or concept study."
      },
      {
        "title": "Produce Presentation Art",
        "target_user": "Founder or educator",
        "description": "Create a polished abstract visual for a keynote, report cover, or editorial slide."
      }
    ],
    "prompt_templates": [
      {
        "title": "Beginner Poster Brief",
        "scenario": "A user wants one polished static poster.",
        "prompt": "Create a single-page PNG poster for [topic]. Use minimal text, strong composition, and a refined design philosophy."
      },
      {
        "title": "Format-Specific Artwork",
        "scenario": "A user has a target output and size.",
        "prompt": "Create a [PNG or PDF] canvas at [size]. Include only the essential words: [text]. Make the visual style sophisticated and original."
      },
      {
        "title": "Conceptual Visual System",
        "scenario": "A user wants an abstract art direction from a subtle reference.",
        "prompt": "Design an abstract artwork inspired by [subtle reference]. Hide the reference in form, rhythm, color, and spatial choices."
      },
      {
        "title": "Advanced Multi-Page Series",
        "scenario": "A user wants a coherent visual sequence.",
        "prompt": "Create a [number]-page PDF series for [theme]. Build one design philosophy, then make each page distinct but visually connected."
      }
    ],
    "output_examples": [
      {
        "input": "Create a poster for an experimental jazz night with only the venue name and date.",
        "output": "A PNG poster with a concise design philosophy, abstract rhythmic forms, restrained typography, and balanced negative space."
      },
      {
        "input": "Make a PDF cover for a climate research report about ocean heat.",
        "output": "A single-page PDF with layered scientific marks, cool color fields, minimal labels, and a polished editorial composition."
      },
      {
        "input": "Create three pages for a gallery booklet about memory and architecture.",
        "output": "A connected PDF sequence with varied layouts, quiet references, architectural rhythm, and consistent typography."
      }
    ],
    "best_practices": [
      "Provide the subject, required text, output format, and intended use before generation starts.",
      "Ask for sparse wording so the artwork can communicate through space, form, and color.",
      "Review the final canvas for margins, overlap, readability, and consistent visual hierarchy."
    ],
    "anti_patterns": [
      "Do not request copies of a specific artist, brand campaign, or copyrighted artwork.",
      "Do not overload the canvas with long paragraphs or dense explanatory text.",
      "Do not use this skill for interactive prototypes, motion graphics, or production-ready source files."
    ],
    "faq": [
      {
        "question": "What file types does this skill create?",
        "answer": "It is designed for Markdown design philosophy files plus PNG or PDF visual outputs."
      },
      {
        "question": "Can it make more than one page?",
        "answer": "Yes. It can create a multi-page PDF or multiple PNG files when the prompt asks for a series."
      },
      {
        "question": "Does it include fonts?",
        "answer": "Yes. The skill includes a canvas-fonts directory with bundled font files for visual typography."
      },
      {
        "question": "Can I ask for a specific artist style?",
        "answer": "No. The skill should create original design directions and avoid copying existing artists."
      },
      {
        "question": "Is this useful for business documents?",
        "answer": "It works best for covers, posters, editorial art, and visual pages rather than text-heavy documents."
      },
      {
        "question": "Does it run code or install tools by itself?",
        "answer": "No scripts are included. Rendering depends on the AI tool and local environment used with the skill."
      }
    ]
  },
