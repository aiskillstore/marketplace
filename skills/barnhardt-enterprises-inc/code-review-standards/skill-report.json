  "content": {
    "user_title": "Review Code with Consistent Standards",
    "value_statement": "Code reviews often vary by reviewer, which causes missed defects and unclear feedback. This skill gives Claude, Codex, and Claude Code a structured review framework with severity levels, checklists, and feedback templates.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "code review standards",
      "pull request review",
      "security checklist",
      "TypeScript review",
      "performance review",
      "maintainability checklist",
      "engineering quality"
    ],
    "actual_capabilities": [
      "Defines critical, high, medium, and low severity levels for review feedback.",
      "Provides checklists for correctness, security, TypeScript quality, testing, performance, maintainability, and architecture.",
      "Includes review process steps for pre-review, security review, code review, feedback, and verdict selection.",
      "Supplies reusable feedback templates for security, TypeScript, performance, and quality issues.",
      "Links to companion guidance files for deeper security, performance, and maintainability criteria."
    ],
    "limitations": [
      "It does not run tests, builds, scanners, or linters by itself.",
      "It depends on available project files and reviewer-provided context.",
      "Some linked companion skills may not be installed in every environment.",
      "It provides review guidance, not a guarantee that every defect is found."
    ],
    "use_cases": [
      {
        "title": "Review a pull request before merge",
        "description": "Apply a consistent checklist and severity model to identify blocking and non-blocking issues.",
        "target_user": "Software engineer"
      },
      {
        "title": "Standardize team review criteria",
        "description": "Use shared expectations for security, tests, performance, and maintainability across reviewers.",
        "target_user": "Engineering manager"
      },
      {
        "title": "Improve review feedback quality",
        "description": "Write actionable comments with risk, impact, fix guidance, and clear merge verdicts.",
        "target_user": "Technical lead"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic Pull Request Review",
        "scenario": "Beginner review of a small change",
        "prompt": "Review this pull request using the code-review-standards framework. Focus on correctness, tests, security basics, and clear severity labels."
      },
      {
        "title": "Security-Focused Review",
        "scenario": "API, authentication, or data handling changes",
        "prompt": "Review these changes with extra attention to authentication, authorization, input validation, sensitive data exposure, and injection risks."
      },
      {
        "title": "Performance and Maintainability Review",
        "scenario": "Feature work that may affect runtime cost or long-term ownership",
        "prompt": "Review this change for performance, database query patterns, React rendering behavior, function complexity, duplication, and error handling."
      },
      {
        "title": "Release Gate Review",
        "scenario": "Advanced review before merging a risky change",
        "prompt": "Perform a full release gate review. Classify findings by severity, list required fixes, identify residual risks, and give an approve or request changes verdict."
      }
    ],
    "output_examples": [
      {
        "input": "Review a login endpoint change before merge.",
        "output": "The review identifies missing input validation as high severity, confirms password hashing expectations, requests tests for failed login cases, and recommends request changes."
      },
      {
        "input": "Review a dashboard query that loads related records.",
        "output": "The review flags a likely N+1 query pattern, explains the performance impact, suggests a joined query or batch loading, and marks the issue high severity."
      },
