      "minimal code changes",
      "developer workflow principles",
      "Claude Code repository context"
    ],
    "actual_capabilities": [
      "Defines rules for reading files before editing them.",
      "Guides AI assistants to make small, focused code changes.",
      "Lists repository context checks for README, workflow, and project files.",
      "Provides response patterns for non-technical users during coding tasks.",
      "Encourages checking diffs, build output, and task state before reporting completion.",
      "Warns against direct production deploys, secret hardcoding, and destructive actions without confirmation."
    ],
    "limitations": [
      "It provides guidance only and does not implement code by itself.",
      "It depends on the assistant to follow the documented workflow correctly.",
      "It does not replace project-specific security policies or code review.",
      "Some examples mention local shell commands that may need approval in restricted environments."
    ],
    "use_cases": [
      {
        "title": "Keep AI Edits Small",
        "description": "Use the skill before modifying files so the assistant reads context and changes only the required lines.",
        "target_user": "Software developer"
      },
      {
        "title": "Understand a Repository Quickly",
        "description": "Use the context checklist to inspect project files, workflow state, and recent git history before planning work.",
        "target_user": "AI coding operator"
      },
      {
        "title": "Guide Non-Technical Builders",
        "description": "Use the VibeCoder guidance to explain next steps in simple language during natural-language development sessions.",
        "target_user": "Product builder"
      }
    ],
    "prompt_templates": [
      {
