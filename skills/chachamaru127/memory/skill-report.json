  "content": {
    "user_title": "Manage Project Memory and Plans",
    "value_statement": "AI-assisted projects can lose decisions, patterns, and task state across sessions. This skill maintains SSOT memory files and migrates workflow documents with backups.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "project memory",
      "SSOT",
      "Plans.md",
      "workflow migration",
      "task preservation",
      "assistant context",
      "memory files"
    ],
    "actual_capabilities": [
      "Routes memory, SSOT, Plans.md merge, and workflow migration requests to focused subskills.",
      "Initializes decisions.md, patterns.md, and optional session-log.md under .claude/memory.",
      "Merges Plans.md while preserving WIP, TODO, done, and archive task sections.",
      "Migrates AGENTS.md, CLAUDE.md, and Plans.md after user confirmation.",
      "Creates backups before workflow file migration and summarizes resulting diffs."
    ],
    "limitations": [
      "It manages project documentation, not application source code.",
      "It depends on existing templates and recognizable Plans.md section markers.",
      "It may edit files that influence future assistant behavior.",
      "It does not provide a database-backed or cloud-synced memory system."
    ],
    "use_cases": [
      {
        "title": "Initialize Team Memory",
        "description": "Create shared decision and pattern files before a new project gains complex history.",
        "target_user": "Project maintainer"
      },
      {
        "title": "Preserve Task State",
        "description": "Update Plans.md structure without losing active, pending, completed, or archived tasks.",
        "target_user": "Long-running Claude Code user"
      },
      {
        "title": "Migrate Workflow Docs",
        "description": "Move AGENTS.md, CLAUDE.md, and Plans.md into a newer format while keeping important rules.",
        "target_user": "Engineering lead"
      }
    ],
    "prompt_templates": [
      {
        "title": "Initialize Memory",
        "prompt": "Initialize the project memory SSOT files. Create missing decisions.md, patterns.md, and session-log.md files without overwriting existing files.",
        "scenario": "Beginner setup for a new repository"
      },
      {
        "title": "Merge Plans Safely",
        "prompt": "Merge the current Plans.md into the latest structure. Preserve all existing task sections and report the task counts.",
        "scenario": "Routine task file update"
      },
      {
        "title": "Review Migration Inputs",
        "prompt": "Review AGENTS.md, CLAUDE.md, and Plans.md for migration. Summarize rules and tasks first, then ask what must be preserved.",
        "scenario": "Guided workflow migration"
      },
      {
        "title": "Migrate With Verification",
        "prompt": "Migrate the workflow files after confirmation. Create backups, preserve project-specific rules, show the diff summary, and wait for final review.",
        "scenario": "Advanced migration with rollback planning"
      }
    ],
    "output_examples": [
      {
        "input": "Initialize memory files for this project.",
        "output": [
          "Created missing memory files for decisions, patterns, and session logging.",
          "Existing files were left unchanged.",
          "The report lists each created file and the recommended git handling."
        ]
      },
      {
        "input": "Merge Plans.md without losing tasks.",
        "output": [
          "Plans.md was reorganized into the current structure.",
          "Active, pending, completed, and archived task sections were preserved.",
          "A task count summary and backup status were provided."
        ]
      },
      {
        "input": "Migrate our workflow files to the new format.",
        "output": [
          "Existing workflow rules were summarized for approval.",
          "Backups were created before edits.",
          "The final response highlighted moved rules, preserved tasks, and items needing review."
        ]
      }
    ],
    "best_practices": [
      "Review existing memory and workflow files before approving migration.",
      "Keep shared decisions and patterns under version control when appropriate.",
      "Inspect the diff summary before accepting rewritten workflow documents."
    ],
    "anti_patterns": [
      "Use this skill for ordinary implementation or code review work.",
      "Approve migration without checking which project rules will be preserved.",
      "Treat session logs as shared SSOT when they contain local notes."
    ],
    "faq": [
      {
        "question": "What does this skill manage?",
        "answer": "It manages SSOT memory files, Plans.md task merges, and migration of assistant workflow documents."
      },
      {
