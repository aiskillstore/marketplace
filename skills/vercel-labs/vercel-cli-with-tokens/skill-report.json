      "Vercel CLI automation",
      "Claude Vercel skill",
      "CI/CD Vercel"
    ],
    "actual_capabilities": [
      "Deploy projects to Vercel using access tokens instead of interactive login",
      "Manage environment variables across preview, production, and development environments",
      "Link local projects to Vercel via git remote or project name",
      "Inspect deployments, view build logs, and manage custom domains",
      "Perform git-based deployments with automatic build triggers",
      "List and verify Vercel project state and authentication"
    ],
    "limitations": [
      "Requires a valid Vercel access token (VERCEL_TOKEN) to be available in the environment or .env file",
      "Cannot create new Vercel teams or projects through the CLI",
      "Environment variable values cannot be read back after being set on Vercel",
      "Requires the Vercel CLI to be installed globally via npm"
    ],
