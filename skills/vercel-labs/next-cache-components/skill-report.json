        "target_user": "Next.js application developer"
      },
      {
        "title": "Design Mixed Rendering Routes",
        "description": "Plan routes that combine static shells, cached data, and dynamic request-time sections using Suspense.",
        "target_user": "Frontend architect"
      },
      {
        "title": "Review Cache Invalidation Strategy",
        "description": "Choose appropriate tag, lifetime, and invalidation APIs for content that changes at different frequencies.",
        "target_user": "Performance engineer"
      }
