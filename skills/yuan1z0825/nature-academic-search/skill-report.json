  "content": {
    "user_title": "Search academic literature across five databases",
    "value_statement": "Academic researchers struggle to search multiple databases, verify citations, and manage reference files separately. This skill unifies PubMed, CrossRef, arXiv, Scopus, and ScienceDirect into coordinated workflows with citation conversion and deduplication.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "academic search",
      "PubMed",
      "arXiv",
      "CrossRef",
      "citation management",
      "literature review",
      "research"
    ],
    "actual_capabilities": [
      "Multi-source concurrent search across PubMed, CrossRef, arXiv, Scopus, and ScienceDirect",
      "Automatic identifier detection for DOI, PMID, and arXiv IDs",
      "Citation formatting in APA, Nature, IEEE, and Vancouver styles",
      "MeSH vocabulary lookup for building PubMed search strategies",
      "Citation file conversion between .nbib, .ris, .bib, and .enw formats",
      "Duplicate detection across sources using DOI/PMID hashing"
    ],
    "limitations": [
      "Google Scholar and Semantic Scholar support is limited; results may vary",
      "Chinese literature databases (CNKI, Wanfang) are not indexed",
      "Citation counts may be delayed; CrossRef updates monthly",
      "Scopus and ScienceDirect require Elsevier API entitlement and consume quota"
    ],
    "use_cases": [
      {
        "title": "Literature review for a research paper",
        "description": "Search multiple databases simultaneously for a topic, deduplicate results, and export citations in the required format.",
        "target_user": "Graduate students writing theses or journal articles"
      },
      {
        "title": "Citation verification and bibliography cleanup",
        "description": "Verify citations extracted from a manuscript against authoritative sources and fix formatting errors.",
        "target_user": "Manuscript editors and peer reviewers"
      },
      {
        "title": "MeSH search strategy construction",
        "description": "Build a precise PubMed search strategy using MeSH vocabulary lookup and Boolean operators.",
        "target_user": "Biomedical researchers and systematic reviewers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic multi-source search",
        "prompt": "Search for recent papers about CRISPR gene editing in cancer therapy across PubMed, CrossRef, and arXiv. Return the top 10 results with abstracts.",
        "scenario": "Quick literature scan on a biomedical topic"
      },
      {
        "title": "Citation verification workflow",
        "prompt": "I have a list of citations from a manuscript. Verify each one against PubMed and CrossRef, flag any that cannot be confirmed, and return corrected entries.",
        "scenario": "Pre-submission bibliography audit"
      },
      {
        "title": "MeSH strategy building",
        "prompt": "Build a PubMed MeSH search strategy for a systematic review on 'machine learning in radiology diagnosis'. Include MeSH terms, synonyms, and Boolean structure.",
        "scenario": "Systematic review preparation"
      },
      {
        "title": "Citation file format conversion",
        "prompt": "Convert my .nbib file from PubMed into BibTeX format. Also export to .ris for EndNote compatibility.",
        "scenario": "Reference manager migration"
      }
    ],
    "output_examples": [
      {
        "input": "Search PubMed for papers on mRNA vaccines from 2023",
        "output": "Returns ranked list of 10 papers with titles, authors, journal, PMID, DOI, and abstracts. Each entry includes a formatted citation ready for copy-paste."
      },
      {
        "input": "Verify this citation: Smith J et al. Nature. 2022. doi:10.1038/s41586-022-12345",
        "output": "Returns confirmed citation with full author list, exact title, journal volume/issue, page numbers, and verified DOI link. Flags any discrepancies from the input."
      },
      {
        "input": "Convert citations.nbib to BibTeX",
        "output": "Produces a .bib file with properly formatted entries including author, title, journal, year, volume, pages, and DOI fields. Handles special characters and LaTeX escaping."
      }
    ],
    "best_practices": [
      "Start with the T1 sources (PubMed for biomedical, CrossRef for cross-disciplinary, arXiv for preprints) before falling back to T2/T3",
      "Always provide a contact email via PUBMED_EMAIL env var or config.toml to comply with NCBI rate limit policies",
      "Run scripts/preflight.py before batch operations to verify API endpoints are reachable",
      "Use the dedicated Scopus/ScienceDirect tools only when needed, as they consume Elsevier API quota"
    ],
    "anti_patterns": [
      "Do not hardcode API keys in plugin files; use environment variables or config.toml instead",
      "Do not run the full MCP server for single-source queries; use the direct source modules for efficiency",
      "Do not skip deduplication when merging results from multiple sources; DOIs and PMIDs often overlap"
    ],
    "faq": [
      {
        "question": "What databases does this skill search?",
        "answer": "PubMed, CrossRef, arXiv, Scopus, and ScienceDirect. Scopus and ScienceDirect require explicit opt-in to avoid consuming Elsevier API quota."
      },
      {
        "question": "Do I need API keys?",
        "answer": "API keys are optional but recommended. NCBI/PubMed and Semantic Scholar offer free tiers. Elsevier keys are read from the local pybliometrics config."
      },
      {
        "question": "How does citation deduplication work?",
        "answer": "The skill uses DOI and PMID hashing to identify duplicate records across sources. Papers found in multiple databases are merged into a single entry."
      },
      {
        "question": "Can I use this without the MCP server?",
        "answer": "Yes. The scripts/academic_search.py script provides a no-MCP fallback using OpenAlex for discovery. The scripts/format-converter.py handles citation file conversion."
      },
      {
        "question": "What citation styles are supported?",
        "answer": "APA, Nature, IEEE, and Vancouver. The get_citation MCP tool formats references in the selected style with DOI links."
      },
      {
        "question": "Does this skill work with Claude Code and Codex?",
        "answer": "Yes. The skill is compatible with Claude, Codex, and Claude Code. Installation via install.sh configures the MCP server for all three."
      }
    ]
  },
