  "content": {
    "user_title": "Draft Nature-Style Manuscripts",
    "value_statement": "Scientific teams often have results but lack a clear manuscript argument. This skill turns claims, figures, notes, and Chinese drafts into structured Nature-style sections with evidence boundaries.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Nature manuscript writing",
      "academic writing skill",
      "scientific paper drafting",
      "research manuscript structure",
      "Nature Communications writing",
      "Chinese to English academic writing",
      "claim evidence mapping"
    ],
    "actual_capabilities": [
      "Drafts abstracts, introductions, methods, experiments, discussions, conclusions, titles, and manuscript outlines.",
      "Builds a one-sentence argument before drafting prose.",
      "Maps claims to supporting evidence, figures, measurements, baselines, and boundaries.",
      "Loads section, paper type, language, and journal fragments based on the user request.",
      "Supports Chinese notes by translating argument intent rather than copying sentence order.",
      "Provides assumptions, missing inputs, and evidence gaps with the draft."
    ],
    "limitations": [
      "It does not verify scientific truth or reproduce experiments.",
      "It needs author-provided claims, evidence, and boundaries to avoid placeholders.",
      "It is not a citation search or reference manager.",
      "It currently references shared files outside the package, which should be fixed before publishing."
    ],
    "use_cases": [
      {
        "title": "Turn Results Into an Abstract",
        "target_user": "Research authors",
        "description": "Convert claims, key results, and limitations into a concise Nature-style abstract with calibrated claims."
      },
      {
        "title": "Rebuild a Manuscript Argument",
        "target_user": "Principal investigators",
        "description": "Plan the section order, paragraph jobs, and claim-evidence map before a full rewrite."
      },
      {
        "title": "Translate Chinese Research Notes",
        "target_user": "Bilingual research teams",
        "description": "Transform Chinese or mixed-language lab notes into English scientific prose with stable terminology."
      }
    ],
    "prompt_templates": [
      {
        "title": "Draft a Short Abstract",
        "scenario": "Beginner request with basic paper details.",
        "prompt": "Draft a Nature-style abstract from these inputs: core claim, method, three main results, target journal, and limitations. Keep placeholders where evidence is missing."
      },
      {
        "title": "Plan an Introduction",
        "scenario": "Intermediate request for section structure.",
        "prompt": "Build an introduction plan for this manuscript. Identify the broad field, unresolved gap, prior attempts, our contribution, evidence, and paragraph map."
      },
      {
        "title": "Rewrite Chinese Notes",
        "scenario": "Advanced bilingual drafting request.",
        "prompt": "Use these Chinese research notes to draft an English Nature Communications methods section. Preserve technical meaning, define terminology, and list assumptions."
      },
      {
        "title": "Audit a Full Manuscript Argument",
        "scenario": "Advanced pre-submission review.",
        "prompt": "Review this manuscript outline for claim-evidence alignment, paragraph flow, missing boundaries, overclaims, and Nature-family desk-rejection risks."
      }
    ],
    "output_examples": [
      {
        "input": "User provides a core claim, three figure results, and a target abstract length.",
        "output": "A one-sentence argument, a paragraph-level abstract draft, and notes listing missing statistics or unsupported novelty claims."
      },
      {
        "input": "User provides Chinese lab notes for a method pipeline.",
        "output": "A terminology ledger, a method subsection map, and English prose organized by motivation, design, workflow, and technical advantage."
      },
      {
        "input": "User asks whether an introduction flows well.",
        "output": "A reverse outline that labels each paragraph job, identifies duplicated gaps, and recommends targeted revisions."
      }
    ],
    "best_practices": [
      "Provide the core claim, strongest evidence, target journal, and boundary before asking for full prose.",
      "Confirm the one-sentence argument and paragraph map before expanding a major section.",
      "Use placeholders for unknown data instead of asking the model to infer results."
    ],
    "anti_patterns": [
      "Do not ask it to invent statistics, mechanisms, references, datasets, or novelty claims.",
      "Do not use it as a substitute for journal instructions or final author review.",
      "Do not request a full rewrite when only one claim or paragraph needs correction."
    ],
    "faq": [
      {
        "question": "Does this skill write a full paper from scratch?",
        "answer": "It can draft sections and outlines, but it needs author-provided claims, evidence, and boundaries."
      },
      {
        "question": "Can it polish finished English prose?",
        "answer": "It can revise structure, but sentence-level polishing is not its main focus."
      },
      {
        "question": "Does it support Nature Communications?",
        "answer": "Yes. It includes journal-specific guidance for Nature Communications and generic Nature-family framing."
      },
      {
        "question": "Can it work from Chinese notes?",
        "answer": "Yes. It can translate argument intent from Chinese or mixed-language notes into English scientific prose."
      },
      {
        "question": "Will it check citations or factual accuracy?",
        "answer": "No. Authors must verify citations, results, methods, and journal rules independently."
      },
      {
        "question": "Why is there a security warning?",
        "answer": "The package references shared files outside its directory. Those references should be bundled or constrained before publication."
      }
    ]
  },
