  "content": {
    "user_title": "Create Journal-Ready Nature Figures",
    "value_statement": "Researchers need figures that communicate evidence clearly and satisfy journal export rules. This skill turns datasets, drafts, and figure ideas into structured Python or R workflows for submission-ready visuals.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Nature figures",
      "scientific plotting",
      "journal figures",
      "matplotlib",
      "ggplot2",
      "publication graphics",
      "data visualization"
    ],
    "actual_capabilities": [
      "Requires a clear Python or R backend before generating plotting code.",
      "Builds a figure contract with conclusion, evidence hierarchy, panel map, and export needs.",
      "Supports matplotlib, seaborn, ggplot2, patchwork, and ComplexHeatmap workflows.",
      "Provides publication export guidance for SVG, PDF, TIFF, and PNG outputs.",
      "Offers reference patterns for bars, trends, heatmaps, image plates, radar plots, and multi-panel layouts.",
      "Includes QA guidance for legends, statistics, source data, typography, and review risks."
    ],
    "limitations": [
      "It does not replace expert statistical review or journal editorial judgment.",
      "It needs usable source data or a clear figure concept to produce reliable plots.",
      "It should not be used for dashboards, interactive apps, or Illustrator-first infographics.",
      "Local rendering depends on installed Python or R packages and export toolchains."
    ],
    "use_cases": [
      {
        "title": "Draft a manuscript figure",
        "description": "Convert a result summary and dataset into a clear multi-panel figure plan and plotting workflow.",
        "target_user": "Academic researcher"
      },
      {
        "title": "Polish revision figures",
        "description": "Audit panels for evidence flow, labels, statistics, source data, and journal export readiness.",
        "target_user": "Graduate student or postdoc"
      },
      {
        "title": "Standardize team figure style",
        "description": "Use shared Python or R patterns to make consistent figures across related manuscript panels.",
        "target_user": "Lab data visualization lead"
      }
    ],
    "prompt_templates": [
      {
        "title": "Start a Figure Plan",
        "scenario": "Beginner request with a clear backend choice.",
        "prompt": "Use Python. Help me plan a Nature-style figure for these results: [describe claim, data tables, and target panels]."
      },
      {
        "title": "Create a Multi-Panel Plot",
        "scenario": "User has data and wants plotting code.",
        "prompt": "Use R. Build a multi-panel figure with one heatmap, two trend panels, and one legend panel from these columns: [paste columns]."
      },
      {
        "title": "Revise an Existing Figure",
        "scenario": "User has an existing script or exported preview.",
        "prompt": "Use Python. Review this plotting script and revise it for clearer evidence hierarchy, editable SVG export, and journal-ready labels."
      },
      {
        "title": "Audit for Submission",
        "scenario": "Advanced pre-submission QA.",
        "prompt": "Use R. Audit this finished figure package for panel logic, source-data traceability, statistical notes, typography, and export risks."
      }
    ],
    "output_examples": [
      {
        "input": "A user asks for a Python figure showing treatment response, toxicity, and histology panels.",
        "output": "The skill produces a figure contract, panel hierarchy, plotting plan, export checklist, and Python workflow for editable SVG and high-resolution TIFF outputs."
      },
      {
        "input": "A user provides single-cell results and asks for an R figure using heatmaps and UMAP-style panels.",
        "output": "The skill selects the R track, structures patchwork and ComplexHeatmap panels, and adds legend, source-data, and typography checks."
      },
      {
        "input": "A user uploads a draft figure and asks whether it is ready for submission.",
        "output": "The skill reports unclear claims, overloaded legends, missing statistical notes, export problems, and concrete revision steps."
      }
    ],
    "best_practices": [
      "Choose Python or R explicitly before asking for scripts or previews.",
      "Provide the core claim, source data columns, desired panels, and journal export requirements.",
      "Review generated output paths and package install commands before running local scripts."
    ],
    "anti_patterns": [
      "Do not ask it to invent scientific results or fabricate source data.",
      "Do not switch backends mid-task just to create a faster preview.",
      "Do not expose private template paths or internal asset filenames in manuscript-facing text."
    ],
    "faq": [
      {
        "question": "Does this skill support both Python and R?",
        "answer": "Yes. It supports Python and R, but the user must choose one backend before plotting starts."
      },
      {
        "question": "Can it make Nature-style multi-panel figures?",
        "answer": "Yes. It guides panel structure, visual hierarchy, typography, and export choices for high-impact journal figures."
      },
      {
        "question": "Does it run without local plotting packages?",
        "answer": "No. Rendering requires the selected Python or R runtime and the needed plotting packages."
      },
      {
        "question": "Can it use my existing plotting script?",
        "answer": "Yes. It can revise an existing Python or R plotting script within the selected backend."
      },
      {
        "question": "Will it guarantee journal acceptance?",
        "answer": "No. It improves figure quality and compliance, but acceptance depends on the research and reviewer judgment."
      },
      {
        "question": "What files can it export?",
        "answer": "It emphasizes editable SVG and PDF outputs, with TIFF or PNG previews when useful."
      }
    ]
  },
