  "content": {
    "user_title": "Create Design-Forward Canvas Art",
    "value_statement": "Static visual projects often need a clear art direction before production. This skill helps Claude, Codex, and Claude Code turn a brief into a design philosophy and a finished PNG or PDF artifact.",
    "seo_keywords": [
      "Claude canvas design",
      "Codex design skill",
      "Claude Code visual art",
      "AI poster design",
      "PNG design generation",
      "PDF artwork creation",
      "typography design",
      "design philosophy",
      "static visual artifacts",
      "canvas art workflow"
    ],
    "actual_capabilities": [
      "Creates a concise design philosophy before visual production.",
      "Guides generation of single-page PNG or PDF artwork.",
      "Uses bundled font files to support varied typography choices.",
      "Encourages minimal text and strong visual hierarchy.",
      "Supports multi-page visual sets when the user requests them.",
      "Adds a refinement pass focused on spacing, polish, and composition."
    ],
    "limitations": [
      "It does not provide executable rendering code by itself.",
      "It may request font downloads when bundled fonts are insufficient.",
      "It depends on the host agent tools for PNG or PDF creation.",
      "It is best suited to static visuals, not interactive interfaces."
    ],
    "use_cases": [
      {
        "title": "Poster Concept Development",
        "description": "Create a distinctive visual direction and finished poster for an event, launch, or cultural program.",
        "target_user": "Designers"
      },
      {
        "title": "Editorial Art Direction",
        "description": "Translate an abstract theme into a polished page with restrained typography and strong composition.",
        "target_user": "Content teams"
      },
      {
        "title": "Brand Mood Exploration",
        "description": "Generate a refined visual artifact that tests color, form, rhythm, and type for a brand concept.",
        "target_user": "Founders and marketers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Simple Poster",
        "scenario": "Beginner request for one static design.",
        "prompt": "Create a single-page PNG poster for [topic]. Use minimal text, strong composition, and a clear design philosophy."
      },
      {
        "title": "Event Artwork",
        "scenario": "Intermediate request with audience and mood.",
        "prompt": "Design a PDF event artwork for [event]. Audience: [audience]. Mood: [mood]. Include a short design philosophy file."
      },
      {
        "title": "Brand Visual Study",
        "scenario": "Advanced request for visual identity exploration.",
        "prompt": "Create a visual study for [brand]. Explore typography, color, and spatial rhythm. Produce one PNG and explain the philosophy."
      },
      {
        "title": "Multi-Page Art Set",
        "scenario": "Advanced request for a cohesive series.",
        "prompt": "Create a three-page PDF art set for [theme]. Each page should share one philosophy but use a distinct visual expression."
      }
    ],
    "output_examples": [
      {
        "input": "Create a poster for an independent film night about memory and cities.",
        "output": "A design philosophy document and a polished PNG poster with architectural forms, muted color, sparse title text, and refined margins."
      },
      {
        "input": "Make a visual identity study for a ceramics studio.",
        "output": "A PDF artwork with quiet spacing, tactile color choices, thin typography, and a short philosophy describing the visual system."
      },
      {
        "input": "Create a three-page abstract booklet about ocean research.",
        "output": "A multi-page PDF set with scientific reference marks, layered patterns, restrained labels, and a cohesive design language."
      }
    ],
    "best_practices": [
      "Provide the topic, audience, format, and any required text before generation.",
      "Review downloaded fonts or ask the agent to use only bundled fonts.",
      "Ask for a refinement pass focused on margins, legibility, and overlap checks."
    ],
    "anti_patterns": [
      "Do not request imitation of a living artist or protected brand style.",
      "Do not use it for text-heavy reports or long-form documents.",
      "Do not allow arbitrary font downloads in restricted environments."
    ],
    "faq": [
      {
        "question": "What does this skill create?",
        "answer": "It creates a design philosophy and static visual outputs such as PNG or PDF artwork."
      },
      {
        "question": "Does it support Claude, Codex, and Claude Code?",
        "answer": "Yes. The report marks support for Claude, Codex, and Claude Code."
      },
      {
        "question": "Can it make multi-page work?",
        "answer": "Yes. It can guide multi-page PDF or PNG sets when the user requests more pages."
      },
      {
        "question": "Does it include fonts?",
        "answer": "Yes. The package includes many bundled font files and related open font licenses."
      },
      {
        "question": "Is network access required?",
        "answer": "No for bundled fonts. The skill may suggest downloading extra fonts, which should be controlled by user policy."
      },
      {
        "question": "Is it safe to publish?",
        "answer": "It appears publishable with a warning about external font downloads and generated local files."
      }
    ]
  },
