  "content": {
    "user_title": "Build Production Shader Effects",
    "value_statement": "Shader work often stalls on math details, rendering artifacts, and technique selection. This skill gives Claude, Codex, and Claude Code structured GLSL guidance for planning and refining visual effects.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "GLSL shader",
      "WebGL",
      "ray marching",
      "signed distance fields",
      "procedural graphics",
      "post-processing",
      "shader debugging"
    ],
    "actual_capabilities": [
      "Selects shader techniques for procedural graphics, SDF modeling, lighting, shadows, particles, fluids, terrain, and water.",
      "Explains GLSL math, rendering tradeoffs, and common WebGL adaptation issues.",
      "Helps plan multi-pass buffers, ping-pong state, and post-processing pipelines.",
      "Reviews shader artifacts and suggests focused debugging steps.",
      "Provides prompt patterns for generating, adapting, or optimizing shader effects."
    ],
    "limitations": [
      "It does not execute shaders or verify GPU output by itself.",
      "Reference examples may need adaptation for the target engine, WebGL version, and precision limits.",
      "Performance guidance depends on hardware, driver behavior, and scene complexity.",
      "Tutorial JavaScript snippets require normal code review before use in production apps."
    ],
    "use_cases": [
      {
        "title": "Prototype Procedural Visuals",
        "target_user": "Creative coder",
        "description": "Turn a visual idea into a shader plan with recommended techniques, uniforms, and debugging checks."
      },
      {
        "title": "Debug Rendering Artifacts",
        "target_user": "Game graphics programmer",
        "description": "Investigate lighting, shadow, SDF, or sampling artifacts with targeted GLSL troubleshooting steps."
      },
      {
        "title": "Translate Art Direction",
        "target_user": "Technical artist",
        "description": "Convert a visual brief into shader components, material choices, and post-processing passes."
      }
    ],
    "prompt_templates": [
      {
        "title": "Explain a Simple Effect",
        "scenario": "Beginner",
        "prompt": "Explain how to build a simple animated GLSL gradient. Include the core math, needed uniforms, and common mistakes."
      },
      {
        "title": "Design a Shader Plan",
        "scenario": "Intermediate",
        "prompt": "Help me design a WebGL fragment shader for [effect]. Use [constraints] and recommend the best shader techniques."
      },
      {
        "title": "Review for Quality",
        "scenario": "Advanced",
        "prompt": "Review this shader plan for performance risks and visual artifacts: [description]. Suggest concrete fixes and validation steps."
      },
      {
        "title": "Plan a Multi-Pass Effect",
        "scenario": "Expert",
        "prompt": "Create a multi-pass shader architecture for [scene or effect]. Include buffers, uniforms, pass order, failure modes, and optimization priorities."
      }
    ],
    "output_examples": [
      {
        "input": "I want a soft ray-marched crystal scene with colored shadows.",
        "output": "The skill would propose SDF primitives, a ray marching loop, normal estimation, soft shadow sampling, Fresnel highlights, and color grading steps."
      },
      {
        "input": "My WebGL shader shows a blank screen after adapting Shadertoy code.",
        "output": "The skill would check WebGL2 syntax, the main wrapper, fragment coordinates, function order, uniforms, and compile-log handling."
      },
      {
        "input": "Design a water surface shader for a stylized game.",
        "output": "The skill would outline wave layers, normal generation, Fresnel reflection, foam masks, fog integration, and performance limits."
      }
    ],
    "best_practices": [
      "Start with the target platform and shader version before choosing technique details.",
      "Ask for artifact-focused debugging when a shader compiles but looks wrong.",
      "Keep performance budgets explicit for loops, texture samples, and multi-pass buffers."
    ],
    "anti_patterns": [
      "Do not request a complete complex scene without constraints on platform, style, or performance.",
      "Do not copy tutorial JavaScript into production without reviewing DOM and input handling.",
      "Do not optimize before confirming the shader compiles and the visual goal is clear."
    ],
    "faq": [
      {
        "question": "What does this skill help create?",
        "answer": "It helps plan, debug, and refine GLSL shaders for procedural visuals, WebGL effects, simulations, lighting, and post-processing."
      },
      {
        "question": "Does it run shaders for me?",
        "answer": "No. It provides guidance and examples, but it does not execute shaders or inspect rendered output by itself."
      },
      {
        "question": "Can it help with Shadertoy to WebGL conversion?",
        "answer": "Yes. It includes adaptation guidance for WebGL2 syntax, main wrappers, uniforms, and common compile errors."
      },
      {
        "question": "Is it useful for game development?",
        "answer": "Yes. It can help with effects such as water, terrain, particles, lighting, shadows, and post-processing."
      },
      {
        "question": "What should I include in a prompt?",
        "answer": "Include the desired effect, target platform, style, performance budget, and any current shader problems."
      },
      {
        "question": "Are the examples production ready?",
        "answer": "They are reference examples. Review and adapt them for your engine, browser support, and security requirements."
      }
    ]
  },
