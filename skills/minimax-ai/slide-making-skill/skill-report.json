  "content": {
    "user_title": "Generate PowerPoint slides with PptxGenJS",
    "value_statement": "Creating professional PowerPoint presentations requires precise formatting, positioning, and styling. This skill provides a complete PptxGenJS reference so AI coding tools can generate native .pptx files with consistent branding, proper typography, and clean layouts.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "PptxGenJS",
      "PowerPoint generation",
      "PPTX creation",
      "slide design",
      "presentation builder",
      "JavaScript pptx"
    ],
    "actual_capabilities": [
      "Generate native .pptx PowerPoint files using the PptxGenJS JavaScript library",
      "Create formatted slides with text, images, shapes, tables, and charts",
      "Apply consistent theme color palettes and font rules across presentations",
      "Produce slide layouts with precise positioning and dimension control",
      "Export charts (bar, line, pie) with customizable styling and labels"
    ],
    "limitations": [
      "Generates static slides only; animations and transitions are not supported",
      "Requires a Node.js runtime environment to execute the generated JavaScript code",
      "Gradient fills are not natively supported; requires gradient image backgrounds",
      "SVG icons require rasterization to PNG for universal PowerPoint compatibility"
    ],
    "use_cases": [
      {
        "title": "Automated report presentations",
        "description": "Generate branded slide decks from data sources for recurring business reports with consistent formatting and color themes.",
        "target_user": "Business analysts"
      },
      {
        "title": "Design system slide templates",
        "description": "Create presentation slides that follow strict brand guidelines with predefined color palettes, typography, and layout rules.",
        "target_user": "Marketing designers"
      },
      {
        "title": "Bulk slide generation",
        "description": "Produce large numbers of similar slides from structured data, such as product catalogs or training materials.",
        "target_user": "Content managers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic cover slide",
        "prompt": "Create a cover slide for a presentation titled \"Annual Report 2025\" using a 16:9 layout with the theme colors provided.",
        "scenario": "Beginner: Create a simple title slide"
      },
      {
        "title": "Content slide with bullets",
        "prompt": "Create a content slide with a section title and three bullet points using the PptxGenJS bullet API. Include a page number badge.",
        "scenario": "Intermediate: Formatted text with proper bullets"
      },
      {
        "title": "Chart with styling",
        "prompt": "Create a bar chart slide showing quarterly sales data. Apply custom colors from the theme, clean white background, subtle gridlines, and data labels on bars.",
        "scenario": "Intermediate: Styled chart with theme colors"
      },
      {
        "title": "Full presentation pipeline",
        "prompt": "Generate a complete presentation with a cover slide, agenda slide, data slides with charts and tables, and a closing slide. Apply the theme contract, font rules, color palette rules, and page number badges on all non-cover slides.",
        "scenario": "Advanced: Multi-slide presentation with full compliance"
      }
    ],
    "output_examples": [
      {
        "input": "Create a cover slide with the title \"Q4 Results\" and subtitle \"Financial Overview\"",
        "output": "A PowerPoint file with a centered title at 48pt bold Arial font, a subtitle at 24pt, and the specified theme background color. No page number badge on the cover slide."
      },
      {
        "input": "Add a bar chart with Q1-Q4 sales data and apply modern styling",
        "output": "A slide with a clean bar chart using custom theme colors, white chart area with rounded corners, muted axis labels, subtle value-axis gridlines, data labels at bar ends, and no legend for single-series display."
      }
    ],
    "best_practices": [
      "Always create a fresh PptxGenJS instance for each presentation; do not reuse presentation objects across files.",
      "Use six-character hex color codes without the hash symbol (e.g., 'FF0000', not '#FF0000') to prevent file corruption.",
      "Apply the 'fit: shrink' option to long titles to prevent text wrapping outside the text box boundaries."
    ],
    "anti_patterns": [
      "Never use async or await inside the createSlide function; the compile script does not await async operations.",
      "Never reuse option objects across multiple PptxGenJS calls; the library mutates objects in-place and corrupts subsequent shapes.",
      "Never use unicode bullet symbols like bullet characters in text; use the PptxGenJS bullet API option instead."
    ],
    "faq": [
      {
        "question": "What slide dimensions does this skill support?",
        "answer": "The skill supports four standard layouts: 16:9 (10 inches by 5.625 inches, default), 16:10, 4:3, and Wide (13.3 inches by 7.5 inches)."
      },
      {
        "question": "Can I add animations or transitions to slides?",
        "answer": "No. Animations and transitions are not supported. All slides must use static content only."
      },
      {
        "question": "Why must hex colors not include the hash symbol?",
        "answer": "Including a hash symbol before hex color values corrupts the output file. Always use six-character hex codes without the prefix, such as 'FF0000'."
      },
      {
        "question": "How do I include a page number on each slide?",
        "answer": "Add a page number badge at position x: 9.3 inches, y: 5.1 inches on every slide except the cover page. Use the current slide number only, not a total count format."
      },
      {
        "question": "Which fonts should I use for text?",
        "answer": "Use Arial for English text and Microsoft YaHei for Chinese text. Body text should not use bold formatting; reserve bold for titles and headings only."
      },
      {
        "question": "Can I use gradient fills for shapes and backgrounds?",
        "answer": "No. Gradient fills are not natively supported in PptxGenJS. Use solid colors only, or use a gradient image as a background."
      }
    ]
  },
