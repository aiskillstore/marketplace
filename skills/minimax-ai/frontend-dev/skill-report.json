  "content": {
    "user_title": "Build Cinematic Frontend Experiences",
    "value_statement": "Modern frontend work often needs polished design, motion, media assets, and persuasive copy at the same time. This skill gives Claude, Codex, and Claude Code a structured workflow for building complete pages with local assets and MiniMax media helpers.",
    "seo_keywords": [
      "Claude frontend skill",
      "Codex frontend development",
      "Claude Code UI design",
      "MiniMax media generation",
      "frontend animation workflow",
      "AI landing page builder",
      "React UI design skill",
      "p5.js generative art",
      "text to speech assets",
      "video generation workflow"
    ],
    "actual_capabilities": [
      "Guides full-page frontend builds for landing pages, product pages, dashboards, and marketing sites.",
      "Provides design rules for typography, layout, color, responsive structure, and component organization.",
      "Includes motion guidance for GSAP, Framer Motion, Three.js, and scroll-based interactions.",
      "Generates MiniMax image, video, music, and text-to-speech assets through included Python helper scripts.",
      "Supplies p5.js templates and recipes for static or animated generative art.",
      "Adds copywriting structure for conversion-focused page sections and calls to action."
    ],
    "limitations": [
      "MiniMax media helpers require a valid MINIMAX_API_KEY and MINIMAX_API_BASE.",
      "Generated media workflows send prompts and text to external MiniMax API endpoints.",
      "The skill provides guidance and scripts, not a complete application framework by itself.",
      "Users must verify licensing, privacy rules, and production readiness for generated assets."
    ],
    "use_cases": [
      {
        "title": "Launch a Product Landing Page",
        "target_user": "Startup founder",
        "description": "Create a polished landing page with strong copy, local hero media, responsive sections, and conversion-focused calls to action."
      },
      {
        "title": "Prototype a Motion-Rich Interface",
        "target_user": "Frontend engineer",
        "description": "Plan and implement scroll reveals, cinematic transitions, and component-level animation without losing performance discipline."
      },
      {
        "title": "Create Branded Media Assets",
        "target_user": "Design team",
        "description": "Use MiniMax helper scripts to produce images, voiceovers, music, or videos that match a site concept."
      }
    ],
    "prompt_templates": [
      {
        "title": "Build a Simple Landing Page",
        "scenario": "Beginner request for a complete page.",
        "prompt": "Use frontend-dev to build a responsive landing page for a new product. Include sections, copy, visual direction, and local asset requirements."
      },
      {
        "title": "Add Motion to an Existing UI",
        "scenario": "Intermediate request for animation planning.",
        "prompt": "Use frontend-dev to improve this existing page with motion. Keep the layout stable, choose suitable animation tools, and explain any dependencies."
      },
      {
        "title": "Generate Media for a Campaign Page",
        "scenario": "Advanced request involving external asset generation.",
        "prompt": "Use frontend-dev to plan and generate image, video, music, and voice assets for a campaign page. Show prompts before running MiniMax scripts."
      },
      {
        "title": "Build a Full Brand Experience",
        "scenario": "Advanced request for design, media, copy, and implementation.",
        "prompt": "Use frontend-dev to design and implement a cinematic brand page with custom assets, persuasive copy, responsive UI, animation, and final quality checks."
      }
    ],
    "output_examples": [
      {
        "input": "Build a homepage for an AI note-taking app.",
        "output": [
          "A responsive page plan with hero, feature, proof, pricing, and call-to-action sections.",
          "A visual system covering typography, color, spacing, and icon direction.",
          "A local asset list for hero imagery, product screenshots, and motion moments."
        ]
      },
      {
        "input": "Create a product page with generated media.",
        "output": [
          "A set of image, video, music, and voiceover prompts ready for review.",
          "Suggested MiniMax script commands with output paths inside the project assets folder.",
          "Implementation notes for integrating generated media into the final page."
        ]
      },
      {
        "input": "Make an interactive art page for a gallery.",
        "output": [
          "A p5.js concept with seeded randomness, adjustable parameters, and responsive canvas behavior.",
          "A viewer layout that presents the artwork without distracting interface elements.",
          "Quality checks for frame rate, reproducibility, and exported visuals."
        ]
      }
    ],
    "best_practices": [
      "Review all MiniMax prompts before running scripts, especially when prompts include private product or customer data.",
      "Save generated media inside project asset folders and use local references in the final frontend.",
      "Check dependencies, responsive behavior, animation performance, and accessibility before delivery."
    ],
    "anti_patterns": [
      "Do not use placeholder image URLs when the page requires real product or brand assets.",
      "Do not print or share MINIMAX_API_KEY while troubleshooting environment setup.",
      "Do not add heavy motion effects without testing mobile performance and reduced-motion behavior."
    ],
    "faq": [
      {
        "question": "Does this skill build actual frontend code?",
        "answer": "Yes. It guides implementation for frontend pages and can support React, Next.js, HTML, and related UI workflows."
      },
      {
        "question": "Does it require MiniMax credentials?",
        "answer": "Only the media generation scripts require MINIMAX_API_KEY and MINIMAX_API_BASE. Design and coding guidance can run without them."
      },
      {
        "question": "Will prompts or text leave my computer?",
        "answer": "Yes, when you run the MiniMax helper scripts. Those scripts send prompts, text, lyrics, or task data to the configured API endpoint."
      },
      {
        "question": "Can I use it with Claude Code and Codex?",
        "answer": "Yes. The report lists support for Claude, Codex, and Claude Code."
      },
      {
        "question": "Does it include ready-made assets?",
        "answer": "It includes fonts, templates, and scripts. Project-specific images, video, audio, and music are generated or supplied during use."
      },
      {
        "question": "What should I review before publishing a site?",
        "answer": "Review generated asset rights, privacy constraints, accessibility, responsive behavior, performance, and any third-party dependencies."
      }
    ]
  },
