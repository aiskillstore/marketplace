  "content": {
    "user_title": "Build Rich Frontend Experiences",
    "value_statement": "Frontend projects often need design, motion, copy, and media assets to work together. This skill gives Claude, Codex, and Claude Code structured workflows for building polished web experiences.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "frontend development",
      "UI design",
      "web animation",
      "AI media assets",
      "generative art",
      "React landing pages",
      "MiniMax assets"
    ],
    "actual_capabilities": [
      "Guides React, Next.js, Vue, Svelte, Astro, and pure HTML project structure.",
      "Provides UI design rules for typography, layout, colors, states, and responsive behavior.",
      "Includes motion guidance for Framer Motion, GSAP, Three.js, and CSS animation.",
      "Supplies MiniMax helper scripts for image, video, speech, and music asset generation.",
      "Includes p5.js templates and font assets for static and interactive generative art.",
      "Defines copywriting workflows for landing pages, product pages, dashboards, and marketing sites."
    ],
    "limitations": [
      "MiniMax asset generation requires a valid API key and a configured API base URL.",
      "Generated media prompts may send user content to an external MiniMax API endpoint.",
      "The skill provides guidance and templates, not a complete frontend framework.",
      "Security review is recommended before running helper scripts in sensitive projects."
    ],
    "use_cases": [
      {
        "title": "Launch Marketing Pages",
        "target_user": "Startup founder",
        "description": "Create landing pages with persuasive copy, local media assets, and polished responsive sections."
      },
      {
        "title": "Prototype Product Interfaces",
        "target_user": "Product designer",
        "description": "Turn product ideas into interactive frontend prototypes with motion, states, and visual hierarchy."
      },
      {
        "title": "Create Generative Art Experiences",
        "target_user": "Creative developer",
        "description": "Use p5.js templates, seeded randomness, and canvas fonts to build reproducible visual work."
      }
    ],
    "prompt_templates": [
      {
        "title": "Simple Landing Page",
        "scenario": "Beginner request for a polished first page.",
        "prompt": "Build a responsive landing page for a small business. Include clear copy, visual hierarchy, mobile layout, and empty states where relevant."
      },
      {
        "title": "Animated Product Page",
        "scenario": "Intermediate request with motion and media.",
        "prompt": "Create a product page with local asset placeholders, tasteful scroll animation, pricing details, and accessibility checks."
      },
      {
        "title": "Dashboard Interface",
        "scenario": "Advanced application UI request.",
        "prompt": "Design and implement a dashboard with dense information, loading states, error states, responsive navigation, and restrained motion."
      },
      {
        "title": "Media-Rich Experience",
        "scenario": "Advanced workflow using AI-generated assets.",
        "prompt": "Plan and build a cinematic web experience that uses generated images, video, audio, and copy. Confirm prompts before generating assets."
      }
    ],
    "output_examples": [
      {
        "input": "A landing page for a boutique fitness studio.",
        "output": "A responsive page plan with hero copy, service sections, booking calls to action, local media requirements, and motion notes."
      },
      {
        "input": "A product dashboard for subscription analytics.",
        "output": "A dashboard layout with navigation, metric panels, table states, filters, empty states, and accessibility considerations."
      },
      {
        "input": "An interactive generative art viewer.",
        "output": "A seeded art concept with controls, viewer structure, typography choices, and export guidance."
      }
    ],
    "best_practices": [
      "Confirm all external media generation prompts before running MiniMax helper scripts.",
      "Keep generated assets local and reference them from the project assets directory.",
      "Run accessibility, responsive layout, and reduced motion checks before delivery."
    ],
    "anti_patterns": [
      "Do not run helper scripts with production secrets unless the endpoint is verified.",
      "Do not ship placeholder images, placeholder URLs, or generic filler copy.",
      "Do not combine heavy animation libraries without checking performance and cleanup."
    ],
    "faq": [
      {
        "question": "Does this skill generate images, video, audio, or music?",
        "answer": "Yes. It includes MiniMax helper scripts for those assets when API credentials are configured."
      },
      {
        "question": "Does it require network access?",
        "answer": "Only the MiniMax asset scripts require network access. UI guidance and templates can be used offline."
      },
      {
        "question": "Can it work with Claude, Codex, and Claude Code?",
        "answer": "Yes. The marketplace metadata marks support for Claude, Codex, and Claude Code."
      },
      {
        "question": "Is it only for React projects?",
        "answer": "No. It includes guidance for React, Next.js, Vue, Nuxt, Svelte, Astro, and pure HTML."
      },
      {
        "question": "Does it include security safeguards?",
        "answer": "It requires prompt confirmation before asset generation, but users should verify API endpoints and output paths."
      },
      {
        "question": "Can it create production-ready work?",
        "answer": "It can guide production-style implementation, but teams should still run project tests, reviews, and deployment checks."
      }
    ]
  },
