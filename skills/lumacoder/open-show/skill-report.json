    "critical_findings": [],
    "high_findings": [
      {
        "title": "Unsanitized Document Content Rendered Into Generated HTML",
        "description": "HTML, Markdown, and extracted text are converted into slide blocks and inserted into the final HTML without clear escaping or sanitization. A malicious input document can produce executable or deceptive content in the generated presentation.",
        "locations": [
          {
            "file": "scripts/openshow.py",
            "line_start": 129,
            "line_end": 154
          },
          {
            "file": "scripts/openshow.py",
            "line_start": 202,
            "line_end": 208
          },
          {
            "file": "scripts/openshow.py",
            "line_start": 864,
            "line_end": 897
          }
        ],
        "confidence": 0.94,
        "confidence_reasoning": "The parser stores raw tag strings and inner HTML, then the renderer joins those blocks into the output document. This is direct evidence of an injection path when source files or web pages are untrusted."
      },
      {
        "title": "TLS Verification Disabled On URL Fetch Fallback",
        "description": "URL parsing retries failed requests with certificate verification disabled. This can allow network attackers to modify fetched page content before it is converted into a local HTML presentation.",
        "locations": [
          {
            "file": "scripts/openshow.py",
            "line_start": 276,
            "line_end": 287
          }
        ],
        "confidence": 0.91,
        "confidence_reasoning": "The code explicitly retries requests with verify disabled after suppressing insecure request warnings. The behavior is security-relevant because fetched content becomes trusted presentation content."
      }
    ],
    "medium_findings": [
      {
        "title": "Remote And Local Images Are Embedded Into Output",
        "description": "The helper fetches remote images and reads local image paths referenced by input documents, then embeds the bytes into the generated deck. This is useful for offline decks but can unintentionally disclose local files or contact remote hosts.",
        "locations": [
          {
            "file": "scripts/openshow.py",
            "line_start": 68,
            "line_end": 95
          },
          {
            "file": "scripts/openshow.py",
            "line_start": 291,
            "line_end": 295
          }
        ],
        "confidence": 0.82,
        "confidence_reasoning": "The data URI conversion is intentional and visible in code. The disclosure risk depends on whether the input document is trusted and where the generated HTML is shared."
      },
      {
        "title": "Optional External Browser Command",
        "description": "The openclaw option runs an external command to open the generated file URL. Arguments are passed as a list without shell expansion, so command injection risk is reduced, but it still executes a local program.",
        "locations": [
          {
            "file": "scripts/openshow.py",
            "line_start": 932,
            "line_end": 936
          }
        ],
        "confidence": 0.74,
        "confidence_reasoning": "There is direct subprocess execution, but the command and argument structure are fixed. The remaining risk is local program execution rather than shell injection."
      }
