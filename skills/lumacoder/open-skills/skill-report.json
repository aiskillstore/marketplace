  "content": {
    "user_title": "Browse and Install AI Skills Across Editors",
    "value_statement": "Managing AI Agent skills across multiple editors is tedious and time-consuming. Open-skills provides an interactive CLI to browse, select, and install skills from a centralized registry to Claude Code, Codex, and other supported editors with a single command.",
    "seo_keywords": [
      "Claude Code skills",
      "AI Agent skills",
      "Claude skills marketplace",
      "Codex skills",
      "skill installation CLI",
      "AI coding assistant",
      "developer productivity tools",
      "skill management",
      "open-skills CLI",
      "multi-editor skill sync"
    ],
    "actual_capabilities": [
      "Browse skills by category with interactive TUI interface",
      "Select multiple skills using space bar for batch installation",
      "Install skills to Claude Code, Codex, Cursor, Windsurf, and other supported editors",
      "Sync installed skills with remote registry for updates",
      "Search skills by name or keyword",
      "Export and import skill configurations"
    ],
    "limitations": [
      "Requires Node.js 18 or higher",
      "Not all editors may be installed on the system",
      "Skills must be compatible with the target editor version",
      "Network connection required for registry sync"
    ],
    "use_cases": [
      {
        "title": "Quick Skill Discovery and Installation",
        "description": "Developer wants to add new coding skills to their AI assistant. They browse categories, select multiple relevant skills, and install them with one command.",
        "target_user": "Individual developers customizing their AI coding assistant"
      },
      {
        "title": "Team Skill Standardization",
        "description": "Development team lead exports a skill configuration and shares it with team members to ensure consistent AI assistant capabilities across the team.",
        "target_user": "Development teams and team leads"
      },
      {
        "title": "Cross-Editor Skill Migration",
        "description": "Developer switching from one AI editor to another imports their existing skill configuration to quickly set up the new environment.",
        "target_user": "Developers migrating between AI code editors"
      }
    ],
    "prompt_templates": [
      {
        "title": "Browse Available Skills",
        "prompt": "Show me all available skills for coding tasks",
        "scenario": "When you want to see what skills are available in a category"
      },
      {
        "title": "Search for Specific Skills",
        "prompt": "Search for skills related to testing or debugging",
        "scenario": "When you need a specific type of skill"
      },
      {
        "title": "Install Multiple Skills",
        "prompt": "Install the code review, testing assistant, and documentation generation skills to Claude Code",
        "scenario": "When you want to install specific skills"
      },
      {
        "title": "Sync Skills with Registry",
        "prompt": "Sync all my installed skills with the latest versions from the registry",
        "scenario": "When you want to update installed skills"
      }
    ],
    "output_examples": [
      {
        "input": "List coding-related skills",
        "output": [
          "Available coding skills:",
          "code-review - Automated code review and suggestions",
          "refactoring-assistant - Code refactoring and improvement",
          "test-generator - Generate unit tests automatically",
          "documentation-gen - Auto-generate code documentation",
          "Select skills with space bar, press Enter to install."
        ]
      },
      {
        "input": "Install skills to Claude Code",
        "output": [
          "Installing 3 skills to Claude Code...",
          "code-review installed",
          "test-generator installed",
          "documentation-gen installed",
          "Skills are ready to use. Restart Claude Code to activate."
        ]
      },
      {
        "input": "Sync installed skills",
        "output": [
          "Checking for updates...",
          "code-review: up to date",
          "test-generator: update available (v4.0 to v4.1)",
          "Updating test-generator...",
          "test-generator updated",
          "Sync complete. 1 skill updated."
        ]
      }
    ],
    "best_practices": [
      "Review skill permissions before installation to understand what access the skill requires",
      "Test new skills in a non-critical project first to verify they work as expected",
      "Keep your skill registry synchronized to receive security updates and new features"
    ],
    "anti_patterns": [
      "Avoid installing skills from untrusted sources outside the verified registry",
      "Do not ignore skill compatibility warnings - incompatible skills may not function correctly",
      "Avoid bulk installing many skills at once without reviewing their functionality"
    ],
    "faq": [
      {
        "question": "Which editors does open-skills support?",
        "answer": "Open-skills supports Claude Code, Codex, Cursor, Windsurf, Cline, and Roo Code. Support for additional editors is planned."
      },
      {
        "question": "How do I create and share my own skills?",
        "answer": "Use the create command to scaffold a new skill. Skills follow a standard structure with SKILL.md for instructions and can be shared via GitHub or the skill registry."
      },
      {
        "question": "Can I install skills offline?",
        "answer": "Yes, you can install skills from local files or directories using the install command with a local path."
      },
      {
        "question": "How do I remove an installed skill?",
        "answer": "Use the update command to manage skill removal, or manually delete the skill directory from your editor skills folder."
      },
      {
        "question": "Are skills from the registry safe?",
        "answer": "The registry reviews skills for security issues, but always review skill permissions and code before installation. Report suspicious skills to the maintainers."
      },
      {
        "question": "How do I update an individual skill?",
        "answer": "Run the sync command with the skill name to update a specific skill to its latest version."
      }
    ]
  },
