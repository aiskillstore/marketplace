  "content": {
    "user_title": "Create Full-Stack Starter Projects",
    "value_statement": "Starting a modern app often requires many setup decisions and repeated boilerplate. Genesis gives Claude, Codex, and Claude Code structured templates for frontends, backends, miniapps, landing pages, and motion upgrades.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "React project generator",
      "FastAPI starter",
      "Go Gin template",
      "Taro miniapp",
      "landing page generator",
      "Tailwind V4",
      "project scaffolding"
    ],
    "actual_capabilities": [
      "Creates React 19, Vite, Tailwind CSS V4 starter projects from bundled guidance.",
      "Creates FastAPI backend project structure with SQLModel and async database configuration.",
      "Creates Go Gin backend project structure with GORM, Viper-style configuration, and Mage tasks.",
      "Creates Taro 4 miniapp structure with React and Tailwind integration guidance.",
      "Provides landing page and motion enhancement references for existing React projects."
    ],
    "limitations": [
      "Generated projects still require dependency review before installation.",
      "Some frontend template folders in this copy do not include package manifests.",
      "Backend templates need local database credentials before they run successfully.",
      "The skill does not replace production security review or deployment hardening."
    ],
    "use_cases": [
      {
        "title": "Prototype a Product Interface",
        "description": "Create a React starter with Tailwind styling and reusable UI components for quick validation.",
        "target_user": "Frontend developers"
      },
      {
        "title": "Start an API Service",
        "description": "Generate a FastAPI or Go Gin backend with routing, configuration, database access, and local run commands.",
        "target_user": "Backend engineers"
      },
      {
        "title": "Build a Cross-Platform Miniapp",
        "description": "Use the Taro guidance to start a miniapp project with React, Tailwind, and platform build targets.",
        "target_user": "Mobile and miniapp teams"
      }
    ],
    "prompt_templates": [
      {
        "title": "Create a React Starter",
        "scenario": "Beginner project setup",
        "prompt": "Create a React project named customer-portal. Ask me for the target directory and initialization mode first."
      },
      {
        "title": "Create a FastAPI Backend",
        "scenario": "Backend API setup",
        "prompt": "Create a FastAPI backend named billing-api. Use the template mode and show each command before running it."
      },
      {
        "title": "Generate a Landing Page",
        "scenario": "Existing frontend enhancement",
        "prompt": "Add a production-ready landing page to this React project. Follow the Genesis landing page reference and keep components reusable."
      },
      {
        "title": "Customize a Full Stack Scaffold",
        "scenario": "Advanced multi-project setup",
        "prompt": "Create a React frontend and Go Gin backend for an internal dashboard. Use AI generation mode, explain the structure, and pause before dependency installation."
      }
    ],
    "output_examples": [
      {
        "input": "Create a React project called analytics-console.",
        "output": "The assistant asks for a target directory and mode, copies or generates the React structure, updates the project name, installs dependencies after approval, and reports the local dev command."
      },
      {
        "input": "Create a Python backend for user profiles.",
        "output": "The assistant prepares FastAPI folders, configuration, database session files, routers, and a local run script, then lists required environment values."
      },
      {
        "input": "Add motion to this existing React page.",
        "output": "The assistant reviews the current components, adds Framer Motion transitions, adjusts hover states, and keeps layout and accessibility intact."
      }
    ],
    "best_practices": [
      "Review generated commands before running package managers or dev servers.",
      "Set project names and target directories explicitly before initialization.",
      "Replace demo CORS, database, and environment settings before production use."
    ],
    "anti_patterns": [
      "Do not run generated setup commands in a sensitive directory without review.",
      "Do not commit .env files or real database credentials from generated backends.",
      "Do not deploy the starter templates without dependency and security hardening."
    ],
    "faq": [
      {
        "question": "What does Genesis create?",
        "answer": "It creates starter structures for React, FastAPI, Go Gin, Taro miniapps, landing pages, and React motion upgrades."
      },
      {
        "question": "Does it run commands automatically?",
        "answer": "The skill includes setup commands. Users should review commands before dependency installation or server startup."
      },
      {
        "question": "Can I use it with Codex?",
        "answer": "Yes. The report marks support for Claude, Codex, and Claude Code workflows."
      },
      {
        "question": "Is it safe for production projects?",
        "answer": "Use it as a starter. Review dependencies, CORS settings, secrets, logging, and deployment configuration before production."
      },
      {
        "question": "Does it include backend database setup?",
        "answer": "Yes. Backend templates include database configuration patterns, but users must provide their own local credentials."
      },
      {
        "question": "Can it modify existing React projects?",
        "answer": "Yes. It includes references for landing pages and motion upgrades in existing React projects."
      }
    ]
  },
