  "content": {
    "user_title": "Audit SwiftUI Performance Issues",
    "value_statement": "SwiftUI apps can slow down because view updates, layout, and main-thread work are hard to trace. This skill reviews code and profiling evidence to identify likely causes and practical fixes.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "SwiftUI performance audit",
      "SwiftUI Instruments",
      "iOS performance optimization",
      "SwiftUI profiling",
      "view update debugging",
      "Xcode Instruments",
      "janky scrolling fixes"
    ],
    "actual_capabilities": [
      "Reviews SwiftUI view code for expensive body work, broad state dependencies, and unstable identity.",
      "Guides users through collecting SwiftUI, Time Profiler, and Hangs data in Instruments.",
      "Connects symptoms such as hitches, slow navigation, and high CPU use to likely root causes.",
      "Suggests targeted fixes for sorting, filtering, formatting, image decoding, and layout churn.",
      "Helps compare before and after metrics when users provide trace data or screenshots."
    ],
    "limitations": [
      "Cannot run Instruments or profile an app without user-provided data.",
      "Cannot guarantee performance gains without a measured baseline and follow-up capture.",
      "Needs representative code, symptoms, or trace evidence for accurate diagnosis.",
      "Focuses on SwiftUI runtime performance, not general crash debugging or backend latency."
    ],
    "use_cases": [
      {
        "target_user": "iOS developer",
        "title": "Diagnose a slow SwiftUI screen",
        "description": "Review a problematic view hierarchy and find likely causes of slow rendering or repeated updates."
      },
      {
        "target_user": "Mobile tech lead",
        "title": "Plan a performance remediation pass",
        "description": "Turn symptoms and profiling evidence into prioritized fixes with clear effort and verification steps."
      },
      {
        "target_user": "QA engineer",
        "title": "Reproduce and measure UI hitches",
        "description": "Use Instruments guidance to capture the same interaction before and after a candidate fix."
      }
    ],
    "prompt_templates": [
      {
        "title": "Quick Screen Review",
        "scenario": "Beginner code review for one slow screen",
        "prompt": "Review this SwiftUI screen for performance issues. The symptom is slow rendering during this interaction: [describe interaction]. Here is the relevant view and model code: [paste code]."
      },
      {
        "title": "Instruments Capture Plan",
