    "user_title": "Map Skills to Proficiency Levels",
    "value_statement": "Curriculum teams need consistent skill levels, measurable outcomes, and coherent progression. This skill maps skills to CEFR, Bloom taxonomy, and DigComp levels with practical assessment guidance.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "CEFR skill mapping",
      "Bloom taxonomy",
      "DigComp framework",
      "proficiency assessment",
      "curriculum design",
      "learning objectives",
      "assessment rubrics"
    ],
    "actual_capabilities": [
      "Maps skills to CEFR A1 through C2 proficiency levels.",
      "Aligns learning objectives with Bloom taxonomy cognitive levels.",
      "Uses DigComp concepts for digital skill proficiency mapping.",
      "Checks progression for prerequisites, regression, and isolated skills.",
      "Suggests assessment types that match each target proficiency level.",
      "Creates measurable indicators for learner performance."
    ],
    "limitations": [
      "Does not validate claims against external academic sources in real time.",
      "Does not grade learners without submitted evidence or assessment results.",
      "Requires clear skill definitions and course context for accurate mapping.",
      "May need expert review for regulated certification programs."
    ],
    "use_cases": [
      {
        "title": "Design a Course Skill Map",
        "description": "Convert course skills into CEFR levels, Bloom levels, prerequisites, and assessment methods.",
        "target_user": "Curriculum designer"
      },
      {
        "title": "Audit Learner Progression",
        "description": "Review a syllabus for level regression, missing foundations, and weak assessment alignment.",
        "target_user": "Instructional designer"
      },
      {
        "title": "Standardize Team Training",
        "description": "Create consistent proficiency labels for workplace skills across onboarding and advanced training.",
        "target_user": "Learning and development manager"
      }
    ],
    "prompt_templates": [
      {
        "title": "Map One Skill",
        "scenario": "Beginner mapping for a single objective.",
        "prompt": "Map this skill to a CEFR level and Bloom level: [skill]. Include measurable indicators and one suitable assessment."
      },
      {
        "title": "Build a Skill Progression",
        "scenario": "Intermediate planning for a lesson sequence.",
        "prompt": "Create an A1 to B2 progression for [skill]. Include prerequisites, learner indicators, and assessment types for each level."
      },
      {
        "title": "Audit a Curriculum",
        "scenario": "Advanced review of an existing syllabus.",
        "prompt": "Audit this curriculum for proficiency coherence: [curriculum]. Find regressions, missing prerequisites, vague indicators, and assessment mismatches."
      },
      {
        "title": "Design a Proficiency Framework",
        "scenario": "Advanced framework design for a program.",
        "prompt": "Design a CEFR, Bloom, and DigComp proficiency framework for [program]. Include levels, rubrics, validation checks, and assessment strategy."
      }
    ],
    "output_examples": [
      {
        "input": "Map specification writing for beginner learners.",
        "output": [
          "Recommended level: A2, because learners apply a template to familiar problems.",
          "Bloom alignment: Understand and Apply.",
          "Assessment: write a simple specification from a guided checklist."
        ]
      },
      {
        "input": "Audit a course where a learner writes project specs before learning components.",
        "output": [
          "Issue: B1 task appears before A1 and A2 foundations.",
          "Fix: add recognition, component explanation, and guided writing before independent project work.",
          "Validation: progression should move from recognition to guided application to independent application."
        ]
      },
      {
        "input": "Create assessment guidance for advanced skill evaluation.",
        "output": [
          "Use B2 when learners compare alternatives and defend decisions.",
          "Use C1 when learners design standards or teach others.",
          "Avoid multiple choice as the main assessment for advanced performance."
        ]
      }
    ],
    "best_practices": [
      "Provide the skill definition, learner context, time available, and target outcome.",
      "Ask for measurable indicators instead of broad labels such as beginner or advanced.",
      "Review the output for progression, prerequisites, and assessment fit before publishing."
    ],
    "anti_patterns": [
      "Do not assign CEFR levels only from intuition or perceived difficulty.",
      "Do not place B1 or higher tasks before A1 and A2 foundations.",
      "Do not use recall-only assessments for skills that require application or evaluation."
    ],
    "faq": [
      {
        "question": "What frameworks does this skill use?",
        "answer": "It uses CEFR proficiency levels, Bloom taxonomy cognitive levels, DigComp concepts, and coherence validation checks."
      },
      {
        "question": "Can it assess any subject area?",
        "answer": "Yes, it can map many skill domains when you provide clear skill descriptions and learner context."
      },
      {
        "question": "Does it replace a curriculum expert?",
        "answer": "No. It gives structured guidance that an educator or program owner should review."
      },
      {
        "question": "What input works best?",
        "answer": "Provide skill names, course goals, learner level, lesson sequence, assessment plans, and time constraints."
      },
      {
        "question": "Can it find broken progression?",
        "answer": "Yes. It checks for regression, missing prerequisites, isolated skills, vague indicators, and weak assessment alignment."
      },
      {
        "question": "Is it useful for workplace training?",
        "answer": "Yes. It can standardize proficiency labels for onboarding, upskilling, and role-based training paths."
      }
