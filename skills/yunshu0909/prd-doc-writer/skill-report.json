  "content": {
    "user_title": "Draft Confirmed PRDs From Product Conversations",
    "value_statement": "Product requirements often fail when assumptions are hidden or stories are incomplete. This skill guides discovery, confirms each decision, and produces structured PRDs with diagrams and acceptance criteria.",
    "seo_keywords": [
      "Claude PRD writer",
      "Codex PRD documentation",
      "Claude Code product requirements",
      "AI requirements writing",
      "user story generator",
      "acceptance criteria drafting",
      "Mermaid workflow diagrams",
      "ASCII wireframes",
      "product requirement document",
      "requirements engineering"
    ],
    "actual_capabilities": [
      "Guides staged PRD discovery before final document generation.",
      "Builds a user journey map as the main document structure.",
      "Drafts user stories with value statements, business rules, and acceptance criteria.",
      "Creates ASCII wireframes for stories that include user interfaces.",
      "Adds Mermaid flow, state, and sequence diagrams for requirement alignment.",
      "Produces a PRD registry row for project documentation tracking."
    ],
    "limitations": [
      "Requires user confirmation before moving between major stages.",
      "Does not replace legal, compliance, security, or architecture review.",
      "Needs clear product context to avoid broad placeholder requirements.",
      "Diagram quality depends on the detail provided during discovery."
    ],
    "use_cases": [
      {
        "title": "Plan a New Feature PRD",
        "target_user": "Product manager",
        "description": "Turn early feature notes into a confirmed PRD with journey stages, stories, diagrams, and acceptance criteria."
      },
      {
        "title": "Align UI Requirements",
        "target_user": "Designer",
        "description": "Use ASCII wireframes and story discussion to clarify layout expectations before design work begins."
      },
      {
        "title": "Prepare Development Handoff",
        "target_user": "Engineering lead",
        "description": "Convert product discussions into implementation-ready stories with business rules, edge cases, and testable outcomes."
      }
    ],
    "prompt_templates": [
      {
        "title": "Start a PRD From Notes",
        "scenario": "Beginner discovery",
        "prompt": "Help me create a PRD for this feature. First, ask me questions to build the user journey before drafting anything."
      },
      {
        "title": "Refine One User Story",
        "scenario": "Story detail",
        "prompt": "Work with me on one user story. Confirm the role, goal, business rules, edge cases, and acceptance criteria before continuing."
      },
      {
        "title": "Add UI Wireframes",
        "scenario": "Interface alignment",
        "prompt": "This story includes a user interface. Create an ASCII wireframe draft, then ask me to confirm or adjust the layout."
      },
      {
        "title": "Generate the Final PRD",
        "scenario": "Advanced finalization",
        "prompt": "We have confirmed the journey map and all stories. Generate the final PRD with Mermaid diagrams, wireframes, and a registry row."
      }
    ],
    "output_examples": [
      {
        "input": "A product manager has rough notes for a batch upload feature.",
        "output": "A staged PRD outline with a confirmed journey map, upload story, validation rules, failure paths, and testable acceptance criteria."
      },
      {
        "input": "A designer needs agreement on a dashboard layout before design starts.",
        "output": "An ASCII wireframe showing filters, table areas, controls, empty states, and a confirmation question for layout changes."
      },
      {
        "input": "An engineering lead needs a handoff document for approval workflow work.",
        "output": "A PRD section with workflow diagrams, state transitions, role behavior, exception handling, and a concise registry summary."
      }
    ],
    "best_practices": [
      "Provide goals, user roles, constraints, and known edge cases before asking for final output.",
      "Confirm each journey stage and user story before moving to the next section.",
      "Use diagrams and wireframes to verify behavior and layout with stakeholders."
    ],
    "anti_patterns": [
      "Asking for a complete PRD before the journey map and stories are confirmed.",
      "Using the output as final specification without stakeholder and engineering review.",
      "Skipping error paths, empty states, permission states, or non-goals."
    ],
    "faq": [
      {
        "question": "What type of documents does this skill create?",
        "answer": "It creates PRDs with user journeys, user stories, business rules, acceptance criteria, wireframes, diagrams, and registry summaries."
      },
      {
        "question": "Can it write the final PRD in one step?",
        "answer": "The workflow is designed for staged confirmation. It should ask questions and confirm details before final generation."
      },
      {
        "question": "Does it support UI requirements?",
        "answer": "Yes. It requires ASCII wireframes for user stories that include interface layout decisions."
      },
      {
        "question": "Does it create Mermaid diagrams?",
        "answer": "Yes. It can create flowcharts, state diagrams, and sequence diagrams for requirement alignment."
      },
      {
        "question": "Is it suitable for engineering handoff?",
        "answer": "Yes, when stakeholders confirm the stories, edge cases, dependencies, and acceptance criteria."
      },
      {
        "question": "Does it execute commands or access project files?",
        "answer": "No executable behavior was found in the skill files. The cited command-like patterns are Markdown examples and file path references."
      }
    ]
