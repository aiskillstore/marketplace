  "content": {
    "user_title": "Create Beat-Synced Music Videos",
    "value_statement": "Music-driven videos require accurate timing, frame planning, and repeatable rendering. This skill turns one audio track into a structured HyperFrames workflow with optional media, motion templates, and MP4 output.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "music to video",
      "HyperFrames",
      "beat synced video",
      "lyric video",
      "audio visualization",
      "AI video workflow",
      "motion graphics"
    ],
    "actual_capabilities": [
      "Analyzes a music file into tempo, beats, phrases, energy phases, rolls, silences, and key moments.",
      "Creates a frame skeleton and storyboard that tile the full audio duration.",
      "Plans brand style, templates, motion primitives, copy, and media treatments for each frame.",
      "Stages optional user images and videos for beat-cut or Ken Burns treatments.",
      "Builds per-frame HyperFrames HTML compositions through a frame-worker workflow.",
      "Assembles, validates, previews, and renders the final MP4 with the music track."
    ],
    "limitations": [
      "Requires HyperFrames tooling, Node, Python audio libraries, and ffmpeg or ffprobe on the machine.",
      "Uses music only. It does not create narrated explainers or website capture videos.",
      "Plan approval and render approval are expected before final output.",
      "Some commands may use network access for package tools, authentication checks, or CDN-hosted scripts."
    ],
    "use_cases": [
      {
        "title": "Release a Music Visualizer",
        "target_user": "Musician",
        "description": "Turn a finished track into a beat-synced visual video for social clips, release pages, or live screen loops."
      },
      {
        "title": "Build a Promo Cutdown",
        "target_user": "Marketing producer",
        "description": "Combine a campaign music bed with product images or video clips and render a polished motion promo."
      },
      {
        "title": "Prototype Motion Direction",
        "target_user": "Motion designer",
        "description": "Use the analyzer and storyboard workflow to test pacing, template choices, and frame treatments before manual refinement."
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic Music Video",
        "scenario": "Beginner request with one audio file and no extra assets.",
        "prompt": "Create a 30 second beat-synced HyperFrames video from assets/bgm.mp3. Use typography and motion templates only. Render a draft MP4."
      },
      {
        "title": "Music Video with Images",
        "scenario": "User provides still images for a slideshow or promo.",
        "prompt": "Create a beat-synced music video from my track and the images in ./media. Use beat cuts on high-energy sections and slower motion during calm sections."
      },
      {
        "title": "Lyric Style Promo",
        "scenario": "User wants text-led motion tied to strong musical moments.",
        "prompt": "Make a kinetic text video for this track. Use short phrases, strong drops, and frame-level templates. Ask for plan approval before building frames."
      },
      {
        "title": "Advanced Directed Render",
        "scenario": "Experienced user controls format, pacing, and review gates.",
        "prompt": "Build a 1080x1920 beat-synced HyperFrames video from this rhythmic track. Stage ./clips, create a complete storyboard, validate the plan, inspect key moments, then render after approval."
      }
    ],
    "output_examples": [
      {
        "input": "A fast electronic track with no visual assets.",
        "output": "A typography-led music video with beat-aligned frames, energetic drops, motion primitives, and a draft MP4 render."
      },
      {
        "input": "A product music bed plus a folder of launch images.",
        "output": "A storyboarded promo video where images appear on the beat, calm phrases use slower motion, and the final assembly includes the BGM."
      },
      {
        "input": "A video file used only as the audio source.",
        "output": "A HyperFrames project that extracts the music timing, plans visual frames, validates the composition, and renders a synced MP4."
      }
    ],
    "best_practices": [
      "Run the workflow in a dedicated project directory with trusted local media files.",
      "Review the generated storyboard before frame workers build HTML compositions.",
      "Validate and inspect the assembled project before rendering the final MP4."
    ],
    "anti_patterns": [
      "Do not use this skill for narrated explainers, website tours, or talking-head edits.",
      "Do not skip plan approval when the video has brand, media, or pacing requirements.",
      "Do not run package or render commands in a sensitive repository without checking paths first."
    ],
    "faq": [
      {
        "question": "What input does this skill need?",
        "answer": "It needs one music track or a video that contains audio. Optional images and video clips can be staged as visual assets."
      },
      {
        "question": "Can it make a video with no images?",
        "answer": "Yes. The workflow can create a complete typography and motion-template video without user-supplied visual assets."
      },
      {
        "question": "Does it create narration?",
        "answer": "No. This skill is for music-led videos. Use a different video workflow for narrated explainers or talking-head content."
      },
      {
        "question": "What does the audio analyzer produce?",
        "answer": "It produces an audiomap with duration, tempo, beat grid, phrases, energy sections, rolls, silences, and key moments."
      },
      {
        "question": "Why does the audit mark medium risk?",
        "answer": "The skill runs local commands, writes project files, copies media, and may load third-party scripts. These actions are expected but need user awareness."
      },
      {
        "question": "Which AI tools can use it?",
        "answer": "The report lists support for Claude, Codex, and Claude Code. The workflow is written as an agent skill for HyperFrames projects."
      }
    ]
  },
