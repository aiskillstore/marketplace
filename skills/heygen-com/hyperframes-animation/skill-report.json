  "content": {
    "user_title": "Build HyperFrames Motion Systems",
    "value_statement": "Production video interfaces need motion that stays deterministic across preview and render. This skill gives Claude, Codex, and Claude Code reusable animation rules, blueprints, adapters, and inspection tooling for HyperFrames projects.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "HyperFrames animation",
      "GSAP timeline",
      "motion design skill",
      "video composition",
      "Three.js animation",
      "Lottie adapter",
      "deterministic rendering"
    ],
    "actual_capabilities": [
      "Selects atomic animation rules for entrances, reveals, counters, cursors, cards, SVG paths, and 3D scenes.",
      "Guides multi-phase scene construction with reusable blueprints and runnable HTML examples.",
      "Explains HyperFrames-safe runtime adapters for GSAP, Lottie, Three.js, Anime.js, CSS, WAAPI, and TypeGPU.",
      "Documents transition patterns for scene-to-scene handoffs in seekable video compositions.",
      "Provides an animation-map script that inspects GSAP timelines and reports timing, motion flags, collisions, and dead zones.",
      "Summarizes deterministic constraints such as paused timelines, finite loops, stable measurements, and registered runtime instances."
    ],
    "limitations": [
      "Requires HyperFrames project conventions and the companion core skill for full composition rules.",
      "Does not create final rendered videos by itself; it guides authoring and inspection.",
      "Some examples use browser or GPU features that may need specific Chromium, Brave, or Canary builds.",
      "Helper scripts may install pinned npm packages and should be run only in trusted project environments."
    ],
    "use_cases": [
      {
        "title": "Design a Product Demo Motion Pass",
        "target_user": "Motion designer",
        "description": "Choose animation rules and transitions that make a product walkthrough readable, polished, and deterministic."
      },
      {
        "title": "Build a Reusable Video Scene",
        "target_user": "Frontend engineer",
        "description": "Adapt a blueprint into a HyperFrames scene with registered timelines, runtime adapters, and seek-safe choreography."
      },
      {
        "title": "Audit Animation Timing",
        "target_user": "Creative technologist",
        "description": "Run the animation-map workflow to inspect tween density, element lifecycles, collisions, and visual dead zones."
      }
    ],
    "prompt_templates": [
      {
        "title": "Pick Simple Motion Rules",
        "scenario": "Beginner rule selection",
        "prompt": "Use hyperframes-animation to choose 2 or 3 atomic rules for a clean SaaS feature reveal. Explain why each rule fits the scene."
      },
      {
        "title": "Adapt a Blueprint",
        "scenario": "Intermediate scene assembly",
        "prompt": "Use hyperframes-animation to adapt a multi-phase blueprint for a brand reveal with a logo, tagline, and final call to action."
      },
      {
        "title": "Choose Runtime Adapters",
        "scenario": "Advanced implementation planning",
        "prompt": "Use hyperframes-animation to plan a scene that combines GSAP text motion, a Lottie asset, and a Three.js camera move. Keep it seek-safe."
      },
      {
        "title": "Review Timeline Quality",
        "scenario": "Expert audit workflow",
        "prompt": "Use hyperframes-animation to review an existing HyperFrames composition for deterministic timing, collision risk, dead zones, and runtime adapter mistakes."
      }
    ],
    "output_examples": [
      {
        "input": "Create motion for a landing page hero that reveals three product benefits.",
        "output": [
          "A shortlist of compatible rules for headline entrance, benefit stagger, and final emphasis.",
          "Timing guidance for each phase and recommended easing choices.",
          "Warnings about layout measurements, infinite loops, and unsupported properties."
        ]
      },
      {
        "input": "Improve a demo video transition between two product screens.",
        "output": [
          "A transition approach where outgoing and incoming scenes overlap in time.",
          "Suggestions for blur, push, scale, or 3D handoff patterns.",
          "Checks for readable dwell time and deterministic timeline registration."
        ]
      },
      {
        "input": "Audit a finished HyperFrames animation map.",
        "output": [
          "A plain-language summary of dense moments, dead zones, and overlapping animated elements.",
          "Prioritized fixes for pacing, collisions, and final visibility.",
          "Notes on which issues are artistic choices versus render risks."
        ]
      }
    ],
    "best_practices": [
      "Start with 2 to 4 atomic rules before loading a full blueprint.",
      "Keep all render-critical motion on a single paused timeline or registered runtime instance.",
      "Measure layout once during setup and reuse those values for deterministic seeking."
    ],
    "anti_patterns": [
      "Do not build timelines inside async callbacks, timers, or event handlers.",
      "Do not use infinite repeats, random values, wall-clock time, or CSS-only animation for render-critical motion.",
      "Do not combine many runtimes unless each one is registered and seekable."
    ],
    "faq": [
      {
        "question": "What is this skill for?",
        "answer": "It helps agents design and implement deterministic motion for HyperFrames video compositions."
      },
      {
        "question": "Does it only support GSAP?",
        "answer": "No. GSAP is the default, but the skill also covers Lottie, Three.js, Anime.js, CSS, WAAPI, and TypeGPU adapters."
      },
      {
        "question": "Can it render videos directly?",
        "answer": "No. It provides authoring guidance and inspection scripts. Rendering is handled by HyperFrames tooling."
      },
      {
        "question": "Why are deterministic rules important?",
        "answer": "HyperFrames samples scenes at exact times. Animation must seek correctly in preview, capture, and render."
      },
      {
        "question": "Are the helper scripts safe to run?",
        "answer": "They are useful but elevated. Run them only in trusted projects and review dependency bootstrap prompts first."
      },
      {
        "question": "When should I use a blueprint?",
        "answer": "Use a blueprint when the full scene matches an existing multi-phase pattern and saves implementation time."
      }
    ]
  },
