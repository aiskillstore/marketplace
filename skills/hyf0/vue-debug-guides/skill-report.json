  "content": {
    "user_title": "Diagnose Vue 3 Runtime Bugs",
    "value_statement": "Vue runtime bugs are hard to trace when reactivity, async loading, SSR, and templates interact. This skill maps symptoms to focused Vue 3 debugging guides with practical fixes.",
    "seo_keywords": [
      "Vue debugging",
      "Vue 3 reactivity",
      "Vue SSR hydration",
      "Vue async components",
      "Claude",
      "Codex",
      "Claude Code",
      "frontend debugging",
      "Vue Composition API",
      "Vue template errors"
    ],
    "actual_capabilities": [
      "Maps common Vue 3 symptoms to targeted reference guides.",
      "Explains reactivity, computed, watcher, and template ref failure modes.",
      "Provides debugging guidance for async components, Suspense, KeepAlive, and transitions.",
      "Covers SSR hydration issues, platform-specific APIs, and cross-request state pollution.",
      "Includes TypeScript, v-model, slots, provide/inject, and render function troubleshooting topics."
    ],
    "limitations": [
      "It does not run or inspect a Vue application by itself.",
      "It focuses on Vue 3 and may not apply to Vue 2 projects.",
      "Examples are educational and must be adapted to the user project.",
      "It does not replace framework documentation or production security review."
    ],
    "use_cases": [
      {
        "title": "Fix Reactivity Bugs",
        "target_user": "Frontend developer",
        "description": "Trace missing updates, stale computed values, watcher timing issues, and ref access mistakes in Vue 3 components."
      },
      {
        "title": "Debug SSR Hydration Issues",
        "target_user": "Full-stack Vue engineer",
        "description": "Identify server and client rendering mismatches, browser-only API crashes, and request state isolation problems."
      },
      {
        "title": "Review Vue Migration Problems",
        "target_user": "Technical lead",
        "description": "Check Vue 2 to Vue 3 changes around attrs, emits, render functions, TransitionGroup, and component registration."
      }
    ],
    "prompt_templates": [
      {
        "title": "Find the Right Guide",
        "scenario": "Beginner triage",
        "prompt": "I have a Vue 3 bug where [describe symptom]. Which guide in this skill should I use first, and what should I check?"
      },
      {
        "title": "Explain a Vue Warning",
        "scenario": "Runtime warning diagnosis",
        "prompt": "Explain this Vue warning and give me a step-by-step debugging path: [paste warning and relevant component context]."
      },
      {
        "title": "Review a Component Flow",
        "scenario": "Intermediate debugging",
        "prompt": "Review this Vue component behavior for likely reactivity, watcher, template ref, or lifecycle timing problems: [describe flow]."
      },
      {
        "title": "Analyze SSR State Safety",
        "scenario": "Advanced SSR review",
        "prompt": "Analyze this Vue SSR design for hydration mismatches, platform-specific API usage, and cross-request state pollution risks: [describe design]."
      }
    ],
    "output_examples": [
      {
        "input": "A computed list sorts correctly, but the original list changes order too.",
        "output": "The skill points to the computed array mutation guide, explains why mutating sort changes the source array, and recommends copying before sorting."
      },
      {
        "input": "A component works in the browser but crashes during SSR with window is not defined.",
        "output": "The skill routes the issue to SSR platform API guidance and suggests moving browser API access to mounted hooks or guarded client-only paths."
      },
      {
        "input": "An async component shows a blank area after a network failure.",
        "output": "The skill identifies missing async component error handling and recommends loading, timeout, retry, and fallback UI checks."
      }
    ],
    "best_practices": [
      "Start from the visible symptom and choose the narrowest matching guide.",
      "Verify whether the issue happens during render, mount, update, unmount, or hydration.",
      "Treat bad-code examples as diagnostics, then adapt the corrected pattern to your project."
    ],
    "anti_patterns": [
      "Do not copy every example into production without checking project context.",
      "Do not debug SSR issues only in the browser client.",
      "Do not assume React Hook rules map directly to Vue Composition API behavior."
    ],
    "faq": [
      {
        "question": "Does this skill execute Vue code?",
        "answer": "No. It provides debugging guidance and reference material for Vue 3 issues."
      },
      {
        "question": "Is it useful for Vue 2 projects?",
        "answer": "Only partly. Most guidance targets Vue 3 behavior and Vue 3 migration issues."
      },
      {
        "question": "Can it help with SSR hydration errors?",
        "answer": "Yes. It includes guides for hydration mismatches, browser-only APIs, and request state isolation."
      },
      {
        "question": "Does it cover TypeScript problems?",
        "answer": "Yes. It covers several Vue TypeScript patterns, including props, template refs, dynamic components, and event handlers."
      },
      {
        "question": "Can it replace Vue DevTools?",
        "answer": "No. Use it to decide what to inspect, then verify behavior with DevTools, tests, or logs."
      },
      {
        "question": "Why are some examples marked bad or wrong?",
        "answer": "They show common failure patterns so developers can recognize and replace them with safer Vue patterns."
      }
    ]
  },
