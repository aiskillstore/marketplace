  "content": {
    "user_title": "Search Jobs and Manage Resume on Liepin",
    "value_statement": "Streamline your job search on Liepin (猎聘) by searching positions, submitting applications, and updating your resume directly through Claude. Save time with automated job matching and application management.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Liepin",
      "job search",
      "猎聘",
      "resume management",
      "Chinese recruitment",
      "job application",
      "career tools"
    ],
    "actual_capabilities": [
      "Search for jobs on Liepin platform with filters (location, salary, experience, education)",
      "Retrieve and view your current resume data in JSON format",
      "Update resume sections including basic info, work experience, education, and job expectations",
      "Submit job applications with proper job ID and job kind parameters",
      "Manage authentication tokens for Liepin API access"
    ],
    "limitations": [
      "Requires liepin-cli to be installed on your system before use",
      "Requires valid Liepin user token (LIEPIN_USER_TOKEN) for API access",
      "Job applications require explicit user confirmation before submission",
      "Only works with Liepin (猎聘) platform, not other job sites",
      "Chinese language interface - job search and content primarily in Chinese"
    ],
    "use_cases": [
      {
        "title": "Job Search for Chinese Tech Market",
        "description": "Software developers looking for opportunities in Chinese tech companies can search positions by skills (Java, Python, AI), location (Beijing, Shanghai), and salary range.",
        "target_user": "Job seekers targeting Chinese tech companies"
      },
      {
        "title": "Resume Maintenance and Updates",
        "description": "Professionals maintaining their Liepin profile can quickly update work experience, add new projects, or modify job expectations without logging into the website.",
        "target_user": "Active job seekers updating their profile"
      },
      {
        "title": "Batch Job Application Workflow",
        "description": "Recruiters or active applicants can search for matching roles, review job details, and submit multiple applications efficiently with proper job kind handling.",
        "target_user": "High-volume job applicants or recruiters"
      }
    ],
    "prompt_templates": [
      {
        "title": "Search for Jobs",
        "prompt": "Search for AI product manager positions in Shanghai with salary range 20k-40k",
        "scenario": "User wants to find job opportunities matching specific criteria"
      },
      {
        "title": "View Current Resume",
        "prompt": "Show me my current resume on Liepin",
        "scenario": "User needs to review their profile information before applying"
      },
      {
        "title": "Update Resume Work Experience",
        "prompt": "Add a new work experience: Company ABC, Senior Engineer, 2022-01 to 2024-12, salary 25k",
        "scenario": "User wants to add recent employment to their profile"
      },
      {
        "title": "Apply for a Job",
        "prompt": "Apply for job ID 123456 with job kind 2",
        "scenario": "User has found a specific role and wants to submit an application"
      }
    ],
    "output_examples": [
      {
        "input": "Search for Python developer jobs in Beijing",
        "output": "Found 25 Python developer positions in Beijing. Top results: 1. Senior Python Engineer at TechCorp (25k-40k), 2. Python Backend Developer at StartupXYZ (20k-35k), 3. Full Stack Python Developer at BigData Inc (30k-50k). Use job IDs to apply."
      },
      {
        "input": "Show my resume summary",
        "output": "Your resume shows: Name: Zhang Wei, Experience: 5 years, Education: Master's in CS, Current Position: Senior Software Engineer, Expected Salary: 30k-50k. Consider adding more project details to improve visibility."
      },
      {
        "input": "Apply for job 789012 with kind 1",
