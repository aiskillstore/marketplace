    ],
    "actual_capabilities": [
      "Explains when to use Nx CLI commands for project graphs, affected tasks, builds, tests, and linting.",
      "Provides examples for generating Next.js, React, JavaScript, and Python workspace projects.",
      "Describes Nx cache setup, Nx Cloud connection steps, and cache troubleshooting checks.",
      "Outlines CI patterns for affected-only lint, build, and test workflows.",
      "Includes monorepo workflow guidance for trunk development, PR stacking, code review, and CODEOWNERS."
    ],
    "limitations": [
      "It provides guidance and command examples, but it does not include executable automation scripts.",
      "It assumes users already have Nx and related package managers installed in their workspace.",
      "Some examples are generic and must be adapted to local project names and repository policies.",
      "Nx documentation details may change, so current docs should be checked for exact CLI behavior."
    ],
    "use_cases": [
      {
        "title": "Diagnose Affected Builds",
        "description": "Identify which projects need build, test, or lint runs after a branch change.",
        "target_user": "Frontend or full-stack engineer"
      },
      {
        "title": "Plan Workspace Additions",
        "description": "Choose generator commands and project layout steps for new apps or shared libraries.",
        "target_user": "Platform engineer"
      },
      {
        "title": "Standardize Monorepo Review",
        "description": "Apply branch, PR stacking, CODEOWNERS, and review guidance across multiple teams.",
        "target_user": "Engineering lead"
      }
    ],
    "prompt_templates": [
      {
