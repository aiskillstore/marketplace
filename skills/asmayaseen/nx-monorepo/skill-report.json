        "scenario": "Daily branch validation",
        "prompt": "Help me determine the right Nx affected build, test, and lint commands for my current branch against main."
      },
      {
        "title": "Add a New Project",
        "scenario": "Workspace expansion",
        "prompt": "Plan the steps to add a new application or library to this Nx monorepo, including generation and verification commands."
      },
      {
        "title": "Optimize CI and Ownership",
        "scenario": "Advanced monorepo governance",
        "prompt": "Audit this Nx monorepo workflow for cache use, affected-only CI, CODEOWNERS coverage, and PR review boundaries."
      }
