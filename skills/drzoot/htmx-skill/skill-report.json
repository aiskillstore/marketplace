  "content": {
    "user_title": "Build htmx Interfaces with Local Docs",
    "value_statement": "htmx projects often fail when small attribute details are guessed from memory. This skill gives Claude, Codex, and Claude Code local htmx references for attributes, events, headers, APIs, extensions, and examples.",
    "seo_keywords": [
      "htmx documentation",
      "htmx reference",
      "Claude",
      "Codex",
      "Claude Code",
      "frontend development",
      "AJAX patterns",
      "HTML over the wire",
      "htmx examples",
      "JavaScript events"
    ],
    "actual_capabilities": [
      "Finds the right local reference page for htmx attributes, events, headers, APIs, and extensions.",
      "Explains htmx request, target, swap, trigger, and history behavior from bundled documentation.",
      "Supports implementation planning for common htmx examples such as modals, validation, uploads, and infinite scroll.",
      "Helps compare related htmx features, including hx-push-url, hx-replace-url, hx-select, and hx-swap.",
      "Provides an optional builder script for maintainers to refresh references from the upstream htmx repository."
    ],
    "limitations": [
      "It is a documentation skill, not a runnable htmx application framework.",
      "Examples may require server-side routes, templates, and security controls that are outside the skill.",
      "The optional builder depends on GitHub availability and trusted upstream documentation content.",
      "It does not automatically validate generated application code for CSRF, XSS, or authorization flaws."
    ],
    "use_cases": [
      {
        "title": "Add htmx Behavior to Existing HTML",
        "description": "Use local attribute references to add requests, targets, swaps, and triggers without introducing a larger frontend framework.",
        "target_user": "Backend developers building server-rendered applications"
      },
      {
        "title": "Debug htmx Request Flows",
        "description": "Look up events, headers, and API helpers when diagnosing why a request, swap, history entry, or response header behaves unexpectedly.",
        "target_user": "Full-stack developers maintaining htmx interfaces"
      },
      {
        "title": "Teach htmx Patterns Safely",
        "description": "Use concise references and examples to explain htmx concepts while adding security guidance for dynamic JavaScript and browser storage.",
        "target_user": "Technical writers and developer educators"
      }
    ],
    "prompt_templates": [
      {
        "title": "Find an Attribute",
        "scenario": "Beginner lookup for one htmx behavior.",
        "prompt": "Use the htmx skill to explain which attribute I should use for [behavior]. Include the key syntax and one safety note."
      },
      {
        "title": "Design a Small Interaction",
        "scenario": "Build a focused server-rendered interaction.",
        "prompt": "Use the htmx references to design a [feature] interaction. Cover the attributes, expected server response, and fallback behavior."
      },
      {
        "title": "Debug a Swap Problem",
        "scenario": "Investigate unexpected DOM replacement behavior.",
        "prompt": "Use the htmx skill to debug this swap issue: [describe issue]. Check hx-target, hx-select, hx-swap, and relevant response headers."
      },
      {
        "title": "Review an htmx Architecture",
        "scenario": "Advanced review of a multi-step htmx workflow.",
        "prompt": "Review this htmx workflow for correctness and security: [workflow]. Use the local docs for events, headers, history, and request configuration."
      }
    ],
    "output_examples": [
      {
        "input": "Which htmx attribute should load search results as I type?",
        "output": "A concise recommendation using hx-get, hx-trigger with keyup delay, hx-target, and hx-indicator, plus a note about server-side escaping."
      },
      {
        "input": "Why is my htmx response replacing the wrong element?",
        "output": "A focused checklist covering target resolution, response selection, swap strategy, out-of-band swaps, and response headers."
      },
      {
        "input": "Can I store an auth token for htmx requests in localStorage?",
        "output": "A cautious answer explaining the documented pattern, safer alternatives, and why token storage needs application-specific security review."
      }
    ],
    "best_practices": [
      "Open the most specific reference file before answering detailed htmx syntax questions.",
      "Pair htmx examples with server-side validation, authorization, CSRF protection, and output escaping.",
      "Treat dynamic JavaScript attributes and browser storage examples as advanced patterns that need explicit security review."
    ],
    "anti_patterns": [
      "Do not copy examples into production without adapting routes, validation, and permission checks.",
      "Do not use evaluated htmx attribute values with user-controlled input unless the input is strictly controlled.",
      "Do not rely on htmx documentation examples as a complete frontend security model."
    ],
    "faq": [
      {
        "question": "What does this skill help with?",
        "answer": "It helps AI tools answer htmx questions using bundled local documentation and examples."
      },
      {
        "question": "Does it generate complete applications?",
        "answer": "No. It provides htmx guidance that still needs application code, server routes, templates, and tests."
      },
      {
        "question": "Can it explain htmx events and headers?",
        "answer": "Yes. The references include event, header, API, attribute, extension, and example pages."
      },
      {
        "question": "Is the builder required during normal use?",
        "answer": "No. The builder is a maintenance script for refreshing local documentation from GitHub."
      },
      {
        "question": "Are the included examples always production safe?",
        "answer": "No. Examples demonstrate htmx behavior and may need security hardening before production use."
      },
      {
        "question": "Which AI tools can use it?",
        "answer": "The report lists support for Claude, Codex, and Claude Code."
      }
    ]
  },
