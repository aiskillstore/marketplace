  "content": {
    "user_title": "Analyze Douyin trends and creator data",
    "value_statement": "Researchers and content creators struggle to gather and analyze Douyin data efficiently. This skill provides access to 280+ API endpoints for comprehensive video analytics, creator insights, and trending content research.",
    "seo_keywords": [
      "Douyin API",
      "TikTok analytics",
      "Claude Code",
      "short video research",
      "creator analytics",
      "trending content",
      "video data collection",
      "social media tools",
      "content research",
      "douyin data analysis"
    ],
    "actual_capabilities": [
      "Fetch video details and statistics by video ID or share URL",
      "Analyze creator profiles including followers, engagement metrics, and content performance",
      "Retrieve trending topics, hot searches, and viral content rankings",
      "Access audience demographics and viewer insights for videos and creators",
      "Query creator marketplaces and KOL (key opinion leader) data for influencer research",
      "Extract video IDs and user IDs from Douyin URLs for data enrichment"
    ],
    "limitations": [
      "Does not provide real-time streaming data or live viewer counts",
      "Cannot perform automated engagement actions (likes, comments, follows)",
      "Rate limited to 60 requests per minute; batch operations require user confirmation",
      "Some API endpoints are deprecated and require alternative endpoints"
    ],
    "use_cases": [
      {
        "title": "Market Research Analyst",
        "description": "Analyze trending content patterns and audience demographics to inform marketing strategy and content planning for brands entering the Chinese market.",
        "target_user": "Marketing professionals and market researchers"
      },
      {
        "title": "Content Creator",
        "description": "Research competitor creators, identify popular content themes, and track performance metrics to optimize your own Douyin content strategy.",
        "target_user": "Individual content creators and influencer agencies"
      },
      {
        "title": "Data Journalist",
        "description": "Gather data-driven insights about viral topics, creator trends, and platform patterns to support investigative reporting on social media phenomena.",
        "target_user": "Journalists and media researchers"
      }
    ],
    "prompt_templates": [
      {
        "title": "Basic video search",
        "prompt": "Find popular Douyin videos about {topic} from the past week and show me their view counts and engagement rates.",
        "scenario": "When you need quick trending content research"
      },
      {
        "title": "Creator analysis",
        "prompt": "Analyze the creator at {url} including their follower count, average engagement, and top performing content categories.",
        "scenario": "When evaluating potential influencer partnerships"
      },
      {
        "title": "Trend tracking",
        "prompt": "What are the current hot topics on Douyin? Show me the top 10 trending hashtags with their estimated reach.",
        "scenario": "When monitoring social trends for content planning"
      },
      {
        "title": "Audience insights",
        "prompt": "Get the audience demographics for videos about {industry} including age groups, locations, and interests.",
        "scenario": "When preparing targeted content strategies"
      }
    ],
    "output_examples": [
      {
        "input": "Search for travel content creators with over 100k followers",
        "output": "Found 5 creators matching your criteria:\n\n1. Travel with Li Lei - 245K followers\n   - Avg engagement: 8.2%\n   - Top category: Outdoor adventure\n   - Latest video: 2 days ago, 45K views\n\n2. China Wanderer - 180K followers\n   - Avg engagement: 6.8%\n   - Top category: Food & travel\n   - Latest video: 5 days ago, 32K views\n\n..."
      },
      {
        "input": "Get trending topics in the beauty category",
        "output": "Current beauty trends on Douyin:\n\n1. #CleanGirlAesthetic - 12.5M views\n2. #KBeautyRoutine - 8.3M views\n3. #SkincareRoutine - 6.7M views\n4. #MakeupTutorial - 5.9M views\n5. #BeautyHacks - 4.2M views\n\nRising topics: #GlassSkin (↑47%), #Double Cleansing (↑23%)"
      }
    ],
    "best_practices": [
      "Use specific video IDs or share URLs for accurate data retrieval instead of broad search queries",
      "Monitor your API usage since calls are billed per request; use batch operations sparingly",
      "Chain multiple API calls strategically: search for IDs first, then fetch detailed data for specific items"
    ],
    "anti_patterns": [
      "Do not attempt to use this skill for automated engagement manipulation or fake engagement generation",
      "Avoid making bulk requests without user confirmation as this may exceed rate limits and increase costs",
      "Do not use retrieved data for platforms outside Douyin or for purposes violating Douyin terms of service"
    ],
    "faq": [
      {
        "question": "What is the cost of using this skill?",
        "answer": "The skill uses MaxHub API which charges per API call. You need an active MaxHub account with sufficient balance. The skill will warn you when making more than 20 consecutive calls."
      },
      {
        "question": "Can I get real-time streaming data?",
        "answer": "No, this skill provides historical data and analytics. It does not support live streaming monitoring or real-time viewer counts."
      },
      {
        "question": "How do I find a creator's profile URL?",
        "answer": "You can use the content parsing APIs to extract user IDs from Douyin profile URLs. Then use that ID to fetch full creator analytics."
      },
      {
        "question": "What is the maximum data I can retrieve in one request?",
        "answer": "Single requests return up to 50 items. For larger datasets, use pagination but confirm with the user after 5 pages to control costs."
      },
      {
        "question": "Can I use this skill to interact with videos (like, comment)?",
        "answer": "No, this skill is read-only. It does not support any write operations like posting comments, liking videos, or following accounts."
      },
      {
        "question": "Why are some API endpoints marked as deprecated?",
        "answer": "Douyin occasionally deprecates old API versions. The skill documentation indicates deprecated endpoints and suggests alternative APIs where available."
      }
    ]
  },
