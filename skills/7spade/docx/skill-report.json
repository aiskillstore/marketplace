  "content": {
    "user_title": "Create and Review DOCX Documents",
    "value_statement": "Editing DOCX files directly is difficult because formatting, comments, and tracked changes live inside OOXML packages. This skill gives Claude, Codex, and Claude Code workflows for creating, unpacking, editing, validating, and repacking Word documents.",
    "seo_keywords": [
      "Claude DOCX editing",
      "Codex DOCX automation",
      "Claude Code Word documents",
      "OOXML document editing",
      "tracked changes automation",
      "Word comments workflow",
      "DOCX validation",
      "document conversion",
      "Microsoft Word automation",
      "DOCX text extraction"
    ],
    "actual_capabilities": [
      "Create new .docx files with JavaScript document components and package them as Word documents.",
      "Unpack .docx, .pptx, and .xlsx files to inspect and edit their OOXML XML parts.",
      "Add Word comments, replies, and supporting relationship files through the bundled Python document library.",
      "Create tracked changes with insertion and deletion XML patterns for review workflows.",
      "Validate edited documents against OOXML schemas, relationship rules, and redlining checks.",
      "Convert documents to Markdown, PDF, or page images using installed local tools."
    ],
    "limitations": [
      "The skill requires local dependencies such as pandoc, LibreOffice, Poppler, npm docx, and Python XML packages.",
      "It manipulates OOXML directly, so complex documents can require careful manual inspection and validation.",
      "Archive extraction must be hardened before publishing because unsafe ZIP paths can escape the output directory.",
      "It does not guarantee visual fidelity for every Word feature, especially advanced layouts and third-party extensions."
    ],
    "use_cases": [
      {
        "title": "Review legal changes",
        "target_user": "Legal operations teams",
        "description": "Add precise tracked changes and comments to contract drafts while preserving review history."
      },
      {
        "title": "Automate report creation",
        "target_user": "Business analysts",
        "description": "Generate structured Word reports with headings, tables, formatted text, and packaged output files."
      },
      {
        "title": "Inspect document internals",
        "target_user": "Developers and support engineers",
        "description": "Unpack DOCX files, inspect OOXML parts, diagnose broken relationships, and validate repaired packages."
      }
    ],
    "prompt_templates": [
      {
        "title": "Extract document text",
        "scenario": "Beginner text review",
        "prompt": "Read this DOCX file and summarize its sections. Preserve tracked-change context if the document contains revisions."
      },
      {
        "title": "Create a new document",
        "scenario": "Structured document generation",
        "prompt": "Create a DOCX report with a title page, section headings, bullet lists, and a simple table from the content below."
      },
      {
        "title": "Add review comments",
        "scenario": "Document collaboration",
        "prompt": "Unpack this DOCX file, add comments to the specified paragraphs, validate the result, and repack it as a new DOCX file."
      },
      {
        "title": "Apply tracked changes",
        "scenario": "Advanced redlining workflow",
        "prompt": "Review this contract and implement the requested edits as tracked changes. Batch the edits, validate each batch, and produce a final reviewed DOCX file."
      }
    ],
    "output_examples": [
      {
        "input": "A user provides a draft policy DOCX and asks for reviewer comments on unclear sections.",
        "output": "The assistant returns a revised DOCX with comments attached to the relevant paragraphs and a short summary of each issue."
      },
      {
        "input": "A user asks for a formatted project status report from meeting notes and task data.",
        "output": "The assistant creates a Word document with headings, an executive summary, status tables, risks, and next steps."
      },
      {
        "input": "A user asks to replace contract dates and party names while showing all edits.",
        "output": "The assistant produces a reviewed DOCX with tracked insertions and deletions, then reports the applied changes."
      }
    ],
    "best_practices": [
      "Work on a copy of the original document and keep the source file unchanged until validation passes.",
      "Use tracked changes for legal, business, academic, and government documents that require review history.",
      "Validate relationships, schemas, and redlining rules before sending the edited DOCX to another user."
    ],
    "anti_patterns": [
      "Do not extract untrusted Office archives without ZIP path validation and size limits.",
      "Do not make broad text replacements without checking how Word split the text across XML runs.",
      "Do not skip validation after editing relationships, comments, tracked changes, or content types."
    ],
    "faq": [
      {
        "question": "Can this skill create new Word documents?",
        "answer": "Yes. It includes a docx-js workflow for generating structured .docx files from JavaScript or TypeScript."
      },
      {
        "question": "Can it preserve tracked changes?",
        "answer": "Yes. It provides workflows for reading tracked changes and creating Word insertion and deletion markup."
      },
      {
        "question": "Does it work without external tools?",
        "answer": "Only partly. Text extraction, conversion, validation, and image rendering need local tools such as pandoc or LibreOffice."
      },
      {
        "question": "Is it safe to use with untrusted DOCX files?",
        "answer": "Not without hardening. The current archive extraction code needs ZIP path validation before marketplace publication."
      },
      {
        "question": "Can it add comments and replies?",
        "answer": "Yes. The Python document library can create comment XML files, relationships, comment IDs, and reply metadata."
      },
      {
        "question": "Can it validate edited documents?",
        "answer": "Yes. It includes schema checks, relationship checks, redlining validation, and document conversion validation."
      }
    ]
  },
