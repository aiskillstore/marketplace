  "content": {
    "user_title": "Verify Work With Evidence",
    "value_statement": "AI agents can mark work complete without enough proof. This skill adds a clear evidence workflow for tests, builds, coverage, and deployment checks.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "evidence verification",
      "AI quality assurance",
      "test evidence",
      "build verification",
      "deployment verification",
      "completion checklist",
      "code review evidence"
    ],
    "actual_capabilities": [
      "Define minimum evidence before task completion.",
      "Capture test results with exit codes and coverage.",
      "Document build results with artifacts and warnings.",
      "Track lint, type check, and security scan outcomes.",
      "Create combined evidence reports for reviews.",
      "Record deployment health checks and rollback status."
    ],
    "limitations": [
      "Does not execute commands by itself.",
      "Depends on available project test and build scripts.",
      "Does not fix failed tests or builds.",
      "Requires agents to report evidence accurately."
    ],
    "use_cases": [
      {
        "target_user": "Software engineers",
        "title": "Prove Feature Completion",
        "description": "Collect test, build, and lint evidence before closing implementation work."
      },
      {
        "target_user": "Code reviewers",
        "title": "Review With Verifiable Results",
        "description": "Require exit codes, coverage, and quality checks before approving changes."
      },
      {
        "target_user": "Release managers",
        "title": "Validate Deployment Readiness",
        "description": "Confirm pre-deployment checks, health checks, smoke tests, and rollback readiness."
      }
    ],
    "prompt_templates": [
