  "content": {
    "user_title": "Optimize SQL Queries Faster",
    "value_statement": "Slow SQL queries increase latency and database cost. This skill helps analyze plans, indexes, joins, and query patterns to produce practical optimization steps.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "SQL optimization",
      "query optimizer",
      "database performance",
      "EXPLAIN ANALYZE",
      "index tuning",
      "slow query analysis",
      "PostgreSQL MySQL"
    ],
    "actual_capabilities": [
      "Explains PostgreSQL, MySQL, SQL Server, MariaDB, and SQLite query plan concepts.",
      "Identifies missing indexes, full table scans, inefficient joins, and N+1 query patterns.",
      "Suggests query rewrites for pagination, filtering, aggregation, and subquery performance.",
      "Provides index design guidance, including composite, partial, covering, GIN, and full-text indexes.",
      "Summarizes monitoring options such as pg_stat_statements, slow query logs, and performance schema."
    ],
    "limitations": [
      "It cannot measure real runtime without database access and representative data.",
      "It may need schema details, table sizes, indexes, and execution plans for accurate advice.",
      "Generated database commands should be reviewed before production use.",
      "It does not replace database-specific load testing or capacity planning."
    ],
    "use_cases": [
      {
        "title": "Investigate Slow Application Queries",
        "description": "Review slow SQL and execution plans to find likely bottlenecks and safer rewrite options.",
        "target_user": "Backend engineers"
      },
      {
        "title": "Plan Index Improvements",
        "description": "Compare WHERE, JOIN, ORDER BY, and GROUP BY usage to propose useful indexes.",
        "target_user": "Database administrators"
      },
      {
        "title": "Teach Query Performance Basics",
        "description": "Turn examples into clear explanations of scans, joins, pagination, and monitoring tools.",
        "target_user": "Technical educators"
      }
    ],
    "prompt_templates": [
      {
        "title": "Review One Query",
        "scenario": "Beginner review of a single SQL statement.",
        "prompt": "Analyze this SQL query for performance issues. Explain likely bottlenecks and suggest simple improvements."
      },
      {
        "title": "Compare Before And After",
        "scenario": "Intermediate review of a proposed rewrite.",
        "prompt": "Compare these two query versions. Explain which should perform better, what indexes matter, and what risks remain."
      },
      {
