  "content": {
    "user_title": "Manage Google Cloud Resources with gcloud",
    "value_statement": "Google Cloud operations require precise commands across many services. This skill provides concise gcloud examples for common inspection, deployment, and administration tasks.",
    "seo_keywords": [
      "Claude gcloud skill",
      "Codex gcloud commands",
      "Claude Code Google Cloud",
      "Google Cloud CLI",
      "GCP automation",
      "Cloud Run deployment",
      "GKE management",
      "BigQuery CLI",
      "Google Cloud IAM",
      "DevOps cloud operations"
    ],
    "actual_capabilities": [
      "Lists authentication, project, region, and zone configuration commands.",
      "Provides Compute Engine examples for creating, connecting, stopping, starting, and deleting VMs.",
      "Shows Cloud Run, Cloud Functions, GKE, App Engine, and Cloud Build deployment commands.",
      "Covers Cloud Storage, Cloud SQL, BigQuery, Pub/Sub, Secret Manager, IAM, and Artifact Registry commands.",
      "Includes formatting, filtering, logging, and interactive gcloud helper examples."
    ],
    "limitations": [
      "It is a command reference and does not validate your live Google Cloud environment.",
      "It does not enforce least-privilege IAM roles or organization policy requirements.",
      "Examples use placeholder project, resource, and region names that must be changed.",
      "Some commands can create costs, expose secrets, or delete resources if executed directly."
    ],
    "use_cases": [
      {
        "title": "Inspect Cloud Resources",
        "description": "Check active projects, running services, VM instances, buckets, logs, datasets, and service accounts from a terminal.",
        "target_user": "Cloud operations engineer"
      },
      {
        "title": "Deploy Managed Services",
        "description": "Prepare gcloud commands for Cloud Run, Cloud Functions, App Engine, GKE, and Cloud Build workflows.",
        "target_user": "Application developer"
      },
      {
        "title": "Administer Platform Access",
        "description": "Find IAM, service account, Secret Manager, and Artifact Registry commands for controlled platform administration.",
        "target_user": "Platform administrator"
      }
    ],
    "prompt_templates": [
      {
        "title": "Check My Current GCP Setup",
