  "content": {
    "user_title": "Manage Lark Base Data with CLI Guidance",
    "value_statement": "Lark Base operations are easy to misconfigure when tables, fields, records, and workflows use different identifiers. This skill gives agents a structured command map and safety guidance for lark-cli tasks.",
    "seo_keywords": [
      "Claude",
      "Codex",
      "Claude Code",
      "Lark Base",
      "lark-cli",
      "Feishu Base",
      "Base automation",
      "record management",
      "workflow configuration",
      "office data tools"
    ],
    "actual_capabilities": [
      "Maps Lark Base tasks to current lark-cli base commands.",
      "Guides table, field, record, view, dashboard, form, role, and workflow operations.",
      "Explains formula and lookup field design before creating calculated fields.",
      "Supports data-query planning for grouped, filtered, and aggregated analysis.",
      "Documents Base link, wiki link, table ID, view ID, and token handling rules.",
      "Highlights write, delete, permission, and file upload precautions."
    ],
    "limitations": [
      "Requires lark-cli to be installed and authenticated separately.",
      "Provides instructions and examples, not an independent API client.",
      "Cannot guarantee the current user has required Lark Base permissions.",
      "Write and delete operations can change live Lark data if executed."
    ],
    "use_cases": [
      {
        "title": "Prepare Base Structures",
        "target_user": "Operations manager",
        "description": "Create tables, fields, views, and forms with command patterns that match current lark-cli syntax."
      },
      {
        "title": "Analyze Base Records",
        "target_user": "Data analyst",
        "description": "Choose between record listing, data-query aggregation, formula fields, and lookup fields for a reporting task."
      },
      {
        "title": "Maintain Automation and Access",
        "target_user": "Workspace administrator",
        "description": "Review workflow, dashboard, role, and advanced-permission commands before changing production Base settings."
      }
    ],
    "prompt_templates": [
      {
        "title": "List Base Structure",
        "scenario": "Beginner discovery",
        "prompt": "Use the Lark Base skill to inspect this Base link. Identify the correct base token, list tables, and tell me which table IDs are available before making changes."
      },
      {
        "title": "Create Fields Safely",
        "scenario": "Intermediate setup",
        "prompt": "Use the Lark Base references to design new fields for a customer tracking table. Check the field property guide first and propose the exact command plan."
      },
      {
        "title": "Run Aggregated Analysis",
        "scenario": "Advanced reporting",
        "prompt": "Use data-query guidance to calculate monthly totals by status. First inspect the table fields, then build the safest aggregation approach."
      },
      {
        "title": "Plan Workflow Automation",
        "scenario": "Advanced automation",
        "prompt": "Use the workflow schema and command references to plan an automation that sends a message when a high-priority record is added. Do not enable it until I approve."
      }
    ],
    "output_examples": [
      {
        "input": "I need to know which records are overdue and grouped by owner.",
        "output": "A short plan that first reads table fields, then uses server-side aggregation when possible, and explains when a formula field is better."
      },
      {
        "input": "Create a Base table for project intake with status, owner, deadline, and priority.",
        "output": "A table design with field types, validation notes, and a staged command sequence for creating the table and checking the result."
      },
      {
        "input": "Delete the old test table from this Base.",
        "output": "A target-verification checklist that confirms the table ID, warns about irreversibility, and then describes the delete command path."
      }
    ],
    "best_practices": [
      "Read the specific command reference before running any lark-cli base command.",
      "Inspect tables and fields before writing records, formulas, lookups, or workflows.",
      "Use explicit IDs for destructive actions and verify targets before passing confirmation flags."
    ],
    "anti_patterns": [
      "Do not guess table names, field names, or workflow step types from natural language alone.",
      "Do not use record-list as a substitute for server-side aggregation queries.",
      "Do not pass full URLs, wiki tokens, or workspace tokens as base tokens."
    ],
    "faq": [
      {
        "question": "Does this skill execute commands by itself?",
        "answer": "No. It provides command guidance for agents that can call lark-cli in their environment."
      },
      {
        "question": "What tools must be available?",
        "answer": "The environment needs lark-cli installed, authenticated, and authorized for the target Lark Base."
      },
      {
        "question": "Can it update live Base data?",
        "answer": "Yes, if an agent runs the documented write commands with valid credentials and permissions."
      },
      {
        "question": "How should deletion requests be handled?",
        "answer": "Confirm the target is unambiguous, prefer explicit IDs, and remember that delete operations can be irreversible."
      },
      {
        "question": "When should data-query be used?",
        "answer": "Use data-query for grouped statistics, totals, averages, counts, comparisons, and filtered aggregate analysis."
      },
      {
        "question": "When are formula or lookup fields better?",
        "answer": "Use formula or lookup fields when the result should remain in Base and update with record changes."
      }
    ]
  },
