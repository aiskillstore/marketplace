  "content": {
    "user_title": "审查 Java 代码是否符合阿里规约",
    "value_statement": "Java 团队常难以持续执行统一的命名、异常、日志、SQL 和安全规则。这个 skill 将阿里巴巴 Java 开发规约转化为代码审查、生成和重构时的检查清单。",
    "seo_keywords": [
      "Alibaba Java Coding Guidelines",
      "阿里巴巴 Java 开发规约",
      "Java code review",
      "Spring code quality",
      "MyBatis SQL review",
      "Claude",
      "Codex",
      "Claude Code",
      "Agent Skills",
      "Java 安全规约"
    ],
    "actual_capabilities": [
      "按强制、推荐和参考级别审查 Java 代码问题。",
      "检查命名、常量、集合、并发、异常和日志使用。",
      "审查 MyBatis、SQL、MySQL 表结构和索引相关风险。",
      "为 Spring、Service、DAO、DTO、VO 和 Mapper 代码生成规范建议。",
      "输出包含级别、位置、风险和修改建议的审查意见。",
      "在项目约定与阿里规约冲突时提示冲突点。"
    ],
    "limitations": [
      "它提供规则摘要，不替代官方完整手册。",
      "它不会自动运行 Java 编译、单元测试或静态分析工具。",
      "它需要用户提供代码上下文才能定位具体行号。",
      "它不能判断所有业务权限、事务和数据一致性要求。"
    ],
    "use_cases": [
      {
        "title": "后端开发者提交前自查",
        "description": "在提交 Java、Spring 或 MyBatis 改动前检查命名、异常、日志、SQL 和安全输入处理。",
        "target_user": "Java 后端开发者"
      },
      {
        "title": "代码评审负责人统一标准",
        "description": "把审查意见按强制、推荐和参考分类，减少团队对规范严重级别的理解差异。",
        "target_user": "技术负责人"
      },
      {
        "title": "新项目生成基础代码",
        "description": "生成 DTO、VO、DO、Service、Mapper 和异常类时默认遵循阿里巴巴 Java 开发规约。",
        "target_user": "项目脚手架维护者"
      }
    ],
    "prompt_templates": [
      {
        "title": "基础代码审查",
        "scenario": "初次使用，检查一段 Java 改动。",
        "prompt": "使用 alibaba-java-coding-guidelines-skill 审查这次 Java 改动。请按强制、推荐和参考分类输出问题、风险和建议。"
      },
      {
        "title": "生成规范类",
        "scenario": "创建符合命名和注释规则的类。",
        "prompt": "请按阿里巴巴 Java 开发规约生成一个订单查询 DTO 和对应校验说明。字段命名、注释和空值语义要清晰。"
      },
      {
        "title": "SQL 与 MyBatis 审查",
        "scenario": "检查 Mapper、SQL 和索引风险。",
        "prompt": "请审查这个 MyBatis 查询和相关表结构。重点检查参数绑定、SELECT 字段、分页、索引、NULL 语义和 SQL 注入风险。"
      },
      {
        "title": "高级重构计划",
        "scenario": "对已有模块做分阶段整改。",
        "prompt": "请基于阿里巴巴 Java 开发规约，为这个模块制定重构计划。按正确性、安全性、性能和可维护性排序，并说明每步的验证方式。"
      }
    ],
    "output_examples": [
      {
        "input": "审查一个包含日志拼接、宽泛异常捕获和 MyBatis 字符串拼接的 Service 改动。",
        "output": [
          "强制：MyBatis 参数应使用安全绑定，避免把用户输入拼入 SQL。",
          "强制：不要直接捕获 Exception 后吞掉异常，应保留上下文并转换为业务异常。",
          "推荐：低级别日志使用占位符，减少无谓字符串拼接。"
        ]
      },
      {
        "input": "生成订单状态枚举、订单视图对象和查询参数对象。",
        "output": [
          "枚举名以 Enum 结尾，枚举项使用大写加下划线。",
          "VO 面向展示字段，DTO 或 Query 承载请求参数。",
          "公开字段语义和空值含义使用中文注释说明。"
        ]
      },
      {
        "input": "评估一段分页查询 SQL 和表索引。",
        "output": [
          "先确认 count 结果，避免无意义分页查询。",
          "排序字段应尽量匹配联合索引顺序。",
          "大分页建议使用延迟关联或基于游标的查询方式。"
        ]
      }
    ],
    "best_practices": [
      "先提供项目已有包结构、测试框架和持久层约定。",
      "要求输出每条问题的级别、位置、风险和修改建议。",
      "把安全、事务、日志和 SQL 风险放在格式问题之前处理。"
    ],
    "anti_patterns": [
      "只要求格式化代码，而不检查异常、权限和 SQL 风险。",
      "把推荐规则全部当作阻塞缺陷处理。",
      "在没有项目上下文时强行重命名公共接口和持久化字段。"
    ],
