        "prompt": "Use the combat-system-creator skill to add a new status effect with chance, duration, mitigation behavior, logs, and turn processing."
      },
      {
        "title": "Refactor Combat Flow",
        "scenario": "Advanced request for architecture cleanup.",
        "prompt": "Use the combat-system-creator skill to refactor mixed combat logic into CombatCalculationSystem and CombatWorkflowSystem responsibilities."
      },
      {
        "title": "Design a Full Combat Feature",
        "scenario": "Advanced request spanning formulas, state, tests, and balance.",
        "prompt": "Use the combat-system-creator skill to design a complete combat feature, including interfaces, calculation steps, workflow application, logs, tests, and balance notes."
      }
    ],
    "output_examples": [
      {
        "input": "Add a poison effect that bypasses defense and ticks each turn.",
        "output": "A design separating poison tick calculation from workflow application, with duration handling, combat log entries, and death-check placement."
      },
      {
        "input": "Refactor critical hit logic so it can be tested directly.",
        "output": "A pure critical-hit calculation plan with controlled randomness, returned result fields, and workflow integration notes."
      },
      {
        "input": "Create a shield effect that absorbs damage before HP loss.",
        "output": "A mitigation sequence showing shield priority, absorbed damage reporting, state updates, and edge cases for broken shields."
      }
    ],
    "best_practices": [
      "Keep formulas in pure calculation functions that return complete result objects.",
      "Apply HP, buffs, cooldowns, and logs only inside workflow handlers.",
      "Add tests for random rolls by passing controlled random values where possible."
    ],
    "anti_patterns": [
      "Mixing damage math, state mutation, and combat logs in one function.",
      "Changing combat state inside calculation helpers.",
      "Adding new effects without documenting mitigation order and turn timing."
