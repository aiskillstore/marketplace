      "refactoring guide"
    ],
    "actual_capabilities": [
      "Defines a dual-system architecture for combat calculations and workflow state updates.",
      "Documents damage, critical hit, defense, mitigation, and status effect formulas.",
      "Provides TypeScript interface patterns for combat results, entities, contexts, and logs.",
      "Guides creation of new combat mechanics, status effects, and turn phases.",
      "Outlines migration steps for extracting combat logic into calculation and workflow systems."
    ],
    "limitations": [
      "Focused on the SHINOBI WAY combat model and its named systems.",
      "Provides guidance and examples, not a complete tested implementation.",
      "Uses simplified pseudocode in some formula sections.",
      "Does not cover graphics, animation, networking, persistence, or multiplayer synchronization."
    ],
    "use_cases": [
      {
        "title": "Add a New Status Effect",
        "description": "Design a damage, control, defense, buff, debuff, or recovery effect with calculation and workflow responsibilities separated.",
        "target_user": "Game developer"
      },
      {
        "title": "Refactor Existing Combat Logic",
        "description": "Move mixed damage and state code into pure calculation functions and workflow handlers with clearer interfaces.",
        "target_user": "Technical lead"
      },
      {
        "title": "Balance Combat Formulas",
        "description": "Review hit chance, critical hits, defense caps, mitigation order, and resource formulas using documented constants.",
        "target_user": "Game designer"
      }
    ],
    "prompt_templates": [
