    "user_title": "Run Inference.sh AI Apps",
    "value_statement": "Teams need one way to reach many hosted AI tools without managing GPUs or provider SDKs. This skill guides Claude, Codex, and Claude Code through infsh CLI commands for discovery, execution, and task tracking.",
    "seo_keywords": [
      "Claude inference.sh skill",
      "Codex infsh CLI",
      "Claude Code AI apps",
      "inference.sh",
      "infsh app run",
      "AI image generation CLI",
      "AI video generation CLI",
      "OpenRouter CLI",
      "Tavily search CLI",
      "cloud AI automation"
    ],
    "actual_capabilities": [
      "Lists and searches inference.sh apps by category, keyword, featured status, and pagination.",
      "Runs hosted AI apps with inline input or input files through the infsh CLI.",
      "Generates sample input files before running supported apps.",
      "Tracks long-running tasks and saves task results to files.",
      "Documents authentication, API key use, CLI updates, and troubleshooting steps.",
      "Points users to image, video, LLM, search, audio, 3D, and Twitter/X app examples."
    ],
    "limitations": [
      "Requires the infsh CLI and an inference.sh account before app commands work.",
      "May consume credits or quota when cloud apps are executed.",
      "Does not validate the safety or privacy policy of each hosted app.",
      "Remote installer and API key workflows require user security review."
    ],
    "use_cases": [
      {
        "title": "Prototype AI Media Workflows",
        "target_user": "Product designers",
        "description": "Generate images, videos, audio, or 3D assets from prompts while comparing available hosted apps."
      },
      {
        "title": "Automate Model Evaluation",
        "target_user": "AI engineers",
        "description": "Run LLM and search apps from a consistent CLI while saving inputs and task outputs for review."
      },
      {
        "title": "Operate Cloud AI Tasks",
        "target_user": "Developer operations teams",
        "description": "Discover apps, submit long-running jobs, monitor task status, and troubleshoot authentication from terminal workflows."
      }
    ],
    "prompt_templates": [
      {
        "title": "Find An App",
        "scenario": "Beginner discovery",
        "prompt": "Use agent-tools to find inference.sh apps for image generation. Show the safest commands to list and inspect options first."
      },
      {
        "title": "Generate Sample Input",
        "scenario": "Prepare a run",
        "prompt": "Use agent-tools to get details for a video generation app and create a sample input file that I can edit before running."
      },
      {
        "title": "Run And Track A Task",
        "scenario": "Execute a hosted app",
        "prompt": "Use agent-tools to run an inference.sh app with my input file, then show how to check the task status and save the result."
      },
      {
        "title": "Design A Safe Automation Flow",
        "scenario": "Advanced operational workflow",
        "prompt": "Use agent-tools to design a repeatable infsh workflow for LLM search tasks, including authentication checks, quota cautions, and result storage."
      }
    ],
    "output_examples": [
      {
        "input": "Find a fast image generation app for concept art.",
        "output": "A short list of matching inference.sh apps, commands to inspect each app, and a recommendation to generate sample input before running."
      },
      {
        "input": "Run a long video job and check it later.",
        "output": "A command plan that submits the app without waiting, records the task ID, checks status, and saves the final result."
      },
      {
        "input": "Set up authentication for CI.",
        "output": "A checklist covering API key setup, secret storage, command verification, and warnings about logs and shared runners."
      }
    ],
    "best_practices": [
      "Inspect app details and sample inputs before sending prompts, media, or files to a hosted app.",
      "Prefer signed manual installation and verify checksums before placing the CLI in your PATH.",
      "Store INFSH_API_KEY only in a secret manager or protected environment variable."
    ],
    "anti_patterns": [
      "Do not run curl-to-shell installers in production without reviewing the script and signature path.",
      "Do not send confidential prompts, customer data, or private media to unknown hosted apps.",
      "Do not automate Twitter/X actions without explicit account approval and rate-limit review."
    ],
    "faq": [
